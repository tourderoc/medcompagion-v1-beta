<UserControl x:Class="MedCompanion.Views.Pilotage.PilotageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MedCompanion.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1400"
             Background="#1E1E1E">

    <UserControl.Resources>
        <!-- Couleurs -->
        <SolidColorBrush x:Key="PilotageAccent" Color="#E67E22"/>
        <SolidColorBrush x:Key="PilotageBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="PilotageCardBackground" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="PilotageTextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PilotageTextSecondary" Color="#888888"/>
        <SolidColorBrush x:Key="PilotageBorder" Color="#3D3D3D"/>

        <!-- Indicateurs urgence -->
        <SolidColorBrush x:Key="UrgentColor" Color="#E74C3C"/>
        <SolidColorBrush x:Key="ToSeeColor" Color="#F39C12"/>
        <SolidColorBrush x:Key="InfoColor" Color="#27AE60"/>

        <!-- Converters -->
        <converters:TimePressureConverter x:Key="TimePressureConverter"/>
        <converters:TimePressureColorConverter x:Key="TimePressureColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- Style bouton standard -->
        <Style x:Key="PilotageButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4D4D4D"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style bouton accent -->
        <Style x:Key="PilotageAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource PilotageButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PilotageAccent}"/>
        </Style>

        <!-- Style TabItem Pilotage -->
        <Style x:Key="PilotageTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="Transparent" Padding="{TemplateBinding Padding}"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource PilotageAccent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PilotageCardBackground}"
                BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1"
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Titre -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎯" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="PILOTAGE" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource PilotageAccent}" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Parent'aile" FontSize="16"
                               Foreground="{StaticResource PilotageTextSecondary}"
                               VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                <!-- Stats rapides -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#3D3D3D" CornerRadius="4" Padding="10,5" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource UrgentColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="UrgentCountText" Text="0" Foreground="{StaticResource PilotageTextPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text=" urgent" Foreground="{StaticResource PilotageTextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#3D3D3D" CornerRadius="4" Padding="10,5" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource ToSeeColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="ToSeeCountText" Text="0" Foreground="{StaticResource PilotageTextPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text=" à voir" Foreground="{StaticResource PilotageTextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#3D3D3D" CornerRadius="4" Padding="10,5" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📬" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="TotalCountText" Text="0" Foreground="{StaticResource PilotageTextPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text=" total" Foreground="{StaticResource PilotageTextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Boutons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RefreshBtn" Content="🔄" Padding="10,8" Margin="5,0"
                            Style="{StaticResource PilotageButtonStyle}" ToolTip="Rafraîchir" Click="RefreshBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- CONTENU PRINCIPAL : TabControl 3 onglets -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0"
                    SelectionChanged="MainTabControl_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="HorizontalAlignment" Value="Left"/>
                </Style>
            </TabControl.Resources>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ONGLET 1 : MESSAGES -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource PilotageTabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📨 Messages" FontSize="14" FontWeight="SemiBold"/>
                        <Border x:Name="MessagesBadge" Background="{StaticResource UrgentColor}" CornerRadius="8"
                                Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock x:Name="MessagesBadgeText" Text="0" Foreground="White" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <!-- Contenu Messages : 3 colonnes existantes -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="250"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="400"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="320" MinWidth="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- ═══════════════════════════════════════════════════════════════ -->
                    <!-- COLONNE 1 : Liste des messages -->
                    <!-- ═══════════════════════════════════════════════════════════════ -->
                    <Border Grid.Column="0" Background="{StaticResource PilotageCardBackground}"
                            BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Filtres -->
                            <Border Grid.Row="0" Padding="15,10" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="MESSAGES" FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource PilotageTextSecondary}" Margin="0,0,0,10"/>
                                    <ComboBox x:Name="FilterCombo" SelectedIndex="0" BorderThickness="0"
                                              SelectionChanged="FilterCombo_SelectionChanged">
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Background" Value="#3D3D3D"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ComboBox">
                                                            <Grid>
                                                                <ToggleButton x:Name="ToggleButton" Focusable="False"
                                                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                              ClickMode="Press">
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border Background="#3D3D3D" CornerRadius="4" Padding="12,8">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <ContentPresenter Grid.Column="0"/>
                                                                                    <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="White"
                                                                                          VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                                                </Grid>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                </ToggleButton>
                                                                <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                                  Margin="12,8" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                                    <ContentPresenter.Resources>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Style>
                                                                    </ContentPresenter.Resources>
                                                                </ContentPresenter>
                                                                <Popup x:Name="Popup" Placement="Bottom"
                                                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                                                       AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                                    <Border Background="#2D2D2D" BorderBrush="#4D4D4D"
                                                                            BorderThickness="1" CornerRadius="4" Margin="0,2,0,0">
                                                                        <ScrollViewer MaxHeight="200">
                                                                            <StackPanel IsItemsHost="True"/>
                                                                        </ScrollViewer>
                                                                    </Border>
                                                                </Popup>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ComboBox.Style>
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="12,8"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ComboBoxItem">
                                                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#4D4D4D"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="Background" Value="#E67E22"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                        <ComboBoxItem Content="📬 Non traités" Tag="active"/>
                                        <ComboBoxItem Content="🔴 Urgents" Tag="urgent"/>
                                        <ComboBoxItem Content="🟡 À voir" Tag="moderate"/>
                                        <ComboBoxItem Content="📨 Tous les messages" Tag="all"/>
                                        <ComboBoxItem Content="✅ Archivés (répondus)" Tag="replied"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- Toggle Archives -->
                            <Border Grid.Row="1" Padding="10,6" Background="#252525">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="ActiveCountLabel" Text="0 en attente" FontSize="11"
                                               Foreground="{StaticResource PilotageAccent}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <!-- Liste messages -->
                            <Grid Grid.Row="2">
                                <ListBox x:Name="MessagesListBox" Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         SelectionChanged="MessagesListBox_SelectionChanged">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}" Margin="0,1">
                                                            <ContentPresenter />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#3D3D3D"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#333333"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="10,8" Margin="4,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Indicateur urgence -->
                                                    <Ellipse Grid.Column="0" Width="10" Height="10"
                                                             VerticalAlignment="Top" Margin="0,4,8,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{StaticResource InfoColor}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UrgencyLevel}" Value="Critical">
                                                                        <Setter Property="Fill" Value="{StaticResource UrgentColor}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding UrgencyLevel}" Value="Urgent">
                                                                        <Setter Property="Fill" Value="{StaticResource UrgentColor}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding UrgencyLevel}" Value="Moderate">
                                                                        <Setter Property="Fill" Value="{StaticResource ToSeeColor}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding PatientName}" FontWeight="SemiBold"
                                                                   Foreground="White" FontSize="13"/>
                                                        <TextBlock Text="{Binding Summary}" Foreground="#888888"
                                                                   TextTrimming="CharacterEllipsis" FontSize="11"
                                                                   MaxHeight="28" Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <!-- Temps ecoule + indicateur pression -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding RelativeTimeString}"
                                                                   Foreground="#555555" FontSize="10"/>
                                                        <TextBlock Text="{Binding CreatedAt, Converter={StaticResource TimePressureConverter}}"
                                                                   Foreground="{Binding CreatedAt, Converter={StaticResource TimePressureColorConverter}}"
                                                                   FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- État vide -->
                                <Border x:Name="EmptyStatePanel" Padding="20" Visibility="Collapsed" Background="{StaticResource PilotageCardBackground}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center" Margin="0,20,0,10"/>
                                        <TextBlock Text="Aucun message" FontSize="16"
                                                   Foreground="{StaticResource PilotageTextSecondary}"
                                                   HorizontalAlignment="Center"/>
                                        <Button Content="🔑 Générer un token" Margin="0,20,0,0" Padding="15,10"
                                                Style="{StaticResource PilotageAccentButtonStyle}" Click="TokensBtn_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- Loading Overlay -->
                                <Border x:Name="LoadingOverlay" Background="#80000000" Visibility="Collapsed">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="⌛" FontSize="32" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Chargement..." Foreground="White" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Splitter 1 -->
                    <GridSplitter Grid.Column="1" Width="3" Background="#3D3D3D"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                    <!-- ═══════════════════════════════════════════════════════════════ -->
                    <!-- COLONNE 2 : Détail message + Réponse -->
                    <!-- ═══════════════════════════════════════════════════════════════ -->
                    <Border Grid.Column="2" Background="{StaticResource PilotageBackground}" Padding="15">
                        <Grid x:Name="MessageDetailPanel">
                            <!-- État vide (aucun message sélectionné) -->
                            <StackPanel x:Name="NoSelectionPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="📧" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                                <TextBlock Text="Sélectionnez un message" FontSize="18"
                                           Foreground="{StaticResource PilotageTextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                <TextBlock Text="pour voir son contenu et répondre" FontSize="14"
                                           Foreground="{StaticResource PilotageTextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,5,0,0" Opacity="0.7"/>
                            </StackPanel>

                            <!-- Contenu message (masqué par défaut) -->
                            <Grid x:Name="MessageContentPanel" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- En-tête patient -->
                                <Border Grid.Row="0" Background="{StaticResource PilotageCardBackground}"
                                        CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="PatientNameText" Text="DUPONT Martin"
                                                           FontSize="16" FontWeight="Bold"
                                                           Foreground="{StaticResource PilotageTextPrimary}"/>
                                                <TextBlock x:Name="PatientPseudoText" Text=" (MamanDeThéo)"
                                                           FontSize="13" Foreground="{StaticResource PilotageTextSecondary}"
                                                           VerticalAlignment="Bottom" Margin="5,0,0,1"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock x:Name="MessageDateText" Text="Reçu le 31/01/2026 à 14:32"
                                                           FontSize="11" Foreground="{StaticResource PilotageTextSecondary}"/>
                                                <TextBlock x:Name="TimePressureText" Text="" FontSize="11" FontWeight="Bold"
                                                           Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="⚡ Notif rapide" Padding="12,6" Margin="0,0,8,0"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="QuickReplyBtn_Click"
                                                    ToolTip="Envoyer une notification rapide"/>
                                            <Button Content="📁 Voir dossier" Padding="12,6" Margin="0,0,8,0"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="ViewDossierBtn_Click"/>
                                            <Button Content="✓ Traité" Padding="12,6" Margin="0,0,8,0"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="MarkAsReadBtn_Click"
                                                    ToolTip="Marquer comme traité (pas de réponse nécessaire)"
                                                    Foreground="#27AE60"/>
                                            <Button Content="🗑️ Supprimer" Padding="12,6"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="DeleteMessageBtn_Click"
                                                    ToolTip="Supprimer le message et notifier le parent"
                                                    Foreground="#E74C3C"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Contenu du message -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                                    <Border Background="{StaticResource PilotageCardBackground}"
                                            CornerRadius="8" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="MESSAGE" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource PilotageTextSecondary}" Margin="0,0,0,8"/>
                                            <TextBlock x:Name="MessageContentText"
                                                       Text="Contenu du message..."
                                                       TextWrapping="Wrap" FontSize="14" LineHeight="20"
                                                       Foreground="{StaticResource PilotageTextPrimary}"/>
                                        </StackPanel>
                                    </Border>
                                </ScrollViewer>

                                <!-- Zone réponse inline -->
                                <Border Grid.Row="2" Background="{StaticResource PilotageCardBackground}"
                                        CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="RÉPONDRE" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource PilotageTextSecondary}" Margin="0,0,0,8"/>
                                        <TextBox x:Name="ReplyTextBox"
                                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                                 Background="#3D3D3D" Foreground="White"
                                                 BorderThickness="0" Padding="10"
                                                 VerticalScrollBarVisibility="Auto"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="💡 Suggestion IA" Padding="10,6"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="SuggestionBtn_Click"/>
                                            <Button x:Name="SendFirebaseBtn" Content="📤 Envoyer Firebase" Padding="10,6" Margin="8,0,0,0"
                                                    Style="{StaticResource PilotageAccentButtonStyle}" Click="SendReplyBtn_Click" IsEnabled="False"/>
                                            <Button x:Name="SendEmailBtn" Content="📧 Email + PJ" Padding="10,6" Margin="8,0,0,0"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="SendEmailBtn_Click" IsEnabled="False"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Splitter 2 -->
                    <GridSplitter Grid.Column="3" Width="3" Background="#3D3D3D"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                    <!-- ═══════════════════════════════════════════════════════════════ -->
                    <!-- COLONNE 3 : Documents à joindre -->
                    <!-- ═══════════════════════════════════════════════════════════════ -->
                    <Border Grid.Column="4" Background="{StaticResource PilotageCardBackground}"
                            BorderBrush="{StaticResource PilotageBorder}" BorderThickness="1,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header Documents -->
                            <Border Grid.Row="0" Padding="15,12" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="📎 DOCUMENTS À JOINDRE" FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource PilotageAccent}"/>
                                    <TextBlock x:Name="AttachmentPatientText" Text="Patient: —"
                                               FontSize="11" Foreground="{StaticResource PilotageTextSecondary}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Liste des pièces jointes -->
                            <Grid Grid.Row="1">
                                <!-- État vide documents -->
                                <StackPanel x:Name="NoAttachmentsPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="📄" FontSize="40" HorizontalAlignment="Center" Opacity="0.3"/>
                                    <TextBlock Text="Aucun document" FontSize="13"
                                               Foreground="{StaticResource PilotageTextSecondary}"
                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBlock Text="Utilisez 'Joindre au Pilotage'" FontSize="11"
                                               Foreground="{StaticResource PilotageTextSecondary}"
                                               HorizontalAlignment="Center" Margin="0,3,0,0" Opacity="0.7"/>
                                    <TextBlock Text="depuis Attestations ou Courriers" FontSize="11"
                                               Foreground="{StaticResource PilotageTextSecondary}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" Opacity="0.7"/>
                                </StackPanel>

                                <!-- Liste documents -->
                                <ListBox x:Name="AttachmentsListBox" Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="10,5">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,3"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4" Padding="10,8">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#3D3D3D"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center" Margin="0,0,8,0"/>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}" Foreground="White" FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding FileSize}" Foreground="#666666" FontSize="10"/>
                                                </StackPanel>

                                                <Button Grid.Column="2" Content="🗑️" Padding="5,2"
                                                        Style="{StaticResource PilotageButtonStyle}"
                                                        ToolTip="Retirer" Tag="{Binding FilePath}"
                                                        Click="RemoveAttachment_Click"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <!-- Actions documents + Email -->
                            <Border Grid.Row="2" Padding="12" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <!-- Bouton ajouter fichier -->
                                    <Button Content="📁 Ajouter un fichier..." Padding="10,8"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource PilotageButtonStyle}" Click="AddAttachment_Click"/>

                                    <!-- Séparateur -->
                                    <Border Height="1" Background="{StaticResource PilotageBorder}" Margin="0,12"/>

                                    <!-- Email parent -->
                                    <StackPanel>
                                        <TextBlock Text="📧 EMAIL PARENT" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource PilotageTextSecondary}" Margin="0,0,0,6"/>
                                        <Border Background="#3D3D3D" CornerRadius="4" Padding="10,8">
                                            <TextBlock x:Name="ParentEmailText" Text="—"
                                                       Foreground="{StaticResource PilotageTextPrimary}" FontSize="12"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ONGLET 2 : PATIENTS (tous les patients + token + messages) -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource PilotageTabItemStyle}">
                <TabItem.Header>
                    <TextBlock Text="👤 Patients" FontSize="14" FontWeight="SemiBold"/>
                </TabItem.Header>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" MinWidth="280"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Liste patients (TOUS les patients MedCompanion) -->
                    <Border Grid.Column="0" Background="{StaticResource PilotageCardBackground}"
                            BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Recherche -->
                            <Border Grid.Row="0" Padding="15,10" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="PATIENTS" FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource PilotageTextSecondary}" Margin="0,0,0,10"/>
                                    <TextBox x:Name="PatientSearchBox" Background="#3D3D3D" Foreground="White"
                                             BorderThickness="0" Padding="10,8" FontSize="13"
                                             TextChanged="PatientSearchBox_TextChanged">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Tag" Value="🔍 Rechercher un patient..."/>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>
                            </Border>

                            <!-- Liste -->
                            <Grid Grid.Row="1">
                                <ListBox x:Name="PatientsListBox" Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         SelectionChanged="PatientsListBox_SelectionChanged">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}" Margin="0,1">
                                                            <ContentPresenter/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#3D3D3D"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#333333"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,10" Margin="4,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Indicateur token -->
                                                    <Ellipse Grid.Column="0" Width="10" Height="10"
                                                             VerticalAlignment="Center" Margin="0,0,10,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#555555"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TokenStatus}" Value="Actif">
                                                                        <Setter Property="Fill" Value="{StaticResource InfoColor}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TokenStatus}" Value="En attente">
                                                                        <Setter Property="Fill" Value="{StaticResource ToSeeColor}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TokenStatus}" Value="Révoqué">
                                                                        <Setter Property="Fill" Value="{StaticResource UrgentColor}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding PatientName}" FontWeight="SemiBold"
                                                                   Foreground="White" FontSize="13"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                            <TextBlock Text="{Binding TokenStatusLabel}"
                                                                       Foreground="#888888" FontSize="11"/>
                                                            <TextBlock Text="{Binding MessagesSummary}"
                                                                       Foreground="{StaticResource ToSeeColor}" FontSize="11"
                                                                       Margin="5,0,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1" Text="{Binding LastActivityRelative}"
                                                               Foreground="#555555" FontSize="10"
                                                               VerticalAlignment="Top" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Etat vide patients -->
                                <Border x:Name="NoPatientsPanel" Padding="20" Visibility="Collapsed"
                                        Background="{StaticResource PilotageCardBackground}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="👤" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                                        <TextBlock Text="Aucun patient" FontSize="16"
                                                   Foreground="{StaticResource PilotageTextSecondary}"
                                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="3" Background="#3D3D3D"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                    <!-- Détail patient (Token + Messages) -->
                    <Border Grid.Column="2" Background="{StaticResource PilotageBackground}" Padding="15">
                        <Grid x:Name="PatientDetailPanel">
                            <!-- Etat vide -->
                            <StackPanel x:Name="NoPatientSelectedPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                                <TextBlock Text="Sélectionnez un patient" FontSize="18"
                                           Foreground="{StaticResource PilotageTextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                <TextBlock Text="pour gérer son token et voir ses messages" FontSize="14"
                                           Foreground="{StaticResource PilotageTextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,5,0,0" Opacity="0.7"/>
                            </StackPanel>

                            <!-- Contenu patient -->
                            <ScrollViewer x:Name="PatientContentScroll" Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PatientContentPanel">

                                    <!-- Header patient -->
                                    <Border Background="{StaticResource PilotageCardBackground}"
                                            CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock x:Name="PatientDetailName" Text="" FontSize="18" FontWeight="Bold"
                                                           Foreground="{StaticResource PilotageTextPrimary}"/>
                                                <TextBlock x:Name="PatientDetailPseudo" Text="" FontSize="12"
                                                           Foreground="{StaticResource PilotageTextSecondary}" Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <Button Grid.Column="1" Content="📁 Voir dossier" Padding="12,6"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="PatientViewDossier_Click"/>
                                        </Grid>
                                    </Border>

                                    <!-- ═══ SECTION TOKEN PARENT'AILE ═══ -->
                                    <Border Background="{StaticResource PilotageCardBackground}"
                                            CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="🔑 TOKEN PARENT'AILE" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource PilotageAccent}" Margin="0,0,0,10"/>

                                            <!-- Etat : Pas de token -->
                                            <StackPanel x:Name="NoTokenPanel">
                                                <Border Background="#252525" CornerRadius="6" Padding="15">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="Aucun token généré" FontSize="14"
                                                                   Foreground="{StaticResource PilotageTextSecondary}"
                                                                   HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                        <TextBlock Text="Le parent ne peut pas envoyer de messages" FontSize="11"
                                                                   Foreground="#666666" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                                        <Button x:Name="GenerateTokenBtn" Content="🔑 Générer un token"
                                                                Padding="16,10" FontSize="13" FontWeight="SemiBold"
                                                                Style="{StaticResource PilotageAccentButtonStyle}"
                                                                Click="GenerateTokenBtn_Click"
                                                                HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <!-- Etat : Token existant -->
                                            <StackPanel x:Name="TokenInfoPanel" Visibility="Collapsed">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- QR Code aperçu -->
                                                    <Border Grid.Column="0" Background="White" CornerRadius="8"
                                                            Padding="8" Margin="0,0,15,0" VerticalAlignment="Top">
                                                        <Image x:Name="PatientQRCodeImage" Width="120" Height="120"
                                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                    </Border>

                                                    <!-- Infos token -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                            <TextBlock Text="Statut: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                                            <TextBlock x:Name="PatientTokenStatus" Text="" FontSize="12" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                            <TextBlock Text="Token: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="11"/>
                                                            <TextBlock x:Name="PatientTokenId" Text="" Foreground="#666666"
                                                                       FontSize="11" FontFamily="Consolas"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                            <TextBlock Text="Pseudo: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="11"/>
                                                            <TextBlock x:Name="PatientTokenPseudo" Text="—"
                                                                       Foreground="{StaticResource PilotageAccent}" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                            <TextBlock Text="Créé: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="11"/>
                                                            <TextBlock x:Name="PatientTokenCreatedAt" Text="" Foreground="#888888" FontSize="11"/>
                                                        </StackPanel>

                                                        <!-- Actions token -->
                                                        <WrapPanel>
                                                            <Button x:Name="PrintTokenBtn" Content="🖨️ Imprimer" Padding="10,6" Margin="0,0,6,6"
                                                                    Style="{StaticResource PilotageAccentButtonStyle}" Click="PrintTokenBtn_Click"/>
                                                            <Button x:Name="ShowPatientQRBtn" Content="📱 QR Code" Padding="10,6" Margin="0,0,6,6"
                                                                    Style="{StaticResource PilotageButtonStyle}" Click="ShowPatientQRBtn_Click"/>
                                                            <Button x:Name="RevokePatientTokenBtn" Content="🚫 Révoquer" Padding="10,6" Margin="0,0,6,6"
                                                                    Style="{StaticResource PilotageButtonStyle}" Click="RevokePatientTokenBtn_Click"/>
                                                        </WrapPanel>

                                                        <!-- Bouton régénération (visible uniquement si token révoqué) -->
                                                        <Button x:Name="RegenerateTokenBtn" Content="🔑 Générer un nouveau token"
                                                                Padding="14,8" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold"
                                                                Style="{StaticResource PilotageAccentButtonStyle}"
                                                                Click="RegenerateTokenBtn_Click"
                                                                Visibility="Collapsed"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- ═══ SECTION STATISTIQUES ═══ -->
                                    <Border Background="{StaticResource PilotageCardBackground}"
                                            CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#3D3D3D" CornerRadius="4" Padding="12,6" Margin="0,0,10,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📬 " Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                                    <TextBlock x:Name="PatientStatTotal" Text="0" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                                    <TextBlock Text=" messages" Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#3D3D3D" CornerRadius="4" Padding="12,6" Margin="0,0,10,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⏳ " Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                                    <TextBlock x:Name="PatientStatPending" Text="0" Foreground="{StaticResource ToSeeColor}" FontWeight="Bold" FontSize="12"/>
                                                    <TextBlock Text=" en attente" Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#3D3D3D" CornerRadius="4" Padding="12,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📅 " Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                                    <TextBlock x:Name="PatientStatLastContact" Text="—" Foreground="White" FontSize="12"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- ═══ SECTION HISTORIQUE MESSAGES ═══ -->
                                    <Border Background="{StaticResource PilotageCardBackground}" CornerRadius="8"
                                            MinHeight="200">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Padding="15,10" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1">
                                                <TextBlock Text="HISTORIQUE DES MESSAGES" FontSize="10" FontWeight="Bold"
                                                           Foreground="{StaticResource PilotageTextSecondary}"/>
                                            </Border>

                                            <!-- Etat vide messages -->
                                            <StackPanel x:Name="NoPatientMessagesPanel" Grid.Row="1"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30">
                                                <TextBlock Text="📭" FontSize="32" HorizontalAlignment="Center" Opacity="0.3"/>
                                                <TextBlock Text="Aucun message" FontSize="13"
                                                           Foreground="{StaticResource PilotageTextSecondary}"
                                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                            </StackPanel>

                                            <ListBox x:Name="PatientMessagesListBox" Grid.Row="1" Background="Transparent"
                                                     BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     MaxHeight="250" SelectionChanged="PatientMessagesListBox_SelectionChanged">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border Background="{TemplateBinding Background}" Margin="0,1">
                                                                        <ContentPresenter/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#333333"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#2A3A4A"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="15,10" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Top" Margin="0,5,10,0">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Fill" Value="{StaticResource InfoColor}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Status}" Value="sent">
                                                                                    <Setter Property="Fill" Value="{StaticResource ToSeeColor}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="replied">
                                                                                    <Setter Property="Fill" Value="{StaticResource InfoColor}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>

                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding Summary}" Foreground="White" FontSize="13"
                                                                               TextWrapping="Wrap" MaxHeight="40"/>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                        <TextBlock Text="{Binding Status}" Foreground="#666666" FontSize="10"/>
                                                                        <TextBlock Text=" · Répondu" Foreground="{StaticResource InfoColor}" FontSize="10"
                                                                                   Visibility="{Binding HasReply, Converter={StaticResource BoolToVisConverter}}"/>
                                                                    </StackPanel>
                                                                </StackPanel>

                                                                <TextBlock Grid.Column="2" Text="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                                           Foreground="#555555" FontSize="10" VerticalAlignment="Top"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <!-- ═══ DETAIL DU MESSAGE SELECTIONNÉ ═══ -->
                                            <Border x:Name="PatientMsgDetailPanel" Grid.Row="2" Visibility="Collapsed"
                                                    Background="#252525" Padding="15" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,1,0,0">
                                                <StackPanel>
                                                    <!-- Header détail -->
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock x:Name="PatientMsgDetailDate" Text="" FontSize="11"
                                                                   Foreground="{StaticResource PilotageTextSecondary}"/>
                                                        <Button Grid.Column="1" Content="✕" Padding="6,2"
                                                                Background="Transparent" Foreground="#888888" BorderThickness="0"
                                                                Cursor="Hand" FontSize="14" Click="ClosePatientMsgDetail_Click"/>
                                                    </Grid>

                                                    <!-- Message du parent -->
                                                    <TextBlock Text="MESSAGE DU PARENT" FontSize="9" FontWeight="Bold"
                                                               Foreground="{StaticResource PilotageTextSecondary}" Margin="0,0,0,5"/>
                                                    <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                                        <TextBlock x:Name="PatientMsgDetailContent" Text=""
                                                                   TextWrapping="Wrap" FontSize="13" LineHeight="19"
                                                                   Foreground="{StaticResource PilotageTextPrimary}"/>
                                                    </Border>

                                                    <!-- Réponse du médecin (si présente) -->
                                                    <StackPanel x:Name="PatientMsgReplySection" Visibility="Collapsed">
                                                        <TextBlock Text="RÉPONSE DU MÉDECIN" FontSize="9" FontWeight="Bold"
                                                                   Foreground="{StaticResource InfoColor}" Margin="0,0,0,5"/>
                                                        <Border Background="#1A2A1A" CornerRadius="6" Padding="12"
                                                                BorderBrush="#27AE60" BorderThickness="1,0,0,0">
                                                            <StackPanel>
                                                                <TextBlock x:Name="PatientMsgReplyContent" Text=""
                                                                           TextWrapping="Wrap" FontSize="13" LineHeight="19"
                                                                           Foreground="{StaticResource PilotageTextPrimary}"/>
                                                                <TextBlock x:Name="PatientMsgReplyDate" Text=""
                                                                           FontSize="10" Foreground="#888888" Margin="0,8,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- Pas de réponse -->
                                                    <StackPanel x:Name="PatientMsgNoReplySection" Visibility="Collapsed">
                                                        <TextBlock Text="Pas encore de réponse" FontSize="12" FontStyle="Italic"
                                                                   Foreground="#666666"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ONGLET 3 : UTILISATEURS PARENT'AILE -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource PilotageTabItemStyle}">
                <TabItem.Header>
                    <TextBlock Text="🔑 Utilisateurs" FontSize="14" FontWeight="SemiBold"/>
                </TabItem.Header>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350" MinWidth="300"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Liste utilisateurs/tokens -->
                    <Border Grid.Column="0" Background="{StaticResource PilotageCardBackground}"
                            BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header tokens -->
                            <Border Grid.Row="0" Padding="15,10" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="TOKENS PARENT'AILE" FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource PilotageTextSecondary}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="➕ Nouveau" Padding="10,6"
                                            Style="{StaticResource PilotageAccentButtonStyle}" Click="NewTokenBtn_Click"/>
                                </Grid>
                            </Border>

                            <!-- Statistiques tokens -->
                            <Border Grid.Row="1" Padding="10,6" Background="#1A1A2E"
                                    BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                        <Ellipse Width="8" Height="8" Fill="#27AE60" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatActifs" Text="0 actif" FontSize="11"
                                                   Foreground="#27AE60" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                        <Ellipse Width="8" Height="8" Fill="#F39C12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatEnAttente" Text="0 en attente" FontSize="11"
                                                   Foreground="#F39C12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#E74C3C" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatRevoques" Text="0 revoques" FontSize="11"
                                                   Foreground="#E74C3C" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Liste tokens -->
                            <ListBox x:Name="TokensListBox" Grid.Row="2" Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="TokensListBox_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}" Margin="0,1">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#3D3D3D"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#333333"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12,10" Margin="4,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Indicateur statut -->
                                                <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#555555"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Actif">
                                                                    <Setter Property="Fill" Value="{StaticResource InfoColor}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="En attente d'activation">
                                                                    <Setter Property="Fill" Value="{StaticResource ToSeeColor}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Révoqué">
                                                                    <Setter Property="Fill" Value="{StaticResource UrgentColor}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding PatientDisplayName}" FontWeight="SemiBold"
                                                               Foreground="White" FontSize="13"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding StatusDisplay}" Foreground="#888888" FontSize="11"/>
                                                        <TextBlock Text=" · " Foreground="#555555" FontSize="11"/>
                                                        <TextBlock Text="{Binding Pseudo}" Foreground="{StaticResource PilotageAccent}" FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yy}'}"
                                                           Foreground="#555555" FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Actions globales -->
                            <Border Grid.Row="3" Padding="12" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,1,0,0">
                                <Button x:Name="BroadcastBtn" Content="📢 Broadcast à tous" Padding="10,8"
                                        HorizontalAlignment="Stretch"
                                        Style="{StaticResource PilotageAccentButtonStyle}" Click="BroadcastBtn_Click"
                                        ToolTip="Envoyer une notification à TOUS les parents"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="3" Background="#3D3D3D"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                    <!-- Détail utilisateur -->
                    <Border Grid.Column="2" Background="{StaticResource PilotageBackground}" Padding="15">
                        <Grid x:Name="UserDetailPanel">
                            <!-- Etat vide -->
                            <StackPanel x:Name="NoUserSelectedPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🔑" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                                <TextBlock Text="Sélectionnez un utilisateur" FontSize="18"
                                           Foreground="{StaticResource PilotageTextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                <TextBlock Text="pour voir ses détails et gérer son accès" FontSize="14"
                                           Foreground="{StaticResource PilotageTextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,5,0,0" Opacity="0.7"/>
                            </StackPanel>

                            <!-- Contenu utilisateur -->
                            <Grid x:Name="UserContentPanel" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header token -->
                                <Border Grid.Row="0" Background="{StaticResource PilotageCardBackground}"
                                        CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock x:Name="UserDetailName" Text="" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource PilotageTextPrimary}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="Pseudo: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                            <TextBlock x:Name="UserDetailPseudo" Text="—" Foreground="{StaticResource PilotageAccent}"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="Token: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="11"/>
                                            <TextBlock x:Name="UserDetailTokenId" Text="" Foreground="#666666" FontSize="11"
                                                       FontFamily="Consolas"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="Statut: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                            <TextBlock x:Name="UserDetailStatus" Text="" FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="Créé le: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="11"/>
                                            <TextBlock x:Name="UserDetailCreatedAt" Text="" Foreground="#888888" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Stats utilisateur -->
                                <Border Grid.Row="1" Background="{StaticResource PilotageCardBackground}"
                                        CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#3D3D3D" CornerRadius="4" Padding="12,6" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📬 " FontSize="12"/>
                                                <TextBlock x:Name="UserStatMessages" Text="0" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                                <TextBlock Text=" messages" Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#3D3D3D" CornerRadius="4" Padding="12,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📅 " FontSize="12"/>
                                                <TextBlock Text="Dernier: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                                <TextBlock x:Name="UserStatLastActivity" Text="—" Foreground="White" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Actions -->
                                <Border Grid.Row="2" Background="{StaticResource PilotageCardBackground}"
                                        CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="ACTIONS" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource PilotageTextSecondary}" Margin="0,0,0,10"/>
                                        <WrapPanel>
                                            <Button x:Name="ShowQRBtn" Content="📱 QR Code" Padding="12,8" Margin="0,0,8,8"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="ShowQRBtn_Click"/>
                                            <Button x:Name="RevokeTokenBtn" Content="🚫 Révoquer" Padding="12,8" Margin="0,0,8,8"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="RevokeTokenBtn_Click"/>
                                            <Button x:Name="DeleteTokenBtn" Content="🗑️ Supprimer" Padding="12,8" Margin="0,0,8,8"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="DeleteTokenBtn_Click"/>
                                            <Button Content="📢 Notifier" Padding="12,8" Margin="0,0,8,8"
                                                    Style="{StaticResource PilotageAccentButtonStyle}" Click="NotifyUserBtn_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- FOOTER : Statut + dernière synchro -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource PilotageCardBackground}"
                BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Info sélection -->
                <TextBlock x:Name="SelectionInfoText" Grid.Column="0"
                           Text="Sélectionnez un message pour répondre"
                           Foreground="{StaticResource PilotageTextSecondary}"
                           VerticalAlignment="Center" FontSize="12"/>

                <!-- Dernière synchro -->
                <TextBlock x:Name="LastSyncText" Grid.Column="1"
                           Text="Dernière synchro: —"
                           Foreground="#555555" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

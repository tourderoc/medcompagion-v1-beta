<UserControl x:Class="MedCompanion.Views.Pilotage.PilotageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MedCompanion.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1400"
             Background="#1E1E1E">

    <UserControl.Resources>
        <!-- Couleurs -->
        <SolidColorBrush x:Key="PilotageAccent" Color="#E67E22"/>
        <SolidColorBrush x:Key="PilotageBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="PilotageCardBackground" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="PilotageTextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PilotageTextSecondary" Color="#888888"/>
        <SolidColorBrush x:Key="PilotageBorder" Color="#3D3D3D"/>

        <!-- Indicateurs urgence -->
        <SolidColorBrush x:Key="UrgentColor" Color="#E74C3C"/>
        <SolidColorBrush x:Key="ToSeeColor" Color="#F39C12"/>
        <SolidColorBrush x:Key="InfoColor" Color="#27AE60"/>

        <!-- Converters -->
        <converters:TimePressureConverter x:Key="TimePressureConverter"/>
        <converters:TimePressureColorConverter x:Key="TimePressureColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- Style bouton standard -->
        <Style x:Key="PilotageButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4D4D4D"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style bouton accent -->
        <Style x:Key="PilotageAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource PilotageButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PilotageAccent}"/>
        </Style>

        <!-- Style TabItem Pilotage -->
        <Style x:Key="PilotageTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="Transparent" Padding="{TemplateBinding Padding}"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource PilotageAccent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Style ComboBox sombre (boîte admin) -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Cursor="Hand"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="8,5,0,5"
                                                                  VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="▾"
                                                           Foreground="#888888"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           FontSize="10"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,5,24,5"
                                              VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <Border Background="#2D2D2D" BorderBrush="#555555" BorderThickness="1" CornerRadius="0,0,4,4">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#E67E22"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3D3D3D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PilotageCardBackground}"
                BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1"
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Titre -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎯" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="PILOTAGE" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource PilotageAccent}" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Parent'aile" FontSize="16"
                               Foreground="{StaticResource PilotageTextSecondary}"
                               VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                <!-- Stats rapides -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#3D3D3D" CornerRadius="4" Padding="10,5" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource UrgentColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="UrgentCountText" Text="0" Foreground="{StaticResource PilotageTextPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text=" urgent" Foreground="{StaticResource PilotageTextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#3D3D3D" CornerRadius="4" Padding="10,5" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource ToSeeColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="ToSeeCountText" Text="0" Foreground="{StaticResource PilotageTextPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text=" à voir" Foreground="{StaticResource PilotageTextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#3D3D3D" CornerRadius="4" Padding="10,5" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📬" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="TotalCountText" Text="0" Foreground="{StaticResource PilotageTextPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text=" total" Foreground="{StaticResource PilotageTextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="NewAvatarBadge" Background="#3D3D3D" CornerRadius="4" Padding="10,5" Margin="5,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="NewAvatarCountText" Text="0" Foreground="{StaticResource PilotageAccent}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text=" avatars" Foreground="{StaticResource PilotageTextSecondary}" VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Boutons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RefreshBtn" Content="🔄" Padding="10,8" Margin="5,0"
                            Style="{StaticResource PilotageButtonStyle}" ToolTip="Rafraîchir" Click="RefreshBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- CONTENU PRINCIPAL : TabControl 3 onglets -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0"
                    SelectionChanged="MainTabControl_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="HorizontalAlignment" Value="Left"/>
                </Style>
            </TabControl.Resources>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ONGLET 3 : UTILISATEURS PARENT'AILE -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource PilotageTabItemStyle}">
                <TabItem.Header>
                    <TextBlock Text="🔑 Utilisateurs" FontSize="14" FontWeight="SemiBold"/>
                </TabItem.Header>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350" MinWidth="300"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Liste utilisateurs/tokens -->
                    <Border Grid.Column="0" Background="{StaticResource PilotageCardBackground}"
                            BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header tokens -->
                            <Border Grid.Row="0" Padding="15,10" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="TOKENS PARENT'AILE" FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource PilotageTextSecondary}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="➕ Nouveau" Padding="10,6"
                                            Style="{StaticResource PilotageAccentButtonStyle}" Click="NewTokenBtn_Click"/>
                                </Grid>
                            </Border>

                            <!-- Statistiques tokens -->
                            <Border Grid.Row="1" Padding="10,6" Background="#1A1A2E"
                                    BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                        <Ellipse Width="8" Height="8" Fill="#27AE60" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatActifs" Text="0 actif" FontSize="11"
                                                   Foreground="#27AE60" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                        <Ellipse Width="8" Height="8" Fill="#F39C12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatEnAttente" Text="0 en attente" FontSize="11"
                                                   Foreground="#F39C12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#E74C3C" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatRevoques" Text="0 revoques" FontSize="11"
                                                   Foreground="#E74C3C" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Liste tokens -->
                            <ListBox x:Name="TokensListBox" Grid.Row="2" Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="TokensListBox_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}" Margin="0,1">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#3D3D3D"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#333333"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12,10" Margin="4,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Indicateur statut -->
                                                <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#555555"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Actif">
                                                                    <Setter Property="Fill" Value="{StaticResource InfoColor}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="En attente d'activation">
                                                                    <Setter Property="Fill" Value="{StaticResource ToSeeColor}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Révoqué">
                                                                    <Setter Property="Fill" Value="{StaticResource UrgentColor}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding PatientDisplayName}" FontWeight="SemiBold"
                                                               Foreground="White" FontSize="13"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding StatusDisplay}" Foreground="#888888" FontSize="11"/>
                                                        <TextBlock Text=" · " Foreground="#555555" FontSize="11"/>
                                                        <TextBlock Text="{Binding Pseudo}" Foreground="{StaticResource PilotageAccent}" FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yy}'}"
                                                           Foreground="#555555" FontSize="10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Actions globales -->
                            <Border Grid.Row="3" Padding="12" BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,1,0,0">
                                <Button x:Name="BroadcastBtn" Content="📢 Broadcast à tous" Padding="10,8"
                                        HorizontalAlignment="Stretch"
                                        Style="{StaticResource PilotageAccentButtonStyle}" Click="BroadcastBtn_Click"
                                        ToolTip="Envoyer une notification à TOUS les parents"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="3" Background="#3D3D3D"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                    <!-- Détail utilisateur -->
                    <Border Grid.Column="2" Background="{StaticResource PilotageBackground}" Padding="15">
                        <Grid x:Name="UserDetailPanel">
                            <!-- Etat vide -->
                            <StackPanel x:Name="NoUserSelectedPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🔑" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                                <TextBlock Text="Sélectionnez un utilisateur" FontSize="18"
                                           Foreground="{StaticResource PilotageTextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                <TextBlock Text="pour voir ses détails et gérer son accès" FontSize="14"
                                           Foreground="{StaticResource PilotageTextSecondary}"
                                           HorizontalAlignment="Center" Margin="0,5,0,0" Opacity="0.7"/>
                            </StackPanel>

                            <!-- Contenu utilisateur -->
                            <Grid x:Name="UserContentPanel" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header token -->
                                <Border Grid.Row="0" Background="{StaticResource PilotageCardBackground}"
                                        CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock x:Name="UserDetailName" Text="" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource PilotageTextPrimary}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="Pseudo: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                            <TextBlock x:Name="UserDetailPseudo" Text="—" Foreground="{StaticResource PilotageAccent}"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="Token: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="11"/>
                                            <TextBlock x:Name="UserDetailTokenId" Text="" Foreground="#666666" FontSize="11"
                                                       FontFamily="Consolas"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="Statut: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                            <TextBlock x:Name="UserDetailStatus" Text="" FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="Créé le: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="11"/>
                                            <TextBlock x:Name="UserDetailCreatedAt" Text="" Foreground="#888888" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Stats utilisateur -->
                                <Border Grid.Row="1" Background="{StaticResource PilotageCardBackground}"
                                        CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#3D3D3D" CornerRadius="4" Padding="12,6" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📬 " FontSize="12"/>
                                                <TextBlock x:Name="UserStatMessages" Text="0" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                                <TextBlock Text=" messages" Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#3D3D3D" CornerRadius="4" Padding="12,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📅 " FontSize="12"/>
                                                <TextBlock Text="Dernier: " Foreground="{StaticResource PilotageTextSecondary}" FontSize="12"/>
                                                <TextBlock x:Name="UserStatLastActivity" Text="—" Foreground="White" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Actions -->
                                <Border Grid.Row="2" Background="{StaticResource PilotageCardBackground}"
                                        CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="ACTIONS" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource PilotageTextSecondary}" Margin="0,0,0,10"/>
                                        <WrapPanel>
                                            <Button x:Name="ShowQRBtn" Content="📱 QR Code" Padding="12,8" Margin="0,0,8,8"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="ShowQRBtn_Click"/>
                                            <Button x:Name="RevokeTokenBtn" Content="🚫 Révoquer" Padding="12,8" Margin="0,0,8,8"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="RevokeTokenBtn_Click"/>
                                            <Button x:Name="DeleteTokenBtn" Content="🗑️ Supprimer" Padding="12,8" Margin="0,0,8,8"
                                                    Style="{StaticResource PilotageButtonStyle}" Click="DeleteTokenBtn_Click"/>
                                            <Button Content="📢 Notifier" Padding="12,8" Margin="0,0,8,8"
                                                    Style="{StaticResource PilotageAccentButtonStyle}" Click="NotifyUserBtn_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ONGLET 4 : SERVEUR VPS                                         -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource PilotageTabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖥️ Serveur" FontSize="14" FontWeight="SemiBold"/>
                        <Ellipse x:Name="VpsStatusDot" Width="8" Height="8" Margin="8,0,0,0"
                                 VerticalAlignment="Center" Fill="#555555"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid Background="{StaticResource PilotageBackground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- En-tête -->
                    <Border Grid.Row="0" Background="{StaticResource PilotageCardBackground}"
                            BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1"
                            Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="VpsOnlineDot" Width="12" Height="12" Fill="#555555" Margin="0,0,10,0"/>
                                <TextBlock x:Name="VpsStatusText" Text="Non connecté"
                                           Foreground="{StaticResource PilotageTextSecondary}" FontSize="13"/>
                                <TextBlock x:Name="VpsLastUpdateText" Text=""
                                           Foreground="{StaticResource PilotageTextSecondary}"
                                           FontSize="11" Margin="15,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="VpsRefreshBtn" Content="🔄 Rafraîchir"
                                        Padding="12,6" Margin="0,0,8,0"
                                        Style="{StaticResource PilotageButtonStyle}"
                                        Click="VpsRefresh_Click"/>
                                <Button x:Name="VpsAiBtn" Content="🤖 Avis IA"
                                        Padding="12,6"
                                        Style="{StaticResource PilotageAccentButtonStyle}"
                                        Click="VpsAiAnalysis_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Contenu scrollable -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                        <StackPanel>

                            <!-- MÉTRIQUES SYSTÈME -->
                            <Border Background="{StaticResource PilotageCardBackground}"
                                    BorderBrush="{StaticResource PilotageBorder}" BorderThickness="1"
                                    CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="RESSOURCES SYSTÈME"
                                               Foreground="{StaticResource PilotageTextSecondary}"
                                               FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>

                                    <!-- CPU -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CPU" Foreground="{StaticResource PilotageTextPrimary}"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                        <ProgressBar x:Name="CpuBar" Grid.Column="1" Height="10"
                                                     Minimum="0" Maximum="100" Value="0"
                                                     Foreground="#27AE60" Background="#3D3D3D"
                                                     VerticalAlignment="Center" Margin="10,0"/>
                                        <TextBlock x:Name="CpuText" Grid.Column="2" Text="0%"
                                                   Foreground="{StaticResource PilotageTextPrimary}"
                                                   FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- RAM -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="RAM" Foreground="{StaticResource PilotageTextPrimary}"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                        <ProgressBar x:Name="RamBar" Grid.Column="1" Height="10"
                                                     Minimum="0" Maximum="100" Value="0"
                                                     Foreground="#27AE60" Background="#3D3D3D"
                                                     VerticalAlignment="Center" Margin="10,0"/>
                                        <TextBlock x:Name="RamText" Grid.Column="2" Text="0%"
                                                   Foreground="{StaticResource PilotageTextPrimary}"
                                                   FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Disque -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Disque" Foreground="{StaticResource PilotageTextPrimary}"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                        <ProgressBar x:Name="DiskBar" Grid.Column="1" Height="10"
                                                     Minimum="0" Maximum="100" Value="0"
                                                     Foreground="#27AE60" Background="#3D3D3D"
                                                     VerticalAlignment="Center" Margin="10,0"/>
                                        <TextBlock x:Name="DiskText" Grid.Column="2" Text="0%"
                                                   Foreground="{StaticResource PilotageTextPrimary}"
                                                   FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- SERVICES -->
                            <Border Background="{StaticResource PilotageCardBackground}"
                                    BorderBrush="{StaticResource PilotageBorder}" BorderThickness="1"
                                    CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="SERVICES"
                                                   Foreground="{StaticResource PilotageTextSecondary}"
                                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <WrapPanel x:Name="ServicesPanel"/>
                                </StackPanel>
                            </Border>

                            <!-- AVIS IA -->
                            <Border x:Name="AiAnalysisPanel"
                                    Background="{StaticResource PilotageCardBackground}"
                                    BorderBrush="{StaticResource PilotageBorder}" BorderThickness="1"
                                    CornerRadius="8" Padding="20" Margin="0,0,0,15"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="ANALYSE IA"
                                               Foreground="{StaticResource PilotageTextSecondary}"
                                               FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="AiAnalysisText"
                                               Foreground="{StaticResource PilotageTextPrimary}"
                                               FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                                </StackPanel>
                            </Border>

                            <!-- NETTOYAGE -->
                            <Border Background="{StaticResource PilotageCardBackground}"
                                    BorderBrush="{StaticResource PilotageBorder}" BorderThickness="1"
                                    CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="NETTOYAGE"
                                                   Foreground="{StaticResource PilotageTextSecondary}"
                                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="🧹 Analyser pour nettoyage"
                                                Padding="12,6"
                                                Style="{StaticResource PilotageButtonStyle}"
                                                Click="VpsAnalyzeCleanup_Click"
                                                x:Name="VpsCleanupAnalyzeBtn"/>
                                    </Grid>

                                    <!-- Panel résultat analyse (caché par défaut) -->
                                    <StackPanel x:Name="CleanupPanel" Visibility="Collapsed">

                                        <!-- Avis IA -->
                                        <Border Background="#1A1A1A" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                            <TextBlock x:Name="CleanupAiText"
                                                       Foreground="#AAAAAA" FontSize="12"
                                                       TextWrapping="Wrap" LineHeight="20"/>
                                        </Border>

                                        <!-- Cases à cocher -->
                                        <TextBlock Text="Sélectionnez les actions à exécuter :"
                                                   Foreground="{StaticResource PilotageTextSecondary}"
                                                   FontSize="11" Margin="0,0,0,8"/>

                                        <CheckBox x:Name="CleanJournal7d"
                                                  Content="Journaux système &gt; 7 jours"
                                                  Foreground="White" Margin="0,0,0,6"/>
                                        <CheckBox x:Name="CleanJournal30d"
                                                  Content="Journaux système &gt; 30 jours (nettoyage léger)"
                                                  Foreground="White" Margin="0,0,0,6"/>
                                        <CheckBox x:Name="CleanDockerLogs"
                                                  Content="Logs Docker (livekit)"
                                                  Foreground="White" Margin="0,0,0,6"/>
                                        <CheckBox x:Name="CleanAptCache"
                                                  Content="Cache apt (paquets téléchargés)"
                                                  Foreground="White" Margin="0,0,0,6"/>
                                        <CheckBox x:Name="CleanTmpFiles"
                                                  Content="Fichiers temporaires /tmp &gt; 7 jours"
                                                  Foreground="White" Margin="0,0,0,12"/>

                                        <!-- Résultat exécution -->
                                        <Border x:Name="CleanupResultBorder" Background="#1A1A1A"
                                                CornerRadius="4" Padding="12" Margin="0,0,0,12"
                                                Visibility="Collapsed">
                                            <TextBlock x:Name="CleanupResultText"
                                                       Foreground="#27AE60" FontSize="12"
                                                       TextWrapping="Wrap"/>
                                        </Border>

                                        <Button x:Name="VpsCleanupExecuteBtn"
                                                Content="✅ Exécuter le nettoyage sélectionné"
                                                Padding="12,8" HorizontalAlignment="Left"
                                                Style="{StaticResource PilotageAccentButtonStyle}"
                                                Click="VpsExecuteCleanup_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- LOGS -->
                            <Border Background="{StaticResource PilotageCardBackground}"
                                    BorderBrush="{StaticResource PilotageBorder}" BorderThickness="1"
                                    CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="LOGS"
                                                   Foreground="{StaticResource PilotageTextSecondary}"
                                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <ComboBox x:Name="LogServiceCombo" Width="140" Margin="0,0,8,0"
                                                      Background="#3D3D3D" Foreground="White"
                                                      BorderBrush="{StaticResource PilotageBorder}">
                                                <ComboBox.Resources>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D2D"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E67E22"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="Background" Value="#2D2D2D"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="Padding" Value="8,6"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#4D4D4D"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#E67E22"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBox.Resources>
                                                <ComboBoxItem Content="livekit" IsSelected="True"/>
                                                <ComboBoxItem Content="nginx"/>
                                                <ComboBoxItem Content="parentaile-avatar"/>
                                                <ComboBoxItem Content="parentaile-account"/>
                                            </ComboBox>
                                            <Button Content="📋 Charger" Padding="10,5"
                                                    Style="{StaticResource PilotageButtonStyle}"
                                                    Click="VpsLoadLogs_Click" Margin="0,0,8,0"/>
                                            <Button Content="🤖 Analyser" Padding="10,5"
                                                    Style="{StaticResource PilotageButtonStyle}"
                                                    Click="VpsAnalyzeLogs_Click"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Background="#1A1A1A" CornerRadius="4" Padding="12">
                                        <TextBlock x:Name="LogsText"
                                                   Foreground="#AAAAAA" FontSize="11"
                                                   FontFamily="Consolas" TextWrapping="Wrap"
                                                   Text="Sélectionnez un service et cliquez sur Charger."/>
                                    </Border>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ONGLET BOITE ADMIN                                            -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource PilotageTabItemStyle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📬 Boîte admin" FontSize="14" FontWeight="SemiBold"/>
                        <Border x:Name="InboxBadge" Background="#E74C3C" CornerRadius="10"
                                Padding="6,2" Margin="6,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                            <TextBlock x:Name="InboxBadgeCount" Text="0" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" MinWidth="260"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── COLONNE GAUCHE : filtres + liste ── -->
                    <Border Grid.Column="0" Background="{StaticResource PilotageCardBackground}"
                            BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Filtres -->
                            <Border Grid.Row="0" Padding="12,10"
                                    BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <!-- Filtre statut -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button x:Name="InboxFilterAll" Content="Tous" Padding="10,5" Margin="0,0,4,0"
                                                Style="{StaticResource PilotageAccentButtonStyle}"
                                                Click="InboxFilter_Click" Tag="all"/>
                                        <Button x:Name="InboxFilterUnread" Content="Non lus" Padding="10,5" Margin="0,0,4,0"
                                                Style="{StaticResource PilotageButtonStyle}"
                                                Click="InboxFilter_Click" Tag="unread"/>
                                        <Button x:Name="InboxFilterRead" Content="Lus" Padding="10,5"
                                                Style="{StaticResource PilotageButtonStyle}"
                                                Click="InboxFilter_Click" Tag="read"/>
                                    </StackPanel>
                                    <!-- Filtre type -->
                                    <ComboBox x:Name="InboxTypeFilter"
                                              SelectionChanged="InboxTypeFilter_SelectionChanged"
                                              Style="{StaticResource DarkComboBoxStyle}">
                                        <ComboBoxItem Content="Tous les types" Tag="" IsSelected="True"/>
                                        <ComboBoxItem Content="🐛 Bugs" Tag="feedback_bug"/>
                                        <ComboBoxItem Content="💡 Suggestions" Tag="feedback_suggestion"/>
                                        <ComboBoxItem Content="❓ Questions" Tag="feedback_question"/>
                                        <ComboBoxItem Content="⚠️ Recours ban" Tag="ban_appeal"/>
                                        <ComboBoxItem Content="🚨 Signalements" Tag="ban_report"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- Liste items -->
                            <ListBox x:Name="InboxListBox" Grid.Row="1"
                                     Background="Transparent" BorderThickness="0"
                                     SelectionChanged="InboxListBox_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#2D2D2D"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2D2D2D"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#3D3D3D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Point non-lu -->
                                            <Ellipse Grid.Column="0" Width="6" Height="6"
                                                     Fill="#E67E22" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Reviewed}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                    <TextBlock Text="{Binding TypeIcon}" FontSize="13" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding TypeLabel}" FontSize="11" FontWeight="Bold"
                                                               Foreground="{StaticResource PilotageAccent}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding DisplayPseudo}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding MessagePreview}" FontSize="11"
                                                           Foreground="#888888" TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" Text="{Binding CreatedAt, StringFormat=dd/MM}"
                                                       FontSize="10" Foreground="#555555"
                                                       VerticalAlignment="Top" Margin="8,2,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource PilotageBorder}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                    <!-- ── COLONNE DROITE : panneau détail ── -->
                    <Grid Grid.Column="2">

                        <!-- État vide -->
                        <Border x:Name="InboxEmptyPanel" Background="{StaticResource PilotageBackground}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="📬" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                                <TextBlock Text="Sélectionnez un message" FontSize="14"
                                           Foreground="#555555" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                <TextBlock x:Name="InboxStatusText" Text="" FontSize="11"
                                           Foreground="#444444" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Panneau détail -->
                        <Border x:Name="InboxDetailPanel" Background="{StaticResource PilotageBackground}"
                                Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="24,20">

                                    <!-- En-tête type + date + badge -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="InboxDetailIcon" Text="📬" FontSize="28"
                                                   Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="InboxDetailTypeLabel" Text="" FontSize="16"
                                                       FontWeight="Bold" Foreground="White"/>
                                            <TextBlock x:Name="InboxDetailDate" Text="" FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <Border x:Name="InboxDetailBadge" Grid.Column="2" CornerRadius="4"
                                                Padding="8,3" VerticalAlignment="Center">
                                            <TextBlock x:Name="InboxDetailBadgeText" Text="" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>

                                    <!-- Expéditeur / participant banni -->
                                    <Border Background="#2D2D2D" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="👤" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock x:Name="InboxDetailPseudo" Text="" FontSize="13"
                                                           FontWeight="SemiBold" Foreground="White"/>
                                                <TextBlock x:Name="InboxDetailUid" Text="" FontSize="10" Foreground="#666666"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Personne signalée (ban_report uniquement) -->
                                    <Border x:Name="InboxReportedBlock" Background="#2D2D2D" CornerRadius="4"
                                            Padding="12,10" Margin="0,0,0,10" Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🎯" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="Personne signalée" FontSize="10" Foreground="#888888"/>
                                                <TextBlock x:Name="InboxDetailReportedUid" Text="" FontSize="11" Foreground="#AAAAAA"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Groupe (ban_appeal + ban_report) -->
                                    <Border x:Name="InboxGroupeBlock" Background="#2D2D2D" CornerRadius="4"
                                            Padding="12,10" Margin="0,0,0,10" Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🗣" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="Groupe" FontSize="10" Foreground="#888888"/>
                                                <TextBlock x:Name="InboxDetailGroupeId" Text="" FontSize="11" Foreground="#AAAAAA"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Message -->
                                    <TextBlock Text="MESSAGE" FontSize="10" FontWeight="Bold"
                                               Foreground="#888888" Margin="0,6,0,8"/>
                                    <Border Background="#2D2D2D" CornerRadius="4" Padding="14,12" Margin="0,0,0,16">
                                        <TextBlock x:Name="InboxDetailMessage" Text="" FontSize="13"
                                                   Foreground="White" TextWrapping="Wrap" LineHeight="22"/>
                                    </Border>

                                    <!-- Contexte technique (feedback uniquement) -->
                                    <Border x:Name="InboxContextBlock" Visibility="Collapsed" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="CONTEXTE" FontSize="10" FontWeight="Bold"
                                                       Foreground="#888888" Margin="0,0,0,8"/>
                                            <Border Background="#1A1A2E" CornerRadius="4" Padding="12,10">
                                                <StackPanel>
                                                    <TextBlock x:Name="InboxCtxUrl" Text="" FontSize="10"
                                                               Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                    <TextBlock x:Name="InboxCtxVersion" Text="" FontSize="10" Foreground="#666666"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Actions -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="InboxMarkReadBtn" Content="✓ Marquer lu" Padding="14,8" Margin="0,0,8,0"
                                                Style="{StaticResource PilotageButtonStyle}" Click="InboxMarkReadBtn_Click"/>
                                        <Button x:Name="InboxDeleteBtn" Content="🗑 Supprimer" Padding="14,8"
                                                Foreground="White" BorderThickness="0" Cursor="Hand"
                                                Click="InboxDeleteBtn_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#5C3030"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#7C2020"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- FOOTER : Statut + dernière synchro -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource PilotageCardBackground}"
                BorderBrush="{StaticResource PilotageBorder}" BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Info sélection -->
                <TextBlock x:Name="SelectionInfoText" Grid.Column="0"
                           Text="Sélectionnez un message pour répondre"
                           Foreground="{StaticResource PilotageTextSecondary}"
                           VerticalAlignment="Center" FontSize="12"/>

                <!-- Dernière synchro -->
                <TextBlock x:Name="LastSyncText" Grid.Column="1"
                           Text="Dernière synchro: —"
                           Foreground="#555555" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

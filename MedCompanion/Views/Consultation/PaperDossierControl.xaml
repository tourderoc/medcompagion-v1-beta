<UserControl x:Class="MedCompanion.Views.Consultation.PaperDossierControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MedCompanion.Views.Consultation"
             xmlns:models="clr-namespace:MedCompanion.Models"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="#F5F7FA">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Couleurs du dossier médical -->
        <SolidColorBrush x:Key="DossierBackgroundBrush" Color="#5A9AAC"/>
        <SolidColorBrush x:Key="DossierBorderBrush" Color="#1B3A44"/>
        <SolidColorBrush x:Key="DossierTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FFFEF8"/>
        <SolidColorBrush x:Key="PageBorderBrush" Color="#D4C9B8"/>
        <SolidColorBrush x:Key="TabActiveBrush" Color="#D4E9F0"/>
        <SolidColorBrush x:Key="TabInactiveBrush" Color="#F0F7FA"/>
        <SolidColorBrush x:Key="SpineBrush" Color="#E8E0D0"/>

        <!-- Style intercalaire vertical -->
        <Style x:Key="IntercalaireStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Margin" Value="-4,2,0,2"/>
            <Setter Property="Padding" Value="5,15"/>
            <Setter Property="Background" Value="{StaticResource TabInactiveBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DossierBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,6,6,0"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.15"/>
                            </Border.Effect>
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#2C3E50"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.LayoutTransform>
                                    <RotateTransform Angle="-90"/>
                                </TextBlock.LayoutTransform>
                            </TextBlock>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#E0EEF4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style intercalaire actif -->
        <Style x:Key="IntercalaireActiveStyle" TargetType="Button" BasedOn="{StaticResource IntercalaireStyle}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Margin" Value="-10,2,0,2"/>
            <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Style bouton navigation page -->
        <Style x:Key="PageNavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Background" Value="#80FFFFFF"/>
            <Setter Property="Foreground" Value="#5A9AAC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Opacity="0.7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBg" Property="Opacity" Value="1"/>
                                <Setter TargetName="NavBg" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="NavBg" Property="Opacity" Value="0.2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style bouton ouvrir/fermer -->
        <Style x:Key="DossierActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="30,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#5A9AAC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="25"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBg" Property="Background" Value="#F0F7FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template pour afficher le contenu d'une page -->
        <DataTemplate x:Key="PageContentTemplate" DataType="{x:Type models:DossierPageItem}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
                <StackPanel>
                    <!-- En-tête de la page -->
                    <Border Background="#F5F5F0" CornerRadius="6" Padding="12" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="#2C3E50"/>
                                <TextBlock Text="{Binding DateFormatted}"
                                           FontSize="12" Foreground="#7F8C8D" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#5A9AAC" CornerRadius="4" Padding="8,4">
                                <TextBlock Text="{Binding DocumentType}"
                                           FontSize="11" Foreground="White"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Contenu de la page -->
                    <TextBlock Text="{Binding Content}"
                               TextWrapping="Wrap"
                               FontSize="13"
                               FontFamily="Georgia, Times New Roman, serif"
                               Foreground="#2C3E50"
                               LineHeight="22"/>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- CORPS DU DOSSIER -->
        <Grid Grid.Column="0" Margin="20">

            <!-- ÉTAT FERMÉ : Couverture -->
            <Viewbox Visibility="{Binding IsDossierClosed, Converter={StaticResource BoolToVis}}"
                     Stretch="Uniform" 
                     HorizontalAlignment="Center" 
                     VerticalAlignment="Center">
                <Border x:Name="CoverView"
                        Width="595" Height="842"
                        Background="{StaticResource DossierBackgroundBrush}"
                        CornerRadius="0,12,12,0"
                        BorderBrush="{StaticResource DossierBorderBrush}"
                        BorderThickness="4,4,2,4">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="10" BlurRadius="25" Opacity="0.3"/>
                    </Border.Effect>

                <Grid Margin="35">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Titre -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,25,0,0">
                        <TextBlock Text="DOSSIER PATIENT"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Dr Lassoued"
                                   FontSize="14"
                                   Foreground="#B0FFFFFF"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Informations Patient -->
                    <Border Grid.Row="1"
                            Background="#30FFFFFF"
                            CornerRadius="10"
                            Padding="25"
                            Margin="0,35,0,0"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <!-- Numéro de dossier -->
                            <Border Background="#20FFFFFF" CornerRadius="6" Padding="12,8" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="N° de Dossier : " Foreground="#B0FFFFFF" FontSize="13"/>
                                    <TextBlock Text="{Binding CurrentPatient.NumeroDossier, TargetNullValue='Non attribué'}"
                                               Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <!-- Nom -->
                            <Grid Margin="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Nom :"
                                           Foreground="#B0FFFFFF" FontSize="14"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Nom}"
                                           Foreground="White" FontWeight="Bold" FontSize="18"/>
                            </Grid>

                            <!-- Prénom -->
                            <Grid Margin="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Prénom :"
                                           Foreground="#B0FFFFFF" FontSize="14"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Prenom}"
                                           Foreground="White" FontWeight="SemiBold" FontSize="16"/>
                            </Grid>

                            <!-- Date de naissance -->
                            <Grid Margin="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Date de naissance :"
                                           Foreground="#B0FFFFFF" FontSize="14"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.DobFormatted}"
                                           Foreground="White" FontSize="14"/>
                            </Grid>

                            <!-- Séparateur -->
                            <Rectangle Height="1" Fill="#40FFFFFF" Margin="0,20"/>

                            <!-- Indicateur de contenu -->
                            <TextBlock Text="Cliquez sur un intercalaire ou sur 'Ouvrir'"
                                       FontSize="12" FontStyle="Italic"
                                       Foreground="#80FFFFFF"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Bouton Ouvrir -->
                    <Button Grid.Row="2"
                            Content="Ouvrir le dossier"
                            Command="{Binding OpenDossierCommand}"
                            Style="{StaticResource DossierActionButtonStyle}"
                            HorizontalAlignment="Center"
                            Margin="0,30,0,25"/>
                </Grid>
            </Border>
            </Viewbox>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- MODE PARTAGE (F2) : Page unique pour lisibilité -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid x:Name="SinglePageView"
                  Visibility="{Binding IsDossierOpen, Converter={StaticResource BoolToVis}}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDossierOpen}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="{StaticResource DossierBackgroundBrush}"
                        CornerRadius="8,8,0,0"
                        Padding="15,10">
                    <Grid>
                        <TextBlock Text="{Binding CurrentSectionData.SectionName}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <Button Content="Fermer"
                                Command="{Binding CloseDossierCommand}"
                                HorizontalAlignment="Right"
                                Padding="10,4"
                                FontSize="11"
                                Background="#40FFFFFF"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Page unique -->
                <Border Grid.Row="1"
                        Background="{StaticResource PageBackgroundBrush}"
                        BorderBrush="{StaticResource PageBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <ContentControl Content="{Binding LeftPage}"
                                        ContentTemplate="{StaticResource PageContentTemplate}"
                                        Visibility="{Binding LeftPage, Converter={StaticResource BoolToVis}}"/>

                        <StackPanel Visibility="{Binding IsCurrentSectionEmpty, Converter={StaticResource BoolToVis}}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Aucun document"
                                       FontSize="16" Foreground="#95A5A6"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Cette section est vide"
                                       FontSize="12" Foreground="#BDC3C7"
                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Navigation compacte -->
                <Border Grid.Row="2"
                        Background="#F0F0F0"
                        CornerRadius="0,0,8,8"
                        Padding="10,8">
                    <Grid>
                        <Button Content="◀"
                                Command="{Binding PreviousPageCommand}"
                                HorizontalAlignment="Left"
                                Width="35" Height="30"
                                FontSize="14"
                                Background="White"
                                BorderThickness="1"
                                BorderBrush="#E0E0E0"
                                Cursor="Hand"/>
                        <TextBlock Text="{Binding PageIndicator}"
                                   FontSize="12" Foreground="#7F8C8D"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Button Content="▶"
                                Command="{Binding NextPageCommand}"
                                HorizontalAlignment="Right"
                                Width="35" Height="30"
                                FontSize="14"
                                Background="White"
                                BorderThickness="1"
                                BorderBrush="#E0E0E0"
                                Cursor="Hand"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- MODE PLEIN ECRAN (F3) : Double page comme un livre -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid x:Name="DoublePageView">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsFocusDossier}" Value="True"/>
                                    <Condition Binding="{Binding IsDossierOpen}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>  <!-- Flèche gauche -->
                    <ColumnDefinition Width="*"/>   <!-- Page gauche -->
                    <ColumnDefinition Width="20"/>  <!-- Reliure -->
                    <ColumnDefinition Width="*"/>   <!-- Page droite -->
                    <ColumnDefinition Width="50"/>  <!-- Flèche droite -->
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Titre section -->
                    <RowDefinition Height="*"/>     <!-- Pages -->
                    <RowDefinition Height="Auto"/>  <!-- Pagination -->
                </Grid.RowDefinitions>

                <!-- Titre de la section -->
                <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                        Background="{StaticResource DossierBackgroundBrush}"
                        CornerRadius="8,8,0,0"
                        Padding="20,12"
                        Margin="0,0,0,0">
                    <Grid>
                        <TextBlock Text="{Binding CurrentSectionData.SectionName}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <Button Content="Fermer"
                                Command="{Binding CloseDossierCommand}"
                                HorizontalAlignment="Right"
                                Padding="15,5"
                                FontSize="12"
                                Background="#40FFFFFF"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Flèche gauche -->
                <Button Grid.Row="1" Grid.Column="0"
                        Content="&#x25C0;"
                        Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource PageNavButtonStyle}"
                        VerticalAlignment="Center"/>

                <!-- PAGE GAUCHE -->
                <Border Grid.Row="1" Grid.Column="1"
                        Background="{StaticResource PageBackgroundBrush}"
                        BorderBrush="{StaticResource PageBorderBrush}"
                        BorderThickness="1,1,0,1"
                        CornerRadius="8,0,0,8">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="3" BlurRadius="8" Opacity="0.1" Direction="180"/>
                    </Border.Effect>

                    <Grid>
                        <ContentControl Content="{Binding LeftPage}"
                                        ContentTemplate="{StaticResource PageContentTemplate}"
                                        Visibility="{Binding LeftPage, Converter={StaticResource BoolToVis}}"/>

                        <StackPanel Visibility="{Binding IsCurrentSectionEmpty, Converter={StaticResource BoolToVis}}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Aucun document"
                                       FontSize="18" Foreground="#95A5A6"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Cette section est vide"
                                       FontSize="13" Foreground="#BDC3C7"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RELIURE (Spine) -->
                <Border Grid.Row="1" Grid.Column="2"
                        Background="{StaticResource SpineBrush}">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.2"/>
                    </Border.Effect>
                    <Rectangle Width="2" Fill="#C0B8A8" HorizontalAlignment="Center"/>
                </Border>

                <!-- PAGE DROITE -->
                <Border Grid.Row="1" Grid.Column="3"
                        Background="{StaticResource PageBackgroundBrush}"
                        BorderBrush="{StaticResource PageBorderBrush}"
                        BorderThickness="0,1,1,1"
                        CornerRadius="0,8,8,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="3" BlurRadius="8" Opacity="0.1" Direction="0"/>
                    </Border.Effect>

                    <Grid>
                        <ContentControl Content="{Binding RightPage}"
                                        ContentTemplate="{StaticResource PageContentTemplate}"
                                        Visibility="{Binding RightPage, Converter={StaticResource BoolToVis}}"/>

                        <TextBlock Text="(Page suivante)"
                                   FontSize="14" FontStyle="Italic" Foreground="#D0D0D0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RightPage}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Flèche droite -->
                <Button Grid.Row="1" Grid.Column="4"
                        Content="&#x25B6;"
                        Command="{Binding NextPageCommand}"
                        Style="{StaticResource PageNavButtonStyle}"
                        VerticalAlignment="Center"/>

                <!-- Indicateur de pagination -->
                <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                        Background="#F0F0F0"
                        CornerRadius="0,0,8,8"
                        Padding="0,10">
                    <TextBlock Text="{Binding PageIndicator}"
                               FontSize="13" Foreground="#7F8C8D"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Indicateur de chargement -->
            <Border Visibility="{Binding IsLoadingDossier, Converter={StaticResource BoolToVis}}"
                    Background="#80FFFFFF"
                    CornerRadius="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Chargement du dossier..."
                               FontSize="16" Foreground="#5A9AAC"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- INTERCALAIRES (toujours visibles) -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,20,10,20">

            <Button Content="SYNTH."
                    Command="{Binding SelectDossierTabCommand}"
                    CommandParameter="Synthese"
                    Style="{Binding IsSyntheseActive, Converter={StaticResource BoolToVis},
                            ConverterParameter={StaticResource IntercalaireActiveStyle},
                            FallbackValue={StaticResource IntercalaireStyle}}"/>

            <Button Content="ADMIN."
                    Command="{Binding SelectDossierTabCommand}"
                    CommandParameter="Administratif"
                    Margin="0,4,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource IntercalaireStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAdminActive}" Value="True">
                                <Setter Property="Width" Value="40"/>
                                <Setter Property="Margin" Value="-10,2,0,2"/>
                                <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="CONSULT."
                    Command="{Binding SelectDossierTabCommand}"
                    CommandParameter="Consultations"
                    Margin="0,4,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource IntercalaireStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConsultationsActive}" Value="True">
                                <Setter Property="Width" Value="40"/>
                                <Setter Property="Margin" Value="-10,2,0,2"/>
                                <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="PROJET"
                    Command="{Binding SelectDossierTabCommand}"
                    CommandParameter="ProjetTherapeutique"
                    Margin="0,4,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource IntercalaireStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProjetActive}" Value="True">
                                <Setter Property="Width" Value="40"/>
                                <Setter Property="Margin" Value="-10,2,0,2"/>
                                <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="BILANS"
                    Command="{Binding SelectDossierTabCommand}"
                    CommandParameter="Bilans"
                    Margin="0,4,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource IntercalaireStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBilansActive}" Value="True">
                                <Setter Property="Width" Value="40"/>
                                <Setter Property="Margin" Value="-10,2,0,2"/>
                                <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="DOCS"
                    Command="{Binding SelectDossierTabCommand}"
                    CommandParameter="Documents"
                    Margin="0,4,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource IntercalaireStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDocumentsActive}" Value="True">
                                <Setter Property="Width" Value="40"/>
                                <Setter Property="Margin" Value="-10,2,0,2"/>
                                <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>

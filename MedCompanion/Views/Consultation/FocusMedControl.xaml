<UserControl x:Class="MedCompanion.Views.Consultation.FocusMedControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MedCompanion.ViewModels"
             xmlns:controls="clr-namespace:MedCompanion.Controls"
             xmlns:converters="clr-namespace:MedCompanion.Converters"
             Background="#F0F4F8">

    <UserControl.DataContext>
        <vm:FocusMedViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- Animation de pulsation pour le micro actif -->
        <Storyboard x:Key="MicPulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="1.0" To="0.5" Duration="0:0:0.5"
                           AutoReverse="True"/>
        </Storyboard>

        <!-- Style pour les cartes archive -->
        <Style x:Key="ArchiveCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#90CAF9"/>
                    <Setter Property="Background" Value="#FAFAFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Layout principal 45% / 24% / 31% -->
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="45*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="24*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="31*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- COLONNE GAUCHE (45%) - Zone Active -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.1"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Zone Active"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#2C3E50"/>
                    <TextBlock Text="Votre espace de réflexion et d'interaction"
                               FontSize="12"
                               Foreground="#7F8C8D"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Zone de conversation -->
                <Border Grid.Row="1"
                        Background="#FAFAFA"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,15">
                    <ScrollViewer x:Name="MessagesScrollViewer" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="MaxWidth" Value="450"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Border CornerRadius="12" Padding="12,10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           FontSize="13"
                                                           Foreground="#2C3E50"/>
                                                <Grid Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Bouton lecture (seulement pour messages Med) -->
                                                    <Button Grid.Column="0"
                                                            Content="🔊"
                                                            FontSize="12"
                                                            Padding="4,2"
                                                            Cursor="Hand"
                                                            ToolTip="Lire ce message"
                                                            Click="SpeakMessage_Click"
                                                            Tag="{Binding Content}"
                                                            Visibility="{Binding IsMed, Converter={StaticResource BoolToVis}}">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="SpeakBorder"
                                                                                    Background="Transparent"
                                                                                    CornerRadius="4"
                                                                                    Padding="4,2">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="SpeakBorder" Property="Background" Value="#BBDEFB"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding TimeLabel}"
                                                               FontSize="10"
                                                               Foreground="#95A5A6"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Zone de saisie -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bouton Micro -->
                    <Button x:Name="VoiceInputButton"
                            Grid.Column="0"
                            Width="50"
                            Height="50"
                            Click="VoiceInputButton_Click"
                            Cursor="Hand"
                            ToolTip="Cliquez pour parler (Handy)">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="VoiceBorder"
                                                    Background="#F5F5F5"
                                                    CornerRadius="8"
                                                    BorderBrush="#E0E0E0"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <TextBlock x:Name="MicEmoji"
                                                               Text="🎤"
                                                               FontSize="20"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="VoiceBorder" Property="Background" Value="#EEEEEE"/>
                                                    <Setter TargetName="VoiceBorder" Property="BorderBrush" Value="#3498DB"/>
                                                </Trigger>
                                                <!-- Mode conversation activé (bleu) -->
                                                <DataTrigger Binding="{Binding IsConversationModeEnabled}" Value="True">
                                                    <Setter TargetName="VoiceBorder" Property="Background" Value="#E3F2FD"/>
                                                    <Setter TargetName="VoiceBorder" Property="BorderBrush" Value="#2196F3"/>
                                                    <Setter TargetName="MicEmoji" Property="Foreground" Value="#2196F3"/>
                                                </DataTrigger>
                                                <!-- En enregistrement (rouge) - priorité sur le bleu -->
                                                <DataTrigger Binding="{Binding IsVoiceRecording}" Value="True">
                                                    <Setter TargetName="VoiceBorder" Property="Background" Value="#FFEBEE"/>
                                                    <Setter TargetName="VoiceBorder" Property="BorderBrush" Value="#E53935"/>
                                                    <Setter TargetName="MicEmoji" Property="Text" Value="🔴"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBox Grid.Column="2"
                             x:Name="InputTextBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="InputTextBox_TextChanged"
                             FontSize="14"
                             Padding="12"
                             MinHeight="50"
                             MaxHeight="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             BorderBrush="#E0E0E0"
                             BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="White"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button Grid.Column="4"
                            x:Name="SendButton"
                            Content="➤"
                            Width="50"
                            Height="50"
                            FontSize="18"
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding SendMessageCommand}"
                            ToolTip="Envoyer le message">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2980B9"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#BDC3C7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- COLONNE CENTRE (24%) - Bureau de Med -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="2"
                Background="White"
                CornerRadius="12"
                BorderBrush="#90CAF9"
                BorderThickness="2">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="12" Opacity="0.15" Color="#3498DB"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Zone Avatar (haut) -->
                <Border Grid.Row="0" Margin="20,20,20,10">
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center">
                        
                        <!-- Titre Assistant IA (déplacé en haut) -->
                        <TextBlock Text="Assistant IA"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"/>

                        <!-- Avatar Med avec animations Lottie -->
                        <Grid>
                            <controls:MedAvatarControl x:Name="MedAvatar"
                                                        AvatarSize="120"
                                                        Background="#E3F2FD"/>

                            <!-- Bouton config (petit engrenage) -->
                            <Button x:Name="ConfigAvatarBtn"
                                    Click="ConfigAvatar_Click"
                                    Width="24"
                                    Height="24"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,-5,-5,0"
                                    ToolTip="Configurer l'avatar"
                                    Cursor="Hand"
                                    Opacity="0.6">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="#F5F5F5"
                                                            CornerRadius="12"
                                                            BorderBrush="#E0E0E0"
                                                            BorderThickness="1">
                                                        <TextBlock Text="⚙"
                                                                   FontSize="12"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- Info LLM (déplacé sous l'avatar) -->
                        <Border Background="#F5F5F5"
                                CornerRadius="8"
                                Padding="10,5"
                                Margin="0,15,0,0"
                                HorizontalAlignment="Center">
                            <TextBlock Text="{Binding LLMInfo}"
                                       FontSize="11"
                                       Foreground="#607D8B"
                                       HorizontalAlignment="Center"
                                       FontFamily="Consolas"/>
                        </Border>

                        <!-- Indicateur d'état dynamique -->
                        <Border CornerRadius="10"
                                Padding="10,5"
                                Margin="0,10,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsThinking}" Value="True">
                                            <Setter Property="Background" Value="#FFF3E0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding MedStatusText}"
                                       FontSize="11"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsThinking}" Value="True">
                                                <Setter Property="Foreground" Value="#F57C00"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                                <Setter Property="Foreground" Value="#1976D2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Indicateur TTS disponible -->
                        <TextBlock FontSize="10"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🔊 Voix activée"/>
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TTSAvailable}" Value="False">
                                            <Setter Property="Text" Value="🔇 Voix indisponible"/>
                                            <Setter Property="Foreground" Value="#95A5A6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Boutons Micro et Stop -->
                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,20">

                    <!-- Bouton unique : Micro / Stop -->
                    <Button x:Name="VoiceControlButton"
                            Click="VoiceControlButton_Click"
                            Width="60"
                            Height="60"
                            Cursor="Hand"
                            HorizontalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="ToolTip" Value="Activer la voix de Med"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="VoiceBorder"
                                                    Background="#F5F5F5"
                                                    CornerRadius="30"
                                                    BorderBrush="#E0E0E0"
                                                    BorderThickness="2">
                                                <TextBlock x:Name="VoiceIcon"
                                                           Text="🎤"
                                                           FontSize="24"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!-- État: Voix activée (micro bleu) -->
                                                <DataTrigger Binding="{Binding IsMicrophoneEnabled}" Value="True">
                                                    <Setter TargetName="VoiceBorder" Property="Background" Value="#E3F2FD"/>
                                                    <Setter TargetName="VoiceBorder" Property="BorderBrush" Value="#3498DB"/>
                                                </DataTrigger>
                                                <!-- État: Med parle (bouton stop rouge) -->
                                                <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                                    <Setter TargetName="VoiceBorder" Property="Background" Value="#FFEBEE"/>
                                                    <Setter TargetName="VoiceBorder" Property="BorderBrush" Value="#E53935"/>
                                                    <Setter TargetName="VoiceIcon" Property="Text" Value="⏹"/>
                                                </DataTrigger>
                                                <!-- Hover -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="VoiceBorder" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <!-- ToolTip dynamique -->
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMicrophoneEnabled}" Value="True">
                                        <Setter Property="ToolTip" Value="Désactiver la voix de Med"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                        <Setter Property="ToolTip" Value="Arrêter Med"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Voix désactivée"/>
                                <Setter Property="Foreground" Value="#95A5A6"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMicrophoneEnabled}" Value="True">
                                        <Setter Property="Text" Value="Voix activée"/>
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                        <Setter Property="Text" Value="Med parle..."/>
                                        <Setter Property="Foreground" Value="#1976D2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Zone Actions / Propositions -->
                <Border Grid.Row="2"
                        Background="#FFF8E1"
                        CornerRadius="0,0,10,10"
                        Padding="15"
                        Visibility="{Binding HasPendingAction, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding PendingActionText}"
                                   FontSize="13"
                                   Foreground="#F57C00"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Oui"
                                    x:Name="AcceptActionBtn"
                                    Width="60"
                                    Height="32"
                                    FontSize="13"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Margin="0,0,10,0"
                                    Click="AcceptAction_Click"
                                    ToolTip="Accepter">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#43A047"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="Non"
                                    x:Name="DeclineActionBtn"
                                    Width="60"
                                    Height="32"
                                    FontSize="13"
                                    Background="#E0E0E0"
                                    Foreground="#666666"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="DeclineAction_Click"
                                    ToolTip="Refuser">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#BDBDBD"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- COLONNE DROITE (31%) - Mémoire de Med -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="4"
                Background="White"
                CornerRadius="12"
                Padding="20"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.1"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧠"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Mémoire de Med"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Ce que Med retient de nos échanges"
                               FontSize="12"
                               Foreground="#7F8C8D"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Liste des blocs mémoire -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding MemoryBlocks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12"
                                        Background="White"
                                        CornerRadius="8"
                                        BorderThickness="1"
                                        Padding="12"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#90CAF9"/>
                                                    <Setter Property="Background" Value="#FAFAFA"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <!-- Mode Lecture -->
                                        <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                            <StackPanel.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                               Command="{Binding DataContext.EditMemoryBlockCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               CommandParameter="{Binding}"/>
                                            </StackPanel.InputBindings>

                                            <!-- Titre avec icône -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontSize="16"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#2C3E50"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Description -->
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="#95A5A6"
                                                       Margin="0,0,0,8"/>

                                            <!-- Aperçu du contenu -->
                                            <TextBlock Text="{Binding Preview}"
                                                       FontSize="12"
                                                       Foreground="#7F8C8D"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="60"/>

                                            <!-- Indication de clic -->
                                            <TextBlock Text="Cliquer pour modifier"
                                                       FontSize="10"
                                                       Foreground="#BDC3C7"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,8,0,0"/>
                                        </StackPanel>

                                        <!-- Mode Édition -->
                                        <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                            <!-- Titre -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontSize="16"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#3498DB"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Zone de texte -->
                                            <TextBox Text="{Binding DataContext.EditingBlockContent, RelativeSource={RelativeSource AncestorType=ItemsControl}, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="12"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     MinHeight="80"
                                                     MaxHeight="150"
                                                     Padding="8"
                                                     VerticalScrollBarVisibility="Auto"
                                                     BorderBrush="#90CAF9"
                                                     BorderThickness="1">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="TextBox">
                                                                    <Border Background="White"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="6">
                                                                        <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>

                                            <!-- Boutons -->
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        Margin="0,10,0,0">
                                                <Button Content="Annuler"
                                                        Command="{Binding DataContext.CancelEditMemoryBlockCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Width="70"
                                                        Height="28"
                                                        FontSize="12"
                                                        Margin="0,0,8,0"
                                                        Cursor="Hand">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bd"
                                                                                Background="#F5F5F5"
                                                                                CornerRadius="4"
                                                                                BorderBrush="#E0E0E0"
                                                                                BorderThickness="1">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="#EEEEEE"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Content="Enregistrer"
                                                        Command="{Binding DataContext.SaveMemoryBlockCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Width="85"
                                                        Height="28"
                                                        FontSize="12"
                                                        Background="#3498DB"
                                                        Foreground="White"
                                                        Cursor="Hand">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bd"
                                                                                Background="{TemplateBinding Background}"
                                                                                CornerRadius="4">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="#2980B9"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<Window x:Class="MedCompanion.Views.Consultation.ContextCompletionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assistant Complétude — Contexte Patient"
        Width="680" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F9"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.05"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="✨ Assistant de Complétude — Contexte Patient"
                           FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Pour fiabiliser la restitution clinique finale, veuillez vérifier et compléter les informations manquantes détectées dans le dossier :"
                           FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Zones de saisie -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
            <StackPanel>

                <!-- ── Section Vérification d'âge (tous les patients) ── -->
                <Border x:Name="AgeSectionBorder" Visibility="Collapsed"
                        Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                        BorderBrush="#E8A01F" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="⚠️ Vérification de l'âge" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#D35400" Margin="0,0,0,10"/>

                        <!-- Comparaison âges -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#FEF9F0" CornerRadius="6" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Âge calculé (dossier DDN)" FontSize="11" Foreground="#7F8C8D"/>
                                    <TextBlock x:Name="TxtAgeCalculeDisplay" FontSize="20" FontWeight="Bold"
                                               Foreground="#2C3E50" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#FEF9F0" CornerRadius="6" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Âge mentionné (interrogatoire)" FontSize="11" Foreground="#7F8C8D"/>
                                    <TextBlock x:Name="TxtAgeInterrDisplay" FontSize="20" FontWeight="Bold"
                                               Foreground="#E74C3C" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- DDN actuelle -->
                        <TextBlock x:Name="TxtDobActuelleInfo" Text="" FontSize="12"
                                   Foreground="#7F8C8D" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <!-- Saisie DDN corrigée -->
                        <TextBlock Text="Date de naissance à corriger / confirmer (format jj/mm/aaaa) :"
                                   FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtDobCorrigee" Height="32" Padding="5,0"
                                 VerticalContentAlignment="Center" BorderBrush="#D6DBDF"
                                 FontSize="14"/>
                    </StackPanel>
                </Border>

                <!-- ── Sections contexte complet (3-11 ans seulement) ── -->
                <StackPanel x:Name="FullContextPanel" Visibility="Collapsed">

                    <!-- Groupe 1 : Scolarité -->
                    <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🏫 Scolarité" FontSize="14" FontWeight="SemiBold" Foreground="#2980B9" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="École / Établissement" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtEcole" Height="30" Padding="5" VerticalContentAlignment="Center" BorderBrush="#D6DBDF"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="Classe / Niveau" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtClasse" Height="30" Padding="5" VerticalContentAlignment="Center" BorderBrush="#D6DBDF"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="Ville / Commune de l'école" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtEcoleLieu" Height="30" Padding="5" VerticalContentAlignment="Center" BorderBrush="#D6DBDF"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Bottom">
                                    <Button x:Name="BtnRechercheEcole" Content="🔎 Rechercher l'école"
                                            Height="30" Padding="8,0" Cursor="Hand" FontSize="12"
                                            Background="#2980B9" Foreground="White" BorderThickness="0"
                                            Click="BtnRechercheEcole_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#2471A3"/></Trigger>
                                                    <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#AAB7B8"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Statut de recherche -->
                            <TextBlock x:Name="TxtRechercheStatut" Text="" FontSize="11" FontStyle="Italic"
                                       Foreground="#7F8C8D" Margin="0,8,0,0" TextWrapping="Wrap"
                                       Visibility="Collapsed"/>

                            <!-- Sélecteur si plusieurs résultats -->
                            <StackPanel x:Name="PanelResultats" Visibility="Collapsed" Margin="0,8,0,0">
                                <TextBlock Text="Plusieurs établissements trouvés — sélectionnez :" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbEcoleResultats" Height="30"
                                          DisplayMemberPath="DisplayLabel"
                                          SelectionChanged="CmbEcoleResultats_SelectionChanged"/>
                            </StackPanel>

                            <!-- Coordonnées récupérées (éditables) -->
                            <StackPanel x:Name="PanelCoordonnees" Visibility="Collapsed" Margin="0,10,0,0">
                                <Border Background="#EAF2F8" CornerRadius="6" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="📍 Coordonnées de l'école (vérifiables)" FontSize="11" FontWeight="SemiBold" Foreground="#2471A3" Margin="0,0,0,6"/>
                                        <TextBlock Text="Adresse" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtEcoleAdresse" Height="30" Padding="5" VerticalContentAlignment="Center" BorderBrush="#D6DBDF" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Téléphone" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                                <TextBox x:Name="TxtEcoleTel" Height="30" Padding="5" VerticalContentAlignment="Center" BorderBrush="#D6DBDF"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Email" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                                <TextBox x:Name="TxtEcoleEmail" Height="30" Padding="5" VerticalContentAlignment="Center" BorderBrush="#D6DBDF"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Groupe 2 : Famille & Parents -->
                    <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="👪 Famille &amp; Parents" FontSize="14" FontWeight="SemiBold" Foreground="#2980B9" Margin="0,0,0,10"/>
                            <TextBlock Text="Mère" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtMereNom" Grid.Column="0" Height="30" Padding="5" VerticalContentAlignment="Center" Tag="Prénom" BorderBrush="#D6DBDF"/>
                                <TextBox x:Name="TxtMereAge" Grid.Column="2" Height="30" Padding="5" VerticalContentAlignment="Center" Tag="Âge" BorderBrush="#D6DBDF"/>
                                <TextBox x:Name="TxtMereJob" Grid.Column="4" Height="30" Padding="5" VerticalContentAlignment="Center" Tag="Profession" BorderBrush="#D6DBDF"/>
                            </Grid>
                            <TextBlock Text="Père" FontWeight="SemiBold" Foreground="#34495E" Margin="0,5,0,5"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtPereNom" Grid.Column="0" Height="30" Padding="5" VerticalContentAlignment="Center" Tag="Prénom" BorderBrush="#D6DBDF"/>
                                <TextBox x:Name="TxtPereAge" Grid.Column="2" Height="30" Padding="5" VerticalContentAlignment="Center" Tag="Âge" BorderBrush="#D6DBDF"/>
                                <TextBox x:Name="TxtPereJob" Grid.Column="4" Height="30" Padding="5" VerticalContentAlignment="Center" Tag="Profession" BorderBrush="#D6DBDF"/>
                            </Grid>
                            <TextBlock Text="Fratrie (Frères et sœurs, âges, liens)" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtFratrie" Height="50" AcceptsReturn="True" TextWrapping="Wrap" Padding="5" BorderBrush="#D6DBDF"/>
                        </StackPanel>
                    </Border>

                    <!-- Groupe 3 : Acquisitions développementales -->
                    <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="👶 Acquisitions développementales" FontSize="14" FontWeight="SemiBold" Foreground="#2980B9" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="Âge de la marche" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtMarche" Height="30" Padding="5" VerticalContentAlignment="Center" BorderBrush="#D6DBDF"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="Acquisition du langage" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtLangage" Height="30" Padding="5" VerticalContentAlignment="Center" BorderBrush="#D6DBDF"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                                    <TextBlock Text="Statut de la propreté (Diurne &amp; Nocturne)" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtProprete" Height="30" Padding="5" VerticalContentAlignment="Center" BorderBrush="#D6DBDF"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
                <!-- ── Fin contexte complet ── -->

            </StackPanel>
        </ScrollViewer>

        <!-- Pied de page et boutons -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="-1" BlurRadius="4" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Ignorer passera à la sauvegarde sans compléments."
                           VerticalAlignment="Center" FontSize="11" Foreground="#7F8C8D" FontStyle="Italic"/>

                <Button x:Name="BtnIgnore" Grid.Column="1" Content="Ignorer / Passer"
                        Padding="15,8" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                        Click="BtnIgnore_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#7F8C8D"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnSave" Grid.Column="2" Content="💾 Enregistrer les compléments"
                        Padding="15,8" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="BtnSave_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#219A52"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

<UserControl x:Class="MedCompanion.Views.Consultation.Evaluation.EvaluationPhaseControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MedCompanion.ViewModels"
             xmlns:converters="clr-namespace:MedCompanion.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:StringToBrushConverter x:Key="StringToBrush"/>

        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="ValidateButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#27AE60"/>
        </Style>

        <Style x:Key="CategoryTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Template d'un segment Chenille (étape 4) : titre + phrase-boussole + 6 checkboxes
             + badge couleur + lecture émotionnelle. DataContext = CartographieSegmentViewModel. -->
        <DataTemplate x:Key="ChenilleSegmentTemplate">
            <Border Background="#FBFCFD" BorderBrush="#D6E2EC" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                            <TextBlock Text="{Binding PhraseBoussole}" FontSize="11" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <!-- Badge niveau coloré + score, visible uniquement si HasNiveau -->
                        <Border Grid.Column="1" CornerRadius="10" Padding="10,4" VerticalAlignment="Top"
                                Background="{Binding NiveauColor, Converter={StaticResource StringToBrush}}"
                                Visibility="{Binding HasNiveau, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Score}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="/6 — " FontSize="11" Foreground="White"/>
                                <TextBlock Text="{Binding NiveauLabel}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 6 affirmations en checkboxes (désactivées en lecture seule) -->
                    <ItemsControl ItemsSource="{Binding Segment.Items}" Margin="0,8,0,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Affirmation}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          FontSize="12" Foreground="#2C3E50" Margin="0,3,0,3"
                                          VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Lecture émotionnelle (texte canonique du lexique) -->
                    <TextBlock Text="{Binding LectureEmotionnelle}" FontSize="11" FontStyle="Italic" Foreground="#566573"
                               TextWrapping="Wrap" Margin="0,8,0,0"
                               Visibility="{Binding HasNiveau, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Template d'une nervure (étape 5) : titre + badge score + items checkboxes.
             DataContext = NervureViewModel. -->
        <DataTemplate x:Key="NervureTemplate">
            <Border Background="White" BorderBrush="#E5EAF0" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Background="#34495E" CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsCentrale, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Centrale" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="9" Padding="8,3" VerticalAlignment="Top"
                                Background="{Binding DisplayColor, Converter={StaticResource StringToBrush}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Score}"    FontSize="11" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="/"                  FontSize="11" Foreground="White"/>
                                <TextBlock Text="{Binding MaxScore}" FontSize="11" Foreground="White"/>
                                <TextBlock Text=" — "                FontSize="11" Foreground="White"/>
                                <TextBlock Text="{Binding DisplayLabel}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Modele.Items}" Margin="0,6,0,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Affirmation}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          FontSize="12" Foreground="#2C3E50" Margin="0,2,0,2"
                                          VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Template d'une feuille dimensionnelle (étape 5) : Expander avec header
             (label + sous-titre + badge couleur) et contenu (centrale + secondaires).
             DataContext = FeuilleEnvironnementViewModel. -->
        <DataTemplate x:Key="FeuilleEnvironnementTemplate">
            <Border Background="#FBFCFD" BorderBrush="#D6E2EC" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <Grid Margin="0,4,0,4" HorizontalAlignment="Stretch" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Label}"     FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBlock Text="{Binding SousTitre}" FontSize="10" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,1,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="10" Padding="10,4" VerticalAlignment="Center" Margin="0,0,30,0"
                                    Background="{Binding DisplayColor, Converter={StaticResource StringToBrush}}">
                                <TextBlock Text="{Binding DisplayLabel}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                        </Grid>
                    </Expander.Header>
                    <StackPanel Margin="10,8,10,10">
                        <TextBlock Text="{Binding DisplayDescription}" FontSize="11" FontStyle="Italic" Foreground="#566573"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <ContentControl Content="{Binding Centrale}" ContentTemplate="{StaticResource NervureTemplate}"/>
                        <ItemsControl ItemsSource="{Binding Secondaires}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NervureTemplate}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>
            </Border>
        </DataTemplate>

        <!-- Item éditable : TextBox lié à Value + bouton supprimer -->
        <DataTemplate x:Key="EditableItemTemplate">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12" Padding="6,4"
                         BorderBrush="#D6E2EC" BorderThickness="1" Background="White"
                         IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <Button Grid.Column="1" Content="✖" FontSize="10"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="#95A5A6" Margin="4,0,0,0" Padding="6,2"
                        ToolTip="Supprimer cet élément"
                        Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"/>
            </Grid>
        </DataTemplate>

        <!-- Template d'une catégorie (titre + bouton Ajouter + liste éditable) -->
        <!-- Carte d'un axe d'évaluation (état + label + justif + observation + questions) -->
        <DataTemplate x:Key="AxisCardTemplate">
            <Border Background="#FBFCFD" BorderBrush="#D6E2EC" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                            <TextBlock Text="{Binding Justification}" FontSize="10" FontStyle="Italic" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- 3 pastilles colorées (Orange / Jaune / Vert) — désactivées en lecture seule -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <!-- Orange : Non abordé -->
                            <Button Click="AxisState_Click" Tag="0"
                                    ToolTip="Non abordé"
                                    Width="22" Height="22" Margin="3,0,3,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="11">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FDE3CF"/>
                                                    <Setter Property="BorderBrush" Value="#FDE3CF"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsNonAborde}" Value="True">
                                                            <Setter Property="Background" Value="#E67E22"/>
                                                            <Setter Property="BorderBrush" Value="#A04E0A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Jaune : Partiel -->
                            <Button Click="AxisState_Click" Tag="1"
                                    ToolTip="Partiel"
                                    Width="22" Height="22" Margin="3,0,3,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="11">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FCF3CF"/>
                                                    <Setter Property="BorderBrush" Value="#FCF3CF"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPartiel}" Value="True">
                                                            <Setter Property="Background" Value="#F1C40F"/>
                                                            <Setter Property="BorderBrush" Value="#9A7D0A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Vert : Évoqué -->
                            <Button Click="AxisState_Click" Tag="2"
                                    ToolTip="Évoqué"
                                    Width="22" Height="22" Margin="3,0,3,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="11">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#D5F5E3"/>
                                                    <Setter Property="BorderBrush" Value="#D5F5E3"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEvoque}" Value="True">
                                                            <Setter Property="Background" Value="#27AE60"/>
                                                            <Setter Property="BorderBrush" Value="#145A32"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Questions ouvertes proposées (lecture seule, vide si pas de questions) -->
                    <ItemsControl ItemsSource="{Binding SuggestedQuestions}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value, StringFormat='💡 {0}'}" FontSize="11" Foreground="#5D6D7E" Margin="0,0,0,2" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Observations cochables proposées par l'IA (multi-select, vide si pas d'obs) -->
                    <ItemsControl ItemsSource="{Binding ObservationsProposees}" Margin="0,8,0,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          FontSize="11" Foreground="#2C3E50"
                                          Margin="0,2,12,2" VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Proposition Med (en attente de validation) — visible si HasPendingMedText, masqué en lecture seule -->
                    <Border Background="#EAF4FB" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="6"
                            Padding="8" Margin="0,8,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding HasPendingMedText}" Value="True"/>
                                            <Condition Binding="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="✨ Proposition de Med (à valider)" FontSize="10" FontWeight="SemiBold" Foreground="#1F618D" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding PendingMedText, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     FontSize="11" Padding="6" MinHeight="40"
                                     BorderBrush="#85C1E9" BorderThickness="1" Background="White"
                                     Foreground="#1F618D" FontStyle="Italic"
                                     VerticalScrollBarVisibility="Auto"
                                     ToolTip="Édite si besoin, puis Accepter ; ou Ignorer."/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0" HorizontalAlignment="Right">
                                <Button Content="✖ Ignorer" FontSize="11" Padding="8,3"
                                        Background="Transparent" BorderBrush="#BDC3C7" BorderThickness="1"
                                        Foreground="#7F8C8D" Cursor="Hand" Margin="0,0,6,0"
                                        Command="{Binding DataContext.RejectMedTextCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="✓ Accepter" FontSize="11" Padding="8,3"
                                        Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Command="{Binding DataContext.AcceptMedTextCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Observation narrative libre (toujours primaire, validée par le médecin) -->
                    <TextBox Text="{Binding Observation, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             FontSize="11" Padding="6" MinHeight="56" Margin="0,8,0,0"
                             BorderBrush="#D6E2EC" BorderThickness="1" Background="White"
                             VerticalScrollBarVisibility="Auto"
                             IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             ToolTip="Observations cliniques sur cet axe (texte libre — reste l'objet primaire)"/>
                </StackPanel>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <StackPanel>

        <!-- ═════════════════════════════════════════════════════════════════ -->
        <!-- BANNIÈRE LECTURE SEULE (évaluation clôturée ouverte depuis la frise) -->
        <!-- ═════════════════════════════════════════════════════════════════ -->
        <Border Background="#EDE7F6" BorderBrush="#8E5BC2" BorderThickness="1"
                CornerRadius="6" Padding="12" Margin="0,0,0,10"
                Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📖 Évaluation clôturée — lecture seule"
                               FontSize="13" FontWeight="SemiBold" Foreground="#4A2C6A"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="11" Foreground="#7F6E91" Margin="0,2,0,8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Étape 1 — Préparation" FontSize="11" Padding="8,4"
                                Background="White" BorderBrush="#8E5BC2" BorderThickness="1"
                                Foreground="#4A2C6A" Cursor="Hand" Margin="0,0,6,0"
                                Command="{Binding ViewStepCommand}" CommandParameter="1"/>
                        <Button Content="Étape 2 — Évaluation ciblée" FontSize="11" Padding="8,4"
                                Background="White" BorderBrush="#8E5BC2" BorderThickness="1"
                                Foreground="#4A2C6A" Cursor="Hand" Margin="0,0,6,0"
                                Command="{Binding ViewStepCommand}" CommandParameter="2"/>
                        <Button Content="Étape 3 — Synthèse" FontSize="11" Padding="8,4"
                                Background="White" BorderBrush="#8E5BC2" BorderThickness="1"
                                Foreground="#4A2C6A" Cursor="Hand" Margin="0,0,6,0"
                                Command="{Binding ViewStepCommand}" CommandParameter="3"/>
                        <Button Content="Étape 4 — Cartographie enfant" FontSize="11" Padding="8,4"
                                Background="White" BorderBrush="#8E5BC2" BorderThickness="1"
                                Foreground="#4A2C6A" Cursor="Hand" Margin="0,0,6,0"
                                Command="{Binding ViewStepCommand}" CommandParameter="4"/>
                        <Button Content="Étape 5 — Cartographie environnement" FontSize="11" Padding="8,4"
                                Background="White" BorderBrush="#8E5BC2" BorderThickness="1"
                                Foreground="#4A2C6A" Cursor="Hand"
                                Command="{Binding ViewStepCommand}" CommandParameter="5"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Content="✕ Fermer la vue"
                        FontSize="11" Padding="10,5" VerticalAlignment="Top"
                        Background="Transparent" BorderBrush="#8E5BC2" BorderThickness="1"
                        Foreground="#4A2C6A" Cursor="Hand"
                        Command="{Binding CloseReadOnlyCommand}"/>
            </Grid>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════════ -->
        <!-- CAS 1 — Aucune évaluation en cours -->
        <!-- ═════════════════════════════════════════════════════════════════ -->
        <Border Style="{StaticResource SectionBorder}"
                Visibility="{Binding CanStart, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="📋 Phase d'évaluation"
                           FontSize="14" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,6"/>
                <TextBlock Text="Aucune évaluation en cours pour ce patient."
                           FontSize="12" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,0,0,12"/>
                <Button Content="▶ Commencer" Command="{Binding StartCommand}"
                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════════ -->
        <!-- CAS 3 — Évaluation suspendue (entre séances) -->
        <!-- ═════════════════════════════════════════════════════════════════ -->
        <Border Style="{StaticResource SectionBorder}"
                Background="#FEF9E7" BorderBrush="#F39C12"
                Visibility="{Binding CanResume, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="📖 Évaluation en cours"
                           FontSize="14" FontWeight="SemiBold" Foreground="#7E4B00" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding SuspendedMarqueLabel}"
                           FontSize="12" Foreground="#5D4400" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding SuspendedAgoLabel}"
                           FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,12"/>
                <Button Content="▶ Poursuivre" Command="{Binding ResumeCommand}"
                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════════ -->
        <!-- CAS 2 — En cours de séance, Étape 1 Préparation -->
        <!-- ═════════════════════════════════════════════════════════════════ -->
        <Border Style="{StaticResource SectionBorder}"
                BorderBrush="#3498DB" BorderThickness="2"
                Visibility="{Binding IsWorkingPreparation, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="📋 ÉTAPE 1 — PRÉPARATION CLINIQUE"
                                   FontSize="12" FontWeight="Bold" Foreground="#2980B9"/>
                        <TextBlock Text="Organisez vos hypothèses avant d'entrer dans l'exploration."
                                   FontSize="11" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✨ Suggérer (IA)"
                            Command="{Binding SuggestPreparationCommand}"
                            Style="{StaticResource SecondaryButton}"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}"/>
                </Grid>

                <!-- HYPOTHÈSES PRINCIPALES -->
                <StackPanel Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Hypothèses principales" Style="{StaticResource CategoryTitle}"/>
                        <Button Grid.Column="1" Content="+ Ajouter" FontSize="11" Padding="6,2"
                                Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                                Background="Transparent" BorderThickness="1" BorderBrush="#3498DB"
                                Foreground="#3498DB" Cursor="Hand"
                                Command="{Binding AddItemCommand}" CommandParameter="hypotheses"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding HypothesesPrincipales}"
                                  ItemTemplate="{StaticResource EditableItemTemplate}"/>
                </StackPanel>

                <!-- DIFFÉRENTIELS -->
                <StackPanel Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Diagnostics différentiels" Style="{StaticResource CategoryTitle}"/>
                        <Button Grid.Column="1" Content="+ Ajouter" FontSize="11" Padding="6,2"
                                Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                                Background="Transparent" BorderThickness="1" BorderBrush="#3498DB"
                                Foreground="#3498DB" Cursor="Hand"
                                Command="{Binding AddItemCommand}" CommandParameter="differentiels"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Differentiels}"
                                  ItemTemplate="{StaticResource EditableItemTemplate}"/>
                </StackPanel>

                <!-- À ÉLIMINER -->
                <StackPanel Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Diagnostics à éliminer" Style="{StaticResource CategoryTitle}"/>
                        <Button Grid.Column="1" Content="+ Ajouter" FontSize="11" Padding="6,2"
                                Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                                Background="Transparent" BorderThickness="1" BorderBrush="#3498DB"
                                Foreground="#3498DB" Cursor="Hand"
                                Command="{Binding AddItemCommand}" CommandParameter="a_eliminer"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding AEliminer}"
                                  ItemTemplate="{StaticResource EditableItemTemplate}"/>
                </StackPanel>

                <!-- POINTS DE VIGILANCE -->
                <StackPanel Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Points de vigilance" Style="{StaticResource CategoryTitle}"/>
                        <Button Grid.Column="1" Content="+ Ajouter" FontSize="11" Padding="6,2"
                                Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                                Background="Transparent" BorderThickness="1" BorderBrush="#3498DB"
                                Foreground="#3498DB" Cursor="Hand"
                                Command="{Binding AddItemCommand}" CommandParameter="vigilance"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding PointsVigilance}"
                                  ItemTemplate="{StaticResource EditableItemTemplate}"/>
                </StackPanel>

                <!-- QUESTIONS CLINIQUES -->
                <StackPanel Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Questions cliniques à résoudre" Style="{StaticResource CategoryTitle}"/>
                        <Button Grid.Column="1" Content="+ Ajouter" FontSize="11" Padding="6,2"
                                Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                                Background="Transparent" BorderThickness="1" BorderBrush="#3498DB"
                                Foreground="#3498DB" Cursor="Hand"
                                Command="{Binding AddItemCommand}" CommandParameter="questions"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding QuestionsCliniques}"
                                  ItemTemplate="{StaticResource EditableItemTemplate}"/>
                </StackPanel>

                <!-- STATUS + ACTIONS -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#27AE60"
                           Margin="0,0,0,10" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}">
                    <Button Content="⏸ Terminer la séance"
                            Command="{Binding TerminateSessionCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="✓ Valider l'étape 1"
                            Command="{Binding ValidatePreparationCommand}"
                            Style="{StaticResource ValidateButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════════ -->
        <!-- CAS 2bis — En cours de séance, Étape 2 Évaluation ciblée -->
        <!-- ═════════════════════════════════════════════════════════════════ -->
        <Border Style="{StaticResource SectionBorder}"
                BorderBrush="#9B59B6" BorderThickness="2"
                Visibility="{Binding IsWorkingEvaluation, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="🎯 ÉTAPE 2 — ÉVALUATION CIBLÉE"
                                   FontSize="12" FontWeight="Bold" Foreground="#8E44AD"/>
                        <TextBlock Text="Explorez les axes pertinents. États : 🟠 Non abordé · 🟡 Partiel · 🟢 Évoqué."
                                   FontSize="11" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}">
                        <Button Content="✨ Suggérer les axes (IA)"
                                Command="{Binding SuggestAxesCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"/>
                        <!-- 🎙 Démarrer la dicte (visible quand pas en dicte) -->
                        <Button Content="🎙 Démarrer la dicte"
                                Command="{Binding StartDicteCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDicteActive}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- ⏹ Terminer la dicte (visible si IsDicteActive) -->
                        <Button Content="⏹ Terminer la dicte"
                                Command="{Binding StopDicteCommand}" Margin="0,0,6,0"
                                Padding="14,8" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                FontSize="12" FontWeight="SemiBold"
                                Visibility="{Binding IsDicteActive, Converter={StaticResource BoolToVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- 👁 Voir transcription brute -->
                        <Button Content="👁 Transcription"
                                Command="{Binding OpenRawTranscriptCommand}"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="Voir la transcription brute de la dernière dicte"/>
                    </StackPanel>
                </Grid>

                <!-- Indicateur dicte active -->
                <Border Background="#FDEDEC" BorderBrush="#E74C3C" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10"
                        Visibility="{Binding IsDicteActive, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔴" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Med écoute" FontSize="12" FontWeight="SemiBold" Foreground="#8E2E26"/>
                            <ProgressBar Value="{Binding DicteAudioLevelPct, Mode=OneWay}" Maximum="100"
                                         Height="4" Margin="0,4,0,0" Foreground="#E74C3C" Background="#FADBD8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Status global (extraction, etc.) — vide = invisible naturellement -->
                <TextBlock Text="{Binding DicteStatus}" FontSize="11" Foreground="#2980B9"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <!-- AXES PRINCIPAUX -->
                <TextBlock Text="Axes principaux" Style="{StaticResource CategoryTitle}" Margin="0,6,0,6"/>
                <ItemsControl ItemsSource="{Binding AxesPrincipaux}"
                              ItemTemplate="{StaticResource AxisCardTemplate}"/>

                <!-- DIFFÉRENTIELS -->
                <TextBlock Text="Différentiels" Style="{StaticResource CategoryTitle}" Margin="0,6,0,6"/>
                <ItemsControl ItemsSource="{Binding AxesDifferentiels}"
                              ItemTemplate="{StaticResource AxisCardTemplate}"/>

                <!-- SYSTÉMIQUES -->
                <TextBlock Text="Facteurs systémiques" Style="{StaticResource CategoryTitle}" Margin="0,6,0,6"/>
                <ItemsControl ItemsSource="{Binding AxesSystemiques}"
                              ItemTemplate="{StaticResource AxisCardTemplate}"/>

                <!-- STATUS + ACTIONS -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#27AE60"
                           Margin="0,8,0,10" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}">
                    <Button Content="↩ Retour Étape 1"
                            Command="{Binding BackToPreparationCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            ToolTip="Modifier les hypothèses (l'Étape 2 reste conservée)"/>
                    <Button Content="⏸ Terminer la séance"
                            Command="{Binding TerminateSessionCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="✓ Valider l'étape 2"
                            Command="{Binding ValidateEvaluationCommand}"
                            Style="{StaticResource ValidateButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════════ -->
        <!-- CAS 2ter — En cours de séance, Étape 3 Synthèse diagnostique -->
        <!-- ═════════════════════════════════════════════════════════════════ -->
        <Border Style="{StaticResource SectionBorder}"
                BorderBrush="#16A085" BorderThickness="2"
                Visibility="{Binding IsWorkingSynthese, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="🧩 ÉTAPE 3 — SYNTHÈSE DIAGNOSTIQUE"
                                   FontSize="12" FontWeight="Bold" Foreground="#0E8074"/>
                        <TextBlock Text="Mise en cohérence du raisonnement : diagnostic(s), arguments, écartés, certitude."
                                   FontSize="11" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✨ Suggérer la synthèse (IA)"
                            Command="{Binding SuggestSyntheseCommand}"
                            Style="{StaticResource SecondaryButton}"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}"/>
                </Grid>

                <!-- DIAGNOSTICS RETENUS -->
                <StackPanel Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Diagnostic(s) retenu(s)" Style="{StaticResource CategoryTitle}"/>
                        <Button Grid.Column="1" Content="+ Ajouter" FontSize="11" Padding="6,2"
                                Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                                Background="Transparent" BorderThickness="1" BorderBrush="#16A085"
                                Foreground="#16A085" Cursor="Hand"
                                Command="{Binding AddSyntheseItemCommand}" CommandParameter="retenus"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding DiagnosticsRetenus}"
                                  ItemTemplate="{StaticResource EditableItemTemplate}"/>
                </StackPanel>

                <!-- ÉLÉMENTS EN FAVEUR -->
                <StackPanel Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Éléments cliniques en faveur" Style="{StaticResource CategoryTitle}"/>
                        <Button Grid.Column="1" Content="+ Ajouter" FontSize="11" Padding="6,2"
                                Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                                Background="Transparent" BorderThickness="1" BorderBrush="#16A085"
                                Foreground="#16A085" Cursor="Hand"
                                Command="{Binding AddSyntheseItemCommand}" CommandParameter="en_faveur"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ElementsEnFaveur}"
                                  ItemTemplate="{StaticResource EditableItemTemplate}"/>
                </StackPanel>

                <!-- DIAGNOSTICS ÉCARTÉS -->
                <StackPanel Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Diagnostics différentiels écartés" Style="{StaticResource CategoryTitle}"/>
                        <Button Grid.Column="1" Content="+ Ajouter" FontSize="11" Padding="6,2"
                                Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                                Background="Transparent" BorderThickness="1" BorderBrush="#16A085"
                                Foreground="#16A085" Cursor="Hand"
                                Command="{Binding AddDiagnosticEcarteCommand}"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding DiagnosticsEcartes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8FBFA" BorderBrush="#D6E2EC" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBox Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="12" Padding="6,4" FontWeight="SemiBold"
                                                     BorderBrush="#D6E2EC" BorderThickness="1" Background="White"
                                                     IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     ToolTip="Nom du diagnostic écarté"/>
                                            <TextBox Text="{Binding Motif, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="11" Padding="6,4" Margin="0,4,0,0"
                                                     BorderBrush="#D6E2EC" BorderThickness="1" Background="White"
                                                     TextWrapping="Wrap" AcceptsReturn="True"
                                                     IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     ToolTip="Motif clinique d'élimination"
                                                     Foreground="#566573"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="✖" FontSize="10"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Foreground="#95A5A6" Margin="4,0,0,0" Padding="6,2"
                                                VerticalAlignment="Top"
                                                ToolTip="Supprimer ce diagnostic écarté"
                                                Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                                                Command="{Binding DataContext.RemoveDiagnosticEcarteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- NIVEAU DE CERTITUDE -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Niveau de certitude" Style="{StaticResource CategoryTitle}"/>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <RadioButton Content="Hypothèse à confirmer" GroupName="Certitude" Margin="0,0,16,0"
                                     IsChecked="{Binding IsCertitudeHypothese, Mode=OneWay}"
                                     Command="{Binding SetCertitudeCommand}" CommandParameter="1"/>
                        <RadioButton Content="Probable" GroupName="Certitude" Margin="0,0,16,0"
                                     IsChecked="{Binding IsCertitudeProbable, Mode=OneWay}"
                                     Command="{Binding SetCertitudeCommand}" CommandParameter="2"/>
                        <RadioButton Content="Certain" GroupName="Certitude"
                                     IsChecked="{Binding IsCertitudeCertain, Mode=OneWay}"
                                     Command="{Binding SetCertitudeCommand}" CommandParameter="3"/>
                    </StackPanel>
                </StackPanel>

                <!-- STATUS + ACTIONS -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#27AE60"
                           Margin="0,8,0,10" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}">
                    <Button Content="↩ Retour Étape 2"
                            Command="{Binding BackToEvaluationCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            ToolTip="Modifier les axes (l'Étape 3 reste conservée)"/>
                    <Button Content="⏸ Terminer la séance"
                            Command="{Binding TerminateSessionCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="✓ Valider l'étape 3"
                            Command="{Binding ValidateSyntheseCommand}"
                            Style="{StaticResource ValidateButton}"
                            ToolTip="Valide la synthèse — passage à l'étape 4 (Cartographie de l'enfant) si patient 3-11 ans, sinon clôture directe."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════════ -->
        <!-- CAS 2quater — En cours de séance, Étape 4 Cartographie de l'enfant -->
        <!-- ═════════════════════════════════════════════════════════════════ -->
        <Border Style="{StaticResource SectionBorder}"
                BorderBrush="#16A085" BorderThickness="2"
                Visibility="{Binding IsWorkingCartographieEnfant, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="🐛 ÉTAPE 4 — CARTOGRAPHIE DE L'ENFANT"
                                   FontSize="12" FontWeight="Bold" Foreground="#0E8074"/>
                        <TextBlock Text="Chenille universelle — outil de repérage 3-11 ans. 6 segments à 6 items + profil tempérament."
                                   FontSize="11" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <!-- 6 segments questionnaires, structure identique répétée -->
                <ContentControl Content="{Binding AttachementVM}"     ContentTemplate="{StaticResource ChenilleSegmentTemplate}"/>
                <ContentControl Content="{Binding PsychomotriciteVM}" ContentTemplate="{StaticResource ChenilleSegmentTemplate}"/>

                <!-- Tempérament : profil 6 axes (pas de couleur) -->
                <Border Background="#FBFCFD" BorderBrush="#D6E2EC" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="🔥 Tempérament" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                        <TextBlock Text="« Il n'est pas trop ou pas assez… il est lui. »" FontSize="11" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,8"/>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Niveau d'activité" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="{Binding Temperament.NiveauActivite, UpdateSourceTrigger=PropertyChanged}" Margin="6,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Temperament.NiveauActivite}" FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Rythme / Régularité" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="{Binding Temperament.Regularite, UpdateSourceTrigger=PropertyChanged}" Margin="6,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Temperament.Regularite}" FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Réactivité sensorielle" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="{Binding Temperament.ReactiviteSensorielle, UpdateSourceTrigger=PropertyChanged}" Margin="6,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Temperament.ReactiviteSensorielle}" FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Intensité émotionnelle" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="{Binding Temperament.IntensiteEmotionnelle, UpdateSourceTrigger=PropertyChanged}" Margin="6,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Temperament.IntensiteEmotionnelle}" FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Adaptabilité" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="{Binding Temperament.Adaptabilite, UpdateSourceTrigger=PropertyChanged}" Margin="6,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Temperament.Adaptabilite}" FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Temps de réaction" FontSize="11" VerticalAlignment="Center"/>
                            <Slider Grid.Row="5" Grid.Column="1" Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="{Binding Temperament.TempsDeReaction, UpdateSourceTrigger=PropertyChanged}" Margin="6,2"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding Temperament.TempsDeReaction}" FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <ContentControl Content="{Binding LangageVM}"    ContentTemplate="{StaticResource ChenilleSegmentTemplate}"/>
                <ContentControl Content="{Binding EmotionsVM}"   ContentTemplate="{StaticResource ChenilleSegmentTemplate}"/>
                <ContentControl Content="{Binding ImaginaireVM}" ContentTemplate="{StaticResource ChenilleSegmentTemplate}"/>
                <ContentControl Content="{Binding PenseeVM}"     ContentTemplate="{StaticResource ChenilleSegmentTemplate}"/>

                <!-- STATUS + ACTIONS -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#27AE60" Margin="0,8,0,10" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}">
                    <Button Content="↩ Retour Étape 3"
                            Command="{Binding BackToSyntheseCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            ToolTip="Modifier la synthèse (la Cartographie reste conservée)"/>
                    <Button Content="⏸ Terminer la séance"
                            Command="{Binding TerminateSessionCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="✓ Valider l'étape 4"
                            Command="{Binding ValidateCartographieEnfantCommand}"
                            Style="{StaticResource ValidateButton}"
                            ToolTip="Valide la cartographie de l'enfant — passage à l'Étape 5 (Cartographie de l'environnement) si patient 3-11 ans, sinon clôture directe."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════════ -->
        <!-- CAS 2quinquies — En cours de séance, Étape 5 Cartographie environnement -->
        <!-- ═════════════════════════════════════════════════════════════════ -->
        <Border Style="{StaticResource SectionBorder}"
                BorderBrush="#2980B9" BorderThickness="2"
                Visibility="{Binding IsWorkingCartographieEnvironnement, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="🌿 ÉTAPE 5 — CARTOGRAPHIE DE L'ENVIRONNEMENT"
                                   FontSize="12" FontWeight="Bold" Foreground="#1F618D"/>
                        <TextBlock Text="Feuilles dimensionnelles (Tome 3) — 3 niveaux Vert/Jaune/Rouge. 5 dimensions de l'écosystème de l'enfant."
                                   FontSize="11" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <!-- Synthèse globale -->
                    <Border Grid.Column="1" CornerRadius="12" Padding="12,6" VerticalAlignment="Center"
                            Background="{Binding EnvironnementSyntheseColor, Converter={StaticResource StringToBrush}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Synthèse : " FontSize="11" Foreground="White"/>
                            <TextBlock Text="{Binding EnvironnementSyntheseLabel}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 5 feuilles dépliables -->
                <ContentControl Content="{Binding FamilleVM}"           ContentTemplate="{StaticResource FeuilleEnvironnementTemplate}"/>
                <ContentControl Content="{Binding EcolePairsVM}"        ContentTemplate="{StaticResource FeuilleEnvironnementTemplate}"/>
                <ContentControl Content="{Binding EcransMediasVM}"      ContentTemplate="{StaticResource FeuilleEnvironnementTemplate}"/>
                <ContentControl Content="{Binding ValeursSocietalesVM}" ContentTemplate="{StaticResource FeuilleEnvironnementTemplate}"/>
                <ContentControl Content="{Binding CadreEducatifVM}"     ContentTemplate="{StaticResource FeuilleEnvironnementTemplate}"/>

                <!-- STATUS + ACTIONS -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#27AE60" Margin="0,8,0,10" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}">
                    <Button Content="↩ Retour Étape 4"
                            Command="{Binding BackToCartographieEnfantCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            ToolTip="Modifier la cartographie de l'enfant (la cartographie de l'environnement reste conservée)"/>
                    <Button Content="⏸ Terminer la séance"
                            Command="{Binding TerminateSessionCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="✓ Valider et clôturer"
                            Command="{Binding ValidateCartographieEnvironnementCommand}"
                            Style="{StaticResource ValidateButton}"
                            ToolTip="Valide la cartographie de l'environnement et clôture l'évaluation"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>

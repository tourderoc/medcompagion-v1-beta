<UserControl x:Class="MedCompanion.Views.Consultation.ProjetTherapeutique.ProjetTherapeutiqueControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MedCompanion.Converters"
             Background="#FAFBFC">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter             x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter      x:Key="InverseBoolToVis"/>
        <converters:StringToBrushConverter                x:Key="StringToBrush"/>

        <!-- Template d'une ProjetAction : statut cliquable + libellé édit + détail + bouton 🗑
             + bordure colorée selon DiffSuggere (V1.2) + boutons accept/reject si en patch -->
        <DataTemplate x:Key="ActionItemTemplate">
            <Border BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background"  Value="White"/>
                        <Setter Property="BorderBrush" Value="#E5E8EC"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DiffSuggere}" Value="Modifiee">
                                <Setter Property="Background"  Value="#FEF5E7"/>
                                <Setter Property="BorderBrush" Value="#F39C12"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DiffSuggere}" Value="Nouvelle">
                                <Setter Property="Background"  Value="#E8F8F0"/>
                                <Setter Property="BorderBrush" Value="#27AE60"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DiffSuggere}" Value="AArchiver">
                                <Setter Property="Background"  Value="#FDEDEC"/>
                                <Setter Property="BorderBrush" Value="#E74C3C"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Chip statut cliquable (cycle ⚪→🟡→✅→⛔→⚪) -->
                    <Button Grid.Column="0" Width="60" Height="28" Margin="0,0,8,0"
                            VerticalAlignment="Top"
                            Background="{Binding StatutColor, Converter={StaticResource StringToBrush}}"
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            ToolTip="Cliquer pour changer le statut (⚪ → 🟡 → ✅ → ⛔)"
                            Command="{Binding DataContext.CyclerStatutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding StatutIcon}" FontSize="13" Margin="0,0,3,0"/>
                            <TextBlock Text="{Binding StatutLabel}" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Contenu de l'action -->
                    <StackPanel Grid.Column="1">
                        <!-- Résumé du diff (V1.2) en italique si HasDiff -->
                        <TextBlock Text="{Binding DiffResume}" FontSize="10" FontStyle="Italic"
                                   Foreground="#7F6608" TextWrapping="Wrap" Margin="0,0,0,2"
                                   Visibility="{Binding HasDiff, Converter={StaticResource BoolToVis}}"/>
                        <TextBox Text="{Binding Libelle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12" FontWeight="SemiBold" Background="White" BorderBrush="#D6E2EC" BorderThickness="1"
                                 Padding="4" IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="11" Background="White" BorderBrush="#E5E8EC" BorderThickness="1"
                                 TextWrapping="Wrap" AcceptsReturn="True" Padding="4" Margin="0,4,0,0"
                                 IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 MinHeight="30">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="#FBFCFD"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding IndicateurReussite, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="10" Background="#FBFCFD" BorderBrush="#E5E8EC" BorderThickness="1"
                                     Padding="4" Margin="0,0,2,0"
                                     ToolTip="Indicateur de réussite (mesurable)"
                                     IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding LienSyntheseSection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="10" Background="#FBFCFD" BorderBrush="#E5E8EC" BorderThickness="1"
                                     Padding="4" Margin="2,0,0,0"
                                     ToolTip="Lien synthèse : hypotheses | enfant | environnement | articulation | conclusion"
                                     IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Boutons Accepter / Rejeter (visibles si HasDiff) + Supprimer -->
                    <StackPanel Grid.Column="2" Orientation="Vertical" Margin="6,0,0,0" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding HasDiff, Converter={StaticResource BoolToVis}}">
                            <Button Content="✓" FontSize="11" Padding="6,2" Margin="0,0,2,0"
                                    Background="#27AE60" Foreground="White" BorderThickness="0"
                                    ToolTip="Accepter cette proposition"
                                    Command="{Binding DataContext.AccepterActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="✗" FontSize="11" Padding="6,2"
                                    Background="#E74C3C" Foreground="White" BorderThickness="0"
                                    ToolTip="Rejeter (revenir au contenu précédent ou supprimer si nouvelle)"
                                    Command="{Binding DataContext.RejeterActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                        <Button Width="24" Height="24" Margin="0,4,0,0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Foreground="#95A5A6"
                                Content="🗑" FontSize="11"
                                ToolTip="Supprimer cette action"
                                Visibility="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                                Command="{Binding DataContext.SupprimerActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="#27AE60" BorderThickness="2" CornerRadius="8" Margin="10" Padding="16">
        <DockPanel>
            <!-- En-tête -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TitreVue}" FontSize="14" FontWeight="Bold" Foreground="#1E8449"/>
                    <TextBlock Text="{Binding StatutLabel}" FontSize="11" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- ✨ Proposer (Med) : v1 uniquement (génération initiale REMPLACE) -->
                    <Button Padding="10,5" Margin="0,0,6,0"
                            Command="{Binding ProposerCommand}"
                            ToolTip="Med lit la dernière Synthèse Globale validée et propose une v1 complète. REMPLACE le brouillon.">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="✨ Proposer (Med)"/>
                                <Setter Property="Background" Value="#8E44AD"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProposerVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsModePatch}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsProposerEnCours}" Value="True">
                                        <Setter Property="Content" Value="⏳ Med..."/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 🔄 Patch (Med) : v > 1 (mode incrémental) -->
                    <Button Padding="10,5" Margin="0,0,6,0"
                            Command="{Binding PatchCommand}"
                            ToolTip="Med propose des modifications ciblées par section et action. Conserve ce qui ne change pas.">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="🔄 Patch (Med)"/>
                                <Setter Property="Background" Value="#16A085"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModePatch}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsProposerEnCours}" Value="True">
                                        <Setter Property="Content" Value="⏳ Med..."/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- 📊 Pilotage (Med) : transitions de statut basées sur les notes -->
                    <Button Padding="10,5" Margin="0,0,6,0"
                            Command="{Binding PilotageCommand}"
                            Visibility="{Binding PilotageVisible, Converter={StaticResource BoolToVis}}"
                            ToolTip="Med relit les notes récentes et propose des transitions de statut (⚪→🟡→✅) sur les actions concernées.">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="📊 Pilotage (Med)"/>
                                <Setter Property="Background" Value="#2980B9"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPilotageEnCours}" Value="True">
                                        <Setter Property="Content" Value="⏳ Med..."/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="⏸ Fermer" Padding="10,5" Margin="0,0,6,0"
                            Command="{Binding FermerCommand}"
                            ToolTip="Quitter sans valider (brouillon sauvegardé)"/>
                    <Button Content="✓ Valider le projet" Padding="10,5"
                            Background="#27AE60" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                            Command="{Binding ValiderCommand}"
                            ToolTip="Fige cette version (immuable). Une nouvelle version sera nécessaire pour modifier."/>
                </StackPanel>
            </Grid>

            <!-- Status -->
            <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" FontSize="11" Foreground="#16A085"
                       Margin="0,0,0,8" TextWrapping="Wrap"/>

            <!-- Panneau transitions de statut proposées par Med (V1.3) -->
            <Border DockPanel.Dock="Top" Background="#EBF5FB" BorderBrush="#2980B9" BorderThickness="1"
                    CornerRadius="6" Padding="10" Margin="0,0,0,10"
                    MaxHeight="220"
                    Visibility="{Binding HasTransitionsSuggested, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="📊 Transitions de statut proposées par Med" FontSize="12" FontWeight="SemiBold" Foreground="#1F618D" Margin="0,0,0,6"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                        <ItemsControl ItemsSource="{Binding TransitionsSuggested}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="#AED6F1" BorderThickness="1"
                                            CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Traite}" Value="True">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding ActionLibelle}" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding TransitionLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#1F618D" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Justification}" FontSize="11" Foreground="#34495E" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Source, StringFormat='Source : {0}'}" FontSize="10" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"
                                                        Visibility="{Binding Traite, Converter={StaticResource InverseBoolToVis}}">
                                                <Button Content="✓" FontSize="11" Padding="8,3" Margin="6,0,2,0"
                                                        Background="#27AE60" Foreground="White" BorderThickness="0"
                                                        ToolTip="Accepter cette transition de statut"
                                                        Command="{Binding DataContext.AccepterTransitionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="✗" FontSize="11" Padding="8,3"
                                                        Background="#E74C3C" Foreground="White" BorderThickness="0"
                                                        ToolTip="Rejeter (l'action garde son statut actuel)"
                                                        Command="{Binding DataContext.RejeterTransitionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Bandeau réévaluation passée -->
            <Border DockPanel.Dock="Top" Background="#FDEDEC" BorderBrush="#E74C3C" BorderThickness="1"
                    CornerRadius="4" Padding="8" Margin="0,0,0,8"
                    Visibility="{Binding IsReevaluationPassee, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="⚠️ La date de réévaluation prévue est dépassée. Mettez à jour les statuts d'action ou créez une nouvelle version."
                           FontSize="12" Foreground="#922B21" TextWrapping="Wrap"/>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                <StackPanel>

                    <!-- 1. Objectifs prioritaires (texte libre) -->
                    <Border Background="#FBFCFD" BorderBrush="#E5E8EC" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12" Padding="12">
                        <StackPanel>
                            <TextBlock Text="🎯 Objectifs thérapeutiques prioritaires" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                            <TextBox Text="{Binding Projet.ObjectifsPrioritaires, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12" Background="White" BorderBrush="#D6E2EC" BorderThickness="1"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Padding="8" Margin="0,6,0,0"
                                     IsReadOnly="{Binding IsReadOnly}"/>
                        </StackPanel>
                    </Border>

                    <!-- 2. Prise en charge médicale -->
                    <Border Background="#FBFCFD" BorderBrush="#E5E8EC" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12" Padding="12">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="💊 Prise en charge médicale" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <Button Grid.Column="1" Content="+ Action" FontSize="11" Padding="6,2"
                                        Background="Transparent" BorderBrush="#27AE60" BorderThickness="1"
                                        Foreground="#27AE60" Cursor="Hand"
                                        Command="{Binding AjouterActionMedicaleCommand}"
                                        Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Projet.ActionsMedicales}" Margin="0,6,0,0"
                                          ItemTemplate="{StaticResource ActionItemTemplate}"/>
                        </StackPanel>
                    </Border>

                    <!-- 3. Prise en charge psychologique -->
                    <Border Background="#FBFCFD" BorderBrush="#E5E8EC" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12" Padding="12">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🧠 Prise en charge psychologique" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <Button Grid.Column="1" Content="+ Action" FontSize="11" Padding="6,2"
                                        Background="Transparent" BorderBrush="#27AE60" BorderThickness="1"
                                        Foreground="#27AE60" Cursor="Hand"
                                        Command="{Binding AjouterActionPsychologiqueCommand}"
                                        Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Projet.ActionsPsychologiques}" Margin="0,6,0,0"
                                          ItemTemplate="{StaticResource ActionItemTemplate}"/>
                        </StackPanel>
                    </Border>

                    <!-- 4. Accompagnement développemental -->
                    <Border Background="#FBFCFD" BorderBrush="#E5E8EC" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12" Padding="12">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🐛 Accompagnement développemental" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <Button Grid.Column="1" Content="+ Action" FontSize="11" Padding="6,2"
                                        Background="Transparent" BorderBrush="#27AE60" BorderThickness="1"
                                        Foreground="#27AE60" Cursor="Hand"
                                        Command="{Binding AjouterActionDeveloppementaleCommand}"
                                        Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Projet.ActionsDeveloppementales}" Margin="0,6,0,0"
                                          ItemTemplate="{StaticResource ActionItemTemplate}"/>
                        </StackPanel>
                    </Border>

                    <!-- 5. Actions sur l'environnement -->
                    <Border Background="#FBFCFD" BorderBrush="#E5E8EC" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12" Padding="12">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🌿 Actions sur l'environnement" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <Button Grid.Column="1" Content="+ Action" FontSize="11" Padding="6,2"
                                        Background="Transparent" BorderBrush="#27AE60" BorderThickness="1"
                                        Foreground="#27AE60" Cursor="Hand"
                                        Command="{Binding AjouterActionEnvironnementaleCommand}"
                                        Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Projet.ActionsEnvironnementales}" Margin="0,6,0,0"
                                          ItemTemplate="{StaticResource ActionItemTemplate}"/>
                        </StackPanel>
                    </Border>

                    <!-- 6. Ressources à soutenir (texte libre) -->
                    <Border Background="#FBFCFD" BorderBrush="#E5E8EC" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12" Padding="12">
                        <StackPanel>
                            <TextBlock Text="💪 Ressources à soutenir" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                            <TextBlock Text="Forces de l'enfant, ressources familiales, alliés (école, GP, asso…)"
                                       FontSize="10" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                            <TextBox Text="{Binding Projet.RessourcesASoutenir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12" Background="White" BorderBrush="#D6E2EC" BorderThickness="1"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Padding="8" Margin="0,6,0,0"
                                     IsReadOnly="{Binding IsReadOnly}"/>
                        </StackPanel>
                    </Border>

                    <!-- 7. Réévaluation prévue (date + checklist) -->
                    <Border Background="#FBFCFD" BorderBrush="#E5E8EC" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12" Padding="12">
                        <StackPanel>
                            <TextBlock Text="📅 Réévaluation prévue" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Date :" FontSize="11" VerticalAlignment="Center"/>
                                <DatePicker Grid.Column="1" SelectedDate="{Binding Projet.DateReevaluationPrevue, Mode=TwoWay}"
                                            IsEnabled="{Binding IsBrouillon}"/>
                            </Grid>
                            <TextBlock Text="Checklist (points à revérifier) :" FontSize="11" Foreground="#7F8C8D" Margin="0,8,0,4"/>
                            <TextBox Text="{Binding Projet.ReevaluationChecklist, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12" Background="White" BorderBrush="#D6E2EC" BorderThickness="1"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" Padding="8"
                                     IsReadOnly="{Binding IsReadOnly}"/>
                        </StackPanel>
                    </Border>

                    <!-- Section transverse : Co-construction famille -->
                    <Border Background="#F4F8FB" BorderBrush="#2980B9" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12" Padding="12">
                        <StackPanel>
                            <TextBlock Text="👨‍👩‍👧 Co-construction avec la famille" FontSize="13" FontWeight="SemiBold" Foreground="#1F618D"/>
                            <TextBlock Text="Accord, participation, points discutés avec les parents"
                                       FontSize="10" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                            <TextBox Text="{Binding Projet.CoConstructionFamille, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12" Background="White" BorderBrush="#D6E2EC" BorderThickness="1"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Padding="8" Margin="0,6,0,0"
                                     IsReadOnly="{Binding IsReadOnly}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>

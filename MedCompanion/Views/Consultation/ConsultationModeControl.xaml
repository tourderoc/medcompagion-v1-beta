                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="Bd"
                                                                                        Background="White" BorderBrush="#D6E2EC" BorderThickness="1"
                                                                                        CornerRadius="8" Padding="14">
                                                                                    <StackPanel>
                                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                                                            <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                                            <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                                                            <Border Background="#ECF0F1" CornerRadius="3" Padding="6,1" Margin="10,0,0,0">

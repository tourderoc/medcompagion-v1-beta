                                            </StackPanel>
                                            <ScrollViewer Grid.Row="1" Margin="40,0,40,20" VerticalScrollBarVisibility="Auto">
                                                <StackPanel>
                                                    <TextBlock Text="Documents du patient (hors bilans)" FontSize="18" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,15"/>

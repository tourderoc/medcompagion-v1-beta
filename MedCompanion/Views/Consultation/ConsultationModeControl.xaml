<UserControl x:Class="MedCompanion.Views.Consultation.ConsultationModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MedCompanion.ViewModels"
             xmlns:local="clr-namespace:MedCompanion.Views.Consultation"
             xmlns:helpers="clr-namespace:MedCompanion.Helpers"
             Background="#F5F7FA">

    <UserControl.DataContext>
        <vm:ConsultationModeViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Template réutilisable : affichage/édition d'une note sur une page A4 -->
        <DataTemplate x:Key="NotePageTemplate" DataType="{x:Type vm:ConsultationNoteViewModel}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" TextWrapping="Wrap"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}">
                        <Button Content="✏" Command="{Binding StartEditCommand}"
                                ToolTip="Modifier" Width="26" Height="24" FontSize="12"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,4,0"/>
                        <Button Content="🗑" Command="{Binding DeleteCommand}"
                                ToolTip="Supprimer" Width="26" Height="24" FontSize="12"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
                <FlowDocumentPageViewer
                             Document="{Binding DisplayDocument}"
                             Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}"
                             BorderThickness="0" Background="Transparent"
                             FontSize="{Binding DataContext.NoteFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             FontFamily="Georgia"
                             Zoom="100" MinZoom="100" MaxZoom="100"
                             Height="560"
                             Padding="0" Margin="0"/>
                <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                    <TextBox Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             FontSize="11" FontFamily="Consolas" Foreground="#2C3E50"
                             BorderBrush="#3498DB" BorderThickness="1"
                             Height="560" Padding="6" VerticalScrollBarVisibility="Auto"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Annuler" Command="{Binding CancelEditCommand}"
                                Padding="10,5" Margin="0,0,8,0"
                                Background="#ECF0F1" BorderThickness="1" BorderBrush="#BDC3C7" Cursor="Hand" FontSize="11"/>
                        <Button Content="💾 Enregistrer" Command="{Binding SaveEditCommand}"
                                Padding="10,5" Background="#27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Couleurs du dossier patient (bleu medical) -->
        <SolidColorBrush x:Key="DossierBackgroundBrush" Color="#5A9AAC"/>
        <SolidColorBrush x:Key="DossierBorderBrush" Color="#1B3A44"/>
        <SolidColorBrush x:Key="DossierTextBrush" Color="#FFFFFF"/>
        
        <DropShadowEffect x:Key="PageShadow" ShadowDepth="2" BlurRadius="8" Opacity="0.1" Direction="0"/>
        
        <SolidColorBrush x:Key="TabActiveBrush" Color="#D4E9F0"/>
        <SolidColorBrush x:Key="TabInactiveBrush" Color="#F0F7FA"/>
        <SolidColorBrush x:Key="TabHoverBrush" Color="#E0EEF4"/>

        <!-- Style bouton switch d'etat -->
        <Style x:Key="StateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style bouton etat actif -->
        <Style x:Key="StateButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource StateButtonStyle}">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Style bouton mode Med -->
        <Style x:Key="MedModeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style intercalaire dossier (ancien - horizontal) -->
        <Style x:Key="DossierTabStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="{StaticResource TabInactiveBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#C5D8E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource TabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style pour les Intercalaires Verticaux -->
        <Style x:Key="VerticalTabStyle" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource TabInactiveBrush}"/>
            <Setter Property="Foreground" Value="#5A7A8A"/>
            <Setter Property="BorderThickness" Value="1,1,1,1"/>
            <Setter Property="BorderBrush" Value="#B8D4E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="-4,1,0,1"/>
            <Setter Property="Padding" Value="0,15,0,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,6,6,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.1" Direction="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <ContentPresenter.LayoutTransform>
                                    <RotateTransform Angle="-90"/>
                                </ContentPresenter.LayoutTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0EEF4"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4A90A4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style intercalaire vertical ACTIF -->
        <Style x:Key="VerticalTabActiveStyle" TargetType="Button" BasedOn="{StaticResource VerticalTabStyle}">
            <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>
            <Setter Property="Foreground" Value="#2C5A6A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{StaticResource DossierBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2,2,0,2"/>
            <Setter Property="Margin" Value="-15,1,0,1"/>
            <Setter Property="Padding" Value="0,20,0,20"/>
        </Style>

        <!-- Style intercalaire interne Viewbox (pour mode plein écran F3) -->
        <Style x:Key="ViewboxTabStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource TabInactiveBrush}"/>
            <Setter Property="Foreground" Value="#5A7A8A"/>
            <Setter Property="BorderThickness" Value="1,1,1,1"/>
            <Setter Property="BorderBrush" Value="#B8D4E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="0,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,6,6,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.1" Direction="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <ContentPresenter.LayoutTransform>
                                    <RotateTransform Angle="-90"/>
                                </ContentPresenter.LayoutTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0EEF4"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4A90A4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F1" Command="{Binding SwitchToFocusTravailCommand}"/>
        <KeyBinding Key="F2" Command="{Binding SwitchToConsultationCommand}"/>
        <KeyBinding Key="F3" Command="{Binding SwitchToDossierCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- BARRE SUPERIEURE - Switch d'etats -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Visibility="Collapsed"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="15,10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Info patient -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Mode Consultation"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2C3E50"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - "
                               Foreground="#95A5A6"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasPatient, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding PatientDisplayName}"
                               FontSize="14"
                               Foreground="#3498DB"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasPatient, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- Boutons switch d'etat -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Focus Travail (F1) -->
                    <Button Command="{Binding SwitchToFocusTravailCommand}"
                            ToolTip="Focus Travail (F1) - 100% espace de travail">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StateButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFocusTravail}" Value="True">
                                        <Setter Property="Background" Value="#3498DB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="[" Margin="0,0,2,0"/>
                            <Border Width="16" Height="12" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" CornerRadius="2"/>
                            <TextBlock Text="]" Margin="2,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Consultation (F2) -->
                    <Button Command="{Binding SwitchToConsultationCommand}"
                            ToolTip="Consultation (F2) - 67% travail / 33% dossier">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StateButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConsultation}" Value="True">
                                        <Setter Property="Background" Value="#3498DB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="[" Margin="0,0,2,0"/>
                            <Border Width="12" Height="12" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" CornerRadius="2"/>
                            <TextBlock Text="|" Margin="2,0,2,0"/>
                            <Border Width="6" Height="12" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" CornerRadius="2"/>
                            <TextBlock Text="]" Margin="2,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Focus Dossier (F3) -->
                    <Button Command="{Binding SwitchToDossierCommand}"
                            ToolTip="Focus Dossier (F3) - 100% dossier patient">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StateButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                        <Setter Property="Background" Value="#3498DB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="[" Margin="0,0,2,0"/>
                            <Border Width="16" Height="12" Background="{StaticResource DossierBorderBrush}" CornerRadius="2"/>
                            <TextBlock Text="]" Margin="2,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ZONE PRINCIPALE - Layout adaptatif -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="15"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                            <Setter Property="Margin" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <!-- Espace de travail (67% en mode Consultation) -->
                <ColumnDefinition x:Name="WorkspaceColumn">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="2*"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFocusTravail}" Value="True">
                                    <Setter Property="Width" Value="*"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>

                <!-- Separateur -->
                <ColumnDefinition Width="15"/>

                <!-- Dossier patient (33% en mode Consultation) -->
                <ColumnDefinition x:Name="DossierColumn">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="*"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFocusTravail}" Value="True">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                    <Setter Property="Width" Value="*"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- ESPACE DE TRAVAIL (Gauche) -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Column="0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <!-- Zone clinicien (3/4) -->
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="10"/>
                    <!-- Zone Med (1/4) -->
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="*"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMedExpanded}" Value="False">
                                        <Setter Property="Width" Value="50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                </Grid.ColumnDefinitions>

                <!-- Zone Clinicien -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="8"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.08"/>
                    </Border.Effect>

                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <!-- Sélecteur type de consultation -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Type :" FontSize="12" Foreground="#7F8C8D"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox Grid.Column="1" x:Name="ConsultationTypeCombo"
                                          FontSize="12" Height="28"
                                          SelectionChanged="ConsultationTypeCombo_SelectionChanged">
                                    <ComboBoxItem Content="— Note libre —" Tag="Normal" IsSelected="True"/>
                                    <ComboBoxItem Content="1ère consultation — Interrogatoire" Tag="PremiereConsultation"/>
                                    <ComboBoxItem Content="Consultation de suivi (bientôt)" IsEnabled="False" Foreground="#AAAAAA"/>
                                    <ComboBoxItem Content="Bilan initial (bientôt)" IsEnabled="False" Foreground="#AAAAAA"/>
                                </ComboBox>
                            </Grid>

                            <TextBlock Text="{Binding ConsultationDate, StringFormat='{}{0:dddd d MMMM yyyy}'}"
                                       FontSize="12"
                                       Foreground="#7F8C8D"/>

                            <!-- Statut extraction (visible uniquement en mode interrogatoire) -->
                            <TextBlock Text="{Binding ExtractionStatus}"
                                       FontSize="11"
                                       Foreground="#3498DB"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInterrogatoireMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Zone principale : switches selon le mode -->
                        <Grid Grid.Row="1">

                            <!-- MODE NORMAL : note libre classique -->
                            <TextBox Text="{Binding NoteContent, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="14"
                                     FontFamily="Segoe UI"
                                     Padding="10"
                                     BorderBrush="#E0E0E0"
                                     BorderThickness="1">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="#FAFAFA"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInterrogatoireMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- V0c : Boutons simples (Interrogatoire vs Observations) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInterrogatoireMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <Button Content="Interrogatoire"
                                        Command="{Binding SwitchToInterrogatoireCommand}"
                                        Padding="15,10" Cursor="Hand" FontSize="13" FontWeight="SemiBold"
                                        Margin="0,0,10,0"
                                        Background="#3498DB" Foreground="White"
                                        BorderThickness="0"/>

                                <Button Content="Observations Cliniques"
                                        Command="{Binding SwitchToClinicalCommand}"
                                        Padding="15,10" Cursor="Hand" FontSize="13" FontWeight="SemiBold"
                                        Background="#27AE60" Foreground="White"
                                        BorderThickness="0"
                                        IsEnabled="{Binding IsStructureFrozen}"/>
                            </StackPanel>

                            <!-- MODE INTERROGATOIRE — Saisie transcription -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInSaisieMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="140"/>
                                    <RowDefinition Height="150"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Transcription de la consultation :"
                                           FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,6"/>

                                <Border Grid.Row="1" Background="#FAFAFA" BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="6" Padding="10">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                                        <TextBlock Text="{Binding TranscriptionInput}"
                                                   TextWrapping="Wrap"
                                                   FontSize="11"
                                                   Foreground="#5D6D7E"
                                                   FontFamily="Segoe UI"/>
                                    </ScrollViewer>
                                </Border>

                                <!-- V0c : Blocs complétés (100%) -->
                                <Border Grid.Row="2" Background="White" BorderThickness="1" BorderBrush="#27AE60" CornerRadius="6" Padding="10" Margin="0,6,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock Text="✓ Blocs complétés" FontSize="11" FontWeight="SemiBold" Foreground="#27AE60" Margin="0,0,0,6"/>
                                            <ItemsControl ItemsSource="{Binding CompletedBlocks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#F0FAF5" BorderBrush="#27AE60" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,4" Cursor="Hand">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="{Binding Title}" FontSize="10" FontWeight="SemiBold" Foreground="#27AE60"/>
                                                                    <TextBlock Text="{Binding CompactPreview}" FontSize="9" Foreground="#7F8C8D" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="1" Text="✓" FontSize="14" Foreground="#27AE60" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <!-- V0c : Blocs actifs (en cours) -->
                                <Border Grid.Row="3" Background="White" BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="6" Padding="10" Margin="0,6,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding ActiveBlocks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,6" CornerRadius="6" BorderThickness="1" Padding="8">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#FAFAFA"/>
                                                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEmpty}" Value="False">
                                                                        <Setter Property="Background" Value="#F0FAF5"/>
                                                                        <Setter Property="BorderBrush" Value="#A8D5BC"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding ProgressPct, StringFormat='{}{0}%'}" FontSize="10" Foreground="#7F8C8D"/>
                                                                </Grid>
                                                                <ProgressBar Height="4" Minimum="0" Maximum="100" Value="{Binding ProgressPct, Mode=OneWay}" Margin="0,4,0,4" Foreground="{Binding ProgressBarColor}" Background="#E0E0E0" BorderThickness="0"/>
                                                                <TextBlock Text="{Binding FreeText}" FontSize="9" Foreground="#5D6D7E" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis" Visibility="{Binding IsNotEmpty, Converter={StaticResource BoolToVis}}"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Content="👁‍🗨" VerticalAlignment="Top" Command="{Binding Path=DataContext.ToggleBlockVisibilityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="24" Height="24" Padding="0" FontSize="11" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Masquer ce bloc"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <StackPanel Grid.Row="4" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="0,8,0,0">

                                    <!-- Sélecteur mode dictée (visible quand pas en cours) -->
                                    <CheckBox Content="Mode Batch (90s)"
                                              IsChecked="{Binding UseBatchMode}"
                                              VerticalAlignment="Center" Margin="0,0,12,0"
                                              FontSize="11"
                                              Visibility="{Binding IsNotRecording, Converter={StaticResource BoolToVis}}"
                                              ToolTip="Coché : transcription toutes les 90s (qualité max, recommandé pour consultation)&#x0a;Décoché : streaming temps réel (peut fragmenter sur débit lent)"/>

                                    <!-- V0b : Bouton Vocabulaire Whisper -->
                                    <Button x:Name="VocabBtn" Content="📝 Vocab"
                                            Click="VocabBtn_Click"
                                            Padding="8,5" Cursor="Hand" FontSize="10"
                                            Background="#F3E5F5" Foreground="#7B1FA2"
                                            BorderThickness="1" BorderBrush="#CE93D8"
                                            Margin="0,0,8,0"
                                            ToolTip="Éditer le vocabulaire personnalisé Whisper"
                                            Visibility="{Binding IsNotRecording, Converter={StaticResource BoolToVis}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BdVocab" Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BdVocab" Property="Background" Value="#E1BEE7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Bouton Démarrer dictée -->
                                    <Button Content="🎙 Dicter"
                                            Command="{Binding StartRecordingCommand}"
                                            IsEnabled="{Binding IsInSaisieMode}"
                                            Padding="12,7" Cursor="Hand" FontSize="12"
                                            Background="#27AE60" Foreground="White"
                                            BorderThickness="0" Margin="0,0,8,0"
                                            Visibility="{Binding IsNotRecording, Converter={StaticResource BoolToVis}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#219A52"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#BDC3C7"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Bouton Arrêter dictée -->
                                    <Button Content="⏹ Arrêter"
                                            Command="{Binding StopRecordingCommand}"
                                            Padding="12,7" Cursor="Hand" FontSize="12"
                                            Background="#E74C3C" Foreground="White"
                                            BorderThickness="0" Margin="0,0,8,0"
                                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#C0392B"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button x:Name="ImportTxtBtn" Content="📂 Importer .txt"
                                            Click="ImportTxtBtn_Click"
                                            Padding="12,7" Background="#ECF0F1" BorderThickness="1"
                                            BorderBrush="#BDC3C7" Cursor="Hand" FontSize="12"
                                            Margin="0,0,8,0"/>
                                    <Button Content="⚙ Extraire avec IA"
                                            Command="{Binding ExtractInterrogatoireCommand}"
                                            Padding="14,7" Background="#3498DB" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" FontSize="12">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#2980B9"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#BDC3C7"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <!-- Indicateur visuel enregistrement / coupure -->
                                <Border Grid.Row="5" x:Name="RecordingStatusBand"
                                        CornerRadius="4" Margin="0,6,0,0" Padding="10,5"
                                        Background="#27AE60"
                                        Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#27AE60"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsInCutover}" Value="True">
                                                    <Setter Property="Background" Value="#E67E22"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ExtractionStatus}"
                                               Foreground="White" FontSize="12" FontWeight="Medium"/>
                                </Border>

                            </Grid>

                            <!-- V0c : MODE INTERROGATOIRE — Observations Cliniques -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInClinicalMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Grille 2 colonnes de cartes d'observation -->
                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <ItemsControl Grid.Column="0" Grid.ColumnSpan="2" ItemsSource="{Binding ClinicalObservations.Cards}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2" VerticalAlignment="Top"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FAFAFA" BorderThickness="1" BorderBrush="#E0E0E0"
                                                            CornerRadius="6" Padding="12" Margin="6">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Titre -->
                                                            <TextBlock Grid.Row="0" Text="{Binding Title}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="#2C3E50" Margin="0,0,0,8"/>

                                                            <!-- Chips / Radio buttons (options) -->
                                                            <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                                                                <ItemsControl ItemsSource="{Binding Options}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Content="{Binding}"
                                                                                    Click="ObservationOptionButton_Click"
                                                                                    Padding="10,6" Margin="0,0,6,4"
                                                                                    FontSize="11" Cursor="Hand"
                                                                                    Background="White" Foreground="#2C3E50"
                                                                                    BorderThickness="2" BorderBrush="#3498DB">
                                                                                <Button.Style>
                                                                                    <Style TargetType="Button">
                                                                                        <Setter Property="Template">
                                                                                            <Setter.Value>
                                                                                                <ControlTemplate TargetType="Button">
                                                                                                    <Border Background="{TemplateBinding Background}"
                                                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                                                            Padding="{TemplateBinding Padding}">
                                                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                                    </Border>
                                                                                                    <ControlTemplate.Triggers>
                                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                                            <Setter Property="Background" Value="#E8F4F8"/>
                                                                                                        </Trigger>
                                                                                                    </ControlTemplate.Triggers>
                                                                                                </ControlTemplate>
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                    </Style>
                                                                                </Button.Style>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </WrapPanel>

                                                            <!-- Bouton expand texte + Zone texte -->
                                                            <StackPanel Grid.Row="2">
                                                                <Button Content="+ Notes"
                                                                        Command="{Binding Path=DataContext.ToggleCardExpandCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        FontSize="10" Background="Transparent"
                                                                        BorderThickness="0" Foreground="#3498DB"
                                                                        Cursor="Hand" Padding="0"/>

                                                                <TextBox Text="{Binding FreeText, UpdateSourceTrigger=PropertyChanged}"
                                                                         Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                                                         AcceptsReturn="True" TextWrapping="Wrap"
                                                                         Height="60" Margin="0,6,0,0" Padding="6"
                                                                         FontSize="11"
                                                                         BorderBrush="#E0E0E0" BorderThickness="1"
                                                                         Background="#F9F9F9"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </ScrollViewer>

                                <!-- Boutons d'action -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="← Retour Interrogatoire"
                                            Command="{Binding SwitchToInterrogatoireCommand}"
                                            Padding="10,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                            Background="#ECF0F1" Foreground="#2C3E50"
                                            BorderThickness="1" BorderBrush="#BDC3C7">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#D5DBDB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="✓ Terminer Observations"
                                            Command="{Binding TerminateClinicalObservationsCommand}"
                                            Padding="10,7" Cursor="Hand" FontSize="11"
                                            Background="#27AE60" Foreground="White"
                                            BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#219A52"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- MODE INTERROGATOIRE — Extraction en cours -->
                            <Border CornerRadius="8" Background="#EBF5FB" BorderBrush="#3498DB" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInExtractionMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="⚙ Extraction en cours..." FontSize="16"
                                               Foreground="#2980B9" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Le LLM analyse la transcription..." FontSize="12"
                                               Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- MODE INTERROGATOIRE — Note finale -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInFinalNoteMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Note finale — vérifiez et complétez :"
                                           FontSize="12" Foreground="#27AE60" FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>

                                <!-- V0c : Aperçu final — tous les blocs -->
                                <Border Grid.Row="2" Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="📋 Aperçu final — tous les blocs" FontSize="11" FontWeight="SemiBold" Foreground="#2E7D32" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding InterrogatoireBlocks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="60"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="10" Foreground="#1B5E20" FontWeight="SemiBold"/>
                                                        <ProgressBar Grid.Column="1" Height="8" Minimum="0" Maximum="100" Value="{Binding ProgressPct, Mode=OneWay}" Margin="10,0,10,0" Foreground="{Binding ProgressBarColor}" Background="#CCCCCC" BorderThickness="0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ProgressPct, StringFormat='{}{0}%'}" FontSize="10" Foreground="#558B2F" TextAlignment="Right"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Bandeau contrôle qualité -->
                                <Border Grid.Row="1" Margin="0,0,0,8"
                                        Visibility="{Binding HasQualityIssues, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <!-- En cours -->
                                        <TextBlock Text="⏳ Contrôle qualité en cours..."
                                                   FontSize="11" Foreground="#7F8C8D" FontStyle="Italic"
                                                   Margin="0,0,0,4"
                                                   Visibility="{Binding IsRunningQualityCheck, Converter={StaticResource BoolToVis}}"/>
                                        <!-- Liste des signalements -->
                                        <ItemsControl ItemsSource="{Binding QualityIssues}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FFF9E6" BorderBrush="#F39C12"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Margin="0,0,0,4" Padding="8,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding TypeIcon}" FontSize="12" Margin="0,0,5,0"/>
                                                                    <TextBlock Text="{Binding BlockTitle}" FontSize="11"
                                                                               FontWeight="SemiBold" Foreground="#7F8C8D"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                    <TextBlock Text="{Binding Original}" FontSize="12"
                                                                               Foreground="#E74C3C" TextDecorations="Strikethrough"/>
                                                                    <TextBlock Text=" → " FontSize="12" Foreground="#7F8C8D"/>
                                                                    <TextBlock Text="{Binding Suggestion}" FontSize="12"
                                                                               Foreground="#27AE60" FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Reason}" FontSize="10"
                                                                           Foreground="#95A5A6" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                        VerticalAlignment="Center" Margin="8,0,0,0">
                                                                <Button Content="✓ Appliquer"
                                                                        Command="{Binding AcceptCommand}"
                                                                        Padding="8,4" FontSize="11" Cursor="Hand"
                                                                        Background="#27AE60" Foreground="White"
                                                                        BorderThickness="0" Margin="0,0,4,0">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                                <Button Content="✕"
                                                                        Command="{Binding DismissCommand}"
                                                                        Width="24" Height="24" FontSize="11" Cursor="Hand"
                                                                        Background="#ECF0F1" Foreground="#7F8C8D"
                                                                        BorderThickness="0">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    CornerRadius="3" Padding="2">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <TextBox Grid.Row="3"
                                         Text="{Binding NoteContent, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="13"
                                         FontFamily="Consolas"
                                         Padding="10"
                                         BorderBrush="#27AE60"
                                         BorderThickness="1"
                                         Background="#FAFAFA">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="#FAFAFA"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <StackPanel Grid.Row="4" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="0,8,0,0">
                                    <Button Content="↩ Retour"
                                            Command="{Binding BackToSaisieCommand}"
                                            Padding="12,7" Background="#ECF0F1" BorderThickness="1"
                                            BorderBrush="#BDC3C7" Cursor="Hand" FontSize="12"
                                            Margin="0,0,8,0"/>
                                    <Button Content="💾 Sauvegarder dossier"
                                            Command="{Binding SaveInterrogatoireNoteCommand}"
                                            Padding="14,7" Background="#27AE60" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" FontSize="12">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#219A52"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#BDC3C7"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>

                        </Grid>

                        <!-- Actions rapides — mode normal uniquement -->
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,15,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInterrogatoireMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Button Content="Sauvegarder"
                                    Command="{Binding SaveNoteCommand}"
                                    Padding="15,8"
                                    Background="#27AE60"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#219A52"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bd" Property="Background" Value="#BDC3C7"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Zone Med (1/4) -->
                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="8"
                        BorderBrush="#90CAF9"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.1" Color="#3498DB"/>
                    </Border.Effect>

                    <Grid>
                        <!-- Mode etendu -->
                        <Grid Visibility="{Binding IsMedExpanded, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header Med -->
                            <Border Grid.Row="0"
                                    Background="#E3F2FD"
                                    CornerRadius="8,8,0,0"
                                    Padding="12">
                                <Grid>
                                    <TextBlock Text="Med"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#1976D2"
                                               VerticalAlignment="Center"/>
                                    <Button Content="−"
                                            HorizontalAlignment="Right"
                                            Command="{Binding ToggleMedExpandedCommand}"
                                            ToolTip="Reduire"
                                            Width="24" Height="24"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#1976D2"
                                            Cursor="Hand"/>
                                </Grid>
                            </Border>

                            <!-- Mode switches -->
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="10">
                                <Button Content="🔇"
                                        Command="{Binding SetMedSilencieuxCommand}"
                                        ToolTip="Silencieux">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MedModeButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMedSilencieux}" Value="True">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="💬"
                                        Command="{Binding SetMedSuggestionsCommand}"
                                        ToolTip="Suggestions">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MedModeButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMedSuggestions}" Value="True">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="📋"
                                        Command="{Binding SetMedChecklistCommand}"
                                        ToolTip="Checklist">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MedModeButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMedChecklist}" Value="True">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Contenu contextuel -->
                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          Margin="10,0,10,10">
                                <StackPanel>
                                    <!-- Mode Suggestions -->
                                    <ItemsControl ItemsSource="{Binding Suggestions}"
                                                  Visibility="{Binding IsMedSuggestions, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FAFAFA"
                                                        CornerRadius="6"
                                                        Padding="10"
                                                        Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock Text="{Binding Icon}" FontSize="14"/>
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"
                                                                       Foreground="#2C3E50"
                                                                       Margin="6,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Content}"
                                                                   FontSize="11"
                                                                   Foreground="#7F8C8D"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Mode Checklist -->
                                    <ItemsControl ItemsSource="{Binding ChecklistItems}"
                                                  Visibility="{Binding IsMedChecklist, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsChecked}"
                                                          Margin="0,4">
                                                    <TextBlock Text="{Binding Text}"
                                                               FontSize="12"
                                                               Foreground="#2C3E50"
                                                               TextWrapping="Wrap"/>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Mode Silencieux -->
                                    <TextBlock Text="Med est en mode silencieux. Appelez-le si besoin."
                                               FontSize="11"
                                               Foreground="#95A5A6"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Margin="0,20"
                                               Visibility="{Binding IsMedSilencieux, Converter={StaticResource BoolToVis}}"/>

                                    <!-- ── V0b : Bandeau état adaptatif ─────────────── -->
                                    <Border Margin="0,0,0,8" Padding="8,6" CornerRadius="6"
                                            Background="#EDE7F6" BorderBrush="#B39DDB" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInterrogatoireMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <!-- Âge confirmé -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="👤" FontSize="11" Margin="0,0,4,0"/>
                                                <TextBlock FontSize="11" Foreground="#5E35B1" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Âge : en attente de confirmation"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasConfirmedAge}" Value="True">
                                                                    <Setter Property="Text" Value="{Binding ConfirmedAge, StringFormat='Âge confirmé : {0} ans'}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <!-- Motif détecté -->
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding HasDetectedMotif, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="🎯" FontSize="11" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding DetectedMotif, StringFormat='Motif : {0}'}"
                                                           FontSize="10" Foreground="#7E57C2"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                            </StackPanel>
                                            <!-- Structure gelée -->
                                            <TextBlock Text="🔒 Structure gelée" FontSize="9" Foreground="#9575CD"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding IsStructureFrozen, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ── Blocs Interrogatoire ─────────────────────────── -->
                                    <ItemsControl ItemsSource="{Binding InterrogatoireBlocks}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInterrogatoireMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,6" CornerRadius="6"
                                                        BorderThickness="1" Padding="8">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FAFAFA"/>
                                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEmpty}" Value="False">
                                                                    <Setter Property="Background" Value="#F0FAF5"/>
                                                                    <Setter Property="BorderBrush" Value="#A8D5BC"/>
                                                                </DataTrigger>
                                                                <!-- V0b : Trigger blocks (Identité & Motif) en violet comme le bandeau âge -->
                                                                <DataTrigger Binding="{Binding Key}" Value="identite">
                                                                    <Setter Property="Background" Value="#EDE7F6"/>
                                                                    <Setter Property="BorderBrush" Value="#B39DDB"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Key}" Value="motif">
                                                                    <Setter Property="Background" Value="#EDE7F6"/>
                                                                    <Setter Property="BorderBrush" Value="#B39DDB"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <!-- Titre + % -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Title}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#2C3E50"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ProgressPct, StringFormat='{}{0}%'}"
                                                                       FontSize="10"
                                                                       Foreground="#7F8C8D"/>
                                                        </Grid>
                                                        <!-- Barre de progression -->
                                                        <ProgressBar Height="5" Minimum="0" Maximum="100"
                                                                     Value="{Binding ProgressPct, Mode=OneWay}"
                                                                     Margin="0,4,0,0"
                                                                     Foreground="{Binding ProgressBarColor}"
                                                                     Background="#E0E0E0"
                                                                     BorderThickness="0"/>
                                                        <!-- Texte extrait -->
                                                        <TextBlock Text="{Binding FreeText}"
                                                                   FontSize="10"
                                                                   Foreground="#5D6D7E"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0"
                                                                   MaxHeight="60"
                                                                   TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEmpty}" Value="False">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- ── V0b : Zone Chips — Suggestions de blocs ─────── -->
                                    <Border Margin="0,4,0,8" Padding="8,6" CornerRadius="8"
                                            Background="#FFF8E1" BorderBrush="#FFE082" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsInterrogatoireMode}" Value="True"/>
                                                            <Condition Binding="{Binding HasBlockSuggestions}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <!-- Titre de la zone -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="✨" FontSize="12" Margin="0,0,4,0"/>
                                                <TextBlock Text="Blocs suggérés" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="#F57F17"/>
                                                <TextBlock Text=" — cliquez ✓ pour ajouter" FontSize="10"
                                                           Foreground="#FFA000" VerticalAlignment="Center"
                                                           Margin="4,0,0,0"/>
                                            </StackPanel>

                                            <!-- Liste des chips -->
                                            <ItemsControl ItemsSource="{Binding BlockSuggestions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,6,6" CornerRadius="16"
                                                                Background="White" BorderBrush="#FFD54F"
                                                                BorderThickness="1.5" Padding="0"
                                                                Cursor="Hand">
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="1" BlurRadius="4"
                                                                                  Opacity="0.12" Color="#FFA000"/>
                                                            </Border.Effect>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Icône -->
                                                                <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                                           FontSize="14" VerticalAlignment="Center"
                                                                           Margin="10,6,4,6"/>

                                                                <!-- Titre + Raison -->
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                                            Margin="2,6,6,6">
                                                                    <TextBlock Text="{Binding Title}" FontSize="11"
                                                                               FontWeight="SemiBold" Foreground="#2C3E50"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding Reason}" FontSize="9"
                                                                               Foreground="#95A5A6"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxWidth="130"/>
                                                                </StackPanel>

                                                                <!-- Bouton Accept ✓ -->
                                                                <Button Grid.Column="2"
                                                                        Command="{Binding AcceptCommand}"
                                                                        ToolTip="Ajouter ce bloc"
                                                                        Width="26" Height="26"
                                                                        Margin="0,0,2,0"
                                                                        Cursor="Hand">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="BdAccept"
                                                                                    Background="#E8F5E9"
                                                                                    CornerRadius="13"
                                                                                    Width="26" Height="26">
                                                                                <TextBlock Text="✓" FontSize="13"
                                                                                           FontWeight="Bold"
                                                                                           Foreground="#27AE60"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="BdAccept" Property="Background" Value="#C8E6C9"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsEnabled" Value="False">
                                                                                    <Setter TargetName="BdAccept" Property="Opacity" Value="0.4"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>

                                                                <!-- Bouton Dismiss ✕ -->
                                                                <Button Grid.Column="3"
                                                                        Command="{Binding DismissCommand}"
                                                                        ToolTip="Ignorer"
                                                                        Width="26" Height="26"
                                                                        Margin="0,0,6,0"
                                                                        Cursor="Hand">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="BdDismiss"
                                                                                    Background="#FFEBEE"
                                                                                    CornerRadius="13"
                                                                                    Width="26" Height="26">
                                                                                <TextBlock Text="✕" FontSize="11"
                                                                                           Foreground="#E74C3C"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="BdDismiss" Property="Background" Value="#FFCDD2"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsEnabled" Value="False">
                                                                                    <Setter TargetName="BdDismiss" Property="Opacity" Value="0.4"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- Mode reduit (barre laterale) -->
                        <Border Visibility="{Binding IsMedCollapsed, Converter={StaticResource BoolToVis}}">
                            <Button Content="Med"
                                    Command="{Binding ToggleMedExpandedCommand}"
                                    ToolTip="Developper Med"
                                    Background="#E3F2FD"
                                    Foreground="#1976D2"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Cursor="Hand">
                                <Button.LayoutTransform>
                                    <RotateTransform Angle="90"/>
                                </Button.LayoutTransform>
                            </Button>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- DOSSIER PATIENT SKEUOMORPHIQUE (Droite) -->
            <!-- Design: dossier papier francais avec intercalaires verticaux -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Column="2" ClipToBounds="False">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusTravail}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                    <!-- Contenu du dossier + Intercalaires dans la même cellule pour permettre le chevauchement -->
                    <Grid ClipToBounds="False">
                        <!-- COUVERTURE (fond bleu A4 Fermé) -->
                        <Grid Visibility="{Binding IsCouvertureActive, Converter={StaticResource BoolToVis}}">
                            <!-- MODE ECRAN PARTAGE (F2): Sans intercalaires internes -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Viewbox Stretch="Uniform">
                                    <Border Width="595" Height="842"
                                            Background="{StaticResource DossierBackgroundBrush}"
                                            CornerRadius="6,6,6,6"
                                            BorderBrush="{StaticResource DossierBorderBrush}"
                                            BorderThickness="2">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="5" BlurRadius="15" Opacity="0.25" Color="#2C3E50"/>
                                        </Border.Effect>
                                        <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                            <StackPanel Margin="25,40">
                                                <TextBlock Text="DOSSIER PATIENT" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" Margin="0,20,0,40"/>
                                                <TextBlock Text="Dr Lassoued" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,20"/>
                                                <Border BorderBrush="#B0FFFFFF" BorderThickness="1.5" Margin="0,0,0,20" Padding="12" Background="#30FFFFFF" CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="N° de Dossier :" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <TextBlock Text="{Binding CurrentPatient.NumeroDossier, TargetNullValue='Non attribué'}" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Nom :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Nom}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                    <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Prénom :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Prenom}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                    <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Date de naissance :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.DobFormatted}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                    <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                </Grid>
                                                <Grid Margin="0,20,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Date 1ère consultation :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.FirstConsultDate, FallbackValue='-'}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                    <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Viewbox>
                            </Grid>

                            <!-- MODE PLEIN ECRAN (F3): Avec intercalaires internes dans le Viewbox -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">

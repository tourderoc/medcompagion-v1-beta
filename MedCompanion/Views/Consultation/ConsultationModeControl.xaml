                                        <Setter Property="BorderThickness" Value="2,2,0,2"/>
                                        <Setter Property="Margin" Value="-15,1,0,1"/>
                                        <Setter Property="Padding" Value="0,20,0,20"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Projet Therapeutique -->
                    <Button Grid.Row="3"
                            Command="{Binding SelectDossierTabCommand}"
                            CommandParameter="ProjetTherapeutique"
                            ToolTip="Projet Therapeutique - Objectifs, strategies et suivis">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource VerticalTabStyle}">
                                <Setter Property="Content" Value="PROJET"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProjetActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>
                                        <Setter Property="Foreground" Value="#2C5A6A"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource DossierBorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="2,2,0,2"/>
                                        <Setter Property="Margin" Value="-15,1,0,1"/>
                                        <Setter Property="Padding" Value="0,20,0,20"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

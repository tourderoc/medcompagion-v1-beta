<UserControl x:Class="MedCompanion.Views.Consultation.ConsultationModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MedCompanion.ViewModels"
             xmlns:local="clr-namespace:MedCompanion.Views.Consultation"
             xmlns:urgence="clr-namespace:MedCompanion.Views.Consultation.Urgence"
             xmlns:eval="clr-namespace:MedCompanion.Views.Consultation.Evaluation"
             xmlns:synth="clr-namespace:MedCompanion.Views.Consultation.SyntheseGlobale"
             xmlns:projet="clr-namespace:MedCompanion.Views.Consultation.ProjetTherapeutique"
             xmlns:helpers="clr-namespace:MedCompanion.Helpers"
             xmlns:conv="clr-namespace:MedCompanion.Converters"
             xmlns:vmrest="clr-namespace:MedCompanion.ViewModels.Restitutions"
             xmlns:viewrest="clr-namespace:MedCompanion.Views.Restitutions"
             Background="#F5F7FA">

    <UserControl.DataContext>
        <vm:ConsultationModeViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:StringEqualsMultiConverter x:Key="StringEquals"/>
        <conv:StringNotWhiteSpaceToVisibilityConverter x:Key="StringNotWS"/>
        <conv:StringToBrushConverter x:Key="StringToBrush"/>

        <!-- Template réutilisable : affichage/édition d'une note sur une page A4 -->
        <DataTemplate x:Key="NotePageTemplate" DataType="{x:Type vm:ConsultationNoteViewModel}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" TextWrapping="Wrap"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}">
                        <Button Content="✏" Command="{Binding StartEditCommand}"
                                ToolTip="Modifier" Width="26" Height="24" FontSize="12"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,4,0"/>
                        <Button Content="🗑" Command="{Binding DeleteCommand}"
                                ToolTip="Supprimer" Width="26" Height="24" FontSize="12"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
                <FlowDocumentPageViewer
                             Document="{Binding DisplayDocument}"
                             Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}"
                             BorderThickness="0" Background="Transparent"
                             FontSize="{Binding DataContext.NoteFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             FontFamily="Georgia"
                             Zoom="100" MinZoom="100" MaxZoom="100"
                             Height="560"
                             Padding="0" Margin="0"/>
                <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                    <TextBox Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             FontSize="11" FontFamily="Consolas" Foreground="#2C3E50"
                             BorderBrush="#3498DB" BorderThickness="1"
                             Height="560" Padding="6" VerticalScrollBarVisibility="Auto"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Annuler" Command="{Binding CancelEditCommand}"
                                Padding="10,5" Margin="0,0,8,0"
                                Background="#ECF0F1" BorderThickness="1" BorderBrush="#BDC3C7" Cursor="Hand" FontSize="11"/>
                        <Button Content="💾 Enregistrer" Command="{Binding SaveEditCommand}"
                                Padding="10,5" Background="#27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Couleurs du dossier patient (bleu medical) -->
        <SolidColorBrush x:Key="DossierBackgroundBrush" Color="#5A9AAC"/>
        <SolidColorBrush x:Key="DossierBorderBrush" Color="#1B3A44"/>
        <SolidColorBrush x:Key="DossierTextBrush" Color="#FFFFFF"/>
        
        <DropShadowEffect x:Key="PageShadow" ShadowDepth="2" BlurRadius="8" Opacity="0.1" Direction="0"/>
        
        <SolidColorBrush x:Key="TabActiveBrush" Color="#D4E9F0"/>
        <SolidColorBrush x:Key="TabInactiveBrush" Color="#F0F7FA"/>
        <SolidColorBrush x:Key="TabHoverBrush" Color="#E0EEF4"/>

        <!-- Style bouton switch d'etat -->
        <Style x:Key="StateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style bouton etat actif -->
        <Style x:Key="StateButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource StateButtonStyle}">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Style bouton mode Med -->
        <Style x:Key="MedModeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style intercalaire dossier (ancien - horizontal) -->
        <Style x:Key="DossierTabStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="{StaticResource TabInactiveBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#C5D8E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource TabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style pour les Intercalaires Verticaux -->
        <Style x:Key="VerticalTabStyle" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource TabInactiveBrush}"/>
            <Setter Property="Foreground" Value="#5A7A8A"/>
            <Setter Property="BorderThickness" Value="1,1,1,1"/>
            <Setter Property="BorderBrush" Value="#B8D4E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="-4,1,0,1"/>
            <Setter Property="Padding" Value="0,15,0,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,6,6,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.1" Direction="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <ContentPresenter.LayoutTransform>
                                    <RotateTransform Angle="-90"/>
                                </ContentPresenter.LayoutTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0EEF4"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4A90A4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style intercalaire vertical ACTIF -->
        <Style x:Key="VerticalTabActiveStyle" TargetType="Button" BasedOn="{StaticResource VerticalTabStyle}">
            <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>
            <Setter Property="Foreground" Value="#2C5A6A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{StaticResource DossierBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2,2,0,2"/>
            <Setter Property="Margin" Value="-15,1,0,1"/>
            <Setter Property="Padding" Value="0,20,0,20"/>
        </Style>

        <!-- Style intercalaire interne Viewbox (pour mode plein écran F3) -->
        <Style x:Key="ViewboxTabStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource TabInactiveBrush}"/>
            <Setter Property="Foreground" Value="#5A7A8A"/>
            <Setter Property="BorderThickness" Value="1,1,1,1"/>
            <Setter Property="BorderBrush" Value="#B8D4E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="0,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,6,6,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.1" Direction="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <ContentPresenter.LayoutTransform>
                                    <RotateTransform Angle="-90"/>
                                </ContentPresenter.LayoutTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0EEF4"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4A90A4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F1" Command="{Binding SwitchToFocusTravailCommand}"/>
        <KeyBinding Key="F2" Command="{Binding SwitchToConsultationCommand}"/>
        <KeyBinding Key="F3" Command="{Binding SwitchToDossierCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- BARRE SUPERIEURE - Switch d'etats -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Visibility="Collapsed"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="15,10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Info patient -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Mode Consultation"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2C3E50"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - "
                               Foreground="#95A5A6"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasPatient, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding PatientDisplayName}"
                               FontSize="14"
                               Foreground="#3498DB"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasPatient, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- Boutons switch d'etat -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Focus Travail (F1) -->
                    <Button Command="{Binding SwitchToFocusTravailCommand}"
                            ToolTip="Focus Travail (F1) - 100% espace de travail">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StateButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFocusTravail}" Value="True">
                                        <Setter Property="Background" Value="#3498DB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="[" Margin="0,0,2,0"/>
                            <Border Width="16" Height="12" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" CornerRadius="2"/>
                            <TextBlock Text="]" Margin="2,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Consultation (F2) -->
                    <Button Command="{Binding SwitchToConsultationCommand}"
                            ToolTip="Consultation (F2) - 67% travail / 33% dossier">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StateButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConsultation}" Value="True">
                                        <Setter Property="Background" Value="#3498DB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="[" Margin="0,0,2,0"/>
                            <Border Width="12" Height="12" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" CornerRadius="2"/>
                            <TextBlock Text="|" Margin="2,0,2,0"/>
                            <Border Width="6" Height="12" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" CornerRadius="2"/>
                            <TextBlock Text="]" Margin="2,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Focus Dossier (F3) -->
                    <Button Command="{Binding SwitchToDossierCommand}"
                            ToolTip="Focus Dossier (F3) - 100% dossier patient">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StateButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                        <Setter Property="Background" Value="#3498DB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="[" Margin="0,0,2,0"/>
                            <Border Width="16" Height="12" Background="{StaticResource DossierBorderBrush}" CornerRadius="2"/>
                            <TextBlock Text="]" Margin="2,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ZONE PRINCIPALE - Layout adaptatif -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="15"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                            <Setter Property="Margin" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <!-- Espace de travail (67% en mode Consultation) -->
                <ColumnDefinition x:Name="WorkspaceColumn">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="2*"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFocusTravail}" Value="True">
                                    <Setter Property="Width" Value="*"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>

                <!-- Separateur -->
                <ColumnDefinition Width="15"/>

                <!-- Dossier patient (33% en mode Consultation) -->
                <ColumnDefinition x:Name="DossierColumn">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="*"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFocusTravail}" Value="True">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                    <Setter Property="Width" Value="*"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- Chip d'urgence clinique (Mode Urgence V0 Étape 3). Span toute la largeur de la zone Travail. -->
            <ContentPresenter Grid.Row="0" Grid.ColumnSpan="3"
                              Content="{Binding CurrentUrgenceChip}">
                <ContentPresenter.Resources>
                    <DataTemplate DataType="{x:Type vm:UrgenceChipViewModel}">
                        <urgence:UrgenceChipControl/>
                    </DataTemplate>
                </ContentPresenter.Resources>
            </ContentPresenter>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- ESPACE DE TRAVAIL (Gauche) -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Grid.Column="0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <!-- Zone clinicien (3/4) -->
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="10"/>
                    <!-- Zone Med (1/4) -->
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="*"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMedExpanded}" Value="False">
                                        <Setter Property="Width" Value="50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                </Grid.ColumnDefinitions>

                <!-- Zone Clinicien -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="8"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.08"/>
                    </Border.Effect>

                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <!-- Frise chronologique des consultations (hub) -->
                            <DockPanel Margin="0,0,0,8">
                                <!-- Bouton + (nouvelle consultation) avec badge 🔔 incrémental Synthèse Globale -->
                                <Grid DockPanel.Dock="Right" Margin="8,0,0,0">
                                    <Button x:Name="NewConsultationBtn"
                                            Width="32" Height="32"
                                            Click="NewConsultationBtn_Click"
                                            Background="#3498DB" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            ToolTip="Nouvelle consultation / évaluation / synthèse globale">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="16">
                                                    <TextBlock Text="＋" FontSize="16" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#2980B9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <!-- Badge 🔔 : visible si tracker.ShouldUpdateSynthesis() = true -->
                                    <Border Width="15" Height="15"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-2,-2,0"
                                            Background="#D4AF37" CornerRadius="7.5"
                                            BorderBrush="White" BorderThickness="1.5"
                                            ToolTip="{Binding SyntheseUpdateBadge}"
                                            Visibility="{Binding SyntheseUpdateRecommandee, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="🔔" FontSize="7.5" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <!-- Frise à deux lignes : LIGNE FIXE (parcours) + LIGNE LIBRE (notes de suivi) -->
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <StackPanel Orientation="Vertical">

                                        <!-- ══ LIGNE FIXE : jalons séquentiels du parcours patient ══ -->
                                        <ItemsControl ItemsSource="{Binding FriseStages}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <!-- Jalon -->
                                                        <Button Command="{Binding ActivateCommand}"
                                                                IsEnabled="{Binding IsClickable}"
                                                                Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bg" Width="96" Height="36"
                                                                            CornerRadius="5" Padding="5,3"
                                                                            BorderThickness="1"
                                                                            Background="#F2F2F2" BorderBrush="#D5D5D5">
                                                                        <StackPanel>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock x:Name="IconTb" Text="{Binding Icon}"
                                                                                           FontSize="10" Margin="0,0,3,0"
                                                                                           Foreground="#AAAAAA"/>
                                                                                <TextBlock x:Name="LabelTb" Text="{Binding Label}"
                                                                                           FontSize="8.5" FontWeight="SemiBold"
                                                                                           Foreground="#AAAAAA"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           MaxWidth="70"/>
                                                                            </StackPanel>
                                                                            <TextBlock x:Name="StatusTb" Text="{Binding StatusText}"
                                                                                       FontSize="7.5" Margin="0,1,0,0"
                                                                                       Foreground="#BBBBBB"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <!-- Available : bleu -->
                                                                        <DataTrigger Binding="{Binding Status}" Value="Available">
                                                                            <Setter TargetName="Bg"      Property="Background"   Value="#EBF5FB"/>
                                                                            <Setter TargetName="Bg"      Property="BorderBrush"  Value="#3498DB"/>
                                                                            <Setter TargetName="IconTb"  Property="Foreground"   Value="#2980B9"/>
                                                                            <Setter TargetName="LabelTb" Property="Foreground"   Value="#1A5276"/>
                                                                            <Setter TargetName="StatusTb" Property="Foreground"  Value="#5DADE2"/>
                                                                        </DataTrigger>
                                                                        <!-- InProgress : orange -->
                                                                        <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                                            <Setter TargetName="Bg"      Property="Background"   Value="#FEF3E2"/>
                                                                            <Setter TargetName="Bg"      Property="BorderBrush"  Value="#E67E22"/>
                                                                            <Setter TargetName="Bg"      Property="BorderThickness" Value="1.5"/>
                                                                            <Setter TargetName="IconTb"  Property="Foreground"   Value="#D35400"/>
                                                                            <Setter TargetName="LabelTb" Property="Foreground"   Value="#784212"/>
                                                                            <Setter TargetName="StatusTb" Property="Foreground"  Value="#E67E22"/>
                                                                        </DataTrigger>
                                                                        <!-- Completed : vert -->
                                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                            <Setter TargetName="Bg"      Property="Background"   Value="#E9F7EF"/>
                                                                            <Setter TargetName="Bg"      Property="BorderBrush"  Value="#27AE60"/>
                                                                            <Setter TargetName="IconTb"  Property="Foreground"   Value="#1E8449"/>
                                                                            <Setter TargetName="LabelTb" Property="Foreground"   Value="#145A32"/>
                                                                            <Setter TargetName="StatusTb" Property="Foreground"  Value="#27AE60"/>
                                                                        </DataTrigger>
                                                                        <!-- Hover (seulement si clickable) -->
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsMouseOver}" Value="True"/>
                                                                                <Condition Binding="{Binding IsClickable}" Value="True"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter TargetName="Bg" Property="Opacity" Value="0.82"/>
                                                                        </MultiDataTrigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <!-- Flèche connecteur (masquée pour le dernier jalon) -->
                                                        <TextBlock Text="›" FontSize="14" Foreground="#CCCCCC"
                                                                   VerticalAlignment="Center" Margin="2,0"
                                                                   Visibility="{Binding ShowArrow, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Connecteur en L : descend sous la 1ère consultation puis mène à la note de suivi.
                                             Le point d'origine vert rappelle le jalon « 1ère consultation » (clôturée) d'où dérive la note. -->
                                        <Grid Height="20" HorizontalAlignment="Left" Width="160"
                                              Visibility="{Binding HasFriseStages, Converter={StaticResource BoolToVis}}">
                                            <!-- point d'origine sous le centre du 1er jalon -->
                                            <Ellipse Width="6" Height="6" Fill="#27AE60"
                                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                                     Margin="45,0,0,0"/>
                                            <!-- branche verticale depuis le 1er jalon -->
                                            <Border Width="2" Background="#9FB0C0"
                                                    HorizontalAlignment="Left" Margin="47,3,0,0"
                                                    VerticalAlignment="Stretch"/>
                                            <!-- branche horizontale qui mène au CENTRE de la cartouche note
                                                 (47 = sous le 1er jalon ; +60 ≈ bord gauche note (62) + demi-largeur (45)) -->
                                            <Border Height="2" Background="#9FB0C0"
                                                    HorizontalAlignment="Left" Width="60"
                                                    VerticalAlignment="Bottom" Margin="47,0,0,0"/>
                                        </Grid>

                                        <!-- ══ LIGNE LIBRE : notes de suivi ══ -->
                                        <!-- Indentée pour démarrer au bout du connecteur en L (≈ sous la 1ère consultation). -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="62,0,0,0">

                                            <!-- Carte "Reprendre suivi en cours" -->
                                            <Border Margin="0,0,8,0"
                                                    Background="#FEF9E7" BorderBrush="#F39C12" BorderThickness="1.5"
                                                    CornerRadius="5" Padding="2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding HasSuiviInProgress}" Value="True"/>
                                                                    <Condition Binding="{Binding IsEditingConsultation}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Command="{Binding ResumeSuiviCommand}"
                                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                            ToolTip="Reprendre la consultation de suivi en cours">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" Padding="5,3" CornerRadius="4">
                                                                    <StackPanel>
                                                                        <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="#B7770D">
                                                                            <Run Text="▶"/>
                                                                            <Run Text="Reprendre suivi"/>
                                                                        </TextBlock>
                                                                        <TextBlock Text="brouillon en cours" FontSize="7.5" Foreground="#7D6608"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#FCF3CF"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button Command="{Binding DiscardSuiviCommand}"
                                                            Width="16" Height="16" Margin="2,0,2,0"
                                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                            ToolTip="Abandonner le brouillon">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                                                    <TextBlock Text="🗑" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#FADBD8"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </Border>

                                            <!-- Notes de suivi (type Suivi uniquement, 1ère consultation exclue) -->
                                            <ItemsControl ItemsSource="{Binding SuiviCards}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid x:Name="CardHost" Margin="0,0,8,0">
                                                            <Button Cursor="Hand"
                                                                    Command="{Binding DataContext.OpenCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Cd" Width="90" Height="30"
                                                                                CornerRadius="5" Padding="5,3"
                                                                                Background="#F4F8FB" BorderBrush="#D6E2EC" BorderThickness="1">
                                                                            <StackPanel>
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <TextBlock Text="{Binding Icon}" FontSize="10" Margin="0,0,3,0"/>
                                                                                    <TextBlock Text="{Binding Type}" FontSize="8.5" FontWeight="SemiBold"
                                                                                               Foreground="#2C3E50" TextTrimming="CharacterEllipsis"
                                                                                               MaxWidth="65"/>
                                                                                </StackPanel>
                                                                                <TextBlock Text="{Binding DateText}" FontSize="7.5"
                                                                                           Foreground="#7F8C8D" Margin="0,1,0,0"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Cd" Property="Background" Value="#E8F1F8"/>
                                                                                <Setter TargetName="Cd" Property="BorderBrush" Value="#3498DB"/>
                                                                            </Trigger>
                                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                                <Setter TargetName="Cd" Property="Background" Value="#D6EAF8"/>
                                                                                <Setter TargetName="Cd" Property="BorderBrush" Value="#3498DB"/>
                                                                            </DataTrigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                            <!-- Bouton supprimer -->
                                                            <Button x:Name="DeleteBtn"
                                                                    Width="14" Height="14"
                                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                    Margin="0,-2,-2,0" Cursor="Hand"
                                                                    Visibility="Collapsed"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    ToolTip="Supprimer cette note"
                                                                    Command="{Binding DataContext.DeleteConsultationCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="DBorder" Background="#FFFFFF"
                                                                                BorderBrush="#D6E2EC" BorderThickness="1" CornerRadius="7">
                                                                            <TextBlock Text="🗑" FontSize="8"
                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="DBorder" Property="Background" Value="#FADBD8"/>
                                                                                <Setter TargetName="DBorder" Property="BorderBrush" Value="#E74C3C"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <Trigger SourceName="CardHost" Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="DeleteBtn" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Placeholder ligne libre si aucune note de suivi -->
                                            <TextBlock Text="＋ via le bouton ＋ pour ajouter une note de suivi"
                                                       FontSize="11" Foreground="#C8D6E0"
                                                       VerticalAlignment="Center" Margin="4,0"
                                                       Visibility="{Binding HasNoSuiviCards, Converter={StaticResource BoolToVis}}"/>

                                        </StackPanel>
                                        <!-- ══ Fin ligne libre ══ -->

                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>

                            <TextBlock Text="{Binding ConsultationDate, StringFormat='{}{0:dddd d MMMM yyyy}'}"
                                       FontSize="12"
                                       Foreground="#7F8C8D"/>

                            <!-- Statut extraction (visible uniquement en mode interrogatoire) -->
                            <TextBlock Text="{Binding ExtractionStatus}"
                                       FontSize="11"
                                       Foreground="#3498DB"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInterrogatoireMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Zone principale : switches selon le mode -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- MODE PHASE D'ÉVALUATION : overlay au-dessus de tous les autres modes -->
                            <ScrollViewer Grid.Row="0" Grid.RowSpan="2"
                                          Panel.ZIndex="100"
                                          VerticalScrollBarVisibility="Auto"
                                          Background="#F5F7FA"
                                          Visibility="{Binding IsEvaluationPhaseMode, Converter={StaticResource BoolToVis}}">
                                <eval:EvaluationPhaseControl DataContext="{Binding EvaluationPhase}" Margin="4"/>
                            </ScrollViewer>

                            <!-- MODE SYNTHÈSE GLOBALE : overlay au-dessus du mode normal -->
                            <Grid Grid.Row="0" Grid.RowSpan="2"
                                  Panel.ZIndex="101"
                                  Background="#F5F7FA"
                                  Visibility="{Binding IsSyntheseGlobaleMode, Converter={StaticResource BoolToVis}}">
                                <synth:SyntheseGlobaleControl DataContext="{Binding SyntheseGlobaleVM}"/>
                            </Grid>

                            <!-- MODE PROJET THÉRAPEUTIQUE : overlay au-dessus du mode normal -->
                            <Grid Grid.Row="0" Grid.RowSpan="2"
                                  Panel.ZIndex="102"
                                  Background="#F5F7FA"
                                  Visibility="{Binding IsProjetTherapeutiqueMode, Converter={StaticResource BoolToVis}}">
                                <projet:ProjetTherapeutiqueControl DataContext="{Binding ProjetTherapeutiqueVM}"/>
                            </Grid>

                            <!-- LECTURE D'UNE CONSULTATION PASSÉE -->
                            <Grid Grid.Row="0" Grid.RowSpan="2"
                                  Panel.ZIndex="105"
                                  Background="#F5F7FA"
                                  Visibility="{Binding IsReadingPastConsultationMode, Converter={StaticResource BoolToVis}}">
                                <Border Margin="15" CornerRadius="8" Background="White" BorderBrush="#D6E2EC" BorderThickness="1">
                                    <Grid Margin="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Header -->
                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding SelectedPastConsultation.Title}" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" TextWrapping="Wrap"/>
                                                <TextBlock Text="Mode Lecture Seule" FontSize="11" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            
                                            <!-- Actions (Supprimer) -->
                                            <Button Grid.Column="1" Content="🗑 Supprimer" 
                                                    Command="{Binding DeleteSelectedPastConsultationCommand}"
                                                    Padding="12,6" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#C0392B"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>

                                        <!-- Content -->
                                        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#EAECEF" BorderThickness="1" CornerRadius="4" Padding="15">
                                            <FlowDocumentScrollViewer Document="{Binding SelectedPastConsultation.DisplayDocument}" Zoom="100" BorderThickness="0" Background="Transparent"/>
                                        </Border>

                                        <!-- Footer -->
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                            <Button Content="✕ Fermer la vue" Command="{Binding ClosePastConsultationCommand}"
                                                    Padding="25,9" Background="#7F8C8D" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#707B7C"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- LECTURE D'UNE 1ÈRE CONSULTATION PASSÉE (ETAPES ET LECTURE SEULE) -->
                            <Grid Grid.Row="0" Grid.RowSpan="2"
                                  Panel.ZIndex="106"
                                  Background="#F5F7FA"
                                  Visibility="{Binding IsReadingPastPremiereConsultationMode, Converter={StaticResource BoolToVis}}">
                                <Border Margin="15" CornerRadius="8" Background="White" BorderBrush="#D6E2EC" BorderThickness="1">
                                    <Grid Margin="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header & Steps Navigation -->
                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding SelectedPastConsultation.Title}" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                                                <TextBlock Text="Mode Lecture Seule — Étape par étape" FontSize="11" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                                
                                                <!-- Steps bar (like evaluation) -->
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <!-- Button Step 1 -->
                                                    <Button Content="Étape 1 — Interrogatoire" FontSize="11" Padding="12,6" Cursor="Hand" Margin="0,0,8,0"
                                                            Command="{Binding ViewPastPremiereStepCommand}" CommandParameter="1">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="White"/>
                                                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="Foreground" Value="#3498DB"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPastPremiereStep1}" Value="True">
                                                                        <Setter Property="Background" Value="#3498DB"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#EBF5FB"/>
                                                                    </Trigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsPastPremiereStep1}" Value="True"/>
                                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Background" Value="#2980B9"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <!-- Button Step 2 -->
                                                    <Button Content="Étape 2 — Observations Cliniques" FontSize="11" Padding="12,6" Cursor="Hand" Margin="0,0,8,0"
                                                            Command="{Binding ViewPastPremiereStepCommand}" CommandParameter="2">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="White"/>
                                                                <Setter Property="BorderBrush" Value="#27AE60"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="Foreground" Value="#27AE60"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPastPremiereStep2}" Value="True">
                                                                        <Setter Property="Background" Value="#27AE60"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#E8F8F5"/>
                                                                    </Trigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsPastPremiereStep2}" Value="True"/>
                                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Background" Value="#219653"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <!-- Button Step 3 -->
                                                    <Button Content="Étape 3 — Synthèse Initiale" FontSize="11" Padding="12,6" Cursor="Hand" Margin="0,0,8,0"
                                                            Command="{Binding ViewPastPremiereStepCommand}" CommandParameter="3">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="White"/>
                                                                <Setter Property="BorderBrush" Value="#9B59B6"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="Foreground" Value="#9B59B6"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPastPremiereStep3}" Value="True">
                                                                        <Setter Property="Background" Value="#9B59B6"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#F5EEF8"/>
                                                                    </Trigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsPastPremiereStep3}" Value="True"/>
                                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Background" Value="#8E44AD"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Actions (Supprimer) -->
                                            <Button Grid.Column="1" Content="🗑 Supprimer" 
                                                    Command="{Binding DeleteSelectedPastConsultationCommand}"
                                                    Padding="12,6" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Top">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#C0392B"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>

                                        <!-- Content area -->
                                        <Grid Grid.Row="1">
                                            <!-- STEP 1: Interrogatoire -->
                                            <Grid Visibility="{Binding IsPastPremiereStep1, Converter={StaticResource BoolToVis}}">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <StackPanel Margin="0,0,10,0">
                                                        <ItemsControl ItemsSource="{Binding PastInterrogatoireBlocks}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border BorderBrush="#EAECEF" BorderThickness="1" CornerRadius="6" Background="#FAFAFA" Margin="0,0,0,10" Padding="15">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="BorderThickness" Value="3,1,1,1"/>
                                                                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,6"/>
                                                                            <TextBlock Text="{Binding FreeText}" FontSize="12" Foreground="#34495E" TextWrapping="Wrap" LineHeight="18"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Grid>

                                            <!-- STEP 2: Observations Cliniques -->
                                            <Grid Visibility="{Binding IsPastPremiereStep2, Converter={StaticResource BoolToVis}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <!-- UniformGrid of read-only Cards -->
                                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding PastClinicalCards}" Margin="0,0,10,0">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <UniformGrid Columns="2" VerticalAlignment="Top"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="8" Padding="12" Margin="6" BorderThickness="1.5">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                                            <Setter Property="Background" Value="#FAFAFA"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                                                                    <Setter Property="BorderBrush" Value="#27AE60"/>
                                                                                    <Setter Property="Background" Value="#F0FAF5"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,6"/>
                                                                        
                                                                        <!-- Selection Badge -->
                                                                        <Border HorizontalAlignment="Left" CornerRadius="4" Padding="6,3" Margin="0,0,0,6" Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}" Background="#27AE60">
                                                                            <TextBlock Text="{Binding SelectedOption}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                                        </Border>
                                                                        
                                                                        <!-- Free text comment if exists -->
                                                                        <TextBlock Text="{Binding FreeText}" FontSize="12" Foreground="#5D6D7E" TextWrapping="Wrap" LineHeight="16" FontStyle="Italic"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                                
                                                <!-- Narratif complet -->
                                                <Border Grid.Row="1" Background="#EAF2F8" BorderBrush="#27AE60" BorderThickness="3,1,1,1" CornerRadius="6" Padding="12" Margin="6,10,6,0">
                                                    <StackPanel>
                                                        <TextBlock Text="✍️ Observations rédigées cliniques :" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                                        <TextBlock Text="{Binding PastObservationsNarrative}" FontSize="12" Foreground="#34495E" TextWrapping="Wrap" LineHeight="18"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- STEP 3: Synthèse Initiale -->
                                            <Grid Visibility="{Binding IsPastPremiereStep3, Converter={StaticResource BoolToVis}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                
                                                <!-- Poids de fiabilité -->
                                                <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#EAECEF" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <TextBlock Text="📊 Indicateurs de fiabilité" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="Interrogatoire" FontSize="11" Foreground="#7F8C8D"/>
                                                                <TextBlock Text="{Binding PastInterrogatoireWeight, StringFormat='{}{0:F1}/1.0'}" FontSize="16" FontWeight="Bold" Foreground="#3498DB"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="Observations" FontSize="11" Foreground="#7F8C8D"/>
                                                                <TextBlock Text="{Binding PastObservationsWeight, StringFormat='{}{0:F1}/1.0'}" FontSize="16" FontWeight="Bold" Foreground="#27AE60"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Moyenne" FontSize="11" Foreground="#7F8C8D"/>
                                                                <TextBlock Text="{Binding PastAverageWeight, StringFormat='{}{0:F1}/1.0'}" FontSize="16" FontWeight="Bold" Foreground="#8E44AD"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        
                                                        <TextBlock Text="{Binding PastLLMJustification}" FontSize="11" Foreground="#5D6D7E" Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic"/>
                                                    </StackPanel>
                                                </Border>
                                                
                                                <!-- Synthèse rédigée -->
                                                <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#EAECEF" BorderThickness="1" CornerRadius="6" Padding="15">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <StackPanel>
                                                            <TextBlock Text="📄 Synthèse Clinique :" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                                                            <TextBlock Text="{Binding PastSynthesisContent}" FontSize="12" Foreground="#34495E" TextWrapping="Wrap" LineHeight="18"/>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>
                                        </Grid>

                                        <!-- Footer -->
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                            <Button Content="✕ Fermer la vue" Command="{Binding ClosePastPremiereConsultationCommand}"
                                                    Padding="25,9" Background="#7F8C8D" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#707B7C"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- MODE NORMAL : note libre classique -->
                            <TextBox Grid.Row="1" Text="{Binding NoteContent, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="14"
                                     FontFamily="Segoe UI"
                                     Padding="10"
                                     BorderBrush="#E0E0E0"
                                     BorderThickness="1">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="#FAFAFA"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInterrogatoireMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <!-- V0c : Boutons simples (Interrogatoire vs Observations) -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" Height="40" VerticalAlignment="Top">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInterrogatoireMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <Button Content="Interrogatoire"
                                        Command="{Binding SwitchToInterrogatoireCommand}"
                                        Padding="15,5" Cursor="Hand" FontSize="13" FontWeight="SemiBold"
                                        Margin="0,0,10,0" Height="40"
                                        Background="#3498DB" Foreground="White"
                                        BorderThickness="0"
                                        VerticalAlignment="Top">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="8"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2980B9"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#BDC3C7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="Observations Cliniques"
                                        Command="{Binding SwitchToClinicalCommand}"
                                        Padding="15,5" Cursor="Hand" FontSize="13" FontWeight="SemiBold"
                                        Height="40"
                                        Background="#27AE60" Foreground="White"
                                        BorderThickness="0"
                                        VerticalAlignment="Top">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="8"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#219653"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#BDC3C7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="📄 Synthèse Initiale"
                                        Command="{Binding SwitchToSynthesisCommand}"
                                        Padding="15,5" Cursor="Hand" FontSize="13" FontWeight="SemiBold"
                                        Margin="10,0,0,0" Height="40"
                                        Background="#9B59B6" Foreground="White"
                                        BorderThickness="0"
                                        VerticalAlignment="Top">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="8"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#8E44AD"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#BDC3C7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                            </StackPanel>

                            <!-- MODE INTERROGATOIRE — Saisie transcription -->
                            <Grid Grid.Row="1">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInSaisieMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="140"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Transcription de la consultation :"
                                           FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,6"/>

                                <Border Grid.Row="1" Background="#FAFAFA" BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="6" Padding="2">
                                    <TextBox Text="{Binding TranscriptionInput, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             FontSize="11"
                                             Foreground="#2C3E50"
                                             FontFamily="Segoe UI"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="8"
                                             MaxHeight="120"
                                             VerticalScrollBarVisibility="Auto"
                                             ToolTip="Tapez ou dictez votre transcription. Cliquez sur 'Extraire avec IA' pour la traiter."/>
                                </Border>

                                <!-- Blocs complétés — tags compacts (migrent depuis la zone Med à droite) -->
                                <Border Grid.Row="2" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,6,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding CompletedBlocks}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#E8F5E9" BorderBrush="#27AE60" BorderThickness="1"
                                                            CornerRadius="12" Padding="8,3" Margin="0,0,5,5"
                                                            Cursor="Hand" ToolTip="{Binding CompactPreview}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="✓" FontSize="10" FontWeight="Bold"
                                                                       Foreground="#27AE60" Margin="0,0,4,0"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Title}" FontSize="10"
                                                                       FontWeight="SemiBold" Foreground="#1B5E20"
                                                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <TextBlock Text="{Binding CompactPreview}" FontSize="10"
                                                                       Foreground="#558B2F" TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="180" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <!-- Grid.Row=3 vide : les blocs actifs sont affichés à droite (panneau Med) -->
                                <Border Grid.Row="3" Background="Transparent" BorderThickness="0"/>

                                <StackPanel Grid.Row="4" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="0,8,0,0">

                                    <!-- Sélecteur mode dictée (visible quand pas en cours) -->
                                    <CheckBox Content="Mode Batch (90s)"
                                              IsChecked="{Binding UseBatchMode}"
                                              VerticalAlignment="Center" Margin="0,0,12,0"
                                              FontSize="11"
                                              Visibility="{Binding IsNotRecording, Converter={StaticResource BoolToVis}}"
                                              ToolTip="Coché : transcription toutes les 90s (qualité max, recommandé pour consultation)&#x0a;Décoché : streaming temps réel (peut fragmenter sur débit lent)"/>

                                    <!-- V0b : Bouton Vocabulaire Whisper -->
                                    <Button x:Name="VocabBtn" Content="📝 Vocab"
                                            Click="VocabBtn_Click"
                                            Padding="8,5" Cursor="Hand" FontSize="10"
                                            Background="#F3E5F5" Foreground="#7B1FA2"
                                            BorderThickness="1" BorderBrush="#CE93D8"
                                            Margin="0,0,8,0"
                                            ToolTip="Éditer le vocabulaire personnalisé Whisper"
                                            Visibility="{Binding IsNotRecording, Converter={StaticResource BoolToVis}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BdVocab" Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BdVocab" Property="Background" Value="#E1BEE7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Bouton Démarrer dictée -->
                                    <Button Content="🎙 Dicter"
                                            Command="{Binding StartRecordingCommand}"
                                            IsEnabled="{Binding IsInSaisieMode}"
                                            Padding="12,7" Cursor="Hand" FontSize="12"
                                            Background="#27AE60" Foreground="White"
                                            BorderThickness="0" Margin="0,0,8,0"
                                            Visibility="{Binding IsNotRecording, Converter={StaticResource BoolToVis}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#219A52"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#BDC3C7"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Bouton Arrêter dictée -->
                                    <Button Content="⏹ Arrêter"
                                            Command="{Binding StopRecordingCommand}"
                                            Padding="12,7" Cursor="Hand" FontSize="12"
                                            Background="#E74C3C" Foreground="White"
                                            BorderThickness="0" Margin="0,0,8,0"
                                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#C0392B"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button x:Name="ImportTxtBtn" Content="📂 Importer .txt"
                                            Click="ImportTxtBtn_Click"
                                            Padding="12,7" Background="#ECF0F1" BorderThickness="1"
                                            BorderBrush="#BDC3C7" Cursor="Hand" FontSize="12"
                                            Margin="0,0,8,0"/>
                                    <Button Content="⚙ Extraire avec IA"
                                            Command="{Binding ExtractInterrogatoireCommand}"
                                            Padding="14,7" Background="#3498DB" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" FontSize="12">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#2980B9"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#BDC3C7"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <!-- Indicateur visuel enregistrement -->
                                <Border Grid.Row="5" Margin="0,6,0,0" Padding="8,6"
                                        CornerRadius="6" Background="#F0FAF5" BorderThickness="1" BorderBrush="#A8D5BC"
                                        Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Ligne 1 : micro + statut -->
                                        <Grid Grid.Row="0" Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="🎤" FontSize="13"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>

                                            <!-- Barre niveau micro (animée) -->
                                            <ProgressBar Grid.Column="1" Height="8"
                                                         Minimum="0" Maximum="100"
                                                         Value="{Binding MicLevelPct}"
                                                         Background="#DDEEDD" BorderThickness="0"
                                                         VerticalAlignment="Center">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Foreground" Value="#27AE60"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBatchSent}" Value="True">
                                                                <Setter Property="Foreground" Value="#E67E22"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>

                                            <!-- Statut texte (timer + alerts) -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ExtractionStatus}"
                                                       FontSize="11" Foreground="#2C6E49"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>

                                        <!-- Ligne 2 : progression batch 90s -->
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <ProgressBar Grid.Column="0" Height="10"
                                                         Minimum="0" Maximum="100"
                                                         Value="{Binding BatchProgressPct}"
                                                         Background="#DDEEDD" BorderThickness="0">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Foreground" Value="#27AE60"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBatchSent}" Value="True">
                                                                <Setter Property="Foreground" Value="#F39C12"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>

                                            <!-- Label : "45s / 90s" ou "✓ Envoyé" -->
                                            <TextBlock Grid.Column="1" FontSize="10" Margin="6,0,0,0"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding BatchProgressPct, StringFormat='{}{0}s / 90s'}"/>
                                                        <Setter Property="Foreground" Value="#558B2F"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBatchSent}" Value="True">
                                                                <Setter Property="Text" Value="✓ Envoyé"/>
                                                                <Setter Property="Foreground" Value="#E67E22"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Border>

                            </Grid>

                            <!-- V0c : MODE INTERROGATOIRE — Observations Cliniques -->
                            <Grid Grid.Row="1">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInClinicalMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Grille 2 colonnes de cartes d'observation -->
                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <ItemsControl Grid.Column="0" Grid.ColumnSpan="2" ItemsSource="{Binding ClinicalObservations.Cards}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2" VerticalAlignment="Top"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <!-- Carte : bordure verte quand une option est sélectionnée -->
                                                    <Border CornerRadius="8" Padding="14" Margin="6"
                                                            BorderThickness="1.5">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <!-- Default : option sélectionnée (vert) -->
                                                                <Setter Property="Background" Value="#F0FAF5"/>
                                                                <Setter Property="BorderBrush" Value="#27AE60"/>
                                                                <Style.Triggers>
                                                                    <!-- Aucune option : revenir au gris -->
                                                                    <DataTrigger Binding="{Binding SelectedOption}" Value="{x:Null}">
                                                                        <Setter Property="Background" Value="#FAFAFA"/>
                                                                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Titre + valeur sélectionnée -->
                                                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Title}"
                                                                           FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="#2C3E50"
                                                                           VerticalAlignment="Center"/>
                                                                <Border Grid.Column="1" Background="#27AE60" CornerRadius="10"
                                                                        Padding="8,2" Margin="6,0,0,0">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding SelectedOption}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="✓" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                                </Border>
                                                            </Grid>

                                                            <!-- Chips d'options : MVVM clean -->
                                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Options}" Margin="0,0,0,4">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <!-- Button utilise la commande de la CARTE (DataContext via AncestorLevel=1) -->
                                                                        <Button Content="{Binding}"
                                                                                Command="{Binding DataContext.SelectOptionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=1}}"
                                                                                CommandParameter="{Binding}"
                                                                                Padding="12,7" Margin="0,0,6,5"
                                                                                FontSize="11" FontWeight="Medium" Cursor="Hand">
                                                                            <Button.Template>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border x:Name="ChipBorder"
                                                                                            Background="{TemplateBinding Background}"
                                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                                            CornerRadius="14"
                                                                                            Padding="{TemplateBinding Padding}">
                                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter TargetName="ChipBorder" Property="Background" Value="#D4E9F7"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Button.Template>
                                                                            <Button.Style>
                                                                                <Style TargetType="Button">
                                                                                    <!-- Default : non sélectionné -->
                                                                                    <Setter Property="Background" Value="White"/>
                                                                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                                                                    <Setter Property="BorderBrush" Value="#BDC3C7"/>
                                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                                    <Style.Triggers>
                                                                                        <!-- SÉLECTIONNÉ : compare Card.SelectedOption avec l'option du bouton -->
                                                                                        <DataTrigger Value="True">
                                                                                            <DataTrigger.Binding>
                                                                                                <MultiBinding Converter="{StaticResource StringEquals}">
                                                                                                    <Binding Path="DataContext.SelectedOption" RelativeSource="{RelativeSource AncestorType=ItemsControl, AncestorLevel=1}"/>
                                                                                                    <Binding/>
                                                                                                </MultiBinding>
                                                                                            </DataTrigger.Binding>
                                                                                            <Setter Property="Background" Value="#3498DB"/>
                                                                                            <Setter Property="Foreground" Value="White"/>
                                                                                            <Setter Property="BorderBrush" Value="#2980B9"/>
                                                                                            <Setter Property="BorderThickness" Value="1.5"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <!-- Notes (toggle + textarea) -->
                                                            <StackPanel Grid.Row="2">
                                                                <Button Command="{Binding ToggleExpandCommand}"
                                                                        FontSize="10" Background="Transparent"
                                                                        BorderThickness="0" Foreground="#3498DB"
                                                                        Cursor="Hand" Padding="0"
                                                                        HorizontalAlignment="Left">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button">
                                                                            <Setter Property="Content" Value="+ Notes"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                    <Setter Property="Content" Value="− Notes"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>

                                                                <TextBox Text="{Binding FreeText, UpdateSourceTrigger=PropertyChanged}"
                                                                         Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                                                         AcceptsReturn="True" TextWrapping="Wrap"
                                                                         MinHeight="50" MaxHeight="120" Margin="0,6,0,0" Padding="8"
                                                                         FontSize="11"
                                                                         BorderBrush="#E0E0E0" BorderThickness="1"
                                                                         Background="White"
                                                                         VerticalScrollBarVisibility="Auto"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </ScrollViewer>

                                <!-- Boutons d'action -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="← Retour Interrogatoire"
                                            Command="{Binding SwitchToInterrogatoireCommand}"
                                            Padding="10,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                            Background="#ECF0F1" Foreground="#2C3E50"
                                            BorderThickness="1" BorderBrush="#BDC3C7">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#D5DBDB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="✓ Terminer Observations"
                                            Command="{Binding TerminateClinicalObservationsCommand}"
                                            Padding="10,7" Cursor="Hand" FontSize="11"
                                            Background="#27AE60" Foreground="White"
                                            BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#219A52"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- MODE OBSERVATIONS — Revue/édition rédaction clinique -->
                            <Grid Grid.Row="1">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInObservationsReviewMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRestitutionMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- En-tête -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="📝 Rédaction clinique — Observations"
                                               FontSize="14" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                    <TextBlock Text="Générée à partir des chips sélectionnés + notes. Modifiez si besoin avant de valider."
                                               FontSize="11" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Texte éditable -->
                                <Border Grid.Row="1" Background="White" BorderBrush="#27AE60" BorderThickness="1.5"
                                        CornerRadius="6" Padding="10">
                                    <TextBox Text="{Binding ObservationsNarrative, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             FontSize="12" FontFamily="Segoe UI"
                                             BorderThickness="0" Background="Transparent"
                                             VerticalScrollBarVisibility="Auto"/>
                                </Border>

                                <!-- Status -->
                                <TextBlock Grid.Row="2" Text="{Binding ObservationsStatusMessage}"
                                           FontSize="11" Foreground="#27AE60" Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>

                                <!-- Boutons -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="← Retour Observations"
                                            Command="{Binding BackToObservationsCardsCommand}"
                                            Padding="12,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                            Background="#ECF0F1" Foreground="#2C3E50"
                                            BorderThickness="1" BorderBrush="#BDC3C7"/>
                                    <Button Content="💾 Valider et sauvegarder"
                                            Command="{Binding SaveObservationsNoteCommand}"
                                            Padding="14,7" Cursor="Hand" FontSize="11"
                                            Background="#27AE60" Foreground="White" BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- V0d : MODE SYNTHÈSE INITIALE — Poids + Génération -->
                            <Grid Grid.Row="1">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSynthesisMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRestitutionMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>     <!-- Poids section -->
                                    <RowDefinition Height="*"/>        <!-- Synthèse preview -->
                                    <RowDefinition Height="Auto"/>     <!-- Boutons action -->
                                </Grid.RowDefinitions>

                                <!-- SECTION 1: Poids de Fiabilité -->
                                <Border Grid.Row="0" Background="#F8F9FA" Padding="12" Margin="0,0,0,12"
                                        BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                                    <StackPanel>
                                        <!-- Liste des documents déjà importés (lecture seule — l'import se fait depuis Med > Documents) -->
                                        <TextBlock Text="📄 Documents importés pour cette synthèse" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBlock Text="Pour ajouter un document : utilisez le bouton 📄 Documents dans la zone Med (mode Suggestions)."
                                                   FontSize="10" Foreground="#7F8C8D" FontStyle="Italic" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                        <!-- Liste des documents importés -->
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220" Margin="0,0,0,12">
                                        <ItemsControl ItemsSource="{Binding ImportedDocuments}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F5F5F5" BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Nom + poids -->
                                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="24"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding FileName}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Weight, StringFormat='Poids: 0.0'}" FontSize="10" Foreground="#7F8C8D" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                                <Button Grid.Column="2" Content="✕" Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.RemoveDocumentCommand}" CommandParameter="{Binding}"
                                                                        Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" Foreground="#E74C3C" Cursor="Hand" FontSize="10"/>
                                                            </Grid>

                                                            <!-- Slider poids -->
                                                            <Grid Grid.Row="1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="45"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Slider Grid.Column="0" Minimum="0.1" Maximum="1.0" SmallChange="0.1" LargeChange="0.2"
                                                                        Value="{Binding Weight, UpdateSourceTrigger=PropertyChanged}"
                                                                        Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Weight, StringFormat='0.0'}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                                                            </Grid>

                                                            <!-- Statut synthèse -->
                                                            <TextBlock Grid.Row="2" Text="⏳ Génération synthèse..." Foreground="#3498DB" FontSize="9" Margin="0,6,0,0" Visibility="{Binding IsSynthesizing, Converter={StaticResource BoolToVis}}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        </ScrollViewer>

                                        <TextBlock Text="📊 Poids de Fiabilité des Composants" FontWeight="Bold" FontSize="14" Margin="0,8,0,12"/>

                                        <!-- Interrogatoire Weight Slider -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Interrogatoire:" VerticalAlignment="Center" FontSize="12"/>
                                            <Slider Grid.Column="1" Minimum="0.1" Maximum="1.0" SmallChange="0.1" LargeChange="0.2"
                                                    Value="{Binding SynthesisWeights.InterrogatoireWeight, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="12,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding SynthesisWeights.InterrogatoireWeight, StringFormat='0.0'}"
                                                      HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                        </Grid>

                                        <!-- Observations Weight Slider -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Observations:" VerticalAlignment="Center" FontSize="12"/>
                                            <Slider Grid.Column="1" Minimum="0.1" Maximum="1.0" SmallChange="0.1" LargeChange="0.2"
                                                    Value="{Binding SynthesisWeights.ObservationsWeight, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="12,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding SynthesisWeights.ObservationsWeight, StringFormat='0.0'}"
                                                      HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                        </Grid>

                                        <!-- Justification from LLM -->
                                        <TextBlock Text="{Binding SynthesisWeights.LLMJustification}"
                                                  Foreground="#7F8C8D" FontSize="11" FontStyle="Italic" TextWrapping="Wrap"
                                                  Margin="0,0,0,8"/>

                                        <!-- Propose Weights Button -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="🔄 Proposer les poids"
                                                    Command="{Binding ProposeWeightsCommand}"
                                                    Padding="12,6" Background="#34495E" Foreground="White" Cursor="Hand" FontSize="11"
                                                    BorderThickness="0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AreWeightsLoading}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Background" Value="#95A5A6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>

                                        <!-- Status Message -->
                                        <TextBlock Text="{Binding SynthesisStatusMessage}" Foreground="#27AE60" Margin="0,8,0,0" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- SECTION 2: Synthèse Preview -->
                                <Border Grid.Row="1" Background="White" Padding="12" BorderThickness="1" BorderBrush="#DDD" CornerRadius="6" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="✅ Synthèse Initiale" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

                                        <TextBox Name="SynthesisPreview"
                                                Text="{Binding SynthesisContent, Mode=OneWay}"
                                                IsReadOnly="True" Height="280"
                                                Padding="12" BorderThickness="1" BorderBrush="#E0E0E0"
                                                Foreground="#2C3E50" FontFamily="Segoe UI" FontSize="11"
                                                VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding SynthesisStatusMessage}" Foreground="#3498DB" Margin="0,8,0,0" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- SECTION 3: Action Buttons -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                                    <Button Content="← Retour Observations"
                                            Command="{Binding SwitchToClinicalCommand}"
                                            Padding="10,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                            Background="#ECF0F1" Foreground="#2C3E50"
                                            BorderThickness="1" BorderBrush="#BDC3C7">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#D5DBDB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Content="✨ Générer Synthèse"
                                            Command="{Binding GenerateSynthesisCommand}"
                                            Padding="12,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                            Background="#27AE60" Foreground="White"
                                            BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="4"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#219653"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Background" Value="#95A5A6"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGeneratingSynthesis}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="💾 Sauvegarder"
                                            Command="{Binding SaveSynthesisCommand}"
                                            Padding="12,7" Cursor="Hand" FontSize="11"
                                            Background="#3498DB" Foreground="White"
                                            BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="4"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#2980B9"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Background" Value="#95A5A6"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SynthesisContent}" Value="">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- SÉLECTION DU TYPE DE RESTITUTION -->
                            <Grid Grid.Row="1">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectingRestitutionTypeMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="Nouveau Dossier de Restitution" FontSize="24" FontWeight="SemiBold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                                    
                                    <UniformGrid Columns="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- Choix 1 -->
                                        <Button Command="{Binding StartRestitutionCommand}" CommandParameter="PremiereConsultation" 
                                                Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                                                Width="280" Height="180" Margin="10" Cursor="Hand">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                                                <TextBlock Text="🤝" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                                <TextBlock Text="Restitution 1er entretien" FontSize="18" FontWeight="SemiBold" Foreground="#34495E" TextWrapping="Wrap" TextAlignment="Center"/>
                                                <TextBlock Text="Résumé adressé aux parents après la première rencontre." FontSize="13" Foreground="#7F8C8D" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Choix 2 -->
                                        <Button Command="{Binding StartRestitutionCommand}" CommandParameter="DossierClinique" 
                                                Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                                                Width="280" Height="180" Margin="10" Cursor="Hand">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                                                <TextBlock Text="📁" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                                <TextBlock Text="Dossier de restitution clinique" FontSize="18" FontWeight="SemiBold" Foreground="#34495E" TextWrapping="Wrap" TextAlignment="Center"/>
                                                <TextBlock Text="Synthèse globale, résultats des bilans et projet thérapeutique détaillé." FontSize="13" Foreground="#7F8C8D" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>
                                </StackPanel>
                            </Grid>

                            <!-- V0e : RESTITUTION AUX PARENTS (1er entretien) -->
                            <Grid Grid.Row="1">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRestitutionMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <!-- ── PANEL FORMULAIRE (saisie initiale) ── -->
                                <Grid Visibility="{Binding IsRestitutionFormMode, Converter={StaticResource BoolToVis}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0,0,0,12">

                                            <TextBlock Text="📋 Restitution aux Parents" FontWeight="Bold" FontSize="15"
                                                       Foreground="#E67E22" Margin="0,0,0,16"/>

                                            <TextBlock Text="Accompagnant(s) présent(s) :" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                            <ComboBox SelectedIndex="{Binding RestitutionAccompagnantIndex, UpdateSourceTrigger=PropertyChanged}"
                                                      Margin="0,0,0,4">
                                                <ComboBoxItem Content="Les deux parents"/>
                                                <ComboBoxItem Content="Mère seule"/>
                                                <ComboBoxItem Content="Père seul"/>
                                                <ComboBoxItem Content="Grand-parent(s)"/>
                                                <ComboBoxItem Content="Éducateur / référent"/>
                                                <ComboBoxItem Content="Autre"/>
                                            </ComboBox>
                                            <TextBox Text="{Binding Restitution.NomAccompagnant, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="8,5" FontSize="11" Margin="0,0,0,12"
                                                     Background="#FAFAFA" BorderBrush="#BDC3C7" BorderThickness="1">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Restitution.TypeAccompagnant}" Value="LesDeuParents">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>

                                            <Border Background="#FEF9E7" BorderBrush="#F39C12" BorderThickness="1"
                                                    CornerRadius="4" Padding="10" Margin="0,0,0,12"
                                                    Visibility="{Binding Restitution.HasMentionLegale, Converter={StaticResource BoolToVis}}">
                                                <StackPanel>
                                                    <TextBlock Text="⚖ Mention légale (automatique)" FontWeight="SemiBold"
                                                               FontSize="11" Foreground="#B7770D" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding Restitution.MentionLegale}"
                                                               TextWrapping="Wrap" FontSize="11" Foreground="#7D6608"/>
                                                </StackPanel>
                                            </Border>

                                            <TextBlock Text="Séances d'évaluation prévues :" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" Minimum="1" Maximum="6" SmallChange="1" LargeChange="1"
                                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                                        Value="{Binding Restitution.NombreSeances, UpdateSourceTrigger=PropertyChanged}"
                                                        VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Restitution.NombreSeances}"
                                                           FontWeight="Bold" FontSize="14" Foreground="#E67E22"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>

                                            <TextBlock Text="Notes clinicien (optionnel) :" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding Restitution.NotesLibres, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True" Height="80" Padding="8" TextWrapping="Wrap"
                                                     FontSize="11" VerticalScrollBarVisibility="Auto"
                                                     Background="#FAFAFA" BorderBrush="#BDC3C7" BorderThickness="1"
                                                     Margin="0,0,0,12"/>

                                            <TextBlock Text="{Binding RestitutionStatusMessage}" FontSize="11" TextWrapping="Wrap"
                                                       Foreground="#2980B9" Margin="0,0,0,4"
                                                       Visibility="{Binding RestitutionStatusMessage, Converter={StaticResource StringNotWS}}"/>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="← Retour Synthèse" Command="{Binding SwitchToSynthesisCommand}"
                                                Padding="10,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                                Background="#ECF0F1" Foreground="#2C3E50" BorderThickness="1" BorderBrush="#BDC3C7">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Content="✨ Générer Document" Command="{Binding GenerateRestitutionCommand}"
                                                Padding="12,7" Cursor="Hand" FontSize="11"
                                                Background="#E67E22" Foreground="White" BorderThickness="0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#CA6F1E"/></Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#95A5A6"/></Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsGeneratingRestitution}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- ── PANEL RÉVISION (après génération IA) ── -->
                                <Grid Visibility="{Binding IsRestitutionReviewMode, Converter={StaticResource BoolToVis}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0,0,0,12">

                                            <TextBlock Text="✏️ Vérification avant impression" FontWeight="Bold" FontSize="15"
                                                       Foreground="#2980B9" Margin="0,0,0,4"/>
                                            <TextBlock Text="Relisez et modifiez si besoin — un élément par ligne pour les forces et défis."
                                                       FontSize="11" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                            <!-- Intro -->
                                            <TextBlock Text="Introduction :" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding ReviewIntro, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True" Height="60" Padding="8" TextWrapping="Wrap"
                                                     FontSize="11" VerticalScrollBarVisibility="Auto"
                                                     Background="#EBF5FB" BorderBrush="#85C1E9" BorderThickness="1"
                                                     Margin="0,0,0,14"/>

                                            <!-- Motif -->
                                            <TextBlock Text="Motif de consultation :" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding ReviewMotif, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True" Height="60" Padding="8" TextWrapping="Wrap"
                                                     FontSize="11" VerticalScrollBarVisibility="Auto"
                                                     Background="#EBF5FB" BorderBrush="#85C1E9" BorderThickness="1"
                                                     Margin="0,0,0,14"/>

                                            <!-- Forces -->
                                            <Border Background="#F0FBF8" BorderBrush="#2DC5A2" BorderThickness="0,0,0,2"
                                                    CornerRadius="6" Padding="10" Margin="0,0,0,14">
                                                <StackPanel>
                                                    <TextBlock Text="Ce qui fait sa force" FontWeight="Bold" FontSize="12"
                                                               Foreground="#1A9E82" Margin="0,0,0,6"/>
                                                    <TextBlock Text="(un point par ligne)" FontSize="10" Foreground="#7A8899" Margin="0,0,0,5"/>
                                                    <TextBox Text="{Binding ReviewForces, UpdateSourceTrigger=PropertyChanged}"
                                                             AcceptsReturn="True" Height="70" Padding="8" TextWrapping="Wrap"
                                                             FontSize="11" VerticalScrollBarVisibility="Auto"
                                                             Background="White" BorderBrush="#B2DFD8" BorderThickness="1"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Défis -->
                                            <Border Background="#FEF6F0" BorderBrush="#E8834A" BorderThickness="0,0,0,2"
                                                    CornerRadius="6" Padding="10" Margin="0,0,0,14">
                                                <StackPanel>
                                                    <TextBlock Text="Ce que nous allons soutenir" FontWeight="Bold" FontSize="12"
                                                               Foreground="#C4622A" Margin="0,0,0,6"/>
                                                    <TextBlock Text="(un point par ligne)" FontSize="10" Foreground="#7A8899" Margin="0,0,0,5"/>
                                                    <TextBox Text="{Binding ReviewDefis, UpdateSourceTrigger=PropertyChanged}"
                                                             AcceptsReturn="True" Height="70" Padding="8" TextWrapping="Wrap"
                                                             FontSize="11" VerticalScrollBarVisibility="Auto"
                                                             Background="White" BorderBrush="#F0C0A0" BorderThickness="1"/>
                                                </StackPanel>
                                            </Border>

                                            <TextBlock Text="{Binding RestitutionStatusMessage}" FontSize="11" TextWrapping="Wrap"
                                                       Foreground="#2980B9" Margin="0,0,0,4"
                                                       Visibility="{Binding RestitutionStatusMessage, Converter={StaticResource StringNotWS}}"/>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="← Modifier" Command="{Binding BackToRestitutionFormCommand}"
                                                Padding="10,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                                Background="#ECF0F1" Foreground="#2C3E50" BorderThickness="1" BorderBrush="#BDC3C7">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Content="💾 Sauvegarder PDF" Command="{Binding ConfirmRestitutionCommand}"
                                                Padding="12,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                                Background="#2980B9" Foreground="White" BorderThickness="0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1F618D"/></Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#95A5A6"/></Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsGeneratingRestitution}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="🖨 Ouvrir / Imprimer" Command="{Binding OpenRestitutionCommand}"
                                                Padding="12,7" Cursor="Hand" FontSize="11"
                                                Background="#27AE60" Foreground="White" BorderThickness="0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#219653"/></Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#95A5A6"/></Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <!-- V1 : DOSSIER RESTITUTION CLINIQUE -->
                            <Grid Grid.Row="1">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDossierRestitutionCliniqueMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <ContentControl Content="{Binding RestitutionEditor}">
                                    <ContentControl.Resources>
                                        <DataTemplate DataType="{x:Type vmrest:RestitutionEditorViewModel}">
                                            <viewrest:RestitutionEditorView />
                                        </DataTemplate>
                                    </ContentControl.Resources>
                                </ContentControl>
                            </Grid>

                            <!-- MODE CONSULTATION DE SUIVI -->
                            <Grid Grid.Row="1">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSuiviMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,0,0,12">

                                        <TextBlock Text="🔄 Consultation de suivi" FontWeight="Bold" FontSize="15"
                                                   Foreground="#16A085" Margin="0,0,0,4"/>
                                        <TextBlock Text="Cochez ce qui s'applique. Dictez seulement s'il y a un élément à noter."
                                                   FontSize="11" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,0,0,14"/>

                                        <!-- Cases rapides -->
                                        <Border Background="#E8F8F5" BorderBrush="#1ABC9C" BorderThickness="1"
                                                CornerRadius="6" Padding="14" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Text="COCHES RAPIDES" FontWeight="Bold" FontSize="11"
                                                           Foreground="#0E6655" Margin="0,0,0,10"/>

                                                <CheckBox Content="✅ RAS / Va bien  (exclusif — ignore le reste)"
                                                          IsChecked="{Binding Suivi.RAS}"
                                                          FontWeight="SemiBold" Foreground="#0E6655" FontSize="12" Margin="0,0,0,10"/>

                                                <StackPanel>
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="IsEnabled" Value="True"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Suivi.RAS}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <CheckBox Content="Renouvellement du traitement" IsChecked="{Binding Suivi.Renouvellement}" FontSize="12" Margin="0,0,0,5"/>
                                                    <CheckBox Content="Pas d'effets secondaires" IsChecked="{Binding Suivi.PasEffetsSecondaires}" FontSize="12" Margin="0,0,0,5"/>
                                                    <CheckBox Content="Adhésion thérapeutique satisfaisante" IsChecked="{Binding Suivi.AdhesionOk}" FontSize="12" Margin="0,0,0,5"/>
                                                    <CheckBox Content="Évolution scolaire favorable" IsChecked="{Binding Suivi.EvolutionScolaire}" FontSize="12" Margin="0,0,0,5"/>
                                                    <CheckBox Content="Sommeil correct" IsChecked="{Binding Suivi.SommeilCorrect}" FontSize="12" Margin="0,0,0,5"/>
                                                    <CheckBox Content="À revoir dans 1 mois" IsChecked="{Binding Suivi.ARevoir}" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Transcription -->
                                        <StackPanel Margin="0,0,0,12">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="IsEnabled" Value="True"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Suivi.RAS}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <TextBlock Text="TRANSCRIPTION (si éléments à noter)" FontWeight="Bold" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding Suivi.Transcription, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True" Height="110" Padding="8" TextWrapping="Wrap"
                                                     FontSize="11" VerticalScrollBarVisibility="Auto"
                                                     Background="#FAFAFA" BorderBrush="#BDC3C7" BorderThickness="1"/>

                                            <!-- Indicateurs d'enregistrement (visibles seulement quand le mic tourne) -->
                                            <Grid Margin="0,8,0,0"
                                                  Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Ligne 1 : niveau micro -->
                                                <Grid Grid.Row="0" Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="🎤" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <ProgressBar Grid.Column="1" Height="8" Minimum="0" Maximum="100"
                                                                 Value="{Binding MicLevelPct}" Foreground="#27AE60"
                                                                 Background="#DDEEDD" BorderThickness="0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding ExtractionStatus}"
                                                               FontSize="11" Foreground="#2C6E49" VerticalAlignment="Center"
                                                               Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                                </Grid>

                                                <!-- Ligne 2 : progression batch -->
                                                <Grid Grid.Row="1"
                                                      Visibility="{Binding UseBatchMode, Converter={StaticResource BoolToVis}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ProgressBar Grid.Column="0" Height="10" Minimum="0" Maximum="100"
                                                                 Value="{Binding BatchProgressPct}" Foreground="#27AE60"
                                                                 Background="#DDEEDD" BorderThickness="0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding BatchProgressPct, StringFormat='{}{0}s / 90s'}"
                                                               FontSize="10" Foreground="#558B2F"
                                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </Grid>
                                            </Grid>

                                            <!-- Barre boutons dictée / import / IA -->
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <!-- Dicter (visible si pas en cours d'enregistrement) -->
                                                <Button Content="🎙 Dicter"
                                                        Command="{Binding StartRecordingCommand}"
                                                        Padding="12,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                                        Background="#27AE60" Foreground="White" BorderThickness="0"
                                                        Visibility="{Binding IsNotRecording, Converter={StaticResource BoolToVis}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#219A52"/></Trigger>
                                                                <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Background" Value="#BDC3C7"/></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Pause (visible si enregistrement actif) — déclenche l'extraction IA automatique en mode Suivi -->
                                                <Button Content="⏸ Pause"
                                                        Command="{Binding StopRecordingCommand}"
                                                        ToolTip="Met la dictée en pause et extrait automatiquement les puces cliniques"
                                                        Padding="12,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                                        Background="#F39C12" Foreground="White" BorderThickness="0"
                                                        Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#D68910"/></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Importer .txt -->
                                                <Button x:Name="ImportSuiviTxtBtn" Content="📂 Importer .txt"
                                                        Click="ImportSuiviTxtBtn_Click"
                                                        Padding="12,7" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                                        Background="#ECF0F1" Foreground="#2C3E50" BorderThickness="1" BorderBrush="#BDC3C7">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Extraire IA -->
                                                <Button Content="✨ Extraire en puces compactes"
                                                        Command="{Binding ExtractSuiviCommand}"
                                                        Padding="12,7" Cursor="Hand" FontSize="11"
                                                        Background="#3498DB" Foreground="White" BorderThickness="0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#2980B9"/></Trigger>
                                                                <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Background" Value="#95A5A6"/></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Aperçu IA -->
                                        <Border Background="#EBF5FB" BorderBrush="#85C1E9" BorderThickness="1"
                                                CornerRadius="6" Padding="10" Margin="0,0,0,12"
                                                Visibility="{Binding Suivi.AIExtraction, Converter={StaticResource StringNotWS}}">
                                            <StackPanel>
                                                <TextBlock Text="EXTRACTION IA (modifiable)" FontWeight="Bold" FontSize="11"
                                                           Foreground="#2980B9" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding Suivi.AIExtraction, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True" Padding="6" TextWrapping="Wrap" FontSize="11"
                                                         Background="White" BorderBrush="#85C1E9" BorderThickness="1"
                                                         MinHeight="70"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Status -->
                                        <TextBlock Text="{Binding SuiviStatusMessage}" FontSize="11" TextWrapping="Wrap"
                                                   Foreground="#16A085" Margin="0,4,0,0"
                                                   Visibility="{Binding SuiviStatusMessage, Converter={StaticResource StringNotWS}}"/>
                                    </StackPanel>
                                </ScrollViewer>

                                <Button Grid.Row="1" Content="💾 Sauvegarder la note"
                                        Command="{Binding SaveSuiviCommand}"
                                        HorizontalAlignment="Right" Padding="14,8" Margin="0,8,0,0"
                                        Background="#16A085" Foreground="White" BorderThickness="0"
                                        FontSize="12" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#138D75"/></Trigger>
                                                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#95A5A6"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <!-- MODE INTERROGATOIRE — Extraction en cours -->
                            <Border Grid.Row="1" CornerRadius="8" Background="#EBF5FB" BorderBrush="#3498DB" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInExtractionMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRestitutionMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="⚙ Extraction en cours..." FontSize="16"
                                               Foreground="#2980B9" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Le LLM analyse la transcription..." FontSize="12"
                                               Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- MODE INTERROGATOIRE — Note finale -->
                            <Grid Grid.Row="1">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInFinalNoteMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Note finale — vérifiez et complétez :"
                                           FontSize="12" Foreground="#27AE60" FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>

                                <!-- V0c : Aperçu final — tous les blocs -->
                                <Border Grid.Row="2" Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="📋 Aperçu final — tous les blocs" FontSize="11" FontWeight="SemiBold" Foreground="#2E7D32" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding InterrogatoireBlocks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="60"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="10" Foreground="#1B5E20" FontWeight="SemiBold"/>
                                                        <ProgressBar Grid.Column="1" Height="8" Minimum="0" Maximum="100" Value="{Binding ProgressPct, Mode=OneWay}" Margin="10,0,10,0" Foreground="{Binding ProgressBarColor}" Background="#CCCCCC" BorderThickness="0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ProgressPct, StringFormat='{}{0}%'}" FontSize="10" Foreground="#558B2F" TextAlignment="Right"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Bandeau contrôle qualité -->
                                <Border Grid.Row="1" Margin="0,0,0,8"
                                        Visibility="{Binding HasQualityIssues, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <!-- En cours -->
                                        <TextBlock Text="⏳ Contrôle qualité en cours..."
                                                   FontSize="11" Foreground="#7F8C8D" FontStyle="Italic"
                                                   Margin="0,0,0,4"
                                                   Visibility="{Binding IsRunningQualityCheck, Converter={StaticResource BoolToVis}}"/>
                                        <!-- Liste des signalements -->
                                        <ItemsControl ItemsSource="{Binding QualityIssues}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FFF9E6" BorderBrush="#F39C12"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Margin="0,0,0,4" Padding="8,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding TypeIcon}" FontSize="12" Margin="0,0,5,0"/>
                                                                    <TextBlock Text="{Binding BlockTitle}" FontSize="11"
                                                                               FontWeight="SemiBold" Foreground="#7F8C8D"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                    <TextBlock Text="{Binding Original}" FontSize="12"
                                                                               Foreground="#E74C3C" TextDecorations="Strikethrough"/>
                                                                    <TextBlock Text=" → " FontSize="12" Foreground="#7F8C8D"/>
                                                                    <TextBlock Text="{Binding Suggestion}" FontSize="12"
                                                                               Foreground="#27AE60" FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Reason}" FontSize="10"
                                                                           Foreground="#95A5A6" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                        VerticalAlignment="Center" Margin="8,0,0,0">
                                                                <Button Content="✓ Appliquer"
                                                                        Command="{Binding AcceptCommand}"
                                                                        Padding="8,4" FontSize="11" Cursor="Hand"
                                                                        Background="#27AE60" Foreground="White"
                                                                        BorderThickness="0" Margin="0,0,4,0">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                                <Button Content="✕"
                                                                        Command="{Binding DismissCommand}"
                                                                        Width="24" Height="24" FontSize="11" Cursor="Hand"
                                                                        Background="#ECF0F1" Foreground="#7F8C8D"
                                                                        BorderThickness="0">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    CornerRadius="3" Padding="2">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <TextBox Grid.Row="3"
                                         Text="{Binding NoteContent, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="13"
                                         FontFamily="Consolas"
                                         Padding="10"
                                         BorderBrush="#27AE60"
                                         BorderThickness="1"
                                         Background="#FAFAFA">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="#FAFAFA"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="6">
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <StackPanel Grid.Row="4" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Margin="0,8,0,0">
                                    <Button Content="↩ Retour"
                                            Command="{Binding BackToSaisieCommand}"
                                            Padding="12,7" Background="#ECF0F1" BorderThickness="1"
                                            BorderBrush="#BDC3C7" Cursor="Hand" FontSize="12"
                                            Margin="0,0,8,0"/>
                                    <Button Content="💾 Sauvegarder dossier"
                                            Command="{Binding SaveInterrogatoireNoteCommand}"
                                            Padding="14,7" Background="#27AE60" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" FontSize="12">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#219A52"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#BDC3C7"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>

                        </Grid>

                        <!-- Actions rapides — mode normal uniquement -->
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,15,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInterrogatoireMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSuiviMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSynthesisMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEvaluationPhaseMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSyntheseGlobaleMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsProjetTherapeutiqueMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSelectingRestitutionTypeMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDossierRestitutionCliniqueMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRestitutionMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRestitutionReviewMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Button Content="Sauvegarder"
                                    Command="{Binding SaveNoteCommand}"
                                    Padding="15,8"
                                    Background="#27AE60"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#219A52"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Bd" Property="Background" Value="#BDC3C7"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Zone Med (1/4) -->
                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="8"
                        BorderBrush="#90CAF9"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.1" Color="#3498DB"/>
                    </Border.Effect>

                    <Grid>
                        <!-- Mode etendu -->
                        <Grid Visibility="{Binding IsMedExpanded, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header Med -->
                            <Border Grid.Row="0"
                                    Background="#E3F2FD"
                                    CornerRadius="8,8,0,0"
                                    Padding="12">
                                <Grid>
                                    <TextBlock Text="Med"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#1976D2"
                                               VerticalAlignment="Center"/>
                                    <Button Content="−"
                                            HorizontalAlignment="Right"
                                            Command="{Binding ToggleMedExpandedCommand}"
                                            ToolTip="Reduire"
                                            Width="24" Height="24"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#1976D2"
                                            Cursor="Hand"/>
                                </Grid>
                            </Border>

                            <!-- Mode switches -->
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="10">
                                <!-- Voix : toggle indépendant (n'affecte pas le panneau affiché) -->
                                <Button Command="{Binding ToggleMedVoiceCommand}"
                                        ToolTip="Voix de Med (on/off)">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MedModeButtonStyle}">
                                            <Setter Property="Content" Value="🔇"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMedVoiceOn}" Value="True">
                                                    <Setter Property="Content" Value="🔊"/>
                                                    <Setter Property="Background" Value="#E8F8F5"/>
                                                    <Setter Property="BorderBrush" Value="#16A085"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="💬"
                                        Command="{Binding SetMedSuggestionsCommand}"
                                        ToolTip="Suggestions">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MedModeButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMedSuggestions}" Value="True">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="📋"
                                        Command="{Binding SetMedChecklistCommand}"
                                        ToolTip="Checklist">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MedModeButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMedChecklist}" Value="True">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Contenu contextuel -->
                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          Margin="10,0,10,10">
                                <StackPanel>
                                    <!-- Bloc action globale : Documents du patient -->
                                    <Border Background="#EBF5FB" BorderBrush="#85C1E9" BorderThickness="1"
                                            CornerRadius="6" Padding="10" Margin="0,0,0,12"
                                            Visibility="{Binding IsMedSuggestions, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="📄 Documents du patient" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="#1F618D" Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="MedImportDocBtn" Content="📂 Importer"
                                                        Click="MedImportDocBtn_Click"
                                                        Padding="10,6" Background="#3498DB" Foreground="White"
                                                        BorderThickness="0" Cursor="Hand" FontSize="11" Margin="0,0,6,0"
                                                        ToolTip="Importer un bilan / document — l'IA le classera automatiquement">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#2980B9"/></Trigger>
                                                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#BDC3C7"/></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button x:Name="MedScannerBtn" Content="📷 Scanner"
                                                        Click="MedScannerBtn_Click"
                                                        Padding="10,6" Background="#16A085" Foreground="White"
                                                        BorderThickness="0" Cursor="Hand" FontSize="11"
                                                        ToolTip="Scanner un document avec un scanner connecté">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#138D75"/></Trigger>
                                                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#BDC3C7"/></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{Binding MedDocumentStatus}" FontSize="10"
                                                       Foreground="#5D6D7E" Margin="0,6,0,0" TextWrapping="Wrap"
                                                       Visibility="{Binding MedDocumentStatus, Converter={StaticResource StringNotWS}}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Bloc action globale : Restitutions générées -->
                                    <Border Background="#E8F8F5" BorderBrush="#76D7C4" BorderThickness="1"
                                            CornerRadius="6" Padding="10" Margin="0,0,0,12"
                                            Visibility="{Binding IsMedSuggestions, Converter={StaticResource BoolToVis}}">
                                        <StackPanel DataContext="{Binding RestitutionsHub}">
                                            <TextBlock Text="📁 Dossiers de Restitution" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="#117A65" Margin="0,0,0,8"/>
                                            <Button Command="{Binding CreateNewCommand}" Content="➕ Nouveau dossier"
                                                    Padding="10,6" Background="#1ABC9C" Foreground="White"
                                                    BorderThickness="0" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                                    ToolTip="Créer un nouveau Dossier de Restitution pour le patient">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#148F77"/></Trigger>
                                                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#BDC3C7"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- Liste des restitutions existantes -->
                                            <ItemsControl ItemsSource="{Binding Restitutions}" Margin="0,10,0,0"
                                                          Visibility="{Binding HasRestitutions, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="White" BorderBrush="#D1F2EB" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,6">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="📄" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold" Foreground="#117A65"/>
                                                                    <TextBlock Text="{Binding DateText}" FontSize="10" Foreground="#7F8C8D"/>
                                                                </StackPanel>
                                                                <Button Grid.Column="2" Command="{Binding OpenPdfCommand}" Content="PDF"
                                                                        Padding="6,2" Background="#E74C3C" Foreground="White" FontSize="9"
                                                                        BorderThickness="0" Cursor="Hand"
                                                                        Visibility="{Binding HasPdf, Converter={StaticResource BoolToVis}}">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="2" Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#C0392B"/></Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <TextBlock Text="Aucune restitution générée" FontSize="10" Foreground="#7F8C8D" Margin="0,5,0,0"
                                                       Visibility="{Binding HasNoRestitutions, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Mode Suggestions -->
                                    <ItemsControl ItemsSource="{Binding Suggestions}"
                                                  Visibility="{Binding IsMedSuggestions, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FAFAFA"
                                                        CornerRadius="6"
                                                        Padding="10"
                                                        Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock Text="{Binding Icon}" FontSize="14"/>
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"
                                                                       Foreground="#2C3E50"
                                                                       Margin="6,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Content}"
                                                                   FontSize="11"
                                                                   Foreground="#7F8C8D"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Mode Checklist -->
                                    <ItemsControl ItemsSource="{Binding ChecklistItems}"
                                                  Visibility="{Binding IsMedChecklist, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsChecked}"
                                                          Margin="0,4">
                                                    <TextBlock Text="{Binding Text}"
                                                               FontSize="12"
                                                               Foreground="#2C3E50"
                                                               TextWrapping="Wrap"/>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Mode Silencieux -->
                                    <TextBlock Text="Med est en mode silencieux. Appelez-le si besoin."
                                               FontSize="11"
                                               Foreground="#95A5A6"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Margin="0,20"
                                               Visibility="{Binding IsMedSilencieux, Converter={StaticResource BoolToVis}}"/>

                                    <!-- ── Blocs en cours (visibles UNIQUEMENT dans le mode Checklist 📋, pas en mode Suggestions 💬) -->
                                    <ItemsControl ItemsSource="{Binding ActiveBlocks}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsInterrogatoireMode}" Value="True"/>
                                                            <Condition Binding="{Binding IsMedChecklist}"     Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,6" CornerRadius="6"
                                                        BorderThickness="1" Padding="8">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FAFAFA"/>
                                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEmpty}" Value="False">
                                                                    <Setter Property="Background" Value="#F0FAF5"/>
                                                                    <Setter Property="BorderBrush" Value="#A8D5BC"/>
                                                                </DataTrigger>
                                                                <!-- Blocs déclencheurs (âge, motif) en violet -->
                                                                <DataTrigger Binding="{Binding Key}" Value="age">
                                                                    <Setter Property="Background" Value="#EDE7F6"/>
                                                                    <Setter Property="BorderBrush" Value="#B39DDB"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Key}" Value="motif">
                                                                    <Setter Property="Background" Value="#EDE7F6"/>
                                                                    <Setter Property="BorderBrush" Value="#B39DDB"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <!-- Titre + % -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Title}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#2C3E50"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ProgressPct, StringFormat='{}{0}%'}"
                                                                       FontSize="10"
                                                                       Foreground="#7F8C8D"/>
                                                        </Grid>
                                                        <!-- Barre de progression -->
                                                        <ProgressBar Height="5" Minimum="0" Maximum="100"
                                                                     Value="{Binding ProgressPct, Mode=OneWay}"
                                                                     Margin="0,4,0,0"
                                                                     Foreground="{Binding ProgressBarColor}"
                                                                     Background="#E0E0E0"
                                                                     BorderThickness="0"/>
                                                        <!-- Texte extrait -->
                                                        <TextBlock Text="{Binding FreeText}"
                                                                   FontSize="10"
                                                                   Foreground="#5D6D7E"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0"
                                                                   MaxHeight="60"
                                                                   TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEmpty}" Value="False">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- Mode reduit (barre laterale) -->
                        <Border Visibility="{Binding IsMedCollapsed, Converter={StaticResource BoolToVis}}">
                            <Button Content="Med"
                                    Command="{Binding ToggleMedExpandedCommand}"
                                    ToolTip="Developper Med"
                                    Background="#E3F2FD"
                                    Foreground="#1976D2"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Cursor="Hand">
                                <Button.LayoutTransform>
                                    <RotateTransform Angle="90"/>
                                </Button.LayoutTransform>
                            </Button>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- DOSSIER PATIENT SKEUOMORPHIQUE (Droite) -->
            <!-- Design: dossier papier francais avec intercalaires verticaux -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Grid.Column="2" ClipToBounds="False">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFocusTravail}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                    <!-- Contenu du dossier + Intercalaires dans la même cellule pour permettre le chevauchement -->
                    <Grid ClipToBounds="False">
                        <!-- COUVERTURE (fond bleu A4 Fermé) -->
                        <Grid Visibility="{Binding IsCouvertureActive, Converter={StaticResource BoolToVis}}">
                            <!-- MODE ECRAN PARTAGE (F2): Sans intercalaires internes -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Viewbox Stretch="Uniform">
                                    <Border Width="595" Height="842"
                                            Background="{StaticResource DossierBackgroundBrush}"
                                            CornerRadius="6,6,6,6"
                                            BorderBrush="{StaticResource DossierBorderBrush}"
                                            BorderThickness="2">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="5" BlurRadius="15" Opacity="0.25" Color="#2C3E50"/>
                                        </Border.Effect>
                                        <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                            <StackPanel Margin="25,40">
                                                <TextBlock Text="DOSSIER PATIENT" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" Margin="0,20,0,40"/>
                                                <TextBlock Text="Dr Lassoued" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,20"/>
                                                <Border BorderBrush="#B0FFFFFF" BorderThickness="1.5" Margin="0,0,0,20" Padding="12" Background="#30FFFFFF" CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="N° de Dossier :" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <TextBlock Text="{Binding CurrentPatient.NumeroDossier, TargetNullValue='Non attribué'}" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Nom :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Nom}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                    <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Prénom :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Prenom}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                    <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Date de naissance :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.DobFormatted}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                    <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                </Grid>
                                                <Grid Margin="0,20,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Date 1ère consultation :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.FirstConsultDate, FallbackValue='-'}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                    <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Viewbox>
                            </Grid>

                            <!-- MODE PLEIN ECRAN (F3): Avec intercalaires internes dans le Viewbox -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Viewbox Stretch="Uniform">
                                    <!-- Conteneur avec dossier + intercalaires -->
                                    <Grid Width="645" Height="842">
                                        <!-- Dossier fermé -->
                                        <Border Width="595" Height="842" HorizontalAlignment="Left"
                                                Background="{StaticResource DossierBackgroundBrush}"
                                                CornerRadius="6,0,0,6"
                                                BorderBrush="{StaticResource DossierBorderBrush}"
                                                BorderThickness="2,2,0,2">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="5" BlurRadius="15" Opacity="0.25" Color="#2C3E50"/>
                                            </Border.Effect>
                                            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                                <StackPanel Margin="25,40">
                                                    <TextBlock Text="DOSSIER PATIENT" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" Margin="0,20,0,40"/>
                                                    <TextBlock Text="Dr Lassoued" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,20"/>
                                                    <Border BorderBrush="#B0FFFFFF" BorderThickness="1.5" Margin="0,0,0,20" Padding="12" Background="#30FFFFFF" CornerRadius="4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="N° de Dossier :" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding CurrentPatient.NumeroDossier, TargetNullValue='Non attribué'}" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="Nom :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Nom}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                        <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="Prénom :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.Prenom}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                        <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="Date de naissance :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.DobFormatted}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                        <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                    </Grid>
                                                    <Grid Margin="0,20,0,10">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="Date 1ère consultation :" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,10,6"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPatient.FirstConsultDate, FallbackValue='-'}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                                        <Border Grid.ColumnSpan="2" BorderThickness="0,0,0,2" BorderBrush="#B0FFFFFF" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                                    </Grid>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>

                                        <!-- Intercalaires internes (collés au bord droit du dossier) -->
                                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="50" Margin="0,20">
                                            <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="Synthese" Content="SYNTHESE" Style="{StaticResource ViewboxTabStyle}" ToolTip="Synthese" Height="130"/>
                                            <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="Administratif" Content="ADMIN." Style="{StaticResource ViewboxTabStyle}" ToolTip="Administratif" Height="130"/>
                                            <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="Consultations" Content="CONSULT." Style="{StaticResource ViewboxTabStyle}" ToolTip="Consultations" Height="130"/>
                                            <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="ProjetTherapeutique" Content="PROJET" Style="{StaticResource ViewboxTabStyle}" ToolTip="Projet Therapeutique" Height="130"/>
                                            <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="Bilans" Content="BILANS" Style="{StaticResource ViewboxTabStyle}" ToolTip="Bilans" Height="130"/>
                                            <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="Documents" Content="DOCS" Style="{StaticResource ViewboxTabStyle}" ToolTip="Documents" Height="130"/>
                                        </StackPanel>
                                    </Grid>
                                </Viewbox>
                            </Grid>
                        </Grid>

                        <!-- SYNTHESE -->
                        <Grid Visibility="{Binding IsSyntheseActive, Converter={StaticResource BoolToVis}}">
                            <!-- MODE ECRAN PARTAGE (F2): Page unique -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Viewbox Stretch="Uniform">
                                    <Border Width="595" Height="842" Background="White" Effect="{StaticResource PageShadow}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Margin="40,40,40,20">
                                                <TextBlock Text="SYNTHESE" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                                <TextBlock Text="Vue d'ensemble du dossier" FontSize="14" Foreground="#7F8C8D"/>
                                            </StackPanel>
                                            <ScrollViewer Grid.Row="1" Margin="40,0,40,20" VerticalScrollBarVisibility="Auto">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,15">
                                                        <TextBlock Text="Synthese du patient" FontSize="18" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                                        <!-- Barre boutons édition -->
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                            <!-- Modifier (visible en lecture) -->
                                                            <Button Content="✏️ Modifier" Command="{Binding StartEditSynthesisCommand}"
                                                                    Padding="10,5" Background="#3498DB" Foreground="White" BorderThickness="0"
                                                                    Cursor="Hand" FontSize="11"
                                                                    Visibility="{Binding IsSynthesisNotEditing, Converter={StaticResource BoolToVis}}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                            <!-- Enregistrer + Annuler (visible en édition) -->
                                                            <StackPanel Orientation="Horizontal"
                                                                        Visibility="{Binding IsSynthesisEditing, Converter={StaticResource BoolToVis}}">
                                                                <Button Content="💾 Enregistrer" Command="{Binding SaveEditSynthesisCommand}"
                                                                        Padding="10,5" Background="#27AE60" Foreground="White" BorderThickness="0"
                                                                        Cursor="Hand" FontSize="11" Margin="0,0,6,0">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                                <Button Content="✖ Annuler" Command="{Binding CancelEditSynthesisCommand}"
                                                                        Padding="10,5" Background="#95A5A6" Foreground="White" BorderThickness="0"
                                                                        Cursor="Hand" FontSize="11">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Vue READ-ONLY : Markdown formaté -->
                                                    <RichTextBox helpers:RichTextBoxHelper.Document="{Binding PatientSynthesisDocument}"
                                                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                                                 FontSize="13" Foreground="#2C3E50">
                                                        <RichTextBox.Style>
                                                            <Style TargetType="RichTextBox">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding HasPatientSynthesis}"   Value="True"/>
                                                                            <Condition Binding="{Binding IsSynthesisNotEditing}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </RichTextBox.Style>
                                                    </RichTextBox>

                                                    <!-- Vue EDIT : TextBox éditable avec le Markdown brut -->
                                                    <TextBox Text="{Binding PatientSynthesisEditText, UpdateSourceTrigger=PropertyChanged}"
                                                             AcceptsReturn="True" TextWrapping="Wrap"
                                                             FontFamily="Consolas" FontSize="12" Padding="10"
                                                             Background="#FAFAFA" BorderBrush="#3498DB" BorderThickness="1"
                                                             MinHeight="400" VerticalScrollBarVisibility="Auto"
                                                             Visibility="{Binding IsSynthesisEditing, Converter={StaticResource BoolToVis}}"/>
                                                    <!-- Placeholder quand pas de synthèse -->
                                                    <TextBlock Text="Aucune synthèse pour ce patient. Cliquez sur Actualiser dans la barre de gauche pour la générer."
                                                               FontSize="14" Foreground="#7F8C8D" TextWrapping="Wrap" FontStyle="Italic"
                                                               Visibility="{Binding HasNoPatientSynthesis, Converter={StaticResource BoolToVis}}"/>

                                                    <!-- Blocs Synthèse Globale (versions validées) — TOUJOURS EN PREMIER (document de référence) -->
                                                    <ItemsControl ItemsSource="{Binding SyntheseGlobaleBlocks}" Margin="0,18,0,0"
                                                                  Visibility="{Binding HasSyntheseGlobaleBlocks, Converter={StaticResource BoolToVis}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#FBF6E3" BorderBrush="#D4AF37" BorderThickness="2"
                                                                        CornerRadius="6" Padding="14" Margin="0,0,0,12">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding TitreCard}" FontSize="14" FontWeight="SemiBold"
                                                                                   Foreground="#7D6608" Margin="0,0,0,10"/>
                                                                        <ItemsControl ItemsSource="{Binding Sections}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <StackPanel Margin="0,0,0,10">
                                                                                        <TextBlock Text="{Binding Titre}" FontSize="12" FontWeight="SemiBold"
                                                                                                   Foreground="#2C3E50" Margin="0,0,0,4"/>
                                                                                        <TextBlock Text="{Binding Contenu}" FontSize="12" Foreground="#34495E"
                                                                                                   TextWrapping="Wrap" Margin="6,0,0,0"/>
                                                                                    </StackPanel>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- Blocs Synthèse diagnostique (générés depuis les évaluations clôturées, ajoutés sous la synthèse manuelle) -->
                                                    <ItemsControl ItemsSource="{Binding DiagnosticSyntheseBlocks}" Margin="0,18,0,0"
                                                                  Visibility="{Binding HasDiagnosticSyntheseBlocks, Converter={StaticResource BoolToVis}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#F8F4FB" BorderBrush="#D8CCE8" BorderThickness="1"
                                                                        CornerRadius="6" Padding="14" Margin="0,0,0,12">
                                                                    <StackPanel>
                                                                        <!-- En-tête : icône + titre + date + badge certitude -->
                                                                        <Grid Margin="0,0,0,10">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                                <TextBlock Text="🧠" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                                <TextBlock Text="Bilan Final — " FontSize="14" FontWeight="SemiBold" Foreground="#4A2C6A" VerticalAlignment="Center"/>
                                                                                <TextBlock Text="{Binding DateClotureText}" FontSize="14" Foreground="#4A2C6A" VerticalAlignment="Center"/>
                                                                            </StackPanel>
                                                                            <Border Grid.Column="1" Background="{Binding CertitudeColor}" CornerRadius="10" Padding="8,3" VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding CertitudeLabel}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                                            </Border>
                                                                        </Grid>

                                                                        <!-- Diagnostics retenus -->
                                                                        <StackPanel Margin="0,0,0,8"
                                                                                    Visibility="{Binding HasDiagnosticsRetenus, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="Diagnostic(s) retenu(s)" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,4"/>
                                                                            <ItemsControl ItemsSource="{Binding DiagnosticsRetenus}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <TextBlock Text="{Binding StringFormat='• {0}'}" FontSize="12" Foreground="#34495E"
                                                                                                   TextWrapping="Wrap" Margin="6,0,0,2"/>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>

                                                                        <!-- Éléments en faveur -->
                                                                        <StackPanel Margin="0,0,0,8"
                                                                                    Visibility="{Binding HasElementsEnFaveur, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="Éléments cliniques en faveur" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,4"/>
                                                                            <ItemsControl ItemsSource="{Binding ElementsEnFaveur}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <TextBlock Text="{Binding StringFormat='• {0}'}" FontSize="12" Foreground="#34495E"
                                                                                                   TextWrapping="Wrap" Margin="6,0,0,2"/>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>

                                                                        <!-- Différentiels écartés -->
                                                                        <StackPanel Margin="0,0,0,8"
                                                                            Visibility="{Binding HasDiagnosticsEcartes, Converter={StaticResource BoolToVis}}">

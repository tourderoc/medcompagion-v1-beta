                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="1240" Height="842">
                                         <!-- Page GAUCHE -->
                                         <Border Width="590" Height="842" HorizontalAlignment="Left" Background="White" Effect="{StaticResource PageShadow}">
                                             <StackPanel Margin="40">
                                                  <TextBlock Text="DOCUMENTS" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                                                  <TextBlock Text="Pieces jointes" FontSize="16" Foreground="#7F8C8D"/>
                                             </StackPanel>
                                         </Border>

                                         <!-- Page DROITE -->
                                         <Border Width="590" Height="842" Margin="600,0,50,0" Background="White" Effect="{StaticResource PageShadow}">
                                             <Grid>
                                                 <Grid.RowDefinitions>
                                                     <RowDefinition Height="*"/>
                                                     <RowDefinition Height="Auto"/>
                                                 </Grid.RowDefinitions>
                                                 <ScrollViewer Grid.Row="0" Margin="40" VerticalScrollBarVisibility="Hidden">
                                                     <StackPanel>
                                                         <TextBlock Text="Documents" FontSize="18" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                                                         <TextBlock Text="Courriers, attestations, ordonnances..." FontSize="14" Foreground="#34495E" TextWrapping="Wrap"/>
                                                     </StackPanel>
                                                 </ScrollViewer>
                                                 <Button Grid.Row="1" Command="{Binding SelectDossierTabCommand}" CommandParameter="Couverture"
                                                         Content="Fermer le dossier" HorizontalAlignment="Center" Margin="0,0,0,30" Padding="20,10"
                                                         Background="{StaticResource DossierBackgroundBrush}" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                                                         <Button.Template>
                                                             <ControlTemplate TargetType="Button">
                                                                 <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                     <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                 </Border>

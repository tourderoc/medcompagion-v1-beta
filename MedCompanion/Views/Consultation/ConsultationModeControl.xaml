                            <Style TargetType="Button" BasedOn="{StaticResource VerticalTabStyle}">
                                <Setter Property="Content" Value="ADMIN."/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAdminActive}" Value="True">

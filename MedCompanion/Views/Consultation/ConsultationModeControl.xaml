                                <Setter Property="Content" Value="DOCS"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDocumentsActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>

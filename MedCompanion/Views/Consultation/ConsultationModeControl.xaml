        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- PANNEAU MODE URGENCE (Étape 4) — slide-in depuis la droite -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Width="520" HorizontalAlignment="Right"
                Background="White"
                Panel.ZIndex="100"
                Visibility="{Binding IsUrgenceEvaluationOpen, Converter={StaticResource BoolToVis}}">
            <Border.RenderTransform>
                <TranslateTransform X="520"/>
            </Border.RenderTransform>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsUrgenceEvaluationOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         From="520" To="0" Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ContentPresenter Content="{Binding CurrentUrgenceEvaluation}">
                <ContentPresenter.Resources>
                    <DataTemplate DataType="{x:Type vm:UrgenceEvaluationViewModel}">
                        <urgence:ModeUrgenceControl/>
                    </DataTemplate>
                </ContentPresenter.Resources>
            </ContentPresenter>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- DRAWER "PATIENTS RÉCENTS" (style Doctolib, bord gauche) -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->

        <!-- (a) Onglet d'accroche, toujours visible sur le bord gauche -->
        <Button Grid.Row="0" Grid.RowSpan="2"
                Command="{Binding ToggleRecentDrawerCommand}"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Width="28" Height="120"
                Background="#3498DB" Foreground="White" BorderThickness="0"
                Cursor="Hand" Panel.ZIndex="10"
                ToolTip="Patients récemment ouverts">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="TabBd" Background="{TemplateBinding Background}"
                            CornerRadius="0,8,8,0">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="👥" FontSize="14" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="P&#10;A&#10;T&#10;I&#10;E&#10;N&#10;T&#10;S"
                                       FontSize="9" FontWeight="Bold" Foreground="White"
                                       TextAlignment="Center" LineHeight="11"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBd" Property="Background" Value="#2980B9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- (b) Overlay semi-transparent (clic = ferme le drawer) -->
        <Button Grid.Row="0" Grid.RowSpan="2"
                Command="{Binding CloseRecentDrawerCommand}"
                Background="#80000000" BorderThickness="0"
                Visibility="{Binding IsRecentDrawerOpen, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="20" Cursor="Arrow">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- (c) Panneau drawer (slide-in depuis la gauche) -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Width="300" HorizontalAlignment="Left"
                Background="White" BorderBrush="#D6E2EC" BorderThickness="0,0,1,0"
                Panel.ZIndex="30"
                Visibility="{Binding IsRecentDrawerOpen, Converter={StaticResource BoolToVis}}">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="14" Opacity="0.25" Direction="0"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="DrawerTransform" X="-300"/>
            </Border.RenderTransform>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRecentDrawerOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         From="-300" To="0" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Entête drawer -->
                <Border Grid.Row="0" Background="#2C3E50" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Consultations récentes" Foreground="White"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="Cliquez pour ouvrir le dossier"
                                       Foreground="#BDC3C7" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CloseRecentDrawerCommand}"
                                Content="✖" Foreground="White" Background="Transparent"
                                BorderThickness="0" FontSize="14" Cursor="Hand"
                                Padding="6,2" ToolTip="Fermer"/>
                    </Grid>
                </Border>

                <!-- Liste des patients récents -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding RecentPatientsForDrawer}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectRecentPatientCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand" Margin="0" HorizontalContentAlignment="Stretch">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="RpBd" Background="White"
                                                        BorderBrush="#ECEFF1" BorderThickness="0,0,0,1"
                                                        Padding="14,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Avatar -->
                                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                                Background="{Binding AvatarBrush}" VerticalAlignment="Center" Margin="0,0,12,0">
                                                            <TextBlock Text="{Binding Initials}" Foreground="White"
                                                                       FontSize="13" FontWeight="Bold"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <!-- Texte -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding NomComplet}" FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#2C3E50" TextTrimming="CharacterEllipsis"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                <TextBlock Text="{Binding AgeDisplay}" FontSize="10" Foreground="#7F8C8D"/>
                                                                <TextBlock Text=" • " FontSize="10" Foreground="#BDC3C7"/>
                                                                <TextBlock Text="{Binding LastConsultDisplay}" FontSize="10" Foreground="#7F8C8D"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="RpBd" Property="Background" Value="#F4F8FB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Placeholder si liste vide -->
                        <TextBlock Text="Aucun dossier récemment ouvert."
                                   FontSize="12" FontStyle="Italic" Foreground="#95A5A6"
                                   Margin="16,20,16,16" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentPatientsForDrawer.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid> <!-- Close Root (179) -->
</UserControl>

                                                                            <TextBlock Grid.Column="0" Text="{Binding TitreCard}" FontSize="14" FontWeight="SemiBold" Foreground="#1E8449"/>
                                                                            <Border Grid.Column="1" Background="#E74C3C" CornerRadius="3" Padding="6,2"
                                                                                    Visibility="{Binding IsReevaluationPassee, Converter={StaticResource BoolToVis}}">
                                                                                <TextBlock Text="⚠ Réévaluation dépassée" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                                                            </Border>
                                                                        </Grid>

                                                                        <!-- Date réévaluation prévue + progression -->
                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                                                                    Visibility="{Binding HasReevaluation, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="📅 Réévaluation prévue :" FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                                            <TextBlock Text="{Binding DateReevaluationText, StringFormat=' {0}'}" FontSize="11" Foreground="#34495E" Margin="3,0,0,0"/>
                                                                        </StackPanel>

                                                                        <!-- Progression -->
                                                                        <StackPanel Margin="0,0,0,12">
                                                                            <TextBlock Text="Progression des actions" FontSize="10" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                                                                            <Grid Margin="0,2,0,0" Height="14">
                                                                                <Rectangle Fill="#E5E8EC" RadiusX="3" RadiusY="3"/>
                                                                                <Rectangle Fill="#27AE60" RadiusX="3" RadiusY="3"
                                                                                           HorizontalAlignment="Left">
                                                                                    <Rectangle.Width>
                                                                                        <MultiBinding StringFormat="{}0">
                                                                                            <Binding Path="ProgressionPct"/>
                                                                                        </MultiBinding>
                                                                                    </Rectangle.Width>
                                                                                </Rectangle>
                                                                            </Grid>
                                                                            <TextBlock FontSize="10" Foreground="#7F8C8D" Margin="0,2,0,0">
                                                                                <Run Text="{Binding ProgressionPct, Mode=OneWay}"/>
                                                                                <Run Text="% fait · "/>
                                                                                <Run Text="{Binding NbActionsAVenir, Mode=OneWay}"/>
                                                                                <Run Text=" ⚪  "/>
                                                                                <Run Text="{Binding NbActionsEnCours, Mode=OneWay}"/>
                                                                                <Run Text=" 🟡  "/>
                                                                                <Run Text="{Binding NbActionsFaites, Mode=OneWay}"/>
                                                                                <Run Text=" ✅  "/>
                                                                                <Run Text="{Binding NbActionsAbandon, Mode=OneWay}"/>
                                                                                <Run Text=" ⛔"/>
                                                                            </TextBlock>
                                                                        </StackPanel>

                                                                        <!-- Objectifs prioritaires -->
                                                                        <StackPanel Margin="0,0,0,10"
                                                                                    Visibility="{Binding HasObjectifs, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="🎯 Objectifs prioritaires" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                                            <TextBlock Text="{Binding ObjectifsPrioritaires}" FontSize="11" Foreground="#34495E" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                                        </StackPanel>

                                                                        <!-- 4 sections d'actions -->
                                                                        <ItemsControl ItemsSource="{Binding Sections}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <StackPanel Margin="0,0,0,10">
                                                                                        <TextBlock Text="{Binding Titre}" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,4"/>
                                                                                        <ItemsControl ItemsSource="{Binding Actions}">
                                                                                            <ItemsControl.ItemTemplate>
                                                                                                <DataTemplate>
                                                                                                    <Grid Margin="0,0,0,4">
                                                                                                        <Grid.ColumnDefinitions>
                                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                                            <ColumnDefinition Width="*"/>
                                                                                                        </Grid.ColumnDefinitions>
                                                                                                        <TextBlock Grid.Column="0" Text="{Binding StatutIcon}" FontSize="12" Margin="0,0,6,0"/>
                                                                                                        <StackPanel Grid.Column="1">
                                                                                                            <TextBlock Text="{Binding Libelle}" FontSize="11" FontWeight="SemiBold" Foreground="#34495E" TextWrapping="Wrap"/>
                                                                                                            <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#7F8C8D" TextWrapping="Wrap"
                                                                                                                       Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}"/>
                                                                                                            <TextBlock Text="{Binding IndicateurReussite, StringFormat='📈 {0}'}" FontSize="10" FontStyle="Italic" Foreground="#16A085" TextWrapping="Wrap"
                                                                                                                       Visibility="{Binding HasIndicateur, Converter={StaticResource BoolToVis}}"/>
                                                                                                        </StackPanel>
                                                                                                    </Grid>
                                                                                                </DataTemplate>
                                                                                            </ItemsControl.ItemTemplate>
                                                                                        </ItemsControl>
                                                                                    </StackPanel>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>

                                                                        <!-- Ressources -->
                                                                        <StackPanel Margin="0,0,0,10"
                                                                                    Visibility="{Binding HasRessources, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="💪 Ressources à soutenir" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                                            <TextBlock Text="{Binding RessourcesASoutenir}" FontSize="11" Foreground="#34495E" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                                        </StackPanel>

                                                                        <!-- Réévaluation checklist -->
                                                                        <StackPanel Margin="0,0,0,10"
                                                                                    Visibility="{Binding HasReevaluation, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="📅 Réévaluation prévue — checklist" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                                            <TextBlock Text="{Binding ReevaluationChecklist}" FontSize="11" Foreground="#34495E" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                                        </StackPanel>

                                                                        <!-- Co-construction famille -->
                                                                        <Border Background="#F4F8FB" BorderBrush="#2980B9" BorderThickness="1" CornerRadius="4" Padding="8"
                                                                                Visibility="{Binding HasCoConstruction, Converter={StaticResource BoolToVis}}">
                                                                            <StackPanel>
                                                                                <TextBlock Text="👨‍👩‍👧 Co-construction avec la famille" FontSize="11" FontWeight="SemiBold" Foreground="#1F618D"/>
                                                                                <TextBlock Text="{Binding CoConstructionFamille}" FontSize="11" Foreground="#34495E" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </ScrollViewer>
                                            <Button Grid.Row="2" Command="{Binding SelectDossierTabCommand}" CommandParameter="Couverture"
                                                    Content="Fermer le dossier" HorizontalAlignment="Center" Margin="0,0,0,30" Padding="20,10"
                                                    Background="{StaticResource DossierBackgroundBrush}" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Viewbox>
                            </Grid>

                            <!-- MODE PLEIN ECRAN (F3): Double page avec intercalaires -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="1240" Height="842">
                                         <!-- Page GAUCHE -->
                                         <Border Width="590" Height="842" HorizontalAlignment="Left" Background="White" Effect="{StaticResource PageShadow}">
                                             <StackPanel Margin="40">
                                                  <TextBlock Text="PROJET THERAPEUTIQUE" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                                                  <TextBlock Text="Objectifs et suivis" FontSize="16" Foreground="#7F8C8D"/>
                                             </StackPanel>
                                         </Border>

                                         <!-- Page DROITE -->
                                         <Border Width="590" Height="842" Margin="600,0,50,0" Background="White" Effect="{StaticResource PageShadow}">
                                             <Grid>
                                                 <Grid.RowDefinitions>
                                                     <RowDefinition Height="*"/>
                                                     <RowDefinition Height="Auto"/>
                                                 </Grid.RowDefinitions>
                                                 <ScrollViewer Grid.Row="0" Margin="40" VerticalScrollBarVisibility="Hidden">
                                                     <StackPanel>
                                                         <TextBlock Text="Projet therapeutique" FontSize="18" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                                                         <TextBlock Text="Objectifs, strategies et suivis..." FontSize="14" Foreground="#34495E" TextWrapping="Wrap"/>
                                                     </StackPanel>
                                                 </ScrollViewer>
                                                 <Button Grid.Row="1" Command="{Binding SelectDossierTabCommand}" CommandParameter="Couverture"
                                                         Content="Fermer le dossier" HorizontalAlignment="Center" Margin="0,0,0,30" Padding="20,10"
                                                         Background="{StaticResource DossierBackgroundBrush}" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                                                         <Button.Template>
                                                             <ControlTemplate TargetType="Button">
                                                                 <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                     <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                 </Border>
                                                             </ControlTemplate>
                                                         </Button.Template>
                                                 </Button>
                                             </Grid>
                                         </Border>

                                         <!-- Intercalaires internes (collés au bord droit) -->
                                         <StackPanel HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="50" Margin="0,20">
                                             <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="Synthese" Content="SYNTHESE" Style="{StaticResource ViewboxTabStyle}" ToolTip="Synthese" Height="130"/>
                                             <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="Administratif" Content="ADMIN." Style="{StaticResource ViewboxTabStyle}" ToolTip="Administratif" Height="130"/>
                                             <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="Consultations" Content="CONSULT." Style="{StaticResource ViewboxTabStyle}" ToolTip="Consultations" Height="130"/>
                                             <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="ProjetTherapeutique" Content="PROJET" ToolTip="Projet Therapeutique" Height="130">
                                                 <Button.Style>
                                                     <Style TargetType="Button" BasedOn="{StaticResource ViewboxTabStyle}">
                                                         <Setter Property="Background" Value="{StaticResource TabActiveBrush}"/>
                                                         <Setter Property="Foreground" Value="#2C5A6A"/>
                                                         <Setter Property="FontWeight" Value="Bold"/>
                                                     </Style>
                                                 </Button.Style>
                                             </Button>
                                             <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="Bilans" Content="BILANS" Style="{StaticResource ViewboxTabStyle}" ToolTip="Bilans" Height="130"/>
                                             <Button Command="{Binding SelectDossierTabCommand}" CommandParameter="Documents" Content="DOCS" Style="{StaticResource ViewboxTabStyle}" ToolTip="Documents" Height="130"/>
                                         </StackPanel>
                                    </Grid>
                                </Viewbox>
                            </Grid>
                        </Grid>

                        <!-- BILANS -->
                        <Grid Visibility="{Binding IsBilansActive, Converter={StaticResource BoolToVis}}">
                            <!-- MODE ECRAN PARTAGE (F2): Page unique -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFocusDossier}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Viewbox Stretch="Uniform">
                                    <Border Width="595" Height="842" Background="White" Effect="{StaticResource PageShadow}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Margin="40,40,40,20">
                                                <TextBlock Text="BILANS" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                                <TextBlock Text="Evaluations et tests" FontSize="14" Foreground="#7F8C8D"/>
                                            </StackPanel>
                                            <ScrollViewer Grid.Row="1" Margin="40,0,40,20" VerticalScrollBarVisibility="Auto">
                                                <StackPanel>
                                                    <TextBlock Text="Bilans et évaluations du patient" FontSize="18" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                                                    <!-- Liste verticale de cartes — clic ouvre la fenêtre de détail/édition -->
                                                    <ItemsControl ItemsSource="{Binding PatientBilans}"
                                                                  Visibility="{Binding HasPatientBilans, Converter={StaticResource BoolToVis}}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Vertical"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,10">
                                                                    <Button Command="{Binding DataContext.OpenDocumentDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Cursor="Hand" HorizontalContentAlignment="Stretch">
                                                                        <Button.Template>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="Bd"
                                                                                        Background="White" BorderBrush="#D6E2EC" BorderThickness="1"
                                                                                        CornerRadius="8" Padding="14">
                                                                                    <StackPanel>
                                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                                                            <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                                            <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                                                            <TextBlock Text="{Binding DateFormatted}" FontSize="11" Foreground="#7F8C8D" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                                                                        </StackPanel>
                                                                                        <TextBlock Text="{Binding PreviewText}" FontSize="11" Foreground="#5D6D7E" TextWrapping="Wrap" TextTrimming="WordEllipsis" MaxHeight="40" Margin="0,0,40,0"/>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="#F4F8FB"/>
                                                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#3498DB"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Button.Template>
                                                                    </Button>
                                                                    <!-- Bouton PDF (ouvre le fichier original) — superposé en haut à droite -->
                                                                    <Button Command="{Binding DataContext.OpenPdfFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip="Ouvrir le PDF original"
                                                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                            Margin="0,8,10,0" Padding="6,3" Cursor="Hand"
                                                                            Background="#E74C3C" Foreground="White" FontSize="10" FontWeight="Bold"
                                                                            BorderThickness="0">
                                                                        <Button.Template>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="PdfBd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                                    <TextBlock Text="📕 PDF" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="PdfBd" Property="Background" Value="#C0392B"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Button.Template>
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <!-- Placeholder quand pas de bilans ET pas de cartographies -->
                                                    <TextBlock FontSize="14" Foreground="#7F8C8D" TextWrapping="Wrap" FontStyle="Italic"
                                                               Text="Aucun bilan importé pour ce patient. Utilisez 📄 Documents dans la zone Med pour en ajouter.">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding HasNoPatientBilans}"                  Value="True"/>
                                                                            <Condition Binding="{Binding HasCartographieBilans}"               Value="False"/>
                                                                            <Condition Binding="{Binding HasCartographieEnvironnementBilans}"  Value="False"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Cartographies de l'environnement (étape 5 des évaluations clôturées) -->
                                                    <ItemsControl ItemsSource="{Binding CartographieEnvironnementBilans}" Margin="0,18,0,0"
                                                                  Visibility="{Binding HasCartographieEnvironnementBilans, Converter={StaticResource BoolToVis}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#EFF6FB" BorderBrush="#C4D9E8" BorderThickness="1"
                                                                        CornerRadius="6" Padding="14" Margin="0,0,0,12">
                                                                    <StackPanel>
                                                                        <Grid Margin="0,0,0,10">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="{Binding TitreCard}" FontSize="14" FontWeight="SemiBold" Foreground="#1F618D"/>
                                                                            <Border Grid.Column="1" CornerRadius="10" Padding="10,3"
                                                                                    Background="{Binding SyntheseColor, Converter={StaticResource StringToBrush}}">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <TextBlock Text="Synthèse : " FontSize="11" Foreground="White"/>
                                                                                    <TextBlock Text="{Binding SyntheseLabel}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </Grid>

                                                                        <!-- 5 lignes feuilles avec badge couleur + lecture Med par feuille -->
                                                                        <ItemsControl ItemsSource="{Binding Feuilles}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <StackPanel Margin="0,0,0,10">
                                                                                        <Grid>
                                                                                            <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="*"/>
                                                                                                <ColumnDefinition Width="Auto"/>
                                                                                            </Grid.ColumnDefinitions>
                                                                                            <StackPanel Grid.Column="0">
                                                                                                <TextBlock Text="{Binding Label}"     FontSize="12" Foreground="#34495E"/>
                                                                                                <TextBlock Text="{Binding SousTitre}" FontSize="10" FontStyle="Italic" Foreground="#7F8C8D"/>
                                                                                            </StackPanel>
                                                                                            <Border Grid.Column="1" CornerRadius="10" Padding="8,2" VerticalAlignment="Center"
                                                                                                    Background="{Binding NiveauColor, Converter={StaticResource StringToBrush}}">
                                                                                                <TextBlock Text="{Binding NiveauLabel}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                                                            </Border>
                                                                                        </Grid>
                                                                                        <!-- Lecture Med de la feuille (V0.3) -->
                                                                                        <Border Background="#FBFCFD" BorderBrush="#D6E2EC" BorderThickness="0,0,0,0"
                                                                                                Margin="0,4,0,0" Padding="8,4"
                                                                                                Visibility="{Binding HasLecture, Converter={StaticResource BoolToVis}}">
                                                                                            <StackPanel>
                                                                                                <TextBlock Text="📝 Lecture Med" FontSize="10" FontWeight="SemiBold" Foreground="#16A085" Margin="0,0,0,2"/>
                                                                                                <TextBlock Text="{Binding LectureMed}" FontSize="11" Foreground="#566573" TextWrapping="Wrap" FontStyle="Italic"/>
                                                                                            </StackPanel>
                                                                                        </Border>
                                                                                    </StackPanel>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>

                                                                        <!-- Lecture globale de la branche (V0.4) -->
                                                                        <Border Background="#EAF8F5" BorderBrush="#16A085" BorderThickness="1" CornerRadius="4"
                                                                                Margin="0,10,0,0" Padding="10"
                                                                                Visibility="{Binding HasLectureBranche, Converter={StaticResource BoolToVis}}">
                                                                            <StackPanel>
                                                                                <TextBlock Text="🌳 Lecture globale de la branche" FontSize="11" FontWeight="SemiBold" Foreground="#117864" Margin="0,0,0,4"/>
                                                                                <TextBlock Text="{Binding LectureBrancheMed}" FontSize="11" Foreground="#2C3E50" TextWrapping="Wrap"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- Cartographies de l'enfant (étape 4 des évaluations clôturées) -->
                                                    <ItemsControl ItemsSource="{Binding CartographieBilans}" Margin="0,18,0,0"
                                                                  Visibility="{Binding HasCartographieBilans, Converter={StaticResource BoolToVis}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#F8F4FB" BorderBrush="#D8CCE8" BorderThickness="1"
                                                                        CornerRadius="6" Padding="14" Margin="0,0,0,12">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding TitreCard}" FontSize="14" FontWeight="SemiBold" Foreground="#4A2C6A" Margin="0,0,0,10"/>

                                                                        <!-- 6 lignes segments avec badge couleur -->
                                                                        <ItemsControl ItemsSource="{Binding Segments}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <Grid Margin="0,0,0,4">
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" Foreground="#34495E" VerticalAlignment="Center"/>
                                                                                        <Border Grid.Column="1" CornerRadius="10" Padding="8,2"
                                                                                                Background="{Binding NiveauColor, Converter={StaticResource StringToBrush}}"
                                                                                                Visibility="{Binding HasNiveau, Converter={StaticResource BoolToVis}}">
                                                                                            <StackPanel Orientation="Horizontal">
                                                                                                <TextBlock Text="{Binding Score}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                                                                <TextBlock Text="/6 — " FontSize="11" Foreground="White"/>
                                                                                                <TextBlock Text="{Binding NiveauLabel}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                                                            </StackPanel>
                                                                                        </Border>
                                                                                    </Grid>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>

                                                                        <!-- Tempérament : 6 lignes de profil -->
                                                                        <StackPanel Margin="0,10,0,0"
                                                                                    Visibility="{Binding HasTemperament, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="Tempérament" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,4"/>
                                                                            <ItemsControl ItemsSource="{Binding TemperamentLignes}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <Grid Margin="0,0,0,2">
                                                                                            <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="*"/>
                                                                                                <ColumnDefinition Width="Auto"/>
                                                                                            </Grid.ColumnDefinitions>
                                                                                            <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11" Foreground="#566573"/>
                                                                                            <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50">
                                                                                                <Run Text="{Binding Value, Mode=OneWay}"/><Run Text="/5"/>
                                                                                            </TextBlock>
                                                                                        </Grid>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </ScrollViewer>
                                            <Button Grid.Row="2" Command="{Binding SelectDossierTabCommand}" CommandParameter="Couverture"
                                                    Content="Fermer le dossier" HorizontalAlignment="Center" Margin="0,0,0,30" Padding="20,10"
                                                    Background="{StaticResource DossierBackgroundBrush}" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Viewbox>
                            </Grid>

                            <!-- MODE PLEIN ECRAN (F3): Double page avec intercalaires -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">

<UserControl x:Class="MedCompanion.Views.Consultation.SyntheseGlobale.SyntheseGlobaleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MedCompanion.Converters"
             Background="#FAFBFC">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter             x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter      x:Key="InverseBoolToVis"/>
        <converters:StringNotWhiteSpaceToVisibilityConverter x:Key="StringNotWhiteSpaceToVis"/>
        <converters:StringToBrushConverter                   x:Key="StringToBrush"/>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="#D4AF37" BorderThickness="2" CornerRadius="8" Margin="10" Padding="16">
        <DockPanel>
            <!-- En-tête : titre + statut + boutons -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TitreVue}" FontSize="14" FontWeight="Bold" Foreground="#7D6608"/>
                    <TextBlock Text="{Binding StatutLabel}" FontSize="11" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- ✨ Proposer (Med) : visible si v1 (génération initiale) -->
                    <Button Padding="10,5" Margin="0,0,6,0"
                            Command="{Binding ProposerCommand}"
                            ToolTip="Med lit le dossier complet et propose une v1. REMPLACE le contenu.">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="✨ Proposer (Med)"/>
                                <Setter Property="Background" Value="#8E44AD"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProposerVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsModePatch}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsProposerEnCours}" Value="True">
                                        <Setter Property="Content" Value="⏳ Med..."/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 🔄 Patch (Med) : visible si v > 1 (mode incrémental) -->
                    <Button Padding="10,5" Margin="0,0,6,0"
                            Command="{Binding PatchCommand}"
                            ToolTip="Med propose un patch des sections impactées par les nouveaux éléments. Conserve ce qui ne change pas.">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="🔄 Patch (Med)"/>
                                <Setter Property="Background" Value="#16A085"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModePatch}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsProposerEnCours}" Value="True">
                                        <Setter Property="Content" Value="⏳ Med..."/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 🔍 Relire (Med) : détection contradictions + hallucinations -->
                    <Button Padding="10,5" Margin="0,0,6,0"
                            Command="{Binding RelireCommand}"
                            Visibility="{Binding RelireVisible, Converter={StaticResource BoolToVis}}"
                            ToolTip="Med relit la synthèse pour détecter contradictions, affirmations non sourcées et sections incomplètes. Obligatoire avant validation.">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="🔍 Relire (Med)"/>
                                <Setter Property="Background" Value="#2980B9"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelectureFaite}" Value="True">
                                        <Setter Property="Content" Value="🔄 Re-relire"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsProposerEnCours}" Value="True">
                                        <Setter Property="Content" Value="⏳ Med..."/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="⏸ Fermer" Padding="10,5" Margin="0,0,6,0"
                            Command="{Binding FermerCommand}"
                            ToolTip="Quitter sans valider (le brouillon reste sauvegardé)"/>
                    <Button Content="✓ Valider la synthèse" Padding="10,5"
                            Background="#27AE60" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
                            Command="{Binding ValiderCommand}"
                            ToolTip="Fige cette version comme source de vérité (immuable)."/>
                </StackPanel>
            </Grid>

            <!-- Status message -->
            <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" FontSize="11" Foreground="#16A085"
                       Margin="0,0,0,8" TextWrapping="Wrap"/>

            <!-- Message de blocage validation (relecture obligatoire / critiques non traités) -->
            <Border DockPanel.Dock="Top" Background="#FEF9E7" BorderBrush="#F39C12" BorderThickness="1"
                    CornerRadius="4" Padding="8" Margin="0,0,0,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ValidationBlocageMessage, Converter={StaticResource StringNotWhiteSpaceToVis}}" Value="Visible">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ValidationBlocageMessage}" FontSize="12" Foreground="#7D6608" TextWrapping="Wrap"/>
            </Border>

            <!-- Panneau récap des flags de relecture (V0.5) — affiché sous le status -->
            <Border DockPanel.Dock="Top" Background="#FBFCFD" BorderBrush="#D6E2EC" BorderThickness="1"
                    CornerRadius="6" Padding="10" Margin="0,0,0,10"
                    Visibility="{Binding HasFlags, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="🔍 Relecture critique de Med" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding Flags}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="8,6" CornerRadius="4"
                                        Background="#FFFFFF" BorderThickness="0,0,0,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{Binding SeveriteColor, Converter={StaticResource StringToBrush}}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Traite}" Value="True">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding SeveriteIcon}" FontSize="12" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding TypeLabel}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding SeveriteColor, Converter={StaticResource StringToBrush}}"/>
                                                <TextBlock Text="·" FontSize="11" Foreground="#7F8C8D" Margin="6,0"/>
                                                <TextBlock Text="{Binding SectionCle}" FontSize="11" FontStyle="Italic" Foreground="#7F8C8D"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="#2C3E50"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Suggestion, StringFormat='💡 {0}'}" FontSize="11" FontStyle="Italic"
                                                       Foreground="#16A085" TextWrapping="Wrap" Margin="0,2,0,0"
                                                       Visibility="{Binding Suggestion, Converter={StaticResource StringNotWhiteSpaceToVis}}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="✓ Traité" Padding="8,3" FontSize="11"
                                                Margin="6,0,0,0" VerticalAlignment="Top"
                                                Command="{Binding DataContext.TraiterFlagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding Traite, Converter={StaticResource InverseBoolToVis}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Contenu : 6 sections empilées avec diff coloré (V0.4) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Synthese.Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" CornerRadius="6" Margin="0,0,0,12" Padding="12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"  Value="#FBFCFD"/>
                                            <Setter Property="BorderBrush" Value="#E5E8EC"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DiffSuggere}" Value="Modifiee">
                                                    <Setter Property="Background"  Value="#FEF5E7"/>
                                                    <Setter Property="BorderBrush" Value="#F39C12"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DiffSuggere}" Value="Nouvelle">
                                                    <Setter Property="Background"  Value="#E8F8F0"/>
                                                    <Setter Property="BorderBrush" Value="#27AE60"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DiffSuggere}" Value="Supprimee">
                                                    <Setter Property="Background"  Value="#FDEDEC"/>
                                                    <Setter Property="BorderBrush" Value="#E74C3C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Titre}" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                <!-- Chip statut diff -->
                                                <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="3" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DiffSuggere}" Value="Modifiee">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Background" Value="#F39C12"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DiffSuggere}" Value="Nouvelle">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Background" Value="#27AE60"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DiffSuggere}" Value="Supprimee">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Background" Value="#E74C3C"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10" Foreground="White" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value=""/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DiffSuggere}" Value="Modifiee">
                                                                        <Setter Property="Text" Value="Modifiée"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DiffSuggere}" Value="Nouvelle">
                                                                        <Setter Property="Text" Value="Nouvelle"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DiffSuggere}" Value="Supprimee">
                                                                        <Setter Property="Text" Value="Supprimée"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                            <!-- Boutons Accepter / Rejeter (visibles si patch en attente) -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DiffSuggere}" Value="Modifiee">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DiffSuggere}" Value="Nouvelle">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DiffSuggere}" Value="Supprimee">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button Content="✓" FontSize="11" Padding="6,2" Margin="0,0,4,0"
                                                        Background="#27AE60" Foreground="White" BorderThickness="0"
                                                        ToolTip="Accepter cette proposition"
                                                        Command="{Binding DataContext.AccepterSectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="✗" FontSize="11" Padding="6,2"
                                                        Background="#E74C3C" Foreground="White" BorderThickness="0"
                                                        ToolTip="Rejeter (revenir au contenu précédent)"
                                                        Command="{Binding DataContext.RejeterSectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Résumé du diff (1 phrase) -->
                                        <TextBlock Text="{Binding DiffResume}" FontSize="11" FontStyle="Italic"
                                                   Foreground="#7F6608" Margin="0,4,0,0" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DiffSuggere}" Value="Modifiee">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DiffSuggere}" Value="Nouvelle">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- TextBox du contenu (édition libre) -->
                                        <TextBox Text="{Binding Contenu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12" Foreground="#2C3E50" Background="White"
                                                 BorderBrush="#D6E2EC" BorderThickness="1"
                                                 TextWrapping="Wrap" AcceptsReturn="True"
                                                 MinHeight="100" Padding="8" Margin="0,6,0,0"
                                                 IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>

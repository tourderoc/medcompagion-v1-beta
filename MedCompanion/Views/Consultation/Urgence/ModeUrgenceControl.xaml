<UserControl x:Class="MedCompanion.Views.Consultation.Urgence.ModeUrgenceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MedCompanion.ViewModels"
             Background="White">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="#FAFBFC"/>
            <Setter Property="BorderBrush" Value="#E0E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="#D6E2EC" BorderThickness="1,0,0,0">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="-3" BlurRadius="14" Opacity="0.25" Direction="180"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ENTÊTE -->
            <Border Grid.Row="0" Background="#7E4B00" Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="⚠️  ÉVALUATION RISQUE SUICIDAIRE"
                                   Foreground="White" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Foreground="#FBEEC1" FontSize="11" Margin="0,4,0,0">
                            <Run Text="{Binding PatientName, Mode=OneWay}"/>
                            <Run Text="  •  "/>
                            <Run Text="{Binding AgeLabel, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Foreground="#FBEEC1" FontSize="10" Margin="0,2,0,0">
                            <Run Text="{Binding ConsultationLabel, Mode=OneWay}"/>
                            <Run Text="  •  "/>
                            <Run Text="{Binding AgeTierLabel, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✖"
                            Command="{Binding CancelCommand}"
                            Foreground="White" Background="Transparent"
                            BorderThickness="0" FontSize="16" Cursor="Hand" Padding="8,4"
                            VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- CONTENU — vue ÉVALUATION (mode initial) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16"
                          Visibility="{Binding IsEvaluationMode, Converter={StaticResource BoolToVis}}">
                <StackPanel>

                    <!-- Sections de la checklist -->
                    <ItemsControl ItemsSource="{Binding Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#2C3E50" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding HelpText}" FontSize="10" FontStyle="Italic"
                                                   Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <ListBox ItemsSource="{Binding Choices}"
                                                 SelectedValue="{Binding SelectedChoiceCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 SelectedValuePath="Code"
                                                 Background="Transparent" BorderThickness="0"
                                                 Focusable="False">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0,1,0,1"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <RadioButton Content="{Binding Label}"
                                                                             IsChecked="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsSelected, Mode=TwoWay}"
                                                                             FontSize="12" Foreground="#2C3E50" Padding="4,0,0,0"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                        <TextBox Text="{Binding FreeText, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 FontSize="11" Padding="6" MinHeight="36" Margin="0,8,0,0"
                                                 BorderBrush="#D6E2EC" BorderThickness="1" Background="White"
                                                 VerticalScrollBarVisibility="Auto"
                                                 ToolTip="Précisions cliniques (optionnel)"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ÉVALUATION FINALE -->
                    <Border Background="#FFF8E1" BorderBrush="#F39C12" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,10,0,10">
                        <StackPanel>
                            <TextBlock Text="ÉVALUATION DU MÉDECIN" FontSize="12" FontWeight="Bold" Foreground="#7E4B00" Margin="0,0,0,8"/>
                            <TextBlock Text="Niveau de risque global" FontSize="11" Foreground="#5D4400" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Faible"  IsChecked="{Binding IsRiskFaible}" Margin="0,0,16,0" FontSize="12"/>
                                <RadioButton Content="Modéré"  IsChecked="{Binding IsRiskModere}" Margin="0,0,16,0" FontSize="12"/>
                                <RadioButton Content="Élevé"   IsChecked="{Binding IsRiskEleve}"  Margin="0,0,16,0" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- PLAN D'ACTION -->
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Text="Plan d'action" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding PlanActions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}"
                                                  FontSize="12" Margin="0,3,0,3"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Revoyure dans" FontSize="12" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding RevoyureJours, UpdateSourceTrigger=PropertyChanged}"
                                         Width="60" Margin="6,0,6,0" Padding="6,3" FontSize="12"
                                         BorderBrush="#D6E2EC" BorderThickness="1" Background="White"
                                         HorizontalContentAlignment="Center"/>
                                <TextBlock Text="jour(s) — 0 = non programmée" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- NOTES LIBRES -->
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Text="Notes libres du médecin" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NotesLibres, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     FontSize="11" Padding="8" MinHeight="80"
                                     BorderBrush="#D6E2EC" BorderThickness="1" Background="White"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- CONTENU — vue RESTITUTION PARENTS (Étape 5) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16"
                          Visibility="{Binding IsRestitutionMode, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <Border Background="#FEF6F0" BorderBrush="#E8834A" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📄 DOCUMENT POUR LES PARENTS" FontSize="12" FontWeight="Bold" Foreground="#7E2D02" Margin="0,0,0,4"/>
                            <TextBlock Foreground="#9C6500" FontSize="11" TextWrapping="Wrap">
                                <Run Text="Pré-rempli automatiquement à partir de votre évaluation. "/>
                                <Run Text="Relisez, ajustez le ton si besoin, puis générez le PDF."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Text="Phrase d'ouverture" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,4"/>
                            <TextBlock Text="Ton chaleureux et sobre — vouvoiement des parents" FontSize="10" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding RestitutionIntro, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     FontSize="11" Padding="8" MinHeight="60"
                                     BorderBrush="#D6E2EC" BorderThickness="1" Background="White"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Text="Ce que nous avons observé" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,4"/>
                            <TextBlock Text="Synthèse bienveillante, sans interprétation pesante. 3 à 4 phrases." FontSize="10" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding RestitutionObserve, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     FontSize="11" Padding="8" MinHeight="80"
                                     BorderBrush="#D6E2EC" BorderThickness="1" Background="White"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Text="Ressources de votre enfant" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,4"/>
                            <TextBlock Text="Une ressource par ligne (forces, soutiens, capacités identifiées)." FontSize="10" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding RestitutionRessources, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     FontSize="11" Padding="8" MinHeight="80"
                                     BorderBrush="#D6E2EC" BorderThickness="1" Background="White"
                                     FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFBE6" BorderBrush="#F1C40F" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🛡️  Contenu fixe inclus automatiquement" FontSize="12" FontWeight="SemiBold" Foreground="#856404" Margin="0,0,0,8"/>
                            <TextBlock Foreground="#5D4400" FontSize="11" TextWrapping="Wrap">
                                <Run Text="• Repères pour la maison (adaptés à l'âge)"/>
                                <LineBreak/>
                                <Run Text="• Plan d'action (repris de votre évaluation : cases cochées + revoyure)"/>
                                <LineBreak/>
                                <Run Text="• Sécurisation du domicile (incluse seulement si risque ≥ Modéré)"/>
                                <LineBreak/>
                                <Run Text="• Signaux à reconnaître (texte validé)"/>
                                <LineBreak/>
                                <Run Text="• Numéros d'urgence : 15, 3114, 112"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Aperçu du PDF généré -->
                    <Border Style="{StaticResource SectionBorder}" Visibility="{Binding HasGeneratedPdf, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="PDF généré" FontSize="13" FontWeight="SemiBold" Foreground="#27AE60" Margin="0,0,0,8"/>
                            <Button Content="📂 Ouvrir le PDF" Command="{Binding OpenGeneratedPdfCommand}"
                                    Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- FOOTER — mode ÉVALUATION -->
            <Border Grid.Row="2" Background="#F5F6FA" BorderBrush="#D6E2EC" BorderThickness="0,1,0,0" Padding="16,12"
                    Visibility="{Binding IsEvaluationMode, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                               FontSize="11" Foreground="#27AE60" VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Annuler" Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                        <Button Content="💾 Enregistrer évaluation" Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- FOOTER — mode RESTITUTION -->
            <Border Grid.Row="2" Background="#F5F6FA" BorderBrush="#D6E2EC" BorderThickness="0,1,0,0" Padding="16,12"
                    Visibility="{Binding IsRestitutionMode, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding RestitutionStatus}"
                               FontSize="11" Foreground="#27AE60" VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="↩ Retour évaluation" Command="{Binding BackToEvaluationCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                        <Button Content="🔄 Régénérer" Command="{Binding GenerateRestitutionCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                        <Button Content="🖨 Générer PDF" Command="{Binding ExportPdfCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>

<UserControl x:Class="MedCompanion.Views.Consultation.Urgence.UrgenceChipControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MedCompanion.ViewModels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <!-- DataContext attendu : UrgenceChipViewModel (peut être null → masqué via parent) -->
    <Border Background="#FFF3CD"
            BorderBrush="#F39C12" BorderThickness="6,1,1,1"
            CornerRadius="6" Padding="14,10"
            Margin="0,0,0,10"
            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icône -->
            <TextBlock Grid.Column="0" Text="⚠️" FontSize="22"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>

            <!-- Texte -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding HeaderText}"
                           FontSize="13" FontWeight="SemiBold" Foreground="#7E4B00"
                           TextWrapping="Wrap"/>
                <TextBlock Foreground="#9C6500" FontSize="11" Margin="0,3,0,0">
                    <Run Text="Le médecin valide. Aucune décision n'est prise automatiquement."/>
                </TextBlock>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Ouvrir évaluation -->
                <Button Command="{Binding OpenEvaluationCommand}"
                        Padding="11,6" Margin="0,0,6,0"
                        Background="#F39C12" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="11" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <TextBlock Text="📋 Ouvrir évaluation" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#D68910"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Voir passages (popup) -->
                <Button x:Name="ShowPassagesButton"
                        Command="{Binding ShowPassagesCommand}"
                        Padding="11,6" Margin="0,0,6,0"
                        Background="White" Foreground="#7E4B00"
                        BorderThickness="1" BorderBrush="#F39C12" Cursor="Hand" FontSize="11">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <TextBlock Text="👁 Voir passages" Foreground="#7E4B00"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FBEEC1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Écarter -->
                <Button Click="DismissButton_Click"
                        Padding="11,6"
                        Background="Transparent" Foreground="#7E4B00"
                        BorderThickness="1" BorderBrush="#D6B370" Cursor="Hand" FontSize="11">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <TextBlock Text="✖ Écarter" Foreground="#7E4B00"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FBEEC1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Popup passages -->
            <Popup PlacementTarget="{Binding ElementName=ShowPassagesButton}"
                   Placement="Bottom"
                   IsOpen="{Binding ShowPassagesPopupOpen}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="White" BorderBrush="#F39C12" BorderThickness="1"
                        CornerRadius="6" Padding="12" MaxWidth="520">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.25"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Passages relevés dans la note"
                                       FontSize="12" FontWeight="SemiBold" Foreground="#7E4B00"/>
                            <Button Grid.Column="1" Content="✖" FontSize="11"
                                    Command="{Binding CloseShowPassagesCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#7E4B00" Cursor="Hand" Padding="4,0"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Passages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF8E1" BorderBrush="#F1C40F" BorderThickness="0,0,0,1"
                                            Padding="8,6" Margin="0,0,0,4" CornerRadius="3">
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                   FontSize="11" Foreground="#5D4400"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>

<UserControl x:Class="MedCompanion.Views.Restitutions.RestitutionEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:MedCompanion.Views.Restitutions"
             xmlns:vm="clr-namespace:MedCompanion.ViewModels.Restitutions"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="600"
             Background="#F8F9FA">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Dossier de Restitution Clinique" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="{Binding PatientName, StringFormat='Patient : {0}'}" FontSize="13" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                </StackPanel>
                
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" 
                           Foreground="#16A085" FontSize="12" Margin="0,0,15,0" FontStyle="Italic"/>
                           
                <Button Grid.Column="2" Command="{Binding GenerateAllCommand}" Content="✨ Tout préremplir" 
                        Padding="12,8" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                        ToolTip="Générer automatiquement toutes les sections vides à partir du contexte clinique">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#2980B9"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Editor List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <ItemsControl ItemsSource="{Binding Blocs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#34495E" VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="Génération en cours..." Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}" 
                                                   VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#F39C12" FontSize="12" FontStyle="Italic"/>
                                        <Button Command="{Binding GenerateCommand}" Content="✨ Suggérer" 
                                                Padding="8,4" Background="#1ABC9C" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="11">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#16A085"/></Trigger>
                                                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#BDC3C7"/></Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                
                                <TextBox Grid.Row="1" Text="{Binding Contenu, UpdateSourceTrigger=PropertyChanged}" 
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                                         FontSize="13" FontFamily="Segoe UI" Padding="8"
                                         BorderBrush="#D6DBDF" BorderThickness="1"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,15,0,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="-1" BlurRadius="4" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="1" Command="{Binding SaveCommand}" Content="💾 Enregistrer" 
                        Padding="15,8" Background="#E67E22" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#D35400"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" Command="{Binding CloseCommand}" Content="✕ Fermer" 
                        Padding="15,8" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#7F8C8D"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>

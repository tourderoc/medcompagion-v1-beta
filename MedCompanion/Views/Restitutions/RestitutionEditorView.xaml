<UserControl x:Class="MedCompanion.Views.Restitutions.RestitutionEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:MedCompanion.Views.Restitutions"
             xmlns:vm="clr-namespace:MedCompanion.ViewModels.Restitutions"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400"
             Loaded="UserControl_Loaded"
             Background="#F8F9FA">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Style pour donner une bordure gauche bleue aux 5 blocs constituant la section centrale (pages 3-4) -->
        <Style x:Key="BlocBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SectionType}" Value="patient_identification">
                    <Setter Property="BorderBrush" Value="#2980B9"/>
                    <Setter Property="BorderThickness" Value="4,1,1,1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SectionType}" Value="patient_motif">
                    <Setter Property="BorderBrush" Value="#2980B9"/>
                    <Setter Property="BorderThickness" Value="4,1,1,1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SectionType}" Value="patient_contexte_familial">
                    <Setter Property="BorderBrush" Value="#2980B9"/>
                    <Setter Property="BorderThickness" Value="4,1,1,1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SectionType}" Value="patient_antecedents">
                    <Setter Property="BorderBrush" Value="#2980B9"/>
                    <Setter Property="BorderThickness" Value="4,1,1,1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SectionType}" Value="patient_situation_actuelle">
                    <Setter Property="BorderBrush" Value="#2980B9"/>
                    <Setter Property="BorderThickness" Value="4,1,1,1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Dossier de Restitution Clinique" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="{Binding PatientName, StringFormat='Patient : {0}'}" FontSize="13" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#16A085" FontSize="12" FontStyle="Italic" TextAlignment="Right"/>
                    <TextBlock Text="{Binding ProgressLabel}"
                               Foreground="#3498DB" FontSize="11" FontWeight="SemiBold" TextAlignment="Right"
                               Visibility="{Binding IsGeneratingAll, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Command="{Binding GenerateAllCommand}" Content="✨ Tout préremplir"
                            Padding="12,8" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Visibility="{Binding IsGeneratingAll, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                            ToolTip="Lecture du dossier patient puis génération séquentielle des sections vides">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGeneratingAll}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#2980B9"/></Trigger>
                                    <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#BDC3C7"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding StopGenerationCommand}" Content="⏸ Arrêter"
                            Padding="12,8" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                            ToolTip="Annule la génération en cours. Les blocs déjà rédigés sont conservés.">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGeneratingAll}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#C0392B"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Split-view : éditeur à gauche, aperçu HTML à droite -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="350"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

        <!-- Editor List -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <ItemsControl ItemsSource="{Binding Blocs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <!-- Group Banner above first element of grouped blocks (patient_identification) -->
                            <Border x:Name="GroupHeaderBanner" Background="#EBF5FB" BorderBrush="#AED6F1" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,12" SnapsToDevicePixels="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SectionType}" Value="patient_identification">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📖" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Pages 3-4 du Document — Patient &amp; Contexte" FontWeight="Bold" Foreground="#1B4F72" FontSize="13"/>
                                        <TextBlock Text="Les 5 blocs suivants forment ensemble la section centrale de présentation du patient." Foreground="#2E86C1" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- The main bloc editor card -->
                            <Border Style="{StaticResource BlocBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#34495E" VerticalAlignment="Center"/>
                                            
                                            <!-- Page Badge mapping blocks to final PDF pages -->
                                            <Border x:Name="PageBadge" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center" SnapsToDevicePixels="True">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <!-- Default style for other pages -->
                                                        <Setter Property="Background" Value="#F2F4F4"/>
                                                        <Setter Property="BorderBrush" Value="#BDC3C7"/>
                                                        <Style.Triggers>
                                                            <!-- Pages 3-4 blocks get a distinct light-blue background -->
                                                            <DataTrigger Binding="{Binding SectionType}" Value="patient_identification">
                                                                <Setter Property="Background" Value="#EBF5FB"/>
                                                                <Setter Property="BorderBrush" Value="#AED6F1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SectionType}" Value="patient_motif">
                                                                <Setter Property="Background" Value="#EBF5FB"/>
                                                                <Setter Property="BorderBrush" Value="#AED6F1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SectionType}" Value="patient_contexte_familial">
                                                                <Setter Property="Background" Value="#EBF5FB"/>
                                                                <Setter Property="BorderBrush" Value="#AED6F1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SectionType}" Value="patient_antecedents">
                                                                <Setter Property="Background" Value="#EBF5FB"/>
                                                                <Setter Property="BorderBrush" Value="#AED6F1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SectionType}" Value="patient_situation_actuelle">
                                                                <Setter Property="Background" Value="#EBF5FB"/>
                                                                <Setter Property="BorderBrush" Value="#AED6F1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="10" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#7F8C8D"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="couverture">
                                                                    <Setter Property="Text" Value="Page 1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="restitution_1page">
                                                                    <Setter Property="Text" Value="Page 2"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="patient_identification">
                                                                    <Setter Property="Text" Value="Pages 3-4"/>
                                                                    <Setter Property="Foreground" Value="#2980B9"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="patient_motif">
                                                                    <Setter Property="Text" Value="Pages 3-4"/>
                                                                    <Setter Property="Foreground" Value="#2980B9"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="patient_contexte_familial">
                                                                    <Setter Property="Text" Value="Pages 3-4"/>
                                                                    <Setter Property="Foreground" Value="#2980B9"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="patient_antecedents">
                                                                    <Setter Property="Text" Value="Pages 3-4"/>
                                                                    <Setter Property="Foreground" Value="#2980B9"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="patient_situation_actuelle">
                                                                    <Setter Property="Text" Value="Pages 3-4"/>
                                                                    <Setter Property="Foreground" Value="#2980B9"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="synthese_diag">
                                                                    <Setter Property="Text" Value="Page 5"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="bilan_final">
                                                                    <Setter Property="Text" Value="Page 6"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="synthese_globale">
                                                                    <Setter Property="Text" Value="Page 7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="projet_therapeutique">
                                                                    <Setter Property="Text" Value="Page 8"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SectionType}" Value="conclusion">
                                                                    <Setter Property="Text" Value="Page 9"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="Génération en cours..." Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#F39C12" FontSize="12" FontStyle="Italic"/>
                                            <!-- Reformuler (blocs texte libre uniquement) -->
                                            <Button Command="{Binding ToggleReformulePanelCommand}"
                                                    Padding="8,4" FontSize="11" Cursor="Hand" Margin="0,0,8,0"
                                                    Background="#D6EAF8" BorderBrush="#AED6F1" BorderThickness="1">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasReformuleButton}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#AED6F1"/></Trigger>
                                                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#F2F3F4"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Content>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="↺ Reformuler"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsReformulePanelVisible}" Value="True">
                                                                        <Setter Property="Text" Value="✕ Fermer"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Button.Content>
                                            </Button>
                                            <Button Command="{Binding GenerateCommand}" Content="✨ Suggérer"
                                                    Padding="8,4" Background="#1ABC9C" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="11">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#16A085"/></Trigger>
                                                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#BDC3C7"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Éditeur structuré pour le bloc couverture (cartouches label + champ) -->
                                    <Grid Grid.Row="1">
                                        <!-- COUVERTURE : formulaire structuré champ par champ -->
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCouverture}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <StackPanel.Resources>
                                                    <Style x:Key="FieldRow" TargetType="Grid">
                                                        <Setter Property="Margin" Value="0,0,0,7"/>
                                                    </Style>
                                                    <Style x:Key="LabelChip" TargetType="Border">
                                                        <Setter Property="Background" Value="#EBF5FB"/>
                                                        <Setter Property="BorderBrush" Value="#AED6F1"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                        <Setter Property="Padding" Value="8,5"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="MinWidth" Value="150"/>
                                                    </Style>
                                                    <Style x:Key="LabelText" TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="#1B4F72"/>
                                                    </Style>
                                                    <Style x:Key="FieldBox" TargetType="TextBox">
                                                        <Setter Property="FontSize" Value="12"/>
                                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                                        <Setter Property="Padding" Value="7,5"/>
                                                        <Setter Property="BorderBrush" Value="#D6DBDF"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="Background" Value="White"/>
                                                    </Style>
                                                </StackPanel.Resources>

                                                <!-- Nom et prénom -->
                                                <Grid Style="{StaticResource FieldRow}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource LabelChip}" Margin="0,0,8,0">
                                                        <TextBlock Text="Nom et prénom" Style="{StaticResource LabelText}"/>
                                                    </Border>
                                                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}"
                                                             Text="{Binding CvNomPrenom, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <!-- Date de naissance -->
                                                <Grid Style="{StaticResource FieldRow}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource LabelChip}" Margin="0,0,8,0">
                                                        <TextBlock Text="Date de naissance" Style="{StaticResource LabelText}"/>
                                                    </Border>
                                                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}"
                                                             Text="{Binding CvDateNaissance, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <!-- Âge -->
                                                <Grid Style="{StaticResource FieldRow}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource LabelChip}" Margin="0,0,8,0">
                                                        <TextBlock Text="Âge" Style="{StaticResource LabelText}"/>
                                                    </Border>
                                                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}"
                                                             Text="{Binding CvAge, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <!-- Établissement -->
                                                <Grid Style="{StaticResource FieldRow}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource LabelChip}" Margin="0,0,8,0">
                                                        <TextBlock Text="Établissement" Style="{StaticResource LabelText}"/>
                                                    </Border>
                                                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}"
                                                             Text="{Binding CvEcole, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <!-- Classe -->
                                                <Grid Style="{StaticResource FieldRow}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource LabelChip}" Margin="0,0,8,0">
                                                        <TextBlock Text="Classe" Style="{StaticResource LabelText}"/>
                                                    </Border>
                                                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}"
                                                             Text="{Binding CvClasse, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <!-- Année scolaire -->
                                                <Grid Style="{StaticResource FieldRow}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource LabelChip}" Margin="0,0,8,0">
                                                        <TextBlock Text="Année scolaire" Style="{StaticResource LabelText}"/>
                                                    </Border>
                                                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}"
                                                             Text="{Binding CvAnneeScolaire, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <!-- Motif de consultation -->
                                                <Grid Style="{StaticResource FieldRow}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource LabelChip}" Margin="0,0,8,0">
                                                        <TextBlock Text="Motif de consultation" Style="{StaticResource LabelText}" TextWrapping="Wrap"/>
                                                    </Border>
                                                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}"
                                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="52"
                                                             Text="{Binding CvMotif, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <!-- Dates d'évaluation -->
                                                <Grid Style="{StaticResource FieldRow}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource LabelChip}" Margin="0,0,8,0">
                                                        <TextBlock Text="Dates d'évaluation" Style="{StaticResource LabelText}" TextWrapping="Wrap"/>
                                                    </Border>
                                                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}"
                                                             Text="{Binding CvDatesEval, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- IDENTIFICATION : formulaire structuré 5 champs -->
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsIdentification}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <StackPanel.Resources>
                                                    <Style x:Key="IdLabelChip" TargetType="Border">
                                                        <Setter Property="Background" Value="#EBF5FB"/>
                                                        <Setter Property="BorderBrush" Value="#AED6F1"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                        <Setter Property="Padding" Value="8,5"/>
                                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                                        <Setter Property="MinWidth" Value="155"/>
                                                    </Style>
                                                    <Style x:Key="IdLabelText" TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="#1B4F72"/>
                                                    </Style>
                                                    <Style x:Key="IdFieldBox" TargetType="TextBox">
                                                        <Setter Property="FontSize" Value="12"/>
                                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                                        <Setter Property="Padding" Value="7,5"/>
                                                        <Setter Property="BorderBrush" Value="#D6DBDF"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="Background" Value="White"/>
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                                    </Style>
                                                </StackPanel.Resources>

                                                <!-- Présentation -->
                                                <Grid Margin="0,0,0,7">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource IdLabelChip}" Margin="0,0,8,0">
                                                        <TextBlock Text="Présentation" Style="{StaticResource IdLabelText}"/>
                                                    </Border>
                                                    <TextBox Grid.Column="1" Style="{StaticResource IdFieldBox}"
                                                             AcceptsReturn="True" MinHeight="70"
                                                             Text="{Binding IdPresentation, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <!-- Période d'évaluation -->
                                                <Grid Margin="0,0,0,7">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource IdLabelChip}" Margin="0,0,8,0">
                                                        <TextBlock Text="Période d'évaluation" Style="{StaticResource IdLabelText}" TextWrapping="Wrap"/>
                                                    </Border>

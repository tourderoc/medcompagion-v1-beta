                                        <!-- RESTITUTION PARENTS : 6 sections avec titre + textarea + reformuler -->
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestitutionParents}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <ItemsControl ItemsSource="{Binding RpSections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,8" BorderBrush="#D6DBDF" BorderThickness="1" CornerRadius="4">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <!-- En-tête de section : titre + bouton Reformuler -->
                                                                <Border Grid.Row="0" Background="#EBF5FB" BorderBrush="#AED6F1"
                                                                        BorderThickness="0,0,0,1" CornerRadius="4,4,0,0" Padding="10,5">
                                                                    <DockPanel>
                                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <TextBlock Text="..." Foreground="#F39C12" FontSize="11" FontStyle="Italic"
                                                                                       VerticalAlignment="Center" Margin="0,0,6,0">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsGenerating}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                            <Button Command="{Binding ToggleInstructionCommand}" Padding="7,3" FontSize="10" Cursor="Hand"
                                                                                    Background="#D6EAF8" BorderBrush="#AED6F1" BorderThickness="1">

                                                                                                    <DataTrigger Binding="{Binding IsInstructionPanelVisible}" Value="True">
                                                                                                        <Setter Property="Text" Value="✕ Fermer"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                </Button.Content>
                                                                            </Button>
                                                                        </StackPanel>
                                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                                                   FontSize="12" Foreground="#1A5276" VerticalAlignment="Center"/>

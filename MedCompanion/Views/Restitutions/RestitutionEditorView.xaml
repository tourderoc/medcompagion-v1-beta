                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#16A085"/></Trigger>
                                                                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#BDC3C7"/></Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#D0D7DE" ShowsPreview="True"
                          ToolTip="Faites glisser pour ajuster la largeur de l'aperçu"/>

            <!-- Preview WebView2 -->
            <Border Grid.Column="2" Background="#DDDDDD" CornerRadius="6" BorderBrush="#C0C7CC" BorderThickness="1">
                <Grid>
                    <TextBlock x:Name="PreviewFallback"
                               Text="📄 Aperçu en cours d'initialisation..."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="13" Foreground="#7F8C8D" FontStyle="Italic"/>
                    <wv2:WebView2 x:Name="PreviewWebView" Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,15,0,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="-1" BlurRadius="4" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Export PDF -->
                <Button x:Name="ExportPdfButton" Grid.Column="1"
                        Content="🖨 Exporter PDF"
                        Click="ExportPdfButton_Click"
                        Padding="15,8" Background="#6C3483" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                        ToolTip="Génère un PDF complet du dossier via Edge (identique à l'aperçu)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#5B2C6F"/></Trigger>
                                <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#BDC3C7"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" Command="{Binding SaveCommand}" Content="💾 Enregistrer" 
                        Padding="15,8" Background="#E67E22" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#D35400"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="3" Command="{Binding CloseCommand}" Content="✕ Fermer" 
                        Padding="15,8" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#7F8C8D"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>

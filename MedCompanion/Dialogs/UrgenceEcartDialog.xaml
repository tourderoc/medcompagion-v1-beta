<Window x:Class="MedCompanion.Dialogs.UrgenceEcartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Écarter le signal"
        Height="290" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6FA"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Écarter le signal d'urgence" Foreground="White"
                           FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="Cette décision est tracée dans le dossier patient (traçabilité médico-légale)."
                           Foreground="#BDC3C7" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Text="Motif (optionnel) :"
                   FontSize="12" Foreground="#2C3E50" Margin="0,0,0,6"/>

        <TextBox Grid.Row="2" x:Name="MotifTextBox"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 Padding="10" FontSize="12"
                 BorderBrush="#BDC3C7" BorderThickness="1"
                 Background="White"
                 VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Annuler" Click="CancelButton_Click"
                    Padding="14,7" Margin="0,0,8,0"
                    Background="#ECF0F1" BorderThickness="1" BorderBrush="#BDC3C7"
                    Cursor="Hand" FontSize="12"/>
            <Button Content="Écarter le signal" Click="ConfirmButton_Click"
                    Padding="14,7"
                    Background="#7E4B00" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="MedCompanion.Dialogs.VpsAccountsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Explorateur de Comptes VPS (Port 8001)" Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="White">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentColor" Color="#27AE60"/>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D2D"/>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="🌍 Comptes Parent'aile" Style="{StaticResource HeaderStyle}"/>
            <TextBlock Text="(Base PostgreSQL)" Foreground="#888888" VerticalAlignment="Bottom" Margin="10,0,0,14" FontSize="14"/>
        </StackPanel>

        <!-- Search and Stats -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Rechercher :" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#AAAAAA"/>
                <TextBox x:Name="SearchBox" Width="250" Height="30" Padding="5,5" 
                         Background="#2D2D2D" Foreground="White" BorderThickness="1" BorderBrush="#444444"
                         TextChanged="SearchBox_TextChanged" IsEnabled="False"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock x:Name="CountText" Text="0 compte(s)" VerticalAlignment="Center" Foreground="#AAAAAA" Margin="0,0,20,0"/>
                <Button x:Name="RefreshBtn" Content="🔄 Actualiser" Padding="15,6" 
                        Background="#3D3D3D" Foreground="White" BorderThickness="0"
                        Click="RefreshBtn_Click"/>
            </StackPanel>
        </Grid>

        <!-- Table -->
        <Border Grid.Row="2" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="2" BorderThickness="1" BorderBrush="#333333">
            <Grid>
                <DataGrid x:Name="AccountsGrid" 
                          AutoGenerateColumns="False" 
                          Background="Transparent" 
                          Foreground="White"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#383838"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#313131"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          FontSize="13"
                          RowHeight="40"
                          SelectionMode="Single"
                          HeadersVisibility="Column">
                    
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#252525"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#444444"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PSEUDO" Binding="{Binding Pseudo}" Width="150"/>
                        <DataGridTextColumn Header="E-MAIL" Binding="{Binding Email}" Width="180"/>
                        <DataGridTextColumn Header="POINTS" Binding="{Binding Points}" Width="80"/>
                        <DataGridTextColumn Header="BADGE" Binding="{Binding Badge}" Width="100"/>
                        <DataGridTextColumn Header="ROLE" Binding="{Binding RoleDisplay}" Width="80"/>
                        <DataGridTextColumn Header="CRÉÉ LE" Binding="{Binding CreationDateDisplay}" Width="160"/>
                        <DataGridTextColumn Header="UID" Binding="{Binding Uid}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading Overlay -->
                <Border x:Name="LoadingOverlay" Background="#AA000000" CornerRadius="8" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Chargement des données..." HorizontalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </Border>
                
                <!-- Empty State -->
                <TextBlock x:Name="EmptyText" Text="Aucun compte trouvé." 
                           VerticalAlignment="Center" HorizontalAlignment="Center" 
                           Foreground="#666666" FontSize="16" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Fermer" Padding="25,10" 
                    Background="#3D3D3D" Foreground="White" BorderThickness="0"
                    Click="Close_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>

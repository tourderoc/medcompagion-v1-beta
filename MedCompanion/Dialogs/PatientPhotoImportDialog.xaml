<Window x:Class="MedCompanion.Dialogs.PatientPhotoImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photo du patient" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA"
        FontFamily="Segoe UI">
    
    <Window.Resources>
        <!-- Styles pour les boutons -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1557B0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD"/>
                    <Setter Property="Foreground" Value="#757575"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1A73E8"/>
            <Setter Property="BorderBrush" Value="#1A73E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F3F4"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="BorderBrush" Value="#BDBDBD"/>
                    <Setter Property="Foreground" Value="#BDBDBD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Photo de l'enfant" FontSize="20" FontWeight="Bold" Foreground="#202124" Margin="0,0,0,20"/>

        <!-- Prévisualisation -->
        <Border Grid.Row="1" Width="150" Height="150" CornerRadius="75" Background="#E8EAED" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <!-- Initiales par défaut si pas d'image -->
                <TextBlock x:Name="InitialsText" Text="??" FontSize="48" FontWeight="Bold" Foreground="#9AA0A6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                
                <!-- Image -->
                <Ellipse>
                    <Ellipse.Fill>
                        <ImageBrush x:Name="PhotoBrush" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>
        </Border>

        <!-- Consentement -->
        <Border Grid.Row="2" Background="#FFF8E1" BorderBrush="#FFC107" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20">
            <CheckBox x:Name="ConsentCheckBox" Checked="ConsentCheckBox_Changed" Unchecked="ConsentCheckBox_Changed">
                <TextBlock TextWrapping="Wrap" Foreground="#202124" VerticalAlignment="Center" Margin="5,0,0,0">
                    <Run FontWeight="Bold">Accord obtenu : </Run>
                    <Run>Je confirme avoir l'accord du représentant légal pour ajouter et conserver une photo de cet enfant dans son dossier médical.</Run>
                </TextBlock>
            </CheckBox>
        </Border>

        <!-- Actions -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="ImportFileButton" Content="Importer du PC" Grid.Column="0" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="False" Click="ImportFileButton_Click"/>
            <Button x:Name="CameraFileButton" Content="Prendre une photo" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False" Click="CameraFileButton_Click"/>
        </Grid>
    </Grid>
</Window>

<Window x:Class="MedCompanion.Dialogs.FormulaireSaisieDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Formulaire parents — Saisie des données"
        Width="1200" Height="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="45*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Gauche : viewer PDF ── -->
        <Border Grid.Column="0" BorderBrush="#DDE3ED" BorderThickness="0,0,1,0">
            <Grid>
                <wv2:WebView2 x:Name="PdfWebView" Visibility="Collapsed"/>
                <TextBlock x:Name="PdfFallback" Text="Chargement du PDF..."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" Foreground="#7F8C8D"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E8ECF0"/>

        <!-- ── Droite : formulaire saisie ── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="14,10,14,8">
                <StackPanel>

                    <!-- Bloc 1 — Père -->
                    <Border Background="#EBF5FB" BorderBrush="#85C1E9" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="1 — PÈRE" FontWeight="Bold" FontSize="12" Foreground="#1A5276" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,4,4">
                                    <TextBlock Text="Prénom" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="PerePrenom" Padding="4,3" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="0" Margin="4,0,0,4">
                                    <TextBlock Text="Nom" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="PereNom" Padding="4,3" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,4,0">
                                    <TextBlock Text="Téléphone" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="PereTel" Padding="4,3" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="4,0,0,0">
                                    <TextBlock Text="Email" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="PereEmail" Padding="4,3" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Bloc 2 — Mère -->
                    <Border Background="#FEF9E7" BorderBrush="#F9CA3B" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="2 — MÈRE" FontWeight="Bold" FontSize="12" Foreground="#7D6608" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,4,4">
                                    <TextBlock Text="Prénom" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="MerePrenom" Padding="4,3" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="0" Margin="4,0,0,4">
                                    <TextBlock Text="Nom" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="MereNom" Padding="4,3" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,4,0">
                                    <TextBlock Text="Téléphone" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="MereTel" Padding="4,3" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="4,0,0,0">
                                    <TextBlock Text="Email" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="MereEmail" Padding="4,3" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Bloc 3 — Adresse -->
                    <Border Background="#F9F9F9" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="3 — ADRESSE DU MILIEU DE VIE" FontWeight="Bold" FontSize="12" Foreground="#2C3E50" Margin="0,0,0,8"/>
                            <TextBlock Text="Adresse" FontSize="11" Foreground="#555"/>
                            <TextBox x:Name="Adresse" Padding="4,3" FontSize="12" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Code postal" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="CodePostal" Padding="4,3" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Ville" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="Ville" Padding="4,3" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Bloc 4 — Situation familiale -->
                    <Border Background="#F5EEF8" BorderBrush="#C39BD3" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="4 — SITUATION FAMILIALE" FontWeight="Bold" FontSize="12" Foreground="#6C3483" Margin="0,0,0,8"/>
                            <WrapPanel Margin="0,0,0,6">
                                <RadioButton x:Name="SitEnsemble"    GroupName="SitFam" Content="Ensemble"        Margin="0,0,10,4" FontSize="11"/>
                                <RadioButton x:Name="SitSepares"     GroupName="SitFam" Content="Séparés"         Margin="0,0,10,4" FontSize="11"/>
                                <RadioButton x:Name="SitDivorces"    GroupName="SitFam" Content="Divorcés"        Margin="0,0,10,4" FontSize="11"/>
                                <RadioButton x:Name="SitGardeAlt"    GroupName="SitFam" Content="Garde alternée"  Margin="0,0,10,4" FontSize="11"/>
                                <RadioButton x:Name="SitRecomposee"  GroupName="SitFam" Content="Recomposée"      Margin="0,0,10,4" FontSize="11"/>
                                <RadioButton x:Name="SitAutre"       GroupName="SitFam" Content="Autre"           Margin="0,0,10,4" FontSize="11"/>
                            </WrapPanel>
                            <TextBlock Text="Garde principale :" FontSize="11" Foreground="#555" Margin="0,0,0,4"/>
                            <WrapPanel>
                                <RadioButton x:Name="GardeParents" GroupName="Garde" Content="Parents" Margin="0,0,10,0" FontSize="11"/>
                                <RadioButton x:Name="GardeMere"    GroupName="Garde" Content="Mère"    Margin="0,0,10,0" FontSize="11"/>
                                <RadioButton x:Name="GardePere"    GroupName="Garde" Content="Père"    Margin="0,0,10,0" FontSize="11"/>
                                <RadioButton x:Name="GardeAutre"   GroupName="Garde" Content="Autre"   FontSize="11"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Bloc 5 — Antécédents familiaux -->
                    <Border Background="#EAFAF1" BorderBrush="#82E0AA" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="5 — ANTÉCÉDENTS FAMILIAUX" FontWeight="Bold" FontSize="12" Foreground="#1E8449" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="48"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="22"/>
                                    <RowDefinition Height="22"/>
                                    <RowDefinition Height="22"/>
                                    <RowDefinition Height="22"/>
                                    <RowDefinition Height="22"/>
                                    <RowDefinition Height="22"/>
                                    <RowDefinition Height="22"/>
                                    <RowDefinition Height="22"/>
                                    <RowDefinition Height="22"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="OUI"  FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="NON"  FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="NSP"  FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- TDAH -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="TDAH / Troubles de l'attention" FontSize="11" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="1" Grid.Column="1" x:Name="TdahOui" GroupName="Tdah" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="1" Grid.Column="2" x:Name="TdahNon" GroupName="Tdah" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="1" Grid.Column="3" x:Name="TdahNsp" GroupName="Tdah" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Dyslexie -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Dyslexie / Troubles des apprentissages" FontSize="11" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="2" Grid.Column="1" x:Name="DyslexieOui" GroupName="Dyslexie" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="2" Grid.Column="2" x:Name="DyslexieNon" GroupName="Dyslexie" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="2" Grid.Column="3" x:Name="DyslexieNsp" GroupName="Dyslexie" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- TSA -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Troubles du spectre de l'autisme (TSA)" FontSize="11" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="3" Grid.Column="1" x:Name="TsaOui" GroupName="Tsa" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="3" Grid.Column="2" x:Name="TsaNon" GroupName="Tsa" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="3" Grid.Column="3" x:Name="TsaNsp" GroupName="Tsa" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Anxieux -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Troubles anxieux" FontSize="11" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="4" Grid.Column="1" x:Name="AnxieuxOui" GroupName="Anxieux" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="4" Grid.Column="2" x:Name="AnxieuxNon" GroupName="Anxieux" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="4" Grid.Column="3" x:Name="AnxieuxNsp" GroupName="Anxieux" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Dépression -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Dépression" FontSize="11" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="5" Grid.Column="1" x:Name="DepOui" GroupName="Depression" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="5" Grid.Column="2" x:Name="DepNon" GroupName="Depression" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="5" Grid.Column="3" x:Name="DepNsp" GroupName="Depression" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Bipolarité -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Bipolarité" FontSize="11" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="6" Grid.Column="1" x:Name="BipoOui" GroupName="Bipolarite" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="6" Grid.Column="2" x:Name="BipoNon" GroupName="Bipolarite" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="6" Grid.Column="3" x:Name="BipoNsp" GroupName="Bipolarite" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Addictions -->
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Addictions (alcool, etc.)" FontSize="11" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="7" Grid.Column="1" x:Name="AddOui" GroupName="Addictions" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="7" Grid.Column="2" x:Name="AddNon" GroupName="Addictions" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="7" Grid.Column="3" x:Name="AddNsp" GroupName="Addictions" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- TS -->
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Tentative de suicide" FontSize="11" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="8" Grid.Column="1" x:Name="TsOui" GroupName="TS" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="8" Grid.Column="2" x:Name="TsNon" GroupName="TS" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="8" Grid.Column="3" x:Name="TsNsp" GroupName="TS" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Bloc 7 — Autorisations -->
                    <Border Background="#FEF9E7" BorderBrush="#F0B27A" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="7 — AUTORISATIONS" FontWeight="Bold" FontSize="12" Foreground="#784212" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="22"/>
                                    <RowDefinition Height="26"/>
                                    <RowDefinition Height="26"/>
                                    <RowDefinition Height="26"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="1" Text="OUI" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="NON" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Communication avec l'école" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <RadioButton Grid.Row="1" Grid.Column="1" x:Name="Autor1Oui" GroupName="Autor1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="1" Grid.Column="2" x:Name="Autor1Non" GroupName="Autor1" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Partage avec confrères / spécialistes" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <RadioButton Grid.Row="2" Grid.Column="1" x:Name="Autor2Oui" GroupName="Autor2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="2" Grid.Column="2" x:Name="Autor2Non" GroupName="Autor2" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Utilisation anonymisée pour recherche / études" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <RadioButton Grid.Row="3" Grid.Column="1" x:Name="Autor3Oui" GroupName="Autor3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton Grid.Row="3" Grid.Column="2" x:Name="Autor3Non" GroupName="Autor3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Bouton Valider -->
            <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="0,1,0,0" Padding="12,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" FontSize="11"
                               Foreground="#27AE60" Margin="0,0,16,0"/>
                    <Button x:Name="BtnAnnuler" Content="Annuler" Click="BtnAnnuler_Click"
                            Padding="16,8" Margin="0,0,8,0" FontSize="12"
                            Background="#ECF0F1" BorderThickness="1" BorderBrush="#BDC3C7" Cursor="Hand"/>
                    <Button x:Name="BtnValider" Content="✅ Valider" Click="BtnValider_Click"
                            Padding="16,8" FontSize="12" FontWeight="SemiBold"
                            Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#219A52"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

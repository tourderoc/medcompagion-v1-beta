<Window x:Class="MedCompanion.Dialogs.DocumentDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:MedCompanion.Helpers"
        mc:Ignorable="d"
        Title="📄 Détail du document"
        Height="700" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6FA"
        MinHeight="500" MinWidth="650">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock x:Name="HeaderFileName" Text="📄 nom-fichier.pdf"
                           Foreground="White" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="HeaderMeta" Text="Catégorie • Date"
                           Foreground="#BDC3C7" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Corps : alterne vue READ-ONLY (RichTextBox) et vue EDIT (TextBox) -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="2">
            <Grid>
                <!-- Vue READ-ONLY : Markdown formaté -->
                <RichTextBox x:Name="ContentRichTextBox"
                             IsReadOnly="True" Background="Transparent" BorderThickness="0"
                             Padding="14" FontSize="13" Foreground="#2C3E50"
                             VerticalScrollBarVisibility="Auto"
                             Visibility="Visible"/>
                <!-- Vue EDIT : Markdown brut éditable -->
                <TextBox x:Name="ContentEditTextBox"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontFamily="Consolas" FontSize="12" Padding="14"
                         Background="#FAFAFA" BorderBrush="#3498DB" BorderThickness="1"
                         VerticalScrollBarVisibility="Auto"
                         Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Barre boutons -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Statut éventuel -->
            <TextBlock Grid.Column="0" x:Name="StatusText" FontSize="11" Foreground="#7F8C8D"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>

            <!-- Boutons à droite -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <!-- Mode LECTURE : Modifier / Fermer -->
                <Button x:Name="EditButton" Content="✏️ Modifier"
                        Click="EditButton_Click"
                        Padding="12,7" Background="#3498DB" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="12" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Mode ÉDITION : Enregistrer / Annuler -->
                <Button x:Name="SaveButton" Content="💾 Enregistrer"
                        Click="SaveButton_Click" Visibility="Collapsed"
                        Padding="12,7" Background="#27AE60" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="12" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="CancelEditButton" Content="✖ Annuler"
                        Click="CancelEditButton_Click" Visibility="Collapsed"
                        Padding="12,7" Background="#95A5A6" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="12" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Toujours : Fermer -->
                <Button Content="Fermer" Click="CloseButton_Click"
                        Padding="12,7" Background="#34495E" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="12">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

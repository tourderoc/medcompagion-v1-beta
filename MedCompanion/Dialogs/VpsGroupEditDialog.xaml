<Window x:Class="MedCompanion.Dialogs.VpsGroupEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifier le groupe" Height="540" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="White"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="✏️ Modifier le groupe" FontSize="20" FontWeight="Bold"
                   Foreground="White" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="ID (lecture seule)"/>
            <TextBox x:Name="IdBox" IsReadOnly="True" Background="#252525" Foreground="#888"/>

            <TextBlock Text="Titre"/>
            <TextBox x:Name="TitreBox"/>

            <TextBlock Text="Thème"/>
            <ComboBox x:Name="ThemeBox">
                <ComboBoxItem Content="ecole"/>
                <ComboBoxItem Content="comportement"/>
                <ComboBoxItem Content="emotions"/>
                <ComboBoxItem Content="developpement"/>
                <ComboBoxItem Content="autre"/>
            </ComboBox>

            <TextBlock Text="Date vocal (locale)"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <DatePicker x:Name="DatePickerVocal" Background="#2D2D2D" Margin="0,4,8,10"/>
                <TextBox x:Name="TimeBox" Grid.Column="1" Width="80" Text="20:30" ToolTip="HH:mm"/>
            </Grid>

            <TextBlock Text="Participants max"/>
            <TextBox x:Name="MaxBox"/>

            <TextBlock Text="Statut"/>
            <ComboBox x:Name="StatusBox">
                <ComboBoxItem Content="scheduled"/>
                <ComboBoxItem Content="in_progress"/>
                <ComboBoxItem Content="completed"/>
                <ComboBoxItem Content="cancelled"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Annuler" Padding="20,8" Margin="0,0,10,0"
                    Background="#3D3D3D" Foreground="White" BorderThickness="0"
                    Click="Cancel_Click"/>
            <Button Content="💾 Enregistrer" Padding="20,8"
                    Background="#27AE60" Foreground="White" BorderThickness="0"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="MedCompanion.Dialogs.ProfileEvaluationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Évaluation profil"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8F9FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="16,12">
            <TextBlock Text="{Binding SphereTitle}"
                       Foreground="White" FontSize="16" FontWeight="SemiBold"/>
        </Border>

        <!-- Axes avec sliders -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Axes}" Margin="20,16,20,8">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="42"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                   VerticalAlignment="Center" FontSize="13"
                                   Foreground="#2C3E50"/>

                        <Slider Grid.Column="1"
                                Value="{Binding Value, Mode=TwoWay}"
                                Minimum="0" Maximum="5"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                TickPlacement="BottomRight"
                                VerticalAlignment="Center"/>

                        <Border Grid.Column="2" Margin="6,0,0,0"
                                Background="#2C3E50" CornerRadius="4"
                                Width="36" Height="22">
                            <TextBlock Text="{Binding ValueLabel}"
                                       Foreground="White"
                                       FontSize="11" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Légende -->
        <TextBlock Grid.Row="2" Margin="20,0,20,12"
                   Text="0 = Non renseigné  |  1 = Très faible  |  3 = Moyen  |  5 = Très élevé"
                   FontSize="11" Foreground="#7F8C8D" FontStyle="Italic"/>

        <!-- Boutons -->
        <Border Grid.Row="3" Background="#ECEFF1" Padding="12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuler" Click="Annuler_Click"
                        Width="90" Height="32" Margin="0,0,8,0"
                        Background="#BDC3C7" Foreground="#2C3E50"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#BDC3C7"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#A8B2B8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="✔ Sauvegarder" Click="Sauvegarder_Click"
                        Width="130" Height="32"
                        Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1ABC9C"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#17A589"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>

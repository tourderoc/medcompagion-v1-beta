<Window x:Class="MedCompanion.Dialogs.QuickReplyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification rapide" Height="560" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentColor" Color="#E67E22"/>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="ButtonBackground" Color="#3D3D3D"/>
        <SolidColorBrush x:Key="AIColor" Color="#9B59B6"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Notification rapide" FontSize="20" FontWeight="Bold" Foreground="White"/>
            <TextBlock x:Name="RecipientText" Text="Destinataire: —" FontSize="12" Foreground="#888888" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Catégories -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <RadioButton x:Name="RdvRadio" Content="RDV" GroupName="Category" IsChecked="True"
                         Foreground="White" Margin="0,0,15,0" Checked="Category_Changed"/>
            <RadioButton x:Name="DoctoLibRadio" Content="Doctolib" GroupName="Category"
                         Foreground="White" Margin="0,0,15,0" Checked="Category_Changed"/>
            <RadioButton x:Name="InfoRadio" Content="Info" GroupName="Category"
                         Foreground="White" Margin="0,0,15,0" Checked="Category_Changed"/>
            <RadioButton x:Name="CustomRadio" Content="Personnalis&#233;" GroupName="Category"
                         Foreground="White" Checked="Category_Changed"/>
        </StackPanel>

        <!-- Templates ou zone personnalisée -->
        <Grid Grid.Row="2">
            <!-- Liste des templates -->
            <ListBox x:Name="TemplatesListBox" Background="Transparent" BorderThickness="0"
                     SelectionChanged="TemplatesListBox_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0,3"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E67E22"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D3D3D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="White" FontSize="13"/>
                            <TextBlock Text="{Binding Body}" Foreground="#AAAAAA" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Zone personnalisée -->
            <StackPanel x:Name="CustomPanel" Visibility="Collapsed">
                <TextBlock Text="Message" Foreground="#888888" FontSize="11" Margin="0,0,0,5"/>
                <TextBox x:Name="CustomBodyBox" Height="120" Background="#3D3D3D" Foreground="White"
                         BorderThickness="0" Padding="10" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Bouton Reformuler IA -->
                <Button x:Name="ReformulateBtn" Content="&#x2728; Reformuler avec IA"
                        Padding="14,8" Margin="0,10,0,0"
                        Background="{StaticResource AIColor}" Foreground="White"
                        FontWeight="SemiBold" FontSize="12"
                        BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Left"
                        Click="ReformulateBtn_Click"
                        ToolTip="Corrige l'orthographe et génère un titre automatiquement"/>

                <!-- Indicateur de chargement IA -->
                <StackPanel x:Name="AILoadingPanel" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                    <TextBlock Text="Reformulation en cours..." Foreground="{StaticResource AIColor}" FontSize="11" FontStyle="Italic"/>
                </StackPanel>

                <!-- Titre (rempli par IA ou manuellement) -->
                <TextBlock Text="Titre" Foreground="#888888" FontSize="11" Margin="0,10,0,5"/>
                <TextBox x:Name="CustomTitleBox" Height="35" Background="#3D3D3D" Foreground="White"
                         BorderThickness="0" Padding="10,8"/>
            </StackPanel>
        </Grid>

        <!-- Aperçu -->
        <Border Grid.Row="3" Background="{StaticResource CardBackground}" CornerRadius="6"
                Padding="12" Margin="0,15,0,0">
            <StackPanel>
                <TextBlock Text="APERCU NOTIFICATION" FontSize="10" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,8"/>
                <Border Background="#252525" CornerRadius="4" Padding="10">
                    <StackPanel>
                        <TextBlock x:Name="PreviewTitle" Text="Titre..." FontWeight="SemiBold"
                                   Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="PreviewBody" Text="Corps du message..."
                                   Foreground="#CCCCCC" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Boutons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Annuler" Padding="20,10" Background="#3D3D3D" Foreground="White"
                    BorderThickness="0" Click="Cancel_Click" Cursor="Hand"/>
            <Button x:Name="SendButton" Content="Envoyer la notification" Padding="20,10" Margin="10,0,0,0"
                    Background="{StaticResource AccentColor}" Foreground="White"
                    BorderThickness="0" Click="Send_Click" Cursor="Hand" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MedCompanion.Dialogs.SphereEvaluationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:MedCompanion.Converters"
        Title="Compléter la sphère"
        Width="500" SizeToContent="Height"
        MaxHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6FA"
        ResizeMode="NoResize">

    <Window.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre sphère -->
        <TextBlock Grid.Row="0" Text="{Binding Label}" FontSize="15" FontWeight="Bold"
                   Foreground="#2C3E50" Margin="0,0,0,6"/>

        <!-- Phrase boussole -->
        <TextBlock Grid.Row="1" Text="{Binding PhraseBoussole}" FontSize="11" FontStyle="Italic"
                   Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,0,0,14"/>

        <!-- Items (checkboxes) -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <ItemsControl ItemsSource="{Binding Segment.Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                  Margin="0,5,0,5" FontSize="12" FontFamily="Segoe UI"
                                  Cursor="Hand">
                            <TextBlock Text="{Binding Affirmation}" TextWrapping="Wrap" FontSize="12"/>
                        </CheckBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Score / Niveau -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                CornerRadius="6" Padding="14,9" Margin="0,0,0,18">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Score, StringFormat='Score : {0}/6'}"
                           FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <Border CornerRadius="10" Padding="10,3"
                        Background="{Binding NiveauColor, Converter={StaticResource StringToBrush}}">
                    <TextBlock Text="{Binding NiveauLabel}" FontSize="11" FontWeight="SemiBold"
                               Foreground="#2C3E50"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Boutons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" Click="Annuler_Click"
                    Padding="14,7" Background="White" Foreground="#555"
                    BorderBrush="#CCC" BorderThickness="1"
                    FontSize="12" FontFamily="Segoe UI" Cursor="Hand" Margin="0,0,10,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="✓ Sauvegarder et fermer" Click="Sauvegarder_Click"
                    Padding="14,7" Background="#27AE60" Foreground="White" BorderThickness="0"
                    FontSize="12" FontFamily="Segoe UI" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#229954"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>

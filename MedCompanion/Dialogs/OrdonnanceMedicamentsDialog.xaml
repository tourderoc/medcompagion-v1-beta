<Window x:Class="MedCompanion.Dialogs.OrdonnanceMedicamentsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ordonnances="clr-namespace:MedCompanion.Views.Ordonnances"
        mc:Ignorable="d"
        Title="💊 Ordonnance de Médicaments"
        Height="780" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6FA"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="700">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0"
                Background="#9B59B6"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="💊 Ordonnance de Médicaments"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="PatientHeaderText"
                           Foreground="White"
                           FontSize="13"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,40,0"
                           Opacity="0.9"/>
            </Grid>
        </Border>

        <!-- Contenu : le UserControl MedicamentsControl existant -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="15"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <ordonnances:MedicamentsControl x:Name="MedicamentsHostedControl"/>
        </Border>

        <!-- Bouton Fermer en bas -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="CloseButton"
                    Content="✕ Fermer"
                    Height="40"
                    Padding="20,0"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Background="#95A5A6"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CloseButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7F8C8D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>

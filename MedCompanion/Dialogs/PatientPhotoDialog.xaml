<Window x:Class="MedCompanion.Dialogs.PatientPhotoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photo du patient" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderTextBlock" Text="Ajouter une photo de l'enfant" FontSize="18" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <StackPanel x:Name="ConsentPanel">
                <TextBlock Text="Pour activer votre mémoire visuelle, vous pouvez ajouter une photo du patient." TextWrapping="Wrap" Margin="0,0,0,15"/>
                
                <CheckBox x:Name="ConsentCheckBox" 
                          Content="Je confirme avoir l'accord du parent ou représentant légal pour prendre et conserver cette photo."
                          IsChecked="False"
                          Checked="ConsentCheckBox_Changed"
                          Unchecked="ConsentCheckBox_Changed"
                          Margin="0,0,0,20">
                    <CheckBox.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </CheckBox.ContentTemplate>
                </CheckBox>
            </StackPanel>

            <Image x:Name="ExistingPhotoImg" Width="150" Height="150" HorizontalAlignment="Center" Margin="0,0,0,20" Visibility="Collapsed" Stretch="UniformToFill">
                <Image.Clip>
                    <EllipseGeometry Center="75,75" RadiusX="75" RadiusY="75" />
                </Image.Clip>
            </Image>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="ImportFileBtn" Content="Importer un fichier" Width="140" Height="35" Margin="0,0,10,0" IsEnabled="False" Click="ImportFileBtn_Click" Background="#1976D2" Foreground="White" BorderThickness="0"/>
                <Button x:Name="CameraBtn" Content="Prendre photo" Width="140" Height="35" IsEnabled="False" Click="CameraBtn_Click" Background="#1976D2" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Annuler" Width="100" Height="30" Margin="0,0,10,0" Click="CancelBtn_Click" Background="Transparent" Foreground="#1976D2" BorderBrush="#1976D2"/>
        </StackPanel>
    </Grid>
</Window>

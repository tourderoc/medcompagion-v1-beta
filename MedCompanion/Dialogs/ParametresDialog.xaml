<Window x:Class="MedCompanion.Dialogs.ParametresDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MedCompanion.Converters"
        Title="⚙️ Paramètres"
        Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:RadioButtonConverter x:Key="RadioButtonConverter"/>
        
        <!-- Style pour les boutons modernes -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Contenu principal avec onglets -->
        <TabControl Grid.Row="0" Margin="0,0,0,20">
            
            <!-- Onglet API -->
            <TabItem Header="🔑 API">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        
                        <!-- En-tête explicatif -->
                        <Border Background="#E7F3FF" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="13" Foreground="#0066CC" Margin="0,0,0,5">
                                    🔐 Stockage sécurisé
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#0066CC">
                                    Les clés API sont chiffrées avec DPAPI et stockées localement sur votre ordinateur.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        
                        <!-- OpenAI API Key -->
                        <TextBlock Text="OpenAI API Key" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- PasswordBox ou TextBox selon IsPasswordVisible -->
                            <PasswordBox x:Name="OpenAIPasswordBox" 
                                        Grid.Column="0"
                                        Height="35"
                                        Padding="10,8"
                                        FontSize="12"
                                        PasswordChar="●"
                                        Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            
                            <TextBox x:Name="OpenAITextBox"
                                    Grid.Column="0"
                                    Text="{Binding OpenAIApiKey, UpdateSourceTrigger=PropertyChanged}"
                                    Height="35"
                                    Padding="10,8"
                                    FontSize="12"
                                    FontFamily="Consolas"
                                    Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            
                            <!-- Bouton toggle visibilité -->
                            <Button Grid.Column="1" 
                                   Content="👁️"
                                   Width="40"
                                   Height="35"
                                   Margin="5,0,0,0"
                                   Command="{Binding TogglePasswordVisibilityCommand}"
                                   ToolTip="Afficher/Masquer la clé"
                                   Style="{StaticResource ModernButtonStyle}"
                                   Background="#6C757D"
                                   Foreground="White"/>
                        </Grid>
                        
                        <!-- Bouton tester connexion -->
                        <Button Command="{Binding TestConnectionCommand}"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,10"
                               Style="{StaticResource ModernButtonStyle}"
                               Background="#007BFF"
                               Foreground="White">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔄 " FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Tester la connexion"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTestingConnection}" Value="True">
                                                    <Setter Property="Text" Value="Test en cours..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        
                        <!-- Statut de connexion -->
                        <Border Padding="12" 
                               CornerRadius="5" 
                               Margin="0,0,0,20"
                               Visibility="{Binding ConnectionStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#D4EDDA"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConnectionSuccess}" Value="False">
                                            <Setter Property="Background" Value="#F8D7DA"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ConnectionStatus}" 
                                      TextWrapping="Wrap" 
                                      FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#155724"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ConnectionSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="#721C24"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        
                        <!-- Séparateur -->
                        <Separator Margin="0,10,0,20"/>

                         <!-- Modèle d'Anonymisation (Local) -->
                        <Border Background="#E8F8F5" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="13" Foreground="#16A085" Margin="0,0,0,5">
                                    🛡️ Sécurité &amp; Confidentialité
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#16A085" Margin="0,0,0,10">
                                    Pour l'extraction de données sensibles (PII), un modèle local est OBLIGATOIRE.
                                    Ce modèle tournera uniquement sur votre machine via Ollama.
                                </TextBlock>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <ComboBox x:Name="AnonymizationModelCombo"
                                              Grid.Column="0"
                                              Height="35"
                                              Padding="10,8"
                                              FontSize="12"
                                              VerticalContentAlignment="Center"
                                              Background="White"/>
                                              
                                    <Button x:Name="RefreshLocalModelsBtn"
                                            Grid.Column="1"
                                            Content="🔄"
                                            Width="40"
                                            Height="35"
                                            Margin="5,0,0,0"
                                            Click="RefreshLocalModelsBtn_Click"
                                            ToolTip="Rafraîchir la liste des modèles locaux (Ollama)"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Background="#16A085"
                                            Foreground="White"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Séparateur -->
                        <Separator Margin="0,10,0,20"/>
                        
                        <!-- Ollama Web API Key (pour le sub-agent recherche web) -->
                        <TextBlock Text="Ollama Web API Key" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <PasswordBox x:Name="OllamaWebPasswordBox"
                                        Grid.Column="0"
                                        Height="35"
                                        Padding="10,8"
                                        FontSize="12"
                                        PasswordChar="●"/>

                            <Button Grid.Column="1"
                                   x:Name="TestOllamaWebBtn"
                                   Content="🧪"
                                   Width="40"
                                   Height="35"
                                   Margin="5,0,0,0"
                                   Click="TestOllamaWebConnection_Click"
                                   ToolTip="Tester la connexion Ollama Web"
                                   Style="{StaticResource ModernButtonStyle}"
                                   Background="#16A085"
                                   Foreground="White"/>
                        </Grid>

                        <TextBlock TextWrapping="Wrap"
                                  FontSize="11"
                                  Foreground="#16A085"
                                  Margin="0,0,0,10">
                            Clé API Ollama pour la recherche web (ollama.com/settings/keys). Nécessaire pour le Sub-Agent Web.
                        </TextBlock>

                        <!-- Séparateur -->
                        <Separator Margin="0,10,0,20"/>

                        <!-- Configuration SMTP Pilotage -->
                        <Border Background="#FCE4EC" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="13" Foreground="#AD1457" Margin="0,0,0,5">
                                    📧 Email Pilotage (Parent'aile)
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#AD1457">
                                    Configuration SMTP Gmail pour envoyer des emails aux parents via parentaile.lassoued@gmail.com.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Mot de passe SMTP -->
                        <TextBlock Text="Mot de passe d'application Gmail" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <PasswordBox x:Name="SmtpPasswordBox"
                                        Grid.Column="0"
                                        Height="35"
                                        Padding="10,8"
                                        FontSize="12"
                                        PasswordChar="●"/>

                            <Button Grid.Column="1"
                                   x:Name="TestSmtpBtn"
                                   Content="🧪"
                                   Width="40"
                                   Height="35"
                                   Margin="5,0,0,0"
                                   Click="TestSmtpConnection_Click"
                                   ToolTip="Tester la configuration SMTP"
                                   Style="{StaticResource ModernButtonStyle}"
                                   Background="#AD1457"
                                   Foreground="White"/>
                        </Grid>

                        <TextBlock TextWrapping="Wrap"
                                  FontSize="11"
                                  Foreground="#666"
                                  Margin="0,0,0,10">
                            Mot de passe d'application Gmail (16 caractères sans espaces).
                            Les emails seront envoyés via smtp.gmail.com (TLS, port 587).
                        </TextBlock>

                        <!-- Séparateur -->
                        <Separator Margin="0,10,0,15"/>

                        <!-- Configuration VPS Monitoring -->
                        <Border Background="#E8F5E9" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="13" Foreground="#2E7D32" Margin="0,0,0,5">
                                    🖥️ Serveur VPS (Parent'aile)
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#2E7D32">
                                    Supervision du serveur VPS depuis MedCompanion. Le token est chiffré localement.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- URL du VPS -->
                        <TextBlock Text="URL du monitoring" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="VpsUrlTextBox"
                                 Height="35"
                                 Padding="10,8"
                                 FontSize="12"
                                 Margin="0,0,0,10"
                                 Text="http://145.223.117.145:5050"/>

                        <!-- Token d'accès -->
                        <TextBlock Text="Token d'accès" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="VpsTokenBox"
                                         Grid.Column="0"
                                         Height="35"
                                         Padding="10,8"
                                         FontSize="12"
                                         PasswordChar="●"/>
                            <Button Grid.Column="1"
                                    x:Name="TestVpsBtn"
                                    Content="🧪"
                                    Width="40"
                                    Height="35"
                                    Margin="5,0,0,0"
                                    Click="TestVpsConnection_Click"
                                    ToolTip="Tester la connexion au VPS"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="#2E7D32"
                                    Foreground="White"/>
                        </Grid>

                        <!-- Activer -->
                        <CheckBox x:Name="VpsEnabledCheckBox"
                                  Content="Activer la supervision VPS"
                                  FontSize="12"
                                  Margin="0,0,0,5"/>

                        <TextBlock TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="#666"
                                   Margin="0,0,0,10">
                            Le token doit correspondre à celui configuré sur le script monitor.py du VPS.
                        </TextBlock>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Onglet Sécurité -->
            <TabItem Header="🔒 Sécurité">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- En-tête explicatif -->
                        <Border Background="#E8F5E9" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="13" Foreground="#2E7D32" Margin="0,0,0,5">
                                    🔐 Protection de l'application
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#2E7D32">
                                    Configurez la sécurité de MedCompanion. Un mot de passe est requis après 3 jours d'absence, sinon un code PIN suffit.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Activer/Désactiver la sécurité -->
                        <Border Background="White" Padding="15" CornerRadius="5" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Authentification au démarrage" FontWeight="Bold" FontSize="13" Margin="0,0,0,3"/>
                                    <TextBlock Text="Demande un code PIN ou mot de passe pour accéder à l'application"
                                               FontSize="11" Foreground="Gray"/>
                                </StackPanel>

                                <CheckBox x:Name="SecurityEnabledCheckBox"
                                          Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Checked="SecurityEnabledCheckBox_Changed"
                                          Unchecked="SecurityEnabledCheckBox_Changed"/>
                            </Grid>
                        </Border>

                        <!-- Section modification mot de passe -->
                        <Border x:Name="PasswordSection" Background="White" Padding="15" CornerRadius="5" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Modifier le mot de passe" FontWeight="Bold" FontSize="13" Margin="0,0,0,15"/>

                                <TextBlock Text="Mot de passe actuel" FontSize="12" Margin="0,0,0,5"/>
                                <PasswordBox x:Name="CurrentPasswordBox" Height="35" Padding="10,8" FontSize="12" Margin="0,0,0,10"/>

                                <TextBlock Text="Nouveau mot de passe" FontSize="12" Margin="0,0,0,5"/>
                                <PasswordBox x:Name="NewPasswordBox" Height="35" Padding="10,8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock Text="Minimum 6 caractères" FontSize="10" Foreground="Gray" Margin="0,0,0,10"/>

                                <TextBlock Text="Confirmer le nouveau mot de passe" FontSize="12" Margin="0,0,0,5"/>
                                <PasswordBox x:Name="ConfirmNewPasswordBox" Height="35" Padding="10,8" FontSize="12" Margin="0,0,0,15"/>

                                <Button x:Name="ChangePasswordButton"
                                        Content="Modifier le mot de passe"
                                        Click="ChangePassword_Click"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Background="#1976D2"
                                        Foreground="White"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- Section modification code PIN -->
                        <Border x:Name="PinSection" Background="White" Padding="15" CornerRadius="5" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Modifier le code PIN" FontWeight="Bold" FontSize="13" Margin="0,0,0,15"/>

                                <TextBlock Text="Mot de passe (pour confirmer)" FontSize="12" Margin="0,0,0,5"/>
                                <PasswordBox x:Name="PasswordForPinBox" Height="35" Padding="10,8" FontSize="12" Margin="0,0,0,10"/>

                                <TextBlock Text="Nouveau code PIN (4 chiffres)" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="NewPinBox"
                                         Height="35"
                                         Padding="10,8"
                                         FontSize="12"
                                         MaxLength="4"
                                         PreviewTextInput="PinBox_PreviewTextInput"
                                         Margin="0,0,0,15"/>

                                <Button x:Name="ChangePinButton"
                                        Content="Modifier le code PIN"
                                        Click="ChangePin_Click"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Background="#1976D2"
                                        Foreground="White"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- Message de statut -->
                        <TextBlock x:Name="SecurityStatusText"
                                   Text=""
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>

                        <!-- Section Réinitialisation (pour tests) -->
                        <Border Background="#FFEBEE" Padding="15" CornerRadius="5" Margin="0,20,0,0" BorderBrush="#FFCDD2" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Zone de test / développement" FontWeight="Bold" FontSize="13" Foreground="#C62828" Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#C62828" Margin="0,0,0,15">
                                    Réinitialiser supprime tous les paramètres de sécurité. Au prochain démarrage, l'assistant de configuration s'affichera comme lors de la première utilisation.
                                </TextBlock>
                                <Button x:Name="ResetSecurityButton"
                                        Content="Réinitialiser la sécurité"
                                        Click="ResetSecurity_Click"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Background="#C62828"
                                        Foreground="White"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Onglet Affichage -->
            <TabItem Header="🖥️ Affichage">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- En-tête explicatif -->
                        <Border Background="#FFF3CD" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="13" Foreground="#856404" Margin="0,0,0,5">
                                    💡 Préférences d'affichage
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#856404">
                                    Configurez comment la fenêtre principale s'affiche au démarrage de l'application.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Options de démarrage -->
                        <TextBlock Text="Au démarrage de l'application :" FontWeight="Bold" FontSize="13" Margin="0,0,0,15"/>

                        <RadioButton GroupName="StartupMode"
                                    Content="Se souvenir du dernier état"
                                    IsChecked="{Binding StartupPreference, Converter={StaticResource RadioButtonConverter}, ConverterParameter=Remember}"
                                    Margin="0,0,0,12"
                                    FontSize="12">
                            <RadioButton.ToolTip>
                                <ToolTip>
                                    <TextBlock TextWrapping="Wrap" MaxWidth="300">
                                        L'application se souviendra de la position, taille et état (normal/maximisé) de la dernière session.
                                    </TextBlock>
                                </ToolTip>
                            </RadioButton.ToolTip>
                        </RadioButton>

                        <RadioButton GroupName="StartupMode"
                                    Content="Toujours démarrer en mode fenêtré"
                                    IsChecked="{Binding StartupPreference, Converter={StaticResource RadioButtonConverter}, ConverterParameter=Windowed}"
                                    Margin="0,0,0,12"
                                    FontSize="12">
                            <RadioButton.ToolTip>
                                <ToolTip>
                                    <TextBlock TextWrapping="Wrap" MaxWidth="300">
                                        L'application démarrera toujours en mode fenêtré (non maximisé).
                                    </TextBlock>
                                </ToolTip>
                            </RadioButton.ToolTip>
                        </RadioButton>

                        <RadioButton GroupName="StartupMode"
                                    Content="Toujours démarrer maximisé"
                                    IsChecked="{Binding StartupPreference, Converter={StaticResource RadioButtonConverter}, ConverterParameter=Maximized}"
                                    Margin="0,0,0,12"
                                    FontSize="12">
                            <RadioButton.ToolTip>
                                <ToolTip>
                                    <TextBlock TextWrapping="Wrap" MaxWidth="300">
                                        L'application démarrera toujours en plein écran (maximisé).
                                    </TextBlock>
                                </ToolTip>
                            </RadioButton.ToolTip>
                        </RadioButton>

                        <!-- Séparateur -->
                        <Separator Margin="0,20,0,20"/>

                        <!-- Section Handy (Dictée vocale) -->
                        <Border Background="#E8F5E9" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="13" Foreground="#2E7D32" Margin="0,0,0,5">
                                    🎙️ Dictée vocale (Handy)
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#2E7D32">
                                    Handy permet la transcription vocale locale. Configurez le raccourci clavier qui déclenche l'enregistrement dans Handy.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Activer Handy -->
                        <Border Background="White" Padding="15" CornerRadius="5" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Activer la dictée vocale" FontWeight="Bold" FontSize="13" Margin="0,0,0,3"/>
                                    <TextBlock Text="Affiche un bouton micro dans les zones de saisie"
                                               FontSize="11" Foreground="Gray"/>
                                </StackPanel>

                                <CheckBox x:Name="HandyEnabledCheckBox"
                                          Grid.Column="1"
                                          VerticalAlignment="Center"
                                          IsChecked="True"/>
                            </Grid>
                        </Border>

                        <!-- Raccourci Handy -->
                        <TextBlock Text="Raccourci clavier Handy" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="HandyHotkeyCombo"
                                      Grid.Column="0"
                                      Height="35"
                                      Padding="10,8"
                                      FontSize="12"
                                      VerticalContentAlignment="Center"
                                      IsEditable="True">
                                <ComboBoxItem Content="Ctrl+Space" IsSelected="True"/>
                                <ComboBoxItem Content="Ctrl+Shift+H"/>
                                <ComboBoxItem Content="Ctrl+Shift+V"/>
                                <ComboBoxItem Content="Alt+V"/>
                                <ComboBoxItem Content="F9"/>
                            </ComboBox>

                            <Button x:Name="TestHandyBtn"
                                    Grid.Column="1"
                                    Content="🧪"
                                    Width="40"
                                    Height="35"
                                    Margin="5,0,0,0"
                                    Click="TestHandy_Click"
                                    ToolTip="Tester le raccourci Handy"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="#4CAF50"
                                    Foreground="White"/>
                        </Grid>

                        <TextBlock TextWrapping="Wrap"
                                  FontSize="11"
                                  Foreground="Gray"
                                  Margin="0,0,0,10">
                            Ce raccourci doit correspondre à celui configuré dans Handy. Par défaut : Ctrl+Space.
                        </TextBlock>

                        <!-- Info Handy -->
                        <Border Background="#FFF3CD" Padding="10" CornerRadius="5" Margin="0,10,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#856404">
                                💡 Handy doit être installé et en cours d'exécution. Téléchargez-le sur handy.dev si besoin.
                            </TextBlock>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
                        <!-- Onglet Prompt Tracker -->
            <TabItem Header="🔍 Prompt Tracker">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="180"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Filtres et actions -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Module :" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="ModuleFilterCombo" Width="150" SelectionChanged="ModuleFilter_Changed">
                            <ComboBoxItem Content="Tous" IsSelected="True"/>
                            <ComboBoxItem Content="Courrier"/>
                            <ComboBoxItem Content="Chat"/>
                            <ComboBoxItem Content="Synthèse"/>
                            <ComboBoxItem Content="Attestation"/>
                            <ComboBoxItem Content="Note"/>
                        </ComboBox>
                        
                        <Button Content="🔄 Rafraîchir" 
                                Click="RefreshPrompts_Click"
                                Margin="10,0,0,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Background="#007BFF"
                                Foreground="White"/>
                                
                        <Button Content="💾 Exporter" 
                                Click="ExportPrompts_Click"
                                Margin="10,0,0,0"
                                Style="{StaticResource ModernButtonStyle}"
                                Background="#28A745"
                                Foreground="White"/>
                    </StackPanel>
                    
                    <!-- Liste des prompts -->
                    <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,10">
                        <ListBox x:Name="PromptHistoryList" 
                                 SelectionChanged="PromptHistory_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding DisplayText}" FontSize="12" FontFamily="Consolas"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                    
                    <!-- Détails du prompt sélectionné -->
                    <TabControl Grid.Row="2">
                        <TabItem Header="System Prompt">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="SystemPromptText" 
                                         TextWrapping="Wrap" 
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="5"/>
                            </ScrollViewer>
                        </TabItem>
                        
                        <TabItem Header="User Prompt">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="UserPromptText" 
                                         TextWrapping="Wrap" 
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="5"/>
                            </ScrollViewer>
                        </TabItem>
                        
                        <TabItem Header="Réponse IA">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="AIResponseText" 
                                         TextWrapping="Wrap" 
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="5"/>
                            </ScrollViewer>
                        </TabItem>
                        
                        <TabItem Header="📊 Stats">
                            <StackPanel Margin="20">
                                <TextBlock x:Name="TotalPromptsText" FontSize="14" Margin="0,0,0,10"/>
                                <TextBlock x:Name="TotalTokensText" FontSize="14" Margin="0,0,0,10"/>
                                <TextBlock x:Name="SuccessRateText" FontSize="14" Margin="0,0,0,10"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                    
                    <!-- Info -->
                    <Border Grid.Row="3" Background="#E7F3FF" Padding="10" CornerRadius="5" Margin="0,10,0,0">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#0066CC">
                            💡 Les 10 derniers prompts sont conservés en mémoire. Utilisez "Exporter" pour sauvegarder.
                        </TextBlock>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Onglet Agents -->
            <TabItem Header="🤖 Agents">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- En-tête explicatif -->
                        <Border Background="#E3F2FD" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="13" Foreground="#1565C0" Margin="0,0,0,5">
                                    🤖 Configuration des Agents IA
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#1565C0">
                                    Configurez le comportement de Med et des futurs agents. Chaque agent peut utiliser un LLM différent et avoir sa propre "posture" (personnalité).
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Agent Med -->
                        <Border Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15" BorderBrush="#90CAF9" BorderThickness="2">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar Med -->
                                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25" Background="#E3F2FD" BorderBrush="#3498DB" BorderThickness="2" Margin="0,0,15,0">
                                        <TextBlock Text="Med" FontSize="14" FontWeight="Bold" Foreground="#3498DB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Info Med -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Med" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                                        <TextBlock Text="Assistant IA bienveillant pour la réflexion clinique" FontSize="11" Foreground="#7F8C8D"/>
                                    </StackPanel>

                                    <!-- Toggle Actif -->
                                    <CheckBox x:Name="MedEnabledCheckBox"
                                              Grid.Column="2"
                                              Content="Actif"
                                              IsChecked="True"
                                              VerticalAlignment="Center"
                                              FontWeight="SemiBold"/>
                                </Grid>

                                <!-- Séparateur -->
                                <Separator Margin="0,0,0,15"/>

                                <!-- Provider LLM -->
                                <TextBlock Text="Provider LLM" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <ComboBox x:Name="MedLLMProviderCombo"
                                          Height="35"
                                          Padding="10,8"
                                          FontSize="12"
                                          VerticalContentAlignment="Center"
                                          SelectionChanged="MedLLMProvider_SelectionChanged"
                                          Margin="0,0,0,15">
                                    <ComboBoxItem Content="OpenAI" IsSelected="True"/>
                                    <ComboBoxItem Content="Ollama"/>
                                </ComboBox>

                                <!-- Modèle LLM -->
                                <TextBlock Text="Modèle" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="MedLLMModelCombo"
                                              Grid.Column="0"
                                              Height="35"
                                              Padding="10,8"
                                              FontSize="12"
                                              VerticalContentAlignment="Center"
                                              IsEditable="True">
                                        <ComboBoxItem Content="gpt-4o-mini" IsSelected="True"/>
                                        <ComboBoxItem Content="gpt-4o"/>
                                        <ComboBoxItem Content="gpt-4-turbo"/>
                                    </ComboBox>

                                    <Button x:Name="RefreshMedModelsBtn"
                                            Grid.Column="1"
                                            Content="🔄"
                                            Width="40"
                                            Height="35"
                                            Margin="5,0,0,0"
                                            Click="RefreshMedModels_Click"
                                            ToolTip="Rafraîchir la liste des modèles"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Background="#3498DB"
                                            Foreground="White"/>
                                </Grid>

                                <!-- Température -->
                                <TextBlock Text="Température (créativité)" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Slider x:Name="MedTemperatureSlider"
                                            Grid.Column="0"
                                            Minimum="0"
                                            Maximum="1"
                                            Value="0.7"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"
                                            Margin="0,0,15,0"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ElementName=MedTemperatureSlider, Path=Value, StringFormat={}{0:F1}}"
                                               FontFamily="Consolas"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="#3498DB"
                                               VerticalAlignment="Center"
                                               MinWidth="40"/>
                                </Grid>

                                <!-- Posture -->
                                <TextBlock Text="Posture de Med (personnalité et instructions)" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="MedPostureTextBox"
                                         Height="200"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="12"
                                         Padding="10"
                                         BorderBrush="#E0E0E0"
                                         BorderThickness="1"/>

                                <!-- Bouton reset posture -->
                                <Button x:Name="ResetMedPostureBtn"
                                        Content="Réinitialiser la posture par défaut"
                                        Click="ResetMedPosture_Click"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Background="#6C757D"
                                        Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- Sub-Agent Web (Recherche) -->
                        <Border Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15" BorderBrush="#81C784" BorderThickness="2">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar Web -->
                                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25" Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="2" Margin="0,0,15,0">
                                        <TextBlock Text="🌐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Info Web -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Web" FontSize="16" FontWeight="Bold" Foreground="#2E7D32"/>
                                        <TextBlock Text="Sub-agent de recherche web, lecture et synthèse" FontSize="11" Foreground="#7F8C8D"/>
                                    </StackPanel>

                                    <!-- Toggle Actif -->
                                    <CheckBox x:Name="WebEnabledCheckBox"
                                              Grid.Column="2"
                                              Content="Actif"
                                              IsChecked="False"
                                              VerticalAlignment="Center"
                                              FontWeight="SemiBold"/>
                                </Grid>

                                <!-- Note clé API -->
                                <TextBlock Text="💡 La clé API Ollama se configure dans l'onglet API"
                                           FontSize="11" Foreground="#666" Margin="0,0,0,15" FontStyle="Italic"/>

                                <!-- Séparateur -->
                                <Separator Margin="0,0,0,15"/>

                                <!-- Provider LLM -->
                                <TextBlock Text="Provider LLM (pour synthèse)" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <ComboBox x:Name="WebLLMProviderCombo"
                                          Height="35"
                                          Padding="10,8"
                                          FontSize="12"
                                          VerticalContentAlignment="Center"
                                          SelectionChanged="WebLLMProvider_SelectionChanged"
                                          Margin="0,0,0,15">
                                    <ComboBoxItem Content="Ollama" IsSelected="True"/>
                                    <ComboBoxItem Content="OpenAI"/>
                                </ComboBox>

                                <!-- Modèle LLM -->
                                <TextBlock Text="Modèle" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="WebLLMModelCombo"
                                              Grid.Column="0"
                                              Height="35"
                                              Padding="10,8"
                                              FontSize="12"
                                              VerticalContentAlignment="Center"
                                              IsEditable="True">
                                        <ComboBoxItem Content="llama3" IsSelected="True"/>
                                        <ComboBoxItem Content="mistral"/>
                                        <ComboBoxItem Content="phi3"/>
                                    </ComboBox>

                                    <Button x:Name="RefreshWebModelsBtn"
                                            Grid.Column="1"
                                            Content="🔄"
                                            Width="40"
                                            Height="35"
                                            Margin="5,0,0,0"
                                            Click="RefreshWebModels_Click"
                                            ToolTip="Rafraîchir la liste des modèles"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Background="#4CAF50"
                                            Foreground="White"/>
                                </Grid>

                                <!-- Température -->
                                <TextBlock Text="Température (créativité)" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Slider x:Name="WebTemperatureSlider"
                                            Grid.Column="0"
                                            Minimum="0"
                                            Maximum="1"
                                            Value="0.3"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"
                                            Margin="0,0,15,0"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ElementName=WebTemperatureSlider, Path=Value, StringFormat={}{0:F1}}"
                                               FontFamily="Consolas"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="#4CAF50"
                                               VerticalAlignment="Center"
                                               MinWidth="40"/>
                                </Grid>

                                <!-- Nombre max de résultats -->
                                <TextBlock Text="Nombre max de résultats" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <ComboBox x:Name="WebMaxResultsCombo"
                                          Height="35"
                                          Padding="10,8"
                                          FontSize="12"
                                          VerticalContentAlignment="Center"
                                          Margin="0,0,0,15">
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="5" IsSelected="True"/>
                                    <ComboBoxItem Content="10"/>
                                </ComboBox>

                                <!-- Posture -->
                                <TextBlock Text="Posture (instructions de synthèse)" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="WebPostureTextBox"
                                         Height="150"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="12"
                                         Padding="10"
                                         BorderBrush="#E0E0E0"
                                         BorderThickness="1"/>

                                <!-- Bouton reset posture -->
                                <Button x:Name="ResetWebPostureBtn"
                                        Content="Réinitialiser la posture par défaut"
                                        Click="ResetWebPosture_Click"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Background="#6C757D"
                                        Foreground="White"/>

                                <!-- Info mots-clés -->
                                <Border Background="#E8F5E9" Padding="10" CornerRadius="5" Margin="0,15,0,0">
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#2E7D32">
                                        🔍 Mots-clés déclencheurs : "cherche", "recherche", "vérifie", "voir sur le net", "sur internet"
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Agent de Pilotage (Parent'aile) -->
                        <Border Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15" BorderBrush="#E67E22" BorderThickness="2">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar Pilotage -->
                                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25" Background="#FDF2E9" BorderBrush="#E67E22" BorderThickness="2" Margin="0,0,15,0">
                                        <TextBlock Text="🎯" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Info Pilotage -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Pilotage" FontSize="16" FontWeight="Bold" Foreground="#D35400"/>
                                        <TextBlock Text="Analyse des messages parents, tri et suggestion de réponse" FontSize="11" Foreground="#7F8C8D"/>
                                    </StackPanel>

                                    <!-- Toggle Actif -->
                                    <CheckBox x:Name="PilotageEnabledCheckBox"
                                               Grid.Column="2"
                                               Content="Actif"
                                               IsChecked="True"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                </Grid>

                                <!-- Séparateur -->
                                <Separator Margin="0,0,0,15"/>

                                <!-- Provider LLM -->
                                <TextBlock Text="Provider LLM" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <ComboBox x:Name="PilotageLLMProviderCombo"
                                           Height="35"
                                           Padding="10,8"
                                           FontSize="12"
                                           VerticalContentAlignment="Center"
                                           SelectionChanged="PilotageLLMProvider_SelectionChanged"
                                           Margin="0,0,0,15">
                                    <ComboBoxItem Content="Ollama" IsSelected="True"/>
                                    <ComboBoxItem Content="OpenAI"/>
                                </ComboBox>

                                <!-- Modèle LLM -->
                                <TextBlock Text="Modèle" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="PilotageLLMModelCombo"
                                               Grid.Column="0"
                                               Height="35"
                                               Padding="10,8"
                                               FontSize="12"
                                               VerticalContentAlignment="Center"
                                               IsEditable="True">
                                        <ComboBoxItem Content="gpt-os:20b" IsSelected="True"/>
                                    </ComboBox>

                                    <Button x:Name="RefreshPilotageModelsBtn"
                                             Grid.Column="1"
                                             Content="🔄"
                                             Width="40"
                                             Height="35"
                                             Margin="5,0,0,0"
                                             Click="RefreshPilotageModels_Click"
                                             ToolTip="Rafraîchir la liste des modèles"
                                             Style="{StaticResource ModernButtonStyle}"
                                             Background="#E67E22"
                                             Foreground="White"/>
                                </Grid>

                                <!-- Température -->
                                <TextBlock Text="Température (créativité)" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Slider x:Name="PilotageTemperatureSlider"
                                             Grid.Column="0"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="0.3"
                                             TickFrequency="0.1"
                                             IsSnapToTickEnabled="True"
                                             VerticalAlignment="Center"
                                             Margin="0,0,15,0"/>

                                    <TextBlock Grid.Column="1"
                                                Text="{Binding ElementName=PilotageTemperatureSlider, Path=Value, StringFormat={}{0:F1}}"
                                                FontFamily="Consolas"
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Foreground="#E67E22"
                                                VerticalAlignment="Center"
                                                MinWidth="40"/>
                                </Grid>

                                <!-- Posture -->
                                <TextBlock Text="Posture (instructions d'analyse)" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="PilotagePostureTextBox"
                                         Height="150"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="12"
                                         Padding="10"
                                         BorderBrush="#E0E0E0"
                                         BorderThickness="1"/>

                                <!-- Bouton reset posture -->
                                <Button x:Name="ResetPilotagePostureBtn"
                                         Content="Réinitialiser la posture par défaut"
                                         Click="ResetPilotagePosture_Click"
                                         Margin="0,10,0,0"
                                         HorizontalAlignment="Left"
                                         Style="{StaticResource ModernButtonStyle}"
                                         Background="#6C757D"
                                         Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- Info futurs agents -->
                        <Border Background="#FFF3CD" Padding="15" CornerRadius="5" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#856404" Margin="0,0,0,8">
                                    💡 Évolutions futures
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#856404">
                                    D'autres agents spécialisés pourront être ajoutés ici (calendrier, analyse de documents, etc.).
                                    Chaque agent aura sa propre configuration et son propre LLM.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Onglet Chat -->
            <TabItem Header="💬 Chat">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- En-tête explicatif -->
                        <Border Background="#E7F3FF" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="13" Foreground="#0066CC" Margin="0,0,0,5">
                                    📚 Mémoire intelligente
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#0066CC">
                                    Le système compacte automatiquement les anciens échanges sauvegardés pour éviter de saturer le contexte de l'IA, tout en préservant les informations médicales essentielles.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Activer la compaction -->
                        <CheckBox x:Name="EnableCompactionCheckBox"
                                 Content="Activer la compaction automatique"
                                 FontWeight="SemiBold"
                                 FontSize="13"
                                 Margin="0,0,0,20"
                                 IsChecked="True"/>

                        <!-- Seuil de compaction -->
                        <TextBlock Text="Seuil de compaction (caractères)" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Slider x:Name="CompactionThresholdSlider"
                                   Grid.Column="0"
                                   Minimum="5000"
                                   Maximum="100000"
                                   Value="20000"
                                   TickFrequency="5000"
                                   IsSnapToTickEnabled="True"
                                   VerticalAlignment="Center"
                                   Margin="0,0,15,0"/>

                            <TextBlock Grid.Column="1"
                                      Text="{Binding ElementName=CompactionThresholdSlider, Path=Value, StringFormat={}{0:N0}}"
                                      FontFamily="Consolas"
                                      FontSize="13"
                                      FontWeight="Bold"
                                      Foreground="#007BFF"
                                      VerticalAlignment="Center"
                                      MinWidth="70"
                                      TextAlignment="Right"/>
                        </Grid>

                        <TextBlock TextWrapping="Wrap"
                                  FontSize="11"
                                  Foreground="Gray"
                                  Margin="0,0,0,20">
                            Nombre de caractères total des échanges sauvegardés avant déclenchement de la compaction.
                        </TextBlock>

                        <!-- Info sur l'architecture -->
                        <Border Background="#FFF3CD" Padding="15" CornerRadius="5" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="12" Foreground="#856404" Margin="0,0,0,8">
                                    📋 Architecture de la mémoire du Chat
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#856404" Margin="0,0,0,5">
                                    • Contexte Patient : synthèse ou notes (jamais compacté)
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#856404" Margin="0,0,0,5">
                                    • Mémoire compactée : résumé de tous les échanges sauvegardés
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#856404" Margin="0,0,0,0">
                                    • Historique temporaire : 3 derniers échanges de la session en cours
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
        
        <!-- Boutons d'action -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler"
                   Click="BtnCancel_Click"
                   Margin="0,0,10,0"
                   Style="{StaticResource ModernButtonStyle}"
                   Background="#6C757D"
                   Foreground="White"
                   Width="100"/>
            
            <Button Content="Enregistrer"
                   Click="BtnSave_Click"
                   Style="{StaticResource ModernButtonStyle}"
                   Background="#28A745"
                   Foreground="White"
                   Width="120"/>
        </StackPanel>
        
    </Grid>
</Window>

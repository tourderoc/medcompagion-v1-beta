<Window x:Class="MedCompanion.Dialogs.CreateLetterWithAIDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MedCompanion.Controls"
        Title="✨ Créer un courrier avec l'IA intelligente"
        Width="650" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="650" MinHeight="500"
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- En-tête -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#2C3E50">
                    ✨ Assistant Courrier Intelligent
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0">
                    Décrivez le courrier dont vous avez besoin et l'IA trouvera automatiquement le meilleur modèle pour vous.
                </TextBlock>
            </StackPanel>

            <!-- Checkbox pour activer/désactiver la bibliothèque MCC -->
            <CheckBox x:Name="UseMCCLibraryCheckBox"
                      Grid.Row="1"
                      Content="📚 Utiliser la bibliothèque MCC"
                      IsChecked="True"
                      FontSize="12"
                      FontWeight="SemiBold"
                      Foreground="#2C3E50"
                      Margin="0,0,0,8"
                      VerticalContentAlignment="Center"/>

            <!-- Bouton toggle Options avancées -->
            <Button x:Name="AdvancedOptionsToggle"
                    Grid.Row="2"
                    Content="⚙️ Options avancées ▲"
                    HorizontalAlignment="Left"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#3498DB"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,0,8"
                    Padding="0"
                    Click="AdvancedOptionsToggle_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#2980B9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Section Options avancées (masquée par défaut) -->
            <Border x:Name="AdvancedOptionsPanel"
                    Grid.Row="3"
                    Visibility="Visible"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#FAFAFA"
                    Padding="12"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ligne 1: Destinataire et Ton -->
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Destinataire" FontSize="11" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,4"/>
                        <ComboBox x:Name="RecipientCombo" FontSize="11" Height="32" IsEditable="True">
                            <ComboBoxItem Content="Automatique" IsSelected="True"/>
                            <ComboBoxItem Content="👨‍⚕️ Confrère médecin"/>
                            <ComboBoxItem Content="🏫 Établissement scolaire"/>
                            <ComboBoxItem Content="🏛️ Administration (MDPH, CPAM...)"/>
                            <ComboBoxItem Content="⚖️ Justice / Avocat"/>
                            <ComboBoxItem Content="👨‍👩‍👧 Parents / Famille"/>
                            <ComboBoxItem Content="🏢 Employeur"/>
                            <ComboBoxItem Content="💼 Assurance"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Ton" FontSize="11" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ToneCombo" FontSize="11" Height="32">
                            <ComboBoxItem Content="Automatique" IsSelected="True"/>
                            <ComboBoxItem Content="🤝 Bienveillant et empathique"/>
                            <ComboBoxItem Content="💼 Professionnel neutre"/>
                            <ComboBoxItem Content="🏛️ Administratif formel"/>
                            <ComboBoxItem Content="⚖️ Juridique prudent"/>
                            <ComboBoxItem Content="👨‍👩‍👧 Familial et accessible"/>
                            <ComboBoxItem Content="🏥 Médical technique"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Ligne 2: Longueur et Format -->
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Longueur" FontSize="11" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,4"/>
                        <ComboBox x:Name="LengthCombo" FontSize="11" Height="32">
                            <ComboBoxItem Content="Automatique" IsSelected="True"/>
                            <ComboBoxItem Content="📝 Court (≤ 10 lignes)"/>
                            <ComboBoxItem Content="📄 Moyen (10-20 lignes)"/>
                            <ComboBoxItem Content="📋 Détaillé (20-30 lignes)"/>
                            <ComboBoxItem Content="📚 Exhaustif (> 30 lignes)"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="Format" FontSize="11" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FormatCombo" FontSize="11" Height="32">
                            <ComboBoxItem Content="Automatique" IsSelected="True"/>
                            <ComboBoxItem Content="📖 Paragraphes narratifs"/>
                            <ComboBoxItem Content="• Liste à puces"/>
                            <ComboBoxItem Content="1️⃣ Liste numérotée"/>
                            <ComboBoxItem Content="📊 Mixte (intro + liste + conclusion)"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Ligne 3: Prudence et Urgence -->
                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock Text="Niveau de prudence" FontSize="11" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,4"/>
                        <ComboBox x:Name="PrudenceCombo" FontSize="11" Height="32">
                            <ComboBoxItem Content="Automatique" IsSelected="True"/>
                            <ComboBoxItem Content="✅ Standard (langage direct)"/>
                            <ComboBoxItem Content="⚠️ Prudent (formulations nuancées)"/>
                            <ComboBoxItem Content="🔒 Très prudent (contexte juridique)"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <TextBlock Text="Urgence" FontSize="11" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,4"/>
                        <ComboBox x:Name="UrgencyCombo" FontSize="11" Height="32">
                            <ComboBoxItem Content="Automatique" IsSelected="True"/>
                            <ComboBoxItem Content="🔴 Urgent (action rapide demandée)"/>
                            <ComboBoxItem Content="🟠 Important (à traiter rapidement)"/>
                            <ComboBoxItem Content="🟢 Standard (délai normal)"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Groupe de saisie regroupé pour une disposition automatique -->
            <StackPanel Grid.Row="4" Margin="0,10,0,0">
                <!-- Étiquette et Micro -->
                <Grid x:Name="RequestHeaderGrid" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="RequestLabel" 
                               Grid.Column="0"
                               FontWeight="SemiBold" 
                               Foreground="#34495E"
                               VerticalAlignment="Center">
                        📝 Décrivez votre demande :
                    </TextBlock>
                    <controls:VoiceDictationButton x:Name="VoiceButton" Grid.Column="1" ToolTip="Dicter votre demande (Handy)" Margin="10,0,0,0"/>
                </Grid>

                <!-- Zone de saisie -->
                <Border x:Name="RequestTextBorder" 
                        BorderBrush="#BDC3C7" 
                        BorderThickness="1" 
                        CornerRadius="4"
                        Background="White"
                        Height="150">
                    <TextBox x:Name="RequestTextBox"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Padding="10"
                             FontSize="13"
                             TextChanged="RequestTextBox_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Exemple : &quot;Courrier pour demande de PAP à l'école pour un enfant avec trouble de l'attention&quot;"
                                                                   Foreground="#95A5A6"
                                                                   Margin="2,2,0,0"
                                                                   FontSize="13"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>
            </StackPanel>

            <!-- Compteur de caractères et infos -->
            <StackPanel Grid.Row="5" Margin="0,8,0,0">
                <DockPanel>
                    <TextBlock x:Name="CharCountText" 
                               DockPanel.Dock="Right"
                               FontSize="11" 
                               Foreground="#95A5A6"
                               Text="0 caractères"/>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11" Foreground="#7F8C8D">
                            ℹ️ L'IA va analyser votre demande, chercher le MCC le plus pertinent et générer un courrier personnalisé avec les informations du patient.
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
                
                <!-- Barre de progression (cachée par défaut) -->
                <StackPanel x:Name="ProgressPanel" 
                            Visibility="Collapsed" 
                            Margin="0,10,0,0">
                    <TextBlock x:Name="ProgressText" 
                               FontSize="12" 
                               Foreground="#2980B9"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>
                    <ProgressBar x:Name="ProgressBar" 
                                 Height="4" 
                                 IsIndeterminate="True"/>
                </StackPanel>
            </StackPanel>

            <!-- Boutons d'action -->
            <Grid Grid.Row="6" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CancelButton"
                        Grid.Column="0"
                        Content="Annuler"
                        HorizontalAlignment="Left"
                        Width="100"
                        Background="#ECF0F1"
                        Click="CancelButton_Click"/>

                <Button x:Name="GenerateButton"
                        Grid.Column="1"
                        Content="🚀 Analyser et Générer"
                        IsEnabled="False"
                        Width="180"
                        Background="#3498DB"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Click="GenerateButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="Margin" Value="5"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#BDC3C7"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>

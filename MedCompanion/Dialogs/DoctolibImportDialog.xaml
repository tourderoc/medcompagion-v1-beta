<Window x:Class="MedCompanion.Dialogs.DoctolibImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Doctolib"
        Width="760" Height="680"
        MinWidth="640" MinHeight="540"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#219A52"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#95A5A6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7F8C8D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Content (scrollable) -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
            <RowDefinition Height="Auto"/>  <!-- Footer buttons -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="#1A3A6A" Padding="24,16">
            <StackPanel>
                <TextBlock Text="📋 Import depuis Doctolib" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="HeaderSubtitle" Text="Capturez les informations patient pour les importer dans le dossier."
                           FontSize="12" Foreground="#A8C4E0" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ===== CONTENT ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <Grid Margin="24,20,24,20">

                <!-- ===== ÉTAPE CAPTURE (visible au début) ===== -->
                <StackPanel x:Name="CapturePanel">

                    <!-- Étape 1 -->
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Step1BadgeBorder" Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                    Background="#3498DB" Margin="0,0,14,0" VerticalAlignment="Top">
                                <TextBlock x:Name="Step1Badge" Text="1" FontSize="16" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Informations administratives" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="12" Margin="0,4,0,0"
                                           Text="Dans Doctolib, naviguez vers le dossier patient (onglet Infos / Patient), faites défiler pour voir l'identité, l'adresse et le NIR, puis cliquez Capturer."/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock x:Name="Capture1StatusIcon" Text="○" FontSize="14" Margin="0,0,6,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#BDC3C7"/>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="✓">
                                                        <Setter Property="Foreground" Value="#27AE60"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock x:Name="Capture1StatusText" Text="En attente" FontSize="12" Foreground="#95A5A6" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2" x:Name="Capture1Btn" Content="📸  Capturer"
                                    Style="{StaticResource BtnPrimary}"
                                    Width="130" VerticalAlignment="Center" Margin="16,0,0,0"
                                    Click="Capture1Btn_Click"/>
                        </Grid>
                    </Border>

                    <!-- Étape 2 -->
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#95A5A6" Margin="0,0,14,0" VerticalAlignment="Top">
                                <TextBlock x:Name="Step2Badge" Text="2" FontSize="16" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Médecin traitant  (optionnel)" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="12" Margin="0,4,0,0"
                                           Text="Faites défiler Doctolib jusqu'à la section Médecin traitant pour voir le nom, l'adresse et le numéro ADELI, puis cliquez Capturer."/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock x:Name="Capture2StatusIcon" Text="○" FontSize="14" Margin="0,0,6,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#BDC3C7"/>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="✓">
                                                        <Setter Property="Foreground" Value="#27AE60"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock x:Name="Capture2StatusText" Text="En attente" FontSize="12" Foreground="#95A5A6" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2" x:Name="Capture2Btn" Content="📸  Capturer"
                                    Style="{StaticResource BtnGhost}"
                                    Width="130" VerticalAlignment="Center" Margin="16,0,0,0"
                                    Click="Capture2Btn_Click" IsEnabled="False"/>
                        </Grid>
                    </Border>

                    <!-- Hint -->
                    <TextBlock Text="💡 Conseil : maximisez Doctolib dans la zone Bureau avant de capturer."
                               FontSize="11" Foreground="#7F8C8D" Margin="0,6,0,0" FontStyle="Italic"/>
                </StackPanel>

                <!-- ===== PANNEAU DE RÉVISION (caché au début) ===== -->
                <StackPanel x:Name="ReviewPanel" Visibility="Collapsed">

                    <TextBlock Text="Vérifiez et corrigez les informations extraites avant d'appliquer."
                               FontSize="13" Foreground="#555" Margin="0,0,0,16"/>

                    <!-- Deux colonnes : Patient | Médecin traitant -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- PATIENT -->
                        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <TextBlock Text="PATIENT" FontSize="11" FontWeight="Bold" Foreground="#3498DB"
                                           Margin="0,0,0,12"/>

                                <TextBlock Text="Prénom" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevPrenom" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="Nom" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevNom" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="Date de naissance" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevDob" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="Sexe (H / F / NB)" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevSexe" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="Adresse" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevAdresse" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Code postal" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="RevCP" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ville" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="RevVille" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Téléphone" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevTelephone" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevEmail" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="N° sécurité sociale (NIR)" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevNIR" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="Lieu de naissance" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevLieuNaissance" Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                        </Border>

                        <!-- MÉDECIN TRAITANT -->
                        <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <TextBlock Text="MÉDECIN TRAITANT" FontSize="11" FontWeight="Bold" Foreground="#3498DB"
                                           Margin="0,0,0,12"/>

                                <TextBlock Text="Nom" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevMTNom" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="Prénom" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevMTPrenom" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="Adresse professionnelle" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevMTAdresse" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Code postal" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="RevMTCP" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ville" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="RevMTVille" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Téléphone" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevMTTelephone" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="N° ADELI" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="RevMTAdeli" Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Note sur champs vides -->
                    <TextBlock Text="ℹ️ Les champs vides ne seront pas modifiés dans le dossier existant."
                               FontSize="11" Foreground="#7F8C8D" Margin="0,12,0,0" FontStyle="Italic"/>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!-- ===== BARRE DE STATUT ===== -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="24,8" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Text="Prêt." FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
        </Border>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="3" Background="White" Padding="24,14" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BackBtn" Content="← Recapturer" Grid.Column="0"
                        Style="{StaticResource BtnGhost}" HorizontalAlignment="Left"
                        Visibility="Collapsed" Click="BackBtn_Click"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Annuler" Style="{StaticResource BtnGhost}"
                            Margin="0,0,12,0" Click="CancelBtn_Click"/>
                    <Button x:Name="AnalyzeBtn" Content="🔍  Analyser →"
                            Style="{StaticResource BtnPrimary}" IsEnabled="False"
                            Click="AnalyzeBtn_Click"/>
                    <Button x:Name="ApplyBtn" Content="✅  Appliquer au dossier"
                            Style="{StaticResource BtnSuccess}" Visibility="Collapsed"
                            Click="ApplyBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>

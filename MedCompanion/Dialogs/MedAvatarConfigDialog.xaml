<Window x:Class="MedCompanion.Dialogs.MedAvatarConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration Avatar Med"
        Height="600"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Configuration Avatar Med"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"/>
            <TextBlock Text="Importez des videos MP4 pour chaque etat de l'avatar"
                       FontSize="12"
                       Foreground="#7F8C8D"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Contenu scrollable -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Taille avatar -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Taille de l'avatar" FontWeight="SemiBold" FontSize="14"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SizeSlider"
                                    Minimum="80"
                                    Maximum="200"
                                    Value="120"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="SizeSlider_ValueChanged"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Value, ElementName=SizeSlider, StringFormat={}{0:0}px}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Liste dynamique des états -->
                <ItemsControl x:Name="StatesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Indicateur d'état -->
                                    <Grid Grid.Column="0" Width="50" Margin="0,0,15,0">
                                        <Ellipse Width="40" Height="40" Fill="#E3F2FD">
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="#2196F3" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <TextBlock Text="{Binding InitialLetter}"
                                                   FontSize="16" FontWeight="Bold" Foreground="#2196F3"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Infos état -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#7F8C8D"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                        <TextBlock FontSize="10" Foreground="#9E9E9E" Margin="0,3,0,0"
                                                   Text="{Binding MediaStatus}"/>
                                    </StackPanel>

                                    <!-- Boutons -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Choisir MP4"
                                                Click="SelectMedia_Click"
                                                Tag="{Binding Name}"
                                                Margin="5,0" Padding="10,5"
                                                Background="#3498DB" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                Style="{StaticResource RoundedButton}"/>
                                        <Button Content="X"
                                                Click="ClearMedia_Click"
                                                Tag="{Binding Name}"
                                                Padding="8,5"
                                                Background="#E74C3C" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                Style="{StaticResource RoundedButton}"
                                                Visibility="{Binding ClearButtonVisibility}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Info -->
                <Border Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Format supporte: MP4" FontWeight="SemiBold" FontSize="13" Foreground="#1976D2"/>
                        <TextBlock Text="Importez des videos MP4 pour personnaliser l'avatar Med selon chaque etat."
                                   FontSize="11" Foreground="#546E7A" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        <TextBlock Text="Les videos seront copiees dans le dossier de configuration."
                                   FontSize="10" Foreground="#78909C" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Button Content="Editeur Avance"
                    HorizontalAlignment="Left"
                    Width="130"
                    Height="35"
                    Background="White"
                    Foreground="#7F8C8D"
                    BorderBrush="#BDC3C7"
                    BorderThickness="1"
                    Cursor="Hand"
                    Click="OpenEditor_Click"
                    Style="{StaticResource RoundedButton}"/>

            <Button Content="Fermer"
                    Width="100"
                    Height="35"
                    HorizontalAlignment="Right"
                    Background="#3498DB"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Close_Click"
                    Style="{StaticResource RoundedButton}"/>
        </Grid>
    </Grid>
</Window>

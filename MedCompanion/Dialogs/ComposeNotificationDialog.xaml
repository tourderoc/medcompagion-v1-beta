<Window x:Class="MedCompanion.Dialogs.ComposeNotificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📧 Nouveau message au parent"
        Width="550" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Text Zone -->
            <RowDefinition Height="Auto"/> <!-- Progress -->
            <RowDefinition Height="Auto"/> <!-- Channels -->
            <RowDefinition Height="Auto"/> <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold" Foreground="#2C3E50">
                🚀 Notifier le parent
            </TextBlock>
            <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#7F8C8D" Margin="0,4,0,0">
                Saisissez vos notes brutes, l'IA les reformulera avec le contexte du patient.
            </TextBlock>
        </StackPanel>

        <!-- Saisie / Résultat -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>    <!-- Draft -->
                <RowDefinition Height="Auto"/> <!-- Button IA -->
                <RowDefinition Height="*"/>    <!-- Result -->
            </Grid.RowDefinitions>

            <!-- Draft -->
            <Border Grid.Row="0" Background="White" BorderBrush="#DCDDE1" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="DraftTextBox" 
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         FontSize="13" Padding="8" BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="DraftTextBox_TextChanged"/>
            </Border>

            <!-- Button IA -->
            <Button x:Name="ReformulateBtn" Grid.Row="1"
                    Content="✨ Reformuler par IA"
                    Background="#3498DB" Foreground="White"
                    FontWeight="SemiBold" Margin="0,10"
                    Click="ReformulateBtn_Click"
                    IsEnabled="False"/>

            <!-- Result -->
            <Border Grid.Row="2" Background="#FDFEFE" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="ResultTextBox" 
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         FontSize="13" Padding="8" BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         Background="Transparent"/>
            </Border>
        </Grid>

        <!-- Progress -->
        <ProgressBar x:Name="AILoadingBar" Grid.Row="2" Height="4" Margin="0,10" IsIndeterminate="True" Visibility="Collapsed"/>

        <!-- Selection Canal -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,15,0,0">
            <CheckBox x:Name="ChannelPushCheck" Content="📲 Notification App" IsChecked="True" VerticalContentAlignment="Center" Margin="0,0,20,0"/>
            <CheckBox x:Name="ChannelEmailCheck" Content="📧 E-mail" IsChecked="False" VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Footer Actions -->
        <Grid Grid.Row="4" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="CancelBtn" Grid.Column="0" Content="Annuler" HorizontalAlignment="Left" Background="#ECF0F1" Click="CancelBtn_Click"/>
            <Button x:Name="SendBtn" Grid.Column="1" Content="🚀 Envoyer au Parent" Background="#27AE60" Foreground="White" FontWeight="Bold" Width="180" Click="SendBtn_Click" IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>

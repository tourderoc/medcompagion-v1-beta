<UserControl x:Class="MedCompanion.Controls.MedAvatarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="AvatarControl">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Animation de pulsation pour l'état Thinking (fallback) -->
        <Storyboard x:Key="ThinkingAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseCircle"
                           Storyboard.TargetProperty="Opacity"
                           From="1.0" To="0.4" Duration="0:0:0.6"
                           AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="PulseScale"
                           Storyboard.TargetProperty="ScaleX"
                           From="1" To="1.05" Duration="0:0:0.6"
                           AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="PulseScale"
                           Storyboard.TargetProperty="ScaleY"
                           From="1" To="1.05" Duration="0:0:0.6"
                           AutoReverse="True"/>
        </Storyboard>

        <!-- Animation d'onde pour l'état Speaking (fallback) -->
        <Storyboard x:Key="SpeakingAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpeakingRing"
                           Storyboard.TargetProperty="Opacity"
                           From="0.8" To="0" Duration="0:0:1"/>
            <DoubleAnimation Storyboard.TargetName="SpeakingRingScale"
                           Storyboard.TargetProperty="ScaleX"
                           From="1" To="1.5" Duration="0:0:1"/>
            <DoubleAnimation Storyboard.TargetName="SpeakingRingScale"
                           Storyboard.TargetProperty="ScaleY"
                           From="1" To="1.5" Duration="0:0:1"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <!-- Container principal -->
        <Grid Width="{Binding AvatarSize, ElementName=AvatarControl}"
              Height="{Binding AvatarSize, ElementName=AvatarControl}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <!-- Anneau d'onde pour Speaking (derrière l'avatar) -->
            <Ellipse x:Name="SpeakingRing"
                     Width="{Binding AvatarSize, ElementName=AvatarControl}"
                     Height="{Binding AvatarSize, ElementName=AvatarControl}"
                     Stroke="#2196F3"
                     StrokeThickness="3"
                     Fill="Transparent"
                     Opacity="0"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="SpeakingRingScale" ScaleX="1" ScaleY="1"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Lecteur Video MP4 -->
            <Border ClipToBounds="True"
                    CornerRadius="{Binding CornerRadius, ElementName=AvatarControl}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <MediaElement x:Name="VideoPlayer"
                              Width="{Binding AvatarSize, ElementName=AvatarControl}"
                              Height="{Binding AvatarSize, ElementName=AvatarControl}"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              Stretch="Uniform"
                              ScrubbingEnabled="True"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Visibility="Collapsed"/>
            </Border>

            <!-- Fallback: Avatar animé WPF natif -->
            <Grid x:Name="FallbackContainer" Visibility="Visible">
                <!-- Cercle principal avec effet de pulsation -->
                <Ellipse x:Name="PulseCircle"
                         Width="{Binding AvatarSize, ElementName=AvatarControl}"
                         Height="{Binding AvatarSize, ElementName=AvatarControl}"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop x:Name="GradientStart" Color="#E3F2FD" Offset="0"/>
                            <GradientStop x:Name="GradientEnd" Color="#BBDEFB" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Stroke>
                        <SolidColorBrush x:Name="CircleStroke" Color="#90CAF9"/>
                    </Ellipse.Stroke>
                    <Ellipse.StrokeThickness>3</Ellipse.StrokeThickness>
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="PulseScale" ScaleX="1" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Icone centrale (texte stylisé) -->
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse x:Name="IconBackground"
                             Width="50" Height="50"
                             Fill="#FFFFFF"
                             Opacity="0.9"/>
                    <TextBlock x:Name="IconText"
                               Text="M"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#1976D2"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"/>
                </Grid>

                <!-- Label d'état -->
                <Border Background="#FFFFFF"
                        CornerRadius="8"
                        Padding="8,3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,5"
                        Opacity="0.95">
                    <TextBlock x:Name="StateLabel"
                               Text="En attente"
                               FontSize="9"
                               Foreground="#546E7A"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Indicateur d'état (petit badge coloré) -->
            <Border x:Name="StateBadge"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,8,8"
                    Width="16"
                    Height="16"
                    CornerRadius="8"
                    Background="#4CAF50"
                    BorderBrush="White"
                    BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="3" ShadowDepth="1" Opacity="0.2"/>
                </Border.Effect>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="MedCompanion.Controls.StateMachineEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MedCompanion.Controls"
             xmlns:models="clr-namespace:MedCompanion.Models.StateMachine"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="#F5F5F5">
        <!-- Toolbar -->
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Orientation="Horizontal" Margin="10" Panel.ZIndex="1">
            <Button Content="+ Add State" Click="OnAddStateClick" Padding="10,5" Background="White" BorderBrush="#DDDDDD"/>
        </StackPanel>

        <!-- Instructions -->
        <TextBlock VerticalAlignment="Top" HorizontalAlignment="Right" Margin="10" Panel.ZIndex="1"
                   Foreground="#888" FontSize="11" TextWrapping="Wrap" MaxWidth="300" TextAlignment="Right"
                   Text="Glisser depuis un connecteur pour creer une transition. Cliquer sur une ligne pour la selectionner. Clic droit sur un etat pour plus d'options."/>

        <!-- Canvas -->
        <ScrollViewer x:Name="EditorScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="EditorGrid" Width="2000" Height="2000" Background="Transparent"
                  MouseLeftButtonUp="OnGridMouseUp" MouseMove="OnGridMouseMove">
                <!-- Connections Layer -->
                <Canvas x:Name="ConnectionsLayer" Background="Transparent"/>

                <!-- Nodes Layer -->
                <ItemsControl x:Name="NodesItemsControl" ItemsSource="{Binding States}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas x:Name="GraphCanvas" Background="Transparent"
                                    MouseLeftButtonDown="OnCanvasMouseDown"
                                    MouseMove="OnCanvasMouseMove"
                                    MouseLeftButtonUp="OnCanvasMouseUp"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding GraphX, Mode=TwoWay}"/>
                            <Setter Property="Canvas.Top" Value="{Binding GraphY, Mode=TwoWay}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:AvatarState}">
                            <Thumb DragDelta="OnThumbDragDelta"
                                   PreviewMouseLeftButtonDown="OnNodeMouseDown"
                                   PreviewMouseRightButtonDown="OnNodeRightClick">
                                <Thumb.Template>
                                    <ControlTemplate>
                                        <local:StateNodeControl/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="MedCompanion.Controls.StateNodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MedCompanion.Controls"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="150"
             x:Name="NodeControl">
    <UserControl.Resources>
        <Style TargetType="Border" x:Key="NodeBorderStyle">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="5" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style pour les connecteurs -->
        <Style x:Key="ConnectorStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Fill" Value="#9E9E9E"/>
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="Cursor" Value="Cross"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#2196F3"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#2196F3" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Connecteur Haut (entrée) -->
        <Ellipse x:Name="ConnectorTop" Style="{StaticResource ConnectorStyle}"
                 HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-6,0,0"
                 Panel.ZIndex="2" Tag="Top"
                 MouseLeftButtonDown="OnConnectorMouseDown"
                 MouseLeftButtonUp="OnConnectorMouseUp"
                 ToolTip="Glisser pour creer une transition"/>

        <!-- Connecteur Bas (sortie) -->
        <Ellipse x:Name="ConnectorBottom" Style="{StaticResource ConnectorStyle}"
                 HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-6"
                 Panel.ZIndex="2" Tag="Bottom"
                 MouseLeftButtonDown="OnConnectorMouseDown"
                 MouseLeftButtonUp="OnConnectorMouseUp"
                 ToolTip="Glisser pour creer une transition"/>

        <!-- Connecteur Gauche (entrée) -->
        <Ellipse x:Name="ConnectorLeft" Style="{StaticResource ConnectorStyle}"
                 HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-6,0,0,0"
                 Panel.ZIndex="2" Tag="Left"
                 MouseLeftButtonDown="OnConnectorMouseDown"
                 MouseLeftButtonUp="OnConnectorMouseUp"
                 ToolTip="Glisser pour creer une transition"/>

        <!-- Connecteur Droit (sortie) -->
        <Ellipse x:Name="ConnectorRight" Style="{StaticResource ConnectorStyle}"
                 HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-6,0"
                 Panel.ZIndex="2" Tag="Right"
                 MouseLeftButtonDown="OnConnectorMouseDown"
                 MouseLeftButtonUp="OnConnectorMouseUp"
                 ToolTip="Glisser pour creer une transition"/>

        <!-- Main Node Body -->
        <Border Style="{StaticResource NodeBorderStyle}" Padding="10">
            <StackPanel>
                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#333333"/>
                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#757575" TextTrimming="CharacterEllipsis"/>

                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="&#x1F3AC;" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding MediaSequence.Count, StringFormat='{}{0} Clips'}" FontSize="11" Foreground="#555"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

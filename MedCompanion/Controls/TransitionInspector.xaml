<UserControl x:Class="MedCompanion.Controls.TransitionInspector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MedCompanion.Controls"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="300"
             Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Transition Properties" FontSize="16" FontWeight="Bold"/>
            <TextBlock x:Name="TransitionSummary" FontSize="11" Foreground="#757575" Margin="0,5,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Trigger Name -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Trigger Name" Foreground="#757575" FontSize="12"/>
            <TextBox x:Name="TriggerTextBox" Margin="0,5,0,15" Padding="5"
                     TextChanged="OnTriggerTextChanged"/>
        </StackPanel>

        <!-- Source/Target Info (Read-only) -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Source State" Foreground="#757575" FontSize="12"/>
            <TextBlock x:Name="SourceStateLabel" FontSize="13" Margin="0,5,0,15" FontWeight="SemiBold"/>

            <TextBlock Text="Target State" Foreground="#757575" FontSize="12"/>
            <TextBlock x:Name="TargetStateLabel" FontSize="13" Margin="0,5,0,15" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
            <Button x:Name="DeleteButton" Content="Supprimer la transition" Click="OnDeleteClick"
                    Padding="10,8" Background="#E74C3C" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</UserControl>

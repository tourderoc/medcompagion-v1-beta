<Window x:Class="MedCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:notes="clr-namespace:MedCompanion.Views.Notes"
        xmlns:patient="clr-namespace:MedCompanion.Views.Patient"
        xmlns:patients="clr-namespace:MedCompanion.Views.Patients"
        xmlns:ordonnances="clr-namespace:MedCompanion.Views.Ordonnances"
        xmlns:attestations="clr-namespace:MedCompanion.Views.Attestations"
        xmlns:formulaires="clr-namespace:MedCompanion.Views.Formulaires"
        xmlns:documents="clr-namespace:MedCompanion.Views.Documents"
        xmlns:courriers="clr-namespace:MedCompanion.Views.Courriers"
        xmlns:chat="clr-namespace:MedCompanion.Views.Chat"
        xmlns:templates="clr-namespace:MedCompanion.Views.Templates"
        xmlns:views="clr-namespace:MedCompanion.Views"
        xmlns:messages="clr-namespace:MedCompanion.Views.Messages"
        xmlns:consultation="clr-namespace:MedCompanion.Views.Consultation"
        xmlns:pilotage="clr-namespace:MedCompanion.Views.Pilotage"
        Title="MedCompanion - Assistant Pédopsychiatrie"
        Height="900" Width="1600"
        MinHeight="700" MinWidth="1200"
        Background="#F5F5F5"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
 
        <Style x:Key="SegmentedButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="BackgroundBorder" Background="Transparent" CornerRadius="8">
                            <ContentPresenter x:Name="Content" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#2C3E50"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#10000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HeaderStateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <!-- CONTENU PRINCIPAL (sans sidebar) -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        
        <!-- Header avec recherche -->
        <Border Grid.Row="0" Background="White" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>      <!-- 0: Logo -->
                    <ColumnDefinition Width="10"/>        <!-- 1: Spacer -->
                    <ColumnDefinition Width="Auto"/>      <!-- 2: LLM Selector -->
                    <ColumnDefinition Width="20"/>        <!-- 3: Spacer -->
                    <ColumnDefinition Width="Auto"/>      <!-- 4: Bouton Prompts -->
                    <ColumnDefinition Width="20"/>        <!-- 5: Spacer -->
                    <ColumnDefinition Width="Auto"/>      <!-- 6: Toggle V1/V2 -->
                    <ColumnDefinition Width="20"/>        <!-- 7: Spacer -->
                    <ColumnDefinition Width="*"/>         <!-- 8: Search + Params -->
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Logo MC -->
                    <Border Background="#2C3E50" CornerRadius="8" Padding="12,8" Margin="0,0,15,0">
                        <TextBlock Text="MC" FontSize="18" FontWeight="Bold" Foreground="#3498DB"/>
                    </Border>

                    <!-- Info App -->
                    <StackPanel VerticalAlignment="Center" Margin="0,0,15,0">
                        <TextBlock Text="MedCompanion" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                        <TextBlock Text="Assistant Pédopsychiatrie avec IA" FontSize="11" Foreground="#7F8C8D"/>
                    </StackPanel>

                    <!-- ComboBox Navigation Mode -->
                    <ComboBox x:Name="NavigationModeCombo"
                              Width="130" Height="40"
                              FontSize="13"
                              VerticalContentAlignment="Center"
                              SelectionChanged="NavigationModeCombo_SelectionChanged">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <ToggleButton x:Name="ToggleButton"
                                                              Focusable="False"
                                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                              ClickMode="Press"
                                                              Background="#2C3E50"
                                                              BorderThickness="0">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border x:Name="Border"
                                                                                Background="{TemplateBinding Background}"
                                                                                CornerRadius="8">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition/>
                                                                                    <ColumnDefinition Width="25"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <ContentPresenter Grid.Column="0" Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                                                <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" Fill="White"/>
                                                                            </Grid>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Border" Property="Background" Value="#34495E"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                                <ContentPresenter x:Name="ContentSite"
                                                                  IsHitTestVisible="False"
                                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                  Margin="12,0,30,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left">
                                                    <ContentPresenter.Resources>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </Style>
                                                    </ContentPresenter.Resources>
                                                </ContentPresenter>
                                                <Popup x:Name="Popup"
                                                       Placement="Bottom"
                                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                                       AllowsTransparency="True"
                                                       Focusable="False"
                                                       PopupAnimation="Slide">
                                                    <Grid x:Name="DropDown"
                                                          SnapsToDevicePixels="True"
                                                          MinWidth="{TemplateBinding ActualWidth}">
                                                        <Border Background="White"
                                                                BorderBrush="#BDC3C7"
                                                                BorderThickness="1"
                                                                CornerRadius="8">
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Popup>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.Style>
                        <ComboBoxItem Content="🖥️ Console" Tag="Console" IsSelected="True"/>
                        <ComboBoxItem Content="🧠 Accueil" Tag="Accueil"/>
                        <ComboBoxItem Content="🏢 Bureau" Tag="Bureau"/>
                        <ComboBoxItem Content="🏥 Consultation" Tag="Consultation"/>
                        <ComboBoxItem Content="🎯 Pilotage" Tag="Pilotage"/>
                    </ComboBox>
                </StackPanel>

                <!-- Barre LLM (Sélecteur + Indicateur) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- ComboBox sélection modèle -->
                    <ComboBox x:Name="LLMModelCombo"
                              Width="220"
                              Height="40"
                              FontSize="13"
                              Padding="10,0"
                              VerticalContentAlignment="Center"
                              SelectionChanged="LLMModelCombo_SelectionChanged"
                              Margin="0,0,10,0">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <ToggleButton x:Name="ToggleButton"
                                                              Grid.Column="2"
                                                              Focusable="False"
                                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                              ClickMode="Press"
                                                              Background="White"
                                                              BorderBrush="#BDC3C7"
                                                              BorderThickness="1">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border x:Name="Border" 
                                                                                Background="{TemplateBinding Background}" 
                                                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                                                CornerRadius="8">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition/>
                                                                                    <ColumnDefinition Width="20"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <ContentPresenter Grid.Column="0" Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                                                <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#666666"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                                <ContentPresenter x:Name="ContentSite" 
                                                                  IsHitTestVisible="False" 
                                                                  Content="{TemplateBinding SelectionBoxItem}" 
                                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                                                  Margin="10,0,30,0" 
                                                                  VerticalAlignment="Center" 
                                                                  HorizontalAlignment="Left"/>
                                                <Popup x:Name="Popup" 
                                                       Placement="Bottom" 
                                                       IsOpen="{TemplateBinding IsDropDownOpen}" 
                                                       AllowsTransparency="True" 
                                                       Focusable="False" 
                                                       PopupAnimation="Slide">
                                                    <Grid x:Name="DropDown" 
                                                          SnapsToDevicePixels="True" 
                                                          MinWidth="{TemplateBinding ActualWidth}" 
                                                          MaxHeight="300">
                                                        <Border x:Name="DropDownBorder" 
                                                                Background="White" 
                                                                BorderBrush="#BDC3C7" 
                                                                BorderThickness="1" 
                                                                CornerRadius="8">
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Popup>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                    
                    <!-- Indicateur de statut circulaire -->
                    <Border x:Name="LLMStatusIndicator"
                            Width="40"
                            Height="40"
                            CornerRadius="20"
                            Background="#95A5A6"
                            ToolTip="LLM initialisation..."
                            Margin="0,0,10,0">
                        <TextBlock x:Name="LLMStatusIcon"
                                   Text="🤖" 
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                
                <!-- Bouton Analyse des prompts -->
                <Button x:Name="AnalysePromptsBtn"
                        Grid.Column="4"
                        Content="⚙️ Prompts"
                        Height="45"
                        Padding="20,0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Background="#8E44AD"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="AnalysePromptsBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#7D3C98"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Zone de recherche avec bouton Paramètres -->
                <Grid x:Name="PatientSearchZone" Grid.Column="6" Grid.ColumnSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Search Bar -->
                    <patient:PatientSearchControl Grid.Column="0" DataContext="{Binding PatientSearchViewModel}"/>

                    <!-- View Switching Buttons (Visible only in Consultation Mode) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Visibility="{Binding Visibility, ElementName=ConsultationModeContent}">
                        <!-- Focus Travail (F1) -->
                        <Button Command="{Binding DataContext.SwitchToFocusTravailCommand, ElementName=ConsultationModeContent}"
                                ToolTip="Focus Travail (F1)">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource HeaderStateButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsFocusTravail, ElementName=ConsultationModeContent}" Value="True">
                                            <Setter Property="Background" Value="#3498DB"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="[" Margin="0,0,2,0"/>
                                <Border Width="16" Height="10" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" CornerRadius="1"/>
                                <TextBlock Text="]" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Consultation (F2) -->
                        <Button Command="{Binding DataContext.SwitchToConsultationCommand, ElementName=ConsultationModeContent}"
                                ToolTip="Consultation (F2)">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource HeaderStateButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsConsultation, ElementName=ConsultationModeContent}" Value="True">
                                            <Setter Property="Background" Value="#3498DB"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="[" Margin="0,0,2,0"/>
                                <Border Width="10" Height="10" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" CornerRadius="1"/>
                                <TextBlock Text="|" Margin="2,0,2,0"/>
                                <Border Width="6" Height="10" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" CornerRadius="1"/>
                                <TextBlock Text="]" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Focus Dossier (F3) -->
                        <Button Command="{Binding DataContext.SwitchToDossierCommand, ElementName=ConsultationModeContent}"
                                ToolTip="Focus Dossier (F3)">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource HeaderStateButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsFocusDossier, ElementName=ConsultationModeContent}" Value="True">
                                            <Setter Property="Background" Value="#3498DB"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="[" Margin="0,0,2,0"/>
                                <Border Width="16" Height="10" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" CornerRadius="1"/>
                                <TextBlock Text="]" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    
                    <!-- Bouton Paramètres -->
                    <Button x:Name="ParametresBtn"
                            Grid.Column="4"
                            Content="⚙️"
                            Width="45"
                            Height="45"
                            FontSize="18"
                            Background="#34495E"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Center"
                            ToolTip="Paramètres"
                            Click="ParametresBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2C3E50"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Zone Bureau (visible seulement en mode Bureau) -->
                <StackPanel x:Name="BureauControlsZone" Grid.Column="6" Grid.ColumnSpan="3"
                            Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                    <ComboBox x:Name="BureauToolsCombo"
                              Width="160" Height="36"
                              FontSize="13"
                              Padding="10,0"
                              VerticalContentAlignment="Center"
                              Margin="0,0,15,0"
                              SelectionChanged="BureauToolsCombo_SelectionChanged">
                        <ComboBoxItem Content="Firefox" IsSelected="True"/>
                        <ComboBoxItem Content="Google Chrome"/>
                        <ComboBoxItem Content="Microsoft Edge"/>
                        <ComboBoxItem Content="LibreOffice"/>
                        <ComboBoxItem Content="Doctolib"/>
                        <ComboBoxItem Content="Calculatrice"/>
                        <ComboBoxItem Content="Notes"/>
                    </ComboBox>
                    <!-- Boutons masqués - intégration automatique via SelectionChanged -->
                    <Button x:Name="BureauIntegrerBtn" Content="Integrer"
                            Click="BureauIntegrerBtn_Click" Visibility="Collapsed"
                            Width="80" Height="36" FontSize="12"
                            Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BureauLibererBtn" Content="Liberer"
                            Click="BureauLibererBtn_Click" Visibility="Collapsed"
                            Width="70" Height="36" FontSize="12"
                            Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BureauAnalyserBtn" Content="Analyser"
                            Click="BureauAnalyserBtn_Click"
                            Width="80" Height="36" FontSize="12"
                            Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BureauParametresBtn"
                            Content="⚙️"
                            Width="36" Height="36" FontSize="14"
                            Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"
                            ToolTip="Parametres"
                            Click="ParametresBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Carte patient -->
        <Border x:Name="PatientCardPanel" Grid.Row="1" Background="#E3F2FD" Padding="20,15" BorderBrush="#90CAF9" BorderThickness="0,0,0,2" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/> <!-- Zone Token -->
                    <ColumnDefinition Width="60"/>   <!-- Espace augmenté (était 20) -->
                    <ColumnDefinition Width="Auto"/> <!-- Bouton Dossier -->
                </Grid.ColumnDefinitions>
                
                <!-- INFOS PATIENT -->
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="PatientNameLabel" Text="Nom Prénom" FontSize="20" FontWeight="Bold" Foreground="#1976D2"/>
                        <TextBlock x:Name="DuplicateIndicator"
                                   Text="⚠️"
                                   FontSize="20"
                                   Margin="10,0,0,0"
                                   Cursor="Hand"
                                   Visibility="Collapsed"
                                   ToolTip="Ce patient a un doublon - cliquer pour voir"
                                   MouseLeftButtonDown="DuplicateIndicator_MainWindow_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock x:Name="PatientAgeLabel" Text="" FontSize="13" Foreground="#424242" Margin="0,0,15,0"/>
                        <TextBlock x:Name="PatientDobLabel" Text="" FontSize="13" Foreground="#424242" Margin="0,0,15,0"/>
                        <TextBlock x:Name="PatientSexLabel" Text="" FontSize="13" Foreground="#424242"/>
                    </StackPanel>
                </StackPanel>

                <!-- ZONE TOKEN PARENT'AILE -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- État : Aucun token -->
                    <Button x:Name="GenerateTokenCardBtn"
                            Content="🔑 Générer Token Parent'aile"
                            Height="42" Padding="20,0"
                            Background="#27AE60" Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"
                            Visibility="Collapsed"
                            Click="GenerateTokenCardBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- État : Token existant (Style "Premium") -->
                    <Border x:Name="TokenStatusCardBorder"
                            Background="White" CornerRadius="12"
                            Padding="15,8" BorderBrush="#BBDEFB" BorderThickness="1.5"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            ToolTip="Cliquez pour les détails, le QR Code et les statistiques de messages"
                            MouseLeftButtonDown="TokenStatusCardBorder_Click">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2" Color="#1976D2"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="TokenStatusCardIcon" Text="🔑" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                <TextBlock x:Name="TokenStatusCardLabel" Text="Token Actif" FontSize="12" FontWeight="Bold" Foreground="#1976D2"/>
                                <TextBlock x:Name="TokenIdCardLabel" Text="---" FontSize="11" Foreground="#546E7A" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="PrintTokenCardBtn" Content="🖨️" ToolTip="Imprimer le Token" Width="36" Height="36" Margin="0,0,8,0" 
                                        FontSize="14" Padding="0"
                                        Style="{StaticResource HeaderStateButtonStyle}" Click="PrintTokenCardBtn_Click"/>
                                <Button x:Name="RevokeTokenCardBtn" Content="🚫" ToolTip="Révoquer le Token" Width="36" Height="36"
                                        FontSize="14" Padding="0"
                                        Style="{StaticResource HeaderStateButtonStyle}" Click="RevokeTokenCardBtn_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <Button Grid.Column="3" 
                        x:Name="OpenPatientFolderBtn"
                        Content="📁 Ouvrir dossier"
                        Height="40"
                        Padding="15,0"
                        FontSize="13"
                        Background="#1976D2"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1565C0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
        
        <!-- Main Content: Colonne patients fixe + 3 colonnes -->
        <Grid Grid.Row="2" Margin="20">

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- CONTENU V1 (Mode Console) - Visible par défaut -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid x:Name="ConsoleContent" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="PatientsPanelColumn" Width="0" MinWidth="0" MaxWidth="300"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="250" MinWidth="200"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="2*" MinWidth="400"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="3*" MinWidth="600"/>
                </Grid.ColumnDefinitions>

            <!-- Colonne Liste Patients (masquée par défaut) -->
            <Border x:Name="PatientsPanel"
                    Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="12"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <patients:PatientListControl x:Name="PatientListControlPanel"/>
            </Border>

            <!-- COL G: Liste Notes uniquement -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="📋 Notes" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#2C3E50"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
                        <ListBox x:Name="NotesList"
                                     ItemsSource="{Binding NoteViewModel.Notes}"
                                     SelectedItem="{Binding NoteViewModel.SelectedNote}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8"/>
                                        <Setter Property="Margin" Value="0,0,0,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Border" 
                                                            Background="{TemplateBinding Background}" 
                                                            Padding="{TemplateBinding Padding}"
                                                            BorderBrush="#E0E0E0"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#E3F2FD"/>
                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#90CAF9"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DateLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#3498DB"/>
                                            <TextBlock Text="{Binding Preview}" FontSize="10" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
            </Border>
            
            <!-- COL C: Notes brute/structurée -->
            <!-- COL C: Notes brute/structurée -->
             <notes:NotesControl x:Name="NotesControlPanel" Grid.Column="4"/>

            
            <!-- COL D: Assistant IA avec Onglets -->
            <Border Grid.Column="6" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="💬 Assistant IA" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#2C3E50"/>
                    
                    <TabControl x:Name="AssistantTabControl" Grid.Row="1" BorderThickness="0" Background="Transparent">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Border" Background="Transparent" Padding="12,8" Margin="0,0,5,0" CornerRadius="6,6,0,0">
                                                <ContentPresenter ContentSource="Header"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#E3F2FD"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>
                        
                        <!-- Onglet Discussion -->
                        <TabItem Header="💬 Discussion">
                            <chat:ChatControl x:Name="ChatControlPanel" Margin="0,10,0,0"/>
                        </TabItem>

                        <!-- Onglet Courriers -->
                        <TabItem Header="📄 Courriers">
                            <courriers:CourriersControl x:Name="CourriersControlPanel" Margin="0,10,0,0"/>
                        </TabItem>
                        
                        <!-- Onglet Attestations -->
                        <TabItem Header="📜 Attestations">
                            <attestations:AttestationsControl x:Name="AttestationsControlPanel"
                                                             DataContext="{Binding AttestationViewModel}"
                                                             Margin="0,10,0,0"/>
                        </TabItem>
                        
                        <!-- Onglet Documents -->
                        <TabItem Header="📄 Documents">
                            <documents:DocumentsControl x:Name="DocumentsControlPanel" Margin="0,10,0,0"/>
                        </TabItem>

                        <!-- Onglet Formulaires -->
                        <TabItem Header="📝 Formulaires">
                            <formulaires:FormulairesControl x:Name="FormulairesControlPanel" Margin="0,10,0,0"/>
                        </TabItem>
                        
                        <!-- Onglet Ordonnances -->
                        <TabItem Header="💊 Ordonnances">
                            <ordonnances:OrdonnancesControl x:Name="OrdonnancesControlPanel" 
                                                           DataContext="{Binding OrdonnanceViewModel}"
                                                           Margin="0,10,0,0"/>
                        </TabItem>
                        
                        <!-- Onglet Messages Parents -->
                        <TabItem x:Name="MessagesTabItem" Header="Messages">
                            <messages:MessagesControl x:Name="MessagesControlPanel" Margin="0,10,0,0"/>
                        </TabItem>

                        <!-- Onglet Templates (MVVM) -->
                        <TabItem Header="⚙️ Templates">
                            <templates:TemplatesControl x:Name="TemplatesPanel"/>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <!-- Fermeture de ConsoleContent (V1) -->
            </Grid>

            <!-- Bouton Toggle Liste Patients (OVERLAY - en dehors de ConsoleContent, visible uniquement en V1) -->
            <Button x:Name="TogglePatientsBtn"
                    Content="▶"
                    Width="25"
                    Height="60"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#34495E"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="0,20,0,0"
                    Click="TogglePatientsBtn_Click"
                    Panel.ZIndex="1000">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="0,8,8,0"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2C3E50"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- CONTENU V2 (Mode Med - Accueil) - Masqué par défaut -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <consultation:FocusMedControl x:Name="AccueilMedContent" Grid.Row="2" VerticalAlignment="Stretch" Visibility="Collapsed"/>
 
            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- CONTENU V3 (Mode Med - Bureau) - Masqué par défaut -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <consultation:BureauMedControl x:Name="BureauMedContent" Grid.Row="2" VerticalAlignment="Stretch" Visibility="Collapsed"/>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- CONTENU V4 (Mode Consultation) - Masqué par défaut -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <consultation:ConsultationModeControl x:Name="ConsultationModeContent" Grid.Row="2" VerticalAlignment="Stretch" Visibility="Collapsed"/>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- CONTENU V5 (Mode Pilotage) - Masqué par défaut -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <pilotage:PilotageControl x:Name="PilotageContent" Grid.Row="2" VerticalAlignment="Stretch" Visibility="Collapsed"/>

        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <TextBlock x:Name="StatusTextBlock" Text="Prêt" FontSize="13" Foreground="#7F8C8D" HorizontalAlignment="Left"/>
                <TextBlock Text="Ctrl+Enter pour envoyer dans le chat" FontSize="11" Foreground="#BDC3C7" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Overlay modal pour les opérations longues (doit être en dernier pour être au-dessus) -->
        <views:BusyOverlay Grid.RowSpan="4"/>
    </Grid>
</Grid>
</Window>
